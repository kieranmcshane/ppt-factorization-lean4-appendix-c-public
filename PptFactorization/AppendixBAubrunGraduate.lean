/-- A transparent sufficient condition for the absorbed-`Q` scalar leaf.

If `D` is bounded by the first Aubrun base and the second Aubrun base has the
extra support-card slack `(2m+1)D`, then the displayed scalar comparison follows.
This does not prove the asymptotic scalar estimate; it isolates the leftover
`2m+1` factor as a concrete base-margin requirement. -/
theorem aubrun_absorbedQ_scalarEnvelope_of_commonBaseMargins
    {d s D : ℝ} {m : ℕ}
    (hD0 : 0 ≤ D)
    (hFirst :
      D ≤ d + aubrunProposition71Q 1 (m + 1))
    (hSecond :
      (2 * m + 1 : ℝ) * D ≤
        Real.sqrt s + aubrunProposition71Q 1 (m + 1)) :
    (2 * m + 1 : ℝ) * D ^ (2 * (m + 1) + 2) ≤
      (d + aubrunProposition71Q 1 (m + 1)) ^ (m + 3) *
        (Real.sqrt s + aubrunProposition71Q 1 (m + 1)) ^ (m + 1) := by
  let A := d + aubrunProposition71Q 1 (m + 1)
  let B := Real.sqrt s + aubrunProposition71Q 1 (m + 1)
  let c : ℝ := (2 * m + 1 : ℝ)
  have hc1 : 1 ≤ c := by
    dsimp [c]
    exact_mod_cast (by omega : 1 ≤ 2 * m + 1)
  have hc0 : 0 ≤ c := le_trans zero_le_one hc1
  have hA0 : 0 ≤ A := le_trans hD0 hFirst
  have hcD0 : 0 ≤ c * D := mul_nonneg hc0 hD0
  have hB0 : 0 ≤ B := le_trans hcD0 hSecond
  have hD_to_A : D ^ (m + 3) ≤ A ^ (m + 3) :=
    pow_le_pow_left₀ hD0 hFirst (m + 3)
  have hc_le_pow : c ≤ c ^ (m + 1) :=
    le_self_pow₀ hc1 (Nat.succ_ne_zero m)
  have hDpow0 : 0 ≤ D ^ (m + 1) := pow_nonneg hD0 _
