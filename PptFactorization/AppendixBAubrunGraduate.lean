/-- Internal `S`-repeat branch of the primitive descended residual frontier. -/
def leftTightStrictReturnIntervalPrimitiveResidualInternalS
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r s : ℕ,
    ∃ hr : r ≤ c - a,
    ∃ hs : s ≤ c - a,
      0 < r ∧
      s < c - a ∧
      r < s ∧
      (finRotate (m + 1) * π).SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩

/-- Start-attached `S`-repeat branch of the primitive descended residual
frontier. -/
def leftTightStrictReturnIntervalPrimitiveResidualStartS
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ s : ℕ,
    ∃ hs : s ≤ c - a,
      1 < s ∧
      s < c - a ∧
      (finRotate (m + 1) * π).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩

/-- End-attached `S`-repeat branch of the primitive descended residual
frontier. -/
def leftTightStrictReturnIntervalPrimitiveResidualEndS
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r : ℕ,
    ∃ hr : r ≤ c - a,
      0 < r ∧
      r + 1 < c - a ∧
      (finRotate (m + 1) * π).SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩

/-- Fixed-predecessor branch of the primitive descended residual frontier. -/
def leftTightStrictReturnIntervalPrimitiveResidualFixedPred
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  π ⟨c - 1, by
      have hc' := Finset.mem_range.mp hc
      omega⟩ =
    ⟨c - 1, by
      have hc' := Finset.mem_range.mp hc
      omega⟩

/-- Adjacent `T`-repeat branch of the primitive descended residual frontier. -/
def leftTightStrictReturnIntervalPrimitiveResidualAdjacentT
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r : ℕ,
    ∃ hr : r + 1 < c - a,
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + (r + 1), by
          have hc' := Finset.mem_range.mp hc
          omega⟩

/-- Raw internal `T`-repeat branch of the strict residual frontier.

This is the branch before the later adjacent/shorter-subinterval descent is
applied.  Keeping it named lets the side-aware smaller contour-repeat leaf be
split without discarding the child contour packet too early. -/
def leftTightStrictReturnIntervalResidualInternalT
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r s : ℕ,
    ∃ hr : r < c - a,
    ∃ hs : s < c - a,
      r < s ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩

/-- Subinterval-preserving descended residual frontier.

This is the side-data-safe replacement for the broad shorter-interval branch
of `leftTightStrictReturnIntervalDescendedResidual`.  The local primitive
branches are unchanged, but the recursive branch now remembers that the
shorter same-`π` interval is an actual internal subinterval `[a+r,a+s]` of the
current return interval. -/
def leftTightStrictReturnIntervalSubintervalDescendedResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c) : Prop :=
  leftTightStrictReturnIntervalPrimitiveResidual π ha hc hac ∨
    (∃ r s : ℕ,
      ∃ hr : r < c - a,
      ∃ hs : s < c - a,
        r < s ∧
        1 < s - r ∧
        π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩)

/-- The internal-subinterval branch of the subinterval-preserving descended
residual frontier.

This names the recursive branch separately from the five local primitive
branches.  Keeping it visible prevents the side-specific nested collision
leaf from being read as one undifferentiated residual assumption. -/
def leftTightStrictReturnIntervalInternalSubintervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r s : ℕ,
    ∃ hr : r < c - a,
    ∃ hs : s < c - a,
      r < s ∧
      1 < s - r ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩

/-- Start-touching internal-subinterval residual.

This is the part of `leftTightStrictReturnIntervalInternalSubintervalResidual`
where the shorter same-`π` interval starts at the left endpoint `a`.  The
nonwrapping first-return side rules this branch out, but the two wrapping
sides do not; keeping it separate prevents the wrap internal leaf from being
treated as though it were automatically open. -/
def leftTightStrictReturnIntervalStartInternalSubintervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ s : ℕ,
    ∃ hs : s < c - a,
      1 < s ∧
      π.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩

/-- Wrap-below position-refined start-touching internal-subinterval residual.

The start-touching shorter same-`π` interval has its right endpoint at or after
the skipped point `x`.  This is the start-branch analogue of the wrap-below
on-cycle refinement: if the right endpoint were below `x`, last-return side
data would be contradicted. -/
def leftTightStrictReturnIntervalStartInternalAfterSkippedSubintervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ s : ℕ,
    ∃ hs : s < c - a,
      1 < s ∧
      π.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ ∧
      x.val ≤ a + s

/-- Wrap-above position-refined start-touching internal-subinterval residual.

The start-touching shorter same-`π` interval has its right endpoint at or
before `π x`.  This is the start-branch analogue of the wrap-above on-cycle
refinement: if the endpoint were after `π x`, first-return side data would be
contradicted. -/
def leftTightStrictReturnIntervalStartInternalBeforeImageSubintervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ s : ℕ,
    ∃ hs : s < c - a,
      1 < s ∧
      π.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ ∧
      a + s ≤ (π x).val

/-- Open internal-subinterval residual.

This is the internal-subinterval branch with the extra information that the
shorter same-`π` interval starts strictly after the left endpoint `a`.  It is
not true for every side automatically, but it is forced by the nonwrapping
first-return side data. -/
def leftTightStrictReturnIntervalOpenInternalSubintervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r s : ℕ,
    ∃ hr : r < c - a,
    ∃ hs : s < c - a,
      0 < r ∧
      r < s ∧
      1 < s - r ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩

/-- Off-cycle open internal-subinterval residual.

This is the open internal-subinterval branch together with the information that
the left endpoint of the shorter same-`π` interval is not in the skipped
`x`-cycle.  In the nonwrapping first-return side this is forced by the
first-return condition: every point of the `x`-cycle strictly between `a` and
`c` is forbidden. -/
def leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r s : ℕ,
    ∃ hr : r < c - a,
    ∃ hs : s < c - a,
      0 < r ∧
      r < s ∧
      1 < s - r ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ ∧
      ¬ π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        x

/-- On-cycle open internal-subinterval residual.

This is the open internal-subinterval branch where the left endpoint of the
shorter same-`π` interval lies in the skipped `x`-cycle.  The wrap sides need
this branch separated from the off-cycle branch: unlike the nonwrapping
first-return side, the wrap side data does not automatically force every open
internal witness away from the skipped cycle. -/
def leftTightStrictReturnIntervalOpenInternalOnCycleSubintervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r s : ℕ,
    ∃ hr : r < c - a,
    ∃ hs : s < c - a,
      0 < r ∧
      r < s ∧
      1 < s - r ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        x

/-- Wrap-below position-refined on-cycle open internal-subinterval residual.

The shorter same-`π` interval starts in the skipped `x`-cycle, but not before
`x` in the ordinary order.  This is forced by the wrap-below last-return side
condition: a same-`π` point of the `x`-cycle strictly between the interval
start and `x` would contradict last-return minimality. -/
def leftTightStrictReturnIntervalOpenInternalOnCycleAfterSkippedSubintervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r s : ℕ,
    ∃ hr : r < c - a,
    ∃ hs : s < c - a,
      0 < r ∧
      r < s ∧
      1 < s - r ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        x ∧
      x.val ≤ a + r

/-- Wrap-above position-refined on-cycle open internal-subinterval residual.

The shorter same-`π` interval starts in the skipped `x`-cycle, but not after
`π x` in the ordinary order.  This is forced by the wrap-above first-return
side condition: a same-`π` point of the `x`-cycle strictly between `π x` and
the interval endpoint would contradict first-return minimality. -/
def leftTightStrictReturnIntervalOpenInternalOnCycleBeforeImageSubintervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
  ∃ r s : ℕ,
    ∃ hr : r < c - a,
    ∃ hs : s < c - a,
      0 < r ∧
      r < s ∧
      1 < s - r ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        x ∧
      a + r ≤ (π x).val

/-- Branch decomposition of the primitive descended residual frontier. -/
theorem leftTightStrictReturnIntervalPrimitiveResidual_iff_branchCases
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c) :
    leftTightStrictReturnIntervalPrimitiveResidual π ha hc hac ↔
      leftTightStrictReturnIntervalPrimitiveResidualInternalS π ha hc hac ∨
        leftTightStrictReturnIntervalPrimitiveResidualStartS π ha hc hac ∨
          leftTightStrictReturnIntervalPrimitiveResidualEndS π ha hc hac ∨
            leftTightStrictReturnIntervalPrimitiveResidualFixedPred π ha hc hac ∨
              leftTightStrictReturnIntervalPrimitiveResidualAdjacentT π ha hc hac := by
  rfl

/-- Branch decomposition of the subinterval-preserving descended residual
frontier. -/
theorem leftTightStrictReturnIntervalSubintervalDescendedResidual_iff
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c) :
    leftTightStrictReturnIntervalSubintervalDescendedResidual π ha hc hac ↔
      leftTightStrictReturnIntervalPrimitiveResidual π ha hc hac ∨
        leftTightStrictReturnIntervalInternalSubintervalResidual π ha hc hac := by
  rfl

/-- The internal-subinterval residual splits into the endpoint-touching branch
and the open branch.

This is deliberately a statement about the residual itself, not about any side
of the predecessor-skip construction.  The nonwrapping side later proves that
the start-touching alternative is impossible from first-return data; the
wrapping sides keep the two alternatives theorem-facing. -/
theorem leftTightStrictReturnIntervalInternalSubintervalResidual_iff_start_or_open
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c) :
    leftTightStrictReturnIntervalInternalSubintervalResidual π ha hc hac ↔
      leftTightStrictReturnIntervalStartInternalSubintervalResidual π ha hc hac ∨
        leftTightStrictReturnIntervalOpenInternalSubintervalResidual π ha hc hac := by
  constructor
  · rintro ⟨r, s, hr, hs, hrs, hgap, hSame⟩
    by_cases hrpos : 0 < r
    · right
      exact ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame⟩
    · left
      have hrzero : r = 0 := by omega
      subst r
      refine ⟨s, hs, ?_, ?_⟩
      · omega
      · simpa using hSame
  · rintro (hStart | hOpen)
    · rcases hStart with ⟨s, hs, hgap, hSame⟩
      refine ⟨0, s, ?_, hs, ?_, hgap, ?_⟩
      · omega
      · omega
      · simpa using hSame
    · rcases hOpen with ⟨r, s, hr, hs, _hrpos, hrs, hgap, hSame⟩
      exact ⟨r, s, hr, hs, hrs, hgap, hSame⟩

/-- An open internal-subinterval residual is either off the skipped `x`-cycle
or on it.

This split is tautological, but it is theorem-facing on the wrap branches where
the first/last-return side data only controls one side of the skipped point.
It prevents the open wrap leaf from hiding two different noncrossing
mechanisms. -/
theorem leftTightStrictReturnIntervalOpenInternalSubintervalResidual_iff_off_or_on_cycle
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))} {x : Fin (m + 1)}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c) :
    leftTightStrictReturnIntervalOpenInternalSubintervalResidual π ha hc hac ↔
      leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual
        π x ha hc hac ∨
        leftTightStrictReturnIntervalOpenInternalOnCycleSubintervalResidual
          π x ha hc hac := by
  constructor
  · rintro ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame⟩
    by_cases hx :
        π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          x
    · right
      exact ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, hx⟩
    · left
      exact ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, hx⟩
  · rintro (hOff | hOn)
    · rcases hOff with ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, _hx⟩
      exact ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame⟩
    · rcases hOn with ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, _hx⟩
      exact ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame⟩

/-- The wrap-below last-return side data position-refines the start-touching
internal-subinterval residual.

The start point `a` is in the skipped `x`-cycle because `a` is in the same
`π`-cycle as `c = πx`.  Hence the start-branch endpoint `a+s` is also in the
skipped cycle.  Last-return side data forces this endpoint not to lie below
`x`. -/
theorem leftTightStrictReturnIntervalStartInternalSubintervalResidual_wrapBelow_afterSkipped
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {x : Fin (m + 1)} {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hT : π.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hceq : c = (π x).val)
    (hlast :
      ∀ z : Fin (m + 1),
        π.SameCycle z x →
        a < z.val →
        z.val < x.val →
        False)
    (hStart :
      leftTightStrictReturnIntervalStartInternalSubintervalResidual
        π ha hc hac) :
    leftTightStrictReturnIntervalStartInternalAfterSkippedSubintervalResidual
      π x ha hc hac := by
  rcases hStart with ⟨s, hs, hgap, hSame⟩
  let A : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let C : Fin (m + 1) := ⟨c, Finset.mem_range.mp hc⟩
  let Z : Fin (m + 1) := ⟨a + s, by
    have hc' := Finset.mem_range.mp hc
    omega⟩
  have hCeq : C = π x := by
    apply Fin.ext
    simpa [C] using hceq
  have hCx : π.SameCycle C x := by
    have hxC : π.SameCycle x C := by
      rw [hCeq]
      exact ⟨1, by simp⟩
    exact hxC.symm
  have hZx : π.SameCycle Z x := by
    have hAx : π.SameCycle A x := hT.trans hCx
    exact hSame.symm.trans hAx
  have hafter : x.val ≤ a + s := by
    by_contra hnot
    have hlt : a + s < x.val := by omega
    have haZ : a < Z.val := by
      simp [Z]
      omega
    have hZlt : Z.val < x.val := by
      simpa [Z] using hlt
    exact hlast Z hZx haZ hZlt
  exact ⟨s, hs, hgap, hSame, hafter⟩

/-- The wrap-above first-return side data position-refines the start-touching
internal-subinterval residual.

Here the start point is exactly `x`, so the start-branch endpoint is in the
skipped `x`-cycle.  First-return side data forces it not to lie after
`πx` and before the return endpoint. -/
theorem leftTightStrictReturnIntervalStartInternalSubintervalResidual_wrapAbove_beforeImage
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {x : Fin (m + 1)} {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (haeq : a = x.val)
    (hfirst :
      ∀ z : Fin (m + 1),
        π.SameCycle z x →
        (π x).val < z.val →
        z.val < c →
        False)
    (hStart :
      leftTightStrictReturnIntervalStartInternalSubintervalResidual
        π ha hc hac) :
    leftTightStrictReturnIntervalStartInternalBeforeImageSubintervalResidual
      π x ha hc hac := by
  rcases hStart with ⟨s, hs, hgap, hSame⟩
  let A : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let Z : Fin (m + 1) := ⟨a + s, by
    have hc' := Finset.mem_range.mp hc
    omega⟩
  have hAeq : A = x := by
    apply Fin.ext
    simpa [A] using haeq
  have hZx : π.SameCycle Z x := by
    have hZA : π.SameCycle Z A := hSame.symm
    simpa [hAeq] using hZA
  have hbefore : a + s ≤ (π x).val := by
    by_contra hnot
    have hlt : (π x).val < a + s := by omega
    have hpZ : (π x).val < Z.val := by
      simpa [Z] using hlt
    have hZc : Z.val < c := by
      simp [Z]
      omega
    exact hfirst Z hZx hpZ hZc
  exact ⟨s, hs, hgap, hSame, hbefore⟩

/-- The wrap-below last-return side data position-refines the on-cycle open
internal-subinterval residual.

If the witness start `a+r` were still below `x`, it would be an earlier
same-`π` point of the skipped `x`-cycle, contradicting the supplied
last-return condition. -/
theorem leftTightStrictReturnIntervalOpenInternalOnCycleSubintervalResidual_wrapBelow_afterSkipped
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {x : Fin (m + 1)} {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hlast :
      ∀ z : Fin (m + 1),
        π.SameCycle z x →
        a < z.val →
        z.val < x.val →
        False)
    (hOn :
      leftTightStrictReturnIntervalOpenInternalOnCycleSubintervalResidual
        π x ha hc hac) :
    leftTightStrictReturnIntervalOpenInternalOnCycleAfterSkippedSubintervalResidual
      π x ha hc hac := by
  rcases hOn with ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, hx⟩
  have hafter : x.val ≤ a + r := by
    by_contra hnot
    have hlt : a + r < x.val := by omega
    let z : Fin (m + 1) := ⟨a + r, by
      have hc' := Finset.mem_range.mp hc
      omega⟩
    have haz : a < z.val := by
      simp [z]
      omega
    have hzx : z.val < x.val := by
      simpa [z] using hlt
    exact hlast z hx haz hzx
  exact ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, hx, hafter⟩

/-- The wrap-above first-return side data position-refines the on-cycle open
internal-subinterval residual.

If the witness start `a+r` were strictly after `π x`, it would be a later
same-`π` point of the skipped `x`-cycle before the return endpoint `c`,
contradicting the supplied first-return condition. -/
theorem leftTightStrictReturnIntervalOpenInternalOnCycleSubintervalResidual_wrapAbove_beforeImage
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {x : Fin (m + 1)} {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hfirst :
      ∀ z : Fin (m + 1),
        π.SameCycle z x →
        (π x).val < z.val →
        z.val < c →
        False)
    (hOn :
      leftTightStrictReturnIntervalOpenInternalOnCycleSubintervalResidual
        π x ha hc hac) :
    leftTightStrictReturnIntervalOpenInternalOnCycleBeforeImageSubintervalResidual
      π x ha hc hac := by
  rcases hOn with ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, hx⟩
  have hbefore : a + r ≤ (π x).val := by
    by_contra hnot
    have hlt : (π x).val < a + r := by omega
    let z : Fin (m + 1) := ⟨a + r, by
      have hc' := Finset.mem_range.mp hc
      omega⟩
    have hpz : (π x).val < z.val := by
      simpa [z] using hlt
    have hzc : z.val < c := by
      simp [z]
      omega
    exact hfirst z hx hpz hzc
  exact ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, hx, hbefore⟩

/-- In the nonwrapping first-return side, the internal-subinterval residual
cannot start at the left endpoint.

The side data says `a = π x`, so the left endpoint is in the `π`-cycle of the
skip witness `x`.  If the shorter interval started at `a`, its right endpoint
would be a strictly internal same-`π` return to the `x`-cycle before the first
return `c`, contradicting the nonwrapping first-return condition. -/
theorem leftTightStrictReturnIntervalInternalSubintervalResidual_nonwrap_start_pos
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {x : Fin (m + 1)} {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (haeq : a = (π x).val)
    (hfirst :
      ∀ z : Fin (m + 1),
        π.SameCycle z x →
        a < z.val →
        z.val < c →
        False)
    (hInternal :
      leftTightStrictReturnIntervalInternalSubintervalResidual π ha hc hac) :
    leftTightStrictReturnIntervalOpenInternalSubintervalResidual π ha hc hac := by
  rcases hInternal with ⟨r, s, hr, hs, hrs, hgap, hSame⟩
  have hrpos : 0 < r := by
    by_contra hnot
    have hrzero : r = 0 := by omega
    subst r
    have hspos : 0 < s := by omega
    have hA :
        (⟨a + 0, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)) = π x := by
      apply Fin.ext
      simp [haeq]
    have hRightCycle :
        π.SameCycle
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          x := by
      have hLeftCycle : π.SameCycle
          (⟨a + 0, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ : Fin (m + 1))
          x := by
        rw [hA]
        exact perm_apply_sameCycle_self π x
      exact hSame.symm.trans hLeftCycle
    have hRight_gt :
        a <
          (⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ : Fin (m + 1)).val := by
      simpa using (show a < a + s by omega)
    have hRight_lt :
        (⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)).val < c := by
      simpa using (show a + s < c by omega)
    exact hfirst
      ⟨a + s, by
        have hc' := Finset.mem_range.mp hc
        omega⟩
      hRightCycle
      hRight_gt
      hRight_lt
  exact ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame⟩

/-- In the nonwrapping first-return side, an open internal-subinterval residual
is automatically off the skipped `x`-cycle.

The open witness has left endpoint `a+r` with `0<r` and `r<c-a`, hence it lies
strictly between `a` and `c`.  The first-return side condition forbids such a
point from being in the same `π`-cycle as `x`. -/
theorem leftTightStrictReturnIntervalOpenInternalSubintervalResidual_nonwrap_offCycle
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {x : Fin (m + 1)} {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hfirst :
      ∀ z : Fin (m + 1),
        π.SameCycle z x →
        a < z.val →
        z.val < c →
        False)
    (hOpen :
      leftTightStrictReturnIntervalOpenInternalSubintervalResidual π ha hc hac) :
    leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual
      π x ha hc hac := by
  rcases hOpen with ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame⟩
  have hleft_gt :
      a <
        (⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)).val := by
    simpa using (show a < a + r by omega)
  have hleft_lt :
      (⟨a + r, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ : Fin (m + 1)).val < c := by
    simpa using (show a + r < c by omega)
  have hnot :
      ¬ π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        x := by
    intro hxcycle
    exact hfirst
      ⟨a + r, by
        have hc' := Finset.mem_range.mp hc
        omega⟩
      hxcycle hleft_gt hleft_lt
  exact ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, hnot⟩

/-- Noncrossing confines an off-cycle open internal residual strictly inside
the return interval.

The witness block starts at a point `a+r` between `a` and `c`.  Because `a`
and `c` lie in the skipped `x`-cycle while `a+r` is off that cycle, the
witness block is a distinct noncrossing block meeting the inside of the
`a,c`-block.  Hence the standard noncrossing interval-nesting lemma traps the
whole witness block in `[a,c]`; the off-cycle condition rules out the endpoints,
so it is actually trapped in `(a,c)`. -/
theorem leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual_block_strictly_inside
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hπNC : NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    {x : Fin (m + 1)} {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hT :
      π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩)
    (haeq : a = (π.1 x).val)
    (hOff :
      leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual
        π.1 x ha hc hac) :
    ∃ r s : ℕ,
      ∃ hr : r < c - a,
      ∃ hs : s < c - a,
        0 < r ∧
        r < s ∧
        1 < s - r ∧
        π.1.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ ∧
        ¬ π.1.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          x ∧
        ∀ y : Fin (m + 1),
          π.1.SameCycle y
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ →
          a < y.val ∧ y.val < c := by
  classical
  rcases hOff with ⟨r, s, hr, hs, hrpos, hrs, hgap, hSame, hOffCycle⟩
