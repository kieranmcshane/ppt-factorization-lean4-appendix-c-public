    (m := m) (d := d) (t := t) (D := D) (Q := Q) (ρ := ρ) hDpos
  rwa [linearRatio_normalizedProduct_eq_ratioPowers hDpos.ne']

/-- Ratio-power diagnostic: if both shifted base ratios are at most one, then
the variable-ratio scalar target cannot hold with a positive correction.

Thus the live scalar route must exploit a genuine ratio gain in at least one
of the two shifted bases. -/
theorem linearRatio_ratioPowers_impossible_of_ratios_le_one
    {m : ℕ} {x y ρ : ℝ}
    (hm : 0 < m) (hρ : 0 < ρ)
    (hx0 : 0 ≤ x) (hx1 : x ≤ 1) (hy0 : 0 ≤ y) (hy1 : y ≤ 1)
    (hRatio : 1 + (2 * m : ℝ) * ρ ≤ x ^ (m + 3) * y ^ (m + 1)) :
    False := by
  have hxpow : x ^ (m + 3) ≤ 1 := pow_le_one₀ hx0 hx1
  have hypow : y ^ (m + 1) ≤ 1 := pow_le_one₀ hy0 hy1
  have hprod : x ^ (m + 3) * y ^ (m + 1) ≤ 1 := by
    calc
      x ^ (m + 3) * y ^ (m + 1) ≤ 1 * 1 := by
        exact mul_le_mul hxpow hypow (pow_nonneg hy0 _) zero_le_one
      _ = 1 := by norm_num
  have hleft_gt : 1 < 1 + (2 * m : ℝ) * ρ := by
    have hmReal : 0 < (2 * m : ℝ) := by
      exact_mod_cast Nat.mul_pos (by norm_num) hm
    nlinarith
  have hle : 1 + (2 * m : ℝ) * ρ ≤ 1 := le_trans hRatio hprod
  linarith

/-- Positive form of the ratio-power diagnostic: the scalar target forces at
least one shifted base ratio to be strictly larger than one. -/
theorem linearRatio_ratioPowers_forces_one_ratio_gt_one
    {m : ℕ} {x y ρ : ℝ}
    (hm : 0 < m) (hρ : 0 < ρ)
    (hx0 : 0 ≤ x) (hy0 : 0 ≤ y)
    (hRatio : 1 + (2 * m : ℝ) * ρ ≤ x ^ (m + 3) * y ^ (m + 1)) :
    1 < x ∨ 1 < y := by
  by_cases hx : 1 < x
  · exact Or.inl hx
  · by_cases hy : 1 < y
    · exact Or.inr hy
    · have hx1 : x ≤ 1 := le_of_not_gt hx
      have hy1 : y ≤ 1 := le_of_not_gt hy
      exfalso
      exact linearRatio_ratioPowers_impossible_of_ratios_le_one
        (m := m) (x := x) (y := y) (ρ := ρ)
        hm hρ hx0 hx1 hy0 hy1 hRatio

/-- Convert a forced ratio gain into a strict common-base slack statement. -/
theorem ratio_gt_one_or_ratio_gt_one_iff_base_slack
    {a b D : ℝ} (hD : 0 < D)
    (h : 1 < a / D ∨ 1 < b / D) :
    D < a ∨ D < b := by
  rcases h with ha | hb
  · exact Or.inl ((one_lt_div hD).mp ha)
  · exact Or.inr ((one_lt_div hD).mp hb)

/-- If the common base dominates both shifted bases, the ratio-power scalar
target is impossible with a positive correction. -/
theorem linearRatio_ratioPowers_impossible_of_commonBase_dominates
    {m : ℕ} {a b D ρ : ℝ}
    (hDpos : 0 < D) (hm : 0 < m) (hρ : 0 < ρ)
    (ha0 : 0 ≤ a / D) (hb0 : 0 ≤ b / D)
    (haD : a ≤ D) (hbD : b ≤ D)
    (hRatio :
      1 + (2 * m : ℝ) * ρ ≤
        (a / D) ^ (m + 3) * (b / D) ^ (m + 1)) :
    False := by
  have hgain : D < a ∨ D < b := by
    exact ratio_gt_one_or_ratio_gt_one_iff_base_slack hDpos
      (linearRatio_ratioPowers_forces_one_ratio_gt_one
        (m := m) (x := a / D) (y := b / D) (ρ := ρ)
        hm hρ ha0 hb0 hRatio)
  rcases hgain with ha | hb
  · exact (not_lt_of_ge haD) ha
  · exact (not_lt_of_ge hbD) hb

/-- The ratio-power scalar target cannot be closed by choosing the common base
to be the maximum of the two shifted bases. -/
theorem linearRatio_ratioPowers_impossible_of_maxBase
    {m : ℕ} {a b ρ : ℝ}
    (hm : 0 < m) (hρ : 0 < ρ)
    (ha0 : 0 ≤ a) (hb0 : 0 ≤ b) (hMaxpos : 0 < max a b)
    (hRatio :
      1 + (2 * m : ℝ) * ρ ≤
        (a / max a b) ^ (m + 3) * (b / max a b) ^ (m + 1)) :
    False :=
  linearRatio_ratioPowers_impossible_of_commonBase_dominates
    (m := m) (a := a) (b := b) (D := max a b) (ρ := ρ)
    hMaxpos hm hρ (div_nonneg ha0 hMaxpos.le)
    (div_nonneg hb0 hMaxpos.le) (le_max_left a b) (le_max_right a b)
    hRatio

/-- Bernoulli supplier for the ratio-power scalar target: the first shifted
ratio supplies enough linear gain, while the second shifted ratio is at least
one. -/
theorem linearRatio_ratioPowers_of_first_bernoulli_gain
    {m : ℕ} {x y α ρ : ℝ}
    (hα0 : 0 ≤ α) (hx : 1 + α ≤ x) (hy : 1 ≤ y)
    (hgain : (2 * m : ℝ) * ρ ≤ (m + 3 : ℝ) * α) :
    1 + (2 * m : ℝ) * ρ ≤ x ^ (m + 3) * y ^ (m + 1) := by
  have hminus : (-2 : ℝ) ≤ α := by nlinarith
  have hbern : 1 + (m + 3 : ℝ) * α ≤ (1 + α) ^ (m + 3) := by
    simpa using (one_add_mul_le_pow hminus (m + 3))
  have hleft : 1 + (2 * m : ℝ) * ρ ≤ 1 + (m + 3 : ℝ) * α := by
    nlinarith
  have hx0 : 0 ≤ x := by nlinarith
  have hxpow : (1 + α) ^ (m + 3) ≤ x ^ (m + 3) := by
    exact pow_le_pow_left₀ (by nlinarith) hx (m + 3)
  have hmain : 1 + (2 * m : ℝ) * ρ ≤ x ^ (m + 3) :=
    le_trans hleft (le_trans hbern hxpow)
  have hypow : 1 ≤ y ^ (m + 1) := one_le_pow₀ hy
  have hxpow_nonneg : 0 ≤ x ^ (m + 3) := pow_nonneg hx0 _
  calc
    1 + (2 * m : ℝ) * ρ ≤ x ^ (m + 3) := hmain
    _ = x ^ (m + 3) * 1 := by ring
    _ ≤ x ^ (m + 3) * y ^ (m + 1) := by
      exact mul_le_mul_of_nonneg_left hypow hxpow_nonneg

/-- Bernoulli supplier for the ratio-power scalar target: the second shifted
ratio supplies enough linear gain, while the first shifted ratio is at least
one. -/
theorem linearRatio_ratioPowers_of_second_bernoulli_gain
    {m : ℕ} {x y β ρ : ℝ}
    (hβ0 : 0 ≤ β) (hx : 1 ≤ x) (hy : 1 + β ≤ y)
    (hgain : (2 * m : ℝ) * ρ ≤ (m + 1 : ℝ) * β) :
    1 + (2 * m : ℝ) * ρ ≤ x ^ (m + 3) * y ^ (m + 1) := by
  have hminus : (-2 : ℝ) ≤ β := by nlinarith
  have hbern : 1 + (m + 1 : ℝ) * β ≤ (1 + β) ^ (m + 1) := by
    simpa using (one_add_mul_le_pow hminus (m + 1))
  have hleft : 1 + (2 * m : ℝ) * ρ ≤ 1 + (m + 1 : ℝ) * β := by
    nlinarith
  have hy0 : 0 ≤ y := by nlinarith
  have hypow : (1 + β) ^ (m + 1) ≤ y ^ (m + 1) := by
    exact pow_le_pow_left₀ (by nlinarith) hy (m + 1)
  have hmain : 1 + (2 * m : ℝ) * ρ ≤ y ^ (m + 1) :=
    le_trans hleft (le_trans hbern hypow)
  have hxpow : 1 ≤ x ^ (m + 3) := one_le_pow₀ hx
  have hypow_nonneg : 0 ≤ y ^ (m + 1) := pow_nonneg hy0 _
  calc
    1 + (2 * m : ℝ) * ρ ≤ 1 * y ^ (m + 1) := by
      simpa using hmain
    _ ≤ x ^ (m + 3) * y ^ (m + 1) := by
      exact mul_le_mul_of_nonneg_right hxpow hypow_nonneg

/-- Feasibility diagnostic for the first-ratio Bernoulli route: if the common
base already dominates the two unshifted bases, then the Bernoulli hypotheses
force the two shifted cross-comparisons. -/
theorem linearRatio_firstBernoulliGain_implies_crossBaseComparisons
    {d t D Q α : ℝ}
    (hDpos : 0 < D) (hdD : d ≤ D) (htD : t ≤ D)
    (hα0 : 0 ≤ α)
    (hFirst : 1 + α ≤ (d + Q) / D)
    (hSecond : 1 ≤ (t + Q) / D) :
    t ≤ d + Q ∧ d ≤ t + Q := by
  have hFirstOne : 1 ≤ (d + Q) / D := by linarith
  have hD_dQ : D ≤ d + Q := (one_le_div hDpos).mp hFirstOne
  have hD_tQ : D ≤ t + Q := (one_le_div hDpos).mp hSecond
  constructor
  · exact le_trans htD hD_dQ
  · exact le_trans hdD hD_tQ

/-- Feasibility diagnostic for the second-ratio Bernoulli route: if the common
base already dominates the two unshifted bases, then the Bernoulli hypotheses
force the two shifted cross-comparisons. -/
theorem linearRatio_secondBernoulliGain_implies_crossBaseComparisons
    {d t D Q β : ℝ}
    (hDpos : 0 < D) (hdD : d ≤ D) (htD : t ≤ D)
    (hβ0 : 0 ≤ β)
    (hFirst : 1 ≤ (d + Q) / D)
    (hSecond : 1 + β ≤ (t + Q) / D) :
    t ≤ d + Q ∧ d ≤ t + Q := by
  have hSecondOne : 1 ≤ (t + Q) / D := by linarith
  have hD_dQ : D ≤ d + Q := (one_le_div hDpos).mp hFirst
  have hD_tQ : D ≤ t + Q := (one_le_div hDpos).mp hSecondOne
  constructor
  · exact le_trans htD hD_dQ
  · exact le_trans hdD hD_tQ

/-- The first-ratio Bernoulli route forces the two analytic bases to be
`Q`-close. -/
theorem linearRatio_firstBernoulliGain_implies_abs_sub_le
    {d t D Q α : ℝ}
    (hDpos : 0 < D) (hdD : d ≤ D) (htD : t ≤ D)
    (hα0 : 0 ≤ α)
    (hFirst : 1 + α ≤ (d + Q) / D)
    (hSecond : 1 ≤ (t + Q) / D) :
    |d - t| ≤ Q := by
  rcases linearRatio_firstBernoulliGain_implies_crossBaseComparisons
      hDpos hdD htD hα0 hFirst hSecond with ⟨hCrossLeft, hCrossRight⟩
  exact crossBaseComparisons_imply_abs_sub_le hCrossLeft hCrossRight

/-- The second-ratio Bernoulli route forces the two analytic bases to be
`Q`-close. -/
theorem linearRatio_secondBernoulliGain_implies_abs_sub_le
    {d t D Q β : ℝ}
    (hDpos : 0 < D) (hdD : d ≤ D) (htD : t ≤ D)
    (hβ0 : 0 ≤ β)
    (hFirst : 1 ≤ (d + Q) / D)
    (hSecond : 1 + β ≤ (t + Q) / D) :
    |d - t| ≤ Q := by
  rcases linearRatio_secondBernoulliGain_implies_crossBaseComparisons
      hDpos hdD htD hβ0 hFirst hSecond with ⟨hCrossLeft, hCrossRight⟩
  exact crossBaseComparisons_imply_abs_sub_le hCrossLeft hCrossRight

/-- Aubrun-specialized normalized-product diagnostic for the variable-ratio
common-base scalar envelope. -/
theorem aubrun_linearRatio_commonBaseEnvelope_forces_normalizedProduct
