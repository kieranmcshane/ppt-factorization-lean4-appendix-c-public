    _ ≤ (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1) := hEnvelope

/-- The graduate relation-counting input follows from separate fixed-defect
count bounds and per-term analytic envelopes. -/
theorem aubrunGraduateRelationCounting_of_defectCountAndTermBounds
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ} {C B : ℕ → ℝ}
    (hCount : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤ C Δ)
    (hBnonneg : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3), 0 ≤ B Δ)
    (hTerm : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ π : Equiv.Perm (Fin (m + 1)), wickDefect π = Δ →
        d ^ (wickLeftClassCount π + wickRightClassCount π) *
          Real.sqrt s ^ (2 * wickColumnClassCount π) ≤ B Δ)
    (hEnvelope :
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        C Δ * B Δ) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  apply aubrunGraduateRelationCounting_of_defectSliceCountBounds
    (B := B)
  · exact hTerm
  · calc
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
          (wickPermutationDefectCount m Δ : ℝ) * B Δ) ≤
        Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
          C Δ * B Δ) := by
            refine Finset.sum_le_sum ?_
            intro Δ hΔ
            exact mul_le_mul_of_nonneg_right (hCount Δ hΔ) (hBnonneg Δ hΔ)
        _ ≤ (2 : ℝ) ^ (m + 1) *
            (d + Q (m + 1)) ^ (m + 3) *
              (Real.sqrt s + Q (m + 1)) ^ (m + 1) := hEnvelope

/-- Support-restricted version of
`aubrunGraduateRelationCounting_of_defectCountAndTermBounds`: count and scalar
inputs are required only for defects that are actually attained. -/
theorem aubrunGraduateRelationCounting_of_defectSupportCountAndTermBounds
