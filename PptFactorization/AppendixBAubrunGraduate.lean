          ⟨c, Finset.mem_range.mp hc⟩ := by
      have hxnot : x ≠ Fin.last m := by
        intro hx
        have hxval : c - 1 = m := by
          simpa [x] using congrArg Fin.val hx
        have hc' := Finset.mem_range.mp hc
        omega
      rw [finRotate_succ_apply]
      apply Fin.ext
      have hval : (c - 1) + 1 = c := by omega
      simp [x, Fin.val_add_one, hxnot, hval]
    have hSrot :
        (finRotate (m + 1) * π).SameCycle x (finRotate (m + 1) x) := by
      simpa [x, hrot] using hEnd
    simpa [x] using
      leftTight_fixed_of_sameCycle_self_finRotate hleft x hSrot

/-- Positive frontier form of the minimal contour obstruction.

For a longer same-`π` interval with no strictly internal repeated `π` class,
