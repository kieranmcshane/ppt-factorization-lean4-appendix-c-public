/-- Noncrossing skip-collision reduction for the no-skip leaf.

If every non-fixed predecessor skip in a noncrossing left-tight cycle
partition produces two distinct points lying simultaneously in one `π`-cycle
and one `(finRotate*π)`-cycle, then the left-tight transversality theorem
rules out all non-fixed predecessor skips.  The remaining theorem-strength
input is the pure noncrossing skip-collision statement, not another
predecessor-law wrapper. -/
theorem leftTight_no_nonfixed_cyclicPredecessorSkip_of_nonCrossing_commonCycle
    {m : ℕ}
    (hCollision :
      ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          permCyclicPredecessorSkip π.1 x →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hNC : ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π)) :
    ¬ ∃ π : WickCycleLeftTightClass m,
      ∃ x : Fin (m + 1),
        π.1 x ≠ x ∧ permCyclicPredecessorSkip π.1 x := by
  rintro ⟨π, x, hne, hskip⟩
  rcases hCollision π (hNC π) x hne hskip with
    ⟨y, z, hyz, hπ, hS⟩
  exact hyz (leftTight_cycle_intersection_subsingleton π.2 hπ hS)

/-- Sharpened noncrossing skip-collision reduction.

The direct-hit branch of a predecessor skip is already closed by
`permCyclicPredecessorSkip_direct_commonCycle`.  Hence the theorem-facing input
can be narrowed to the genuinely nested case, where
`finRotate (π x)` is not in the `π`-cycle of `x`. -/
theorem leftTight_no_nonfixed_cyclicPredecessorSkip_of_nonCrossing_nestedCommonCycle
    {m : ℕ}
    (hNested :
      ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          permCyclicPredecessorSkip π.1 x →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hNC : ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π)) :
    ¬ ∃ π : WickCycleLeftTightClass m,
      ∃ x : Fin (m + 1),
        π.1 x ≠ x ∧ permCyclicPredecessorSkip π.1 x := by
  rintro ⟨π, x, hne, hskip⟩
  by_cases hdirect :
      π.1.SameCycle x (finRotate (m + 1) (π.1 x))
  · rcases
      permCyclicPredecessorSkip_direct_commonCycle
        π.1 hskip hdirect with
      ⟨y, z, hyz, hπ, hS⟩
    exact hyz (leftTight_cycle_intersection_subsingleton π.2 hπ hS)
  · rcases hNested π (hNC π) x hne hskip hdirect with
      ⟨y, z, hyz, hπ, hS⟩
    exact hyz (leftTight_cycle_intersection_subsingleton π.2 hπ hS)

/-- Branch-explicit form of the nested skip-collision reduction.

After the direct-hit case has been discharged, the remaining nested collision
input has exactly two branches: the nonwrapping predecessor skip and the
wrapping predecessor skip.  This theorem exposes those two branch obligations
separately before feeding the no-skip leaf. -/
theorem leftTight_no_nonfixed_cyclicPredecessorSkip_of_nonCrossing_branchNestedCommonCycle
    {m : ℕ}
    (hNonwrap :
      ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          (π.1 x).val < x.val →
          (∃ z : Fin (m + 1),
            π.1.SameCycle z x ∧ (π.1 x).val < z.val ∧ z.val < x.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hWrap :
      ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          ¬ (π.1 x).val < x.val →
          ((∃ z : Fin (m + 1), π.1.SameCycle z x ∧ z.val < x.val) ∨
            ∃ z : Fin (m + 1),
              π.1.SameCycle z x ∧ (π.1 x).val < z.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hNC : ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π)) :
    ¬ ∃ π : WickCycleLeftTightClass m,
      ∃ x : Fin (m + 1),
        π.1 x ≠ x ∧ permCyclicPredecessorSkip π.1 x := by
  apply
    leftTight_no_nonfixed_cyclicPredecessorSkip_of_nonCrossing_nestedCommonCycle
      (m := m)
  · intro π hπNC x hne hskip hnotDirect
    rcases hskip with hNonwrapSkip | hWrapSkip
    · rcases hNonwrapSkip with ⟨hpx, hbetween⟩
      exact hNonwrap π hπNC x hne hpx hbetween hnotDirect
    · rcases hWrapSkip with ⟨hnlt, hwrap⟩
      exact hWrap π hπNC x hne hnlt hwrap hnotDirect
  · exact hNC

/-- Fully branch-explicit form of the nested skip-collision reduction.

The wrapping branch itself splits into the below-witness and above-witness
forms from `permCyclicPredecessorSkip`. -/
theorem leftTight_no_nonfixed_cyclicPredecessorSkip_of_nonCrossing_threeBranchNestedCommonCycle
    {m : ℕ}
    (hNonwrap :
      ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          (π.1 x).val < x.val →
          (∃ z : Fin (m + 1),
            π.1.SameCycle z x ∧ (π.1 x).val < z.val ∧ z.val < x.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hWrapBelow :
      ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          ¬ (π.1 x).val < x.val →
          (∃ z : Fin (m + 1), π.1.SameCycle z x ∧ z.val < x.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hWrapAbove :
      ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          ¬ (π.1 x).val < x.val →
          (∃ z : Fin (m + 1),
            π.1.SameCycle z x ∧ (π.1 x).val < z.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hNC : ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π)) :
    ¬ ∃ π : WickCycleLeftTightClass m,
      ∃ x : Fin (m + 1),
        π.1 x ≠ x ∧ permCyclicPredecessorSkip π.1 x := by
  apply
    leftTight_no_nonfixed_cyclicPredecessorSkip_of_nonCrossing_branchNestedCommonCycle
      (m := m)
  · exact hNonwrap
  · intro π hπNC x hne hnlt hwrap hnotDirect
    rcases hwrap with hbelow | habove
    · exact hWrapBelow π hπNC x hne hnlt hbelow hnotDirect
    · exact hWrapAbove π hπNC x hne hnlt habove hnotDirect
  · exact hNC

