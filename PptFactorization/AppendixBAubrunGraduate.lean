/-- A primitive residual on a strict child interval is already a primitive
residual on the parent interval.

The five child primitive branches are not new theorem-facing geometry in the
nonwrapping smaller-contour situation: internal/start/end `S` branches and the
fixed predecessor branch all become an internal parent `S` branch, while an
adjacent child `T` branch becomes an adjacent parent `T` branch.  This is the
arithmetic bridge that lets the parent primitive leaf consume the child
primitive alternatives. -/
theorem leftTightStrictReturnIntervalPrimitiveResidual_of_strictChildPrimitive
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    {a' c' : ℕ}
    (ha' : a' ∈ Finset.range (m + 1))
    (hc' : c' ∈ Finset.range (m + 1))
    (hac' : a' < c')
    (ha_lt : a < a')
    (hc_lt : c' < c)
    (_hgap' : 1 < c' - a')
    (hPrimitive :
      leftTightStrictReturnIntervalPrimitiveResidual π ha' hc' hac') :
    leftTightStrictReturnIntervalPrimitiveResidual π ha hc hac := by
  rw [leftTightStrictReturnIntervalPrimitiveResidual_iff_branchCases] at hPrimitive
  rw [leftTightStrictReturnIntervalPrimitiveResidual_iff_branchCases]
  rcases hPrimitive with hInternalS | hRest
  · left
    rcases hInternalS with ⟨r, s, _hr, _hs, hrpos, hslt, hrs, hS⟩
    let R : ℕ := a' + r - a
    let S : ℕ := a' + s - a
    refine ⟨R, S, ?_, ?_, ?_, ?_, ?_, ?_⟩
    · dsimp [R]
      omega
    · dsimp [S]
      omega
    · dsimp [R]
      omega
    · dsimp [S]
      omega
    · dsimp [R, S]
      omega
    · have hR :
          (⟨a + R, by
              have hc'' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
            ⟨a' + r, by
              have hc'' := Finset.mem_range.mp hc
              omega⟩ := by
          apply Fin.ext
          dsimp [R]
          omega
      have hS' :
          (⟨a + S, by
              have hc'' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
            ⟨a' + s, by
              have hc'' := Finset.mem_range.mp hc
              omega⟩ := by
          apply Fin.ext
          dsimp [S]
          omega
      simpa [hR, hS'] using hS
  · rcases hRest with hStartS | hRest
    · left
      rcases hStartS with ⟨s, _hs, hspos, hslt, hS⟩
      let R : ℕ := a' - a
      let S : ℕ := a' + s - a
      refine ⟨R, S, ?_, ?_, ?_, ?_, ?_, ?_⟩
      · dsimp [R]
        omega
      · dsimp [S]
        omega
      · dsimp [R]
        omega
      · dsimp [S]
        omega
      · dsimp [R, S]
        omega
      · have hR :
            (⟨a + R, by
                have hc'' := Finset.mem_range.mp hc
                omega⟩ : Fin (m + 1)) =
              ⟨a', Finset.mem_range.mp ha'⟩ := by
            apply Fin.ext
            dsimp [R]
            omega
        have hS' :
            (⟨a + S, by
                have hc'' := Finset.mem_range.mp hc
                omega⟩ : Fin (m + 1)) =
              ⟨a' + s, by
                have hc'' := Finset.mem_range.mp hc
                omega⟩ := by
            apply Fin.ext
            dsimp [S]
            omega
        simpa [hR, hS'] using hS
    · rcases hRest with hEndS | hRest
      · left
        rcases hEndS with ⟨r, _hr, hrpos, hrlt, hS⟩
        let R : ℕ := a' + r - a
        let S : ℕ := c' - a
        refine ⟨R, S, ?_, ?_, ?_, ?_, ?_, ?_⟩
        · dsimp [R]
          omega
        · dsimp [S]
          omega
        · dsimp [R]
          omega
        · dsimp [S]
          omega
        · dsimp [R, S]
          omega
        · have hR :
              (⟨a + R, by
                  have hc'' := Finset.mem_range.mp hc
                  omega⟩ : Fin (m + 1)) =
                ⟨a' + r, by
                  have hc'' := Finset.mem_range.mp hc
                  omega⟩ := by
              apply Fin.ext
              dsimp [R]
              omega
          have hS' :
              (⟨a + S, by
                  have hc'' := Finset.mem_range.mp hc
                  omega⟩ : Fin (m + 1)) =
                ⟨c', Finset.mem_range.mp hc'⟩ := by
              apply Fin.ext
              dsimp [S]
              omega
          simpa [hR, hS'] using hS
      · rcases hRest with hFixedPred | hAdjacentT
        · left
          let R : ℕ := c' - 1 - a
          let S : ℕ := c' - a
          refine ⟨R, S, ?_, ?_, ?_, ?_, ?_, ?_⟩
          · dsimp [R]
            omega
          · dsimp [S]
            omega
          · dsimp [R]
            omega
          · dsimp [S]
            omega
          · dsimp [R, S]
            omega
          · let y : Fin (m + 1) :=
              ⟨c' - 1, by
                have hc'' := Finset.mem_range.mp hc'
                omega⟩
            have hrot : finRotate (m + 1) y =
                ⟨c', Finset.mem_range.mp hc'⟩ := by
              rw [finRotate_succ_apply]
              apply Fin.ext
              have hy_succ_lt : y.val + 1 < m + 1 := by
                have hc'' := Finset.mem_range.mp hc'
                simp [y]
                omega
              have hval : (y + 1).val = y.val + 1 := by
                simpa using Fin.val_add_one_of_lt' (i := y) hy_succ_lt
              change (y + 1).val = c'
              simp [y] at hval ⊢
              omega
            have hSrot :
                (finRotate (m + 1) * π).SameCycle
                  y ⟨c', Finset.mem_range.mp hc'⟩ := by
              have hbase :=
                finRotate_mul_perm_sameCycle_self_finRotate_of_fixed
                  (m := m) (π := π) (x := y)
                  (by simpa [y] using hFixedPred)
              simpa [hrot] using hbase
            have hR :
                (⟨a + R, by
                    have hc'' := Finset.mem_range.mp hc
                    omega⟩ : Fin (m + 1)) = y := by
              apply Fin.ext
              dsimp [R, y]
              omega
            have hS' :
                (⟨a + S, by
                    have hc'' := Finset.mem_range.mp hc
                    omega⟩ : Fin (m + 1)) =
                  ⟨c', Finset.mem_range.mp hc'⟩ := by
              apply Fin.ext
              dsimp [S]
              omega
            simpa [hR, hS'] using hSrot
        · right
          right
          right
          right
          rcases hAdjacentT with ⟨r, hr, hT⟩
          let R : ℕ := a' + r - a
          refine ⟨R, ?_, ?_⟩
          · dsimp [R]
            omega
          · have hR :
                (⟨a + R, by
                    have hc'' := Finset.mem_range.mp hc
                    omega⟩ : Fin (m + 1)) =
                  ⟨a' + r, by
                    have hc'' := Finset.mem_range.mp hc
                    omega⟩ := by
                apply Fin.ext
                dsimp [R]
                omega
            have hRsucc :
                (⟨a + (R + 1), by
                    have hc'' := Finset.mem_range.mp hc
                    omega⟩ : Fin (m + 1)) =
                  ⟨a' + (r + 1), by
                    have hc'' := Finset.mem_range.mp hc
                    omega⟩ := by
                apply Fin.ext
                dsimp [R]
                omega
            simpa [hR, hRsucc] using hT

/-- A strict smaller contour-repeat packet reduces to its child internal
subinterval branch once the parent primitive branch is available.

The contour split on the child interval has three outcomes. The common-cycle
outcome closes immediately. The child primitive residual outcome is already a
parent primitive residual by
`leftTightStrictReturnIntervalPrimitiveResidual_of_strictChildPrimitive`.
Thus the only genuinely recursive theorem-facing branch is the child's
internal-subinterval residual. -/
theorem leftTight_strictSmallerContourRepeat_common_of_parentPrimitive_or_childInternal
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hParentPrimitiveCommon :
      leftTightStrictReturnIntervalPrimitiveResidual π.1 ha hc hac →
        ∃ y z : Fin (m + 1),
          y ≠ z ∧
            π.1.SameCycle y z ∧
              (finRotate (m + 1) * π.1).SameCycle y z)
    {x : Fin (m + 1)}
    (hChildInternalCommon :
      ∀ a' c' : ℕ,
        ∀ ha' : a' ∈ Finset.range (m + 1),
        ∀ hc' : c' ∈ Finset.range (m + 1),
        ∀ hac' : a' < c',
          a < a' →
          c' < c →
          1 < c' - a' →
          π.1.SameCycle
            ⟨a', Finset.mem_range.mp ha'⟩
            ⟨c', Finset.mem_range.mp hc'⟩ →
          leftTightStrictReturnIntervalInternalSubintervalResidual
            π.1 ha' hc' hac' →
          (∀ y : Fin (m + 1),
            π.1.SameCycle y
              ⟨a', Finset.mem_range.mp ha'⟩ →
            (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hSmallerContour :
      ∃ a' c' : ℕ,
        ∃ ha' : a' ∈ Finset.range (m + 1),
        ∃ hc' : c' ∈ Finset.range (m + 1),
        ∃ hac' : a' < c',
          a < a' ∧
          c' < c ∧
          1 < c' - a' ∧
          π.1.SameCycle
            ⟨a', Finset.mem_range.mp ha'⟩
            ⟨c', Finset.mem_range.mp hc'⟩ ∧
          leftTightContourIntervalRepeat π.1 ha' hc' hac' ∧
          ∀ y : Fin (m + 1),
            π.1.SameCycle y
              ⟨a', Finset.mem_range.mp ha'⟩ →
            (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.1.SameCycle y z ∧
          (finRotate (m + 1) * π.1).SameCycle y z := by
  rcases hSmallerContour with
    ⟨a', c', ha', hc', hac', ha_lt, hc_lt, hgap',
      hSame', hRepeat, hBlock⟩
  have hFrontier :
      leftTightStrictReturnIntervalFrontier π.1 ha' hc' hac' := by
    exact
      leftTightContourIntervalRepeat_strict_frontier
        (m := m) (π := π.1) π.2 ha' hc' hac' hgap' hSame' hRepeat
  rcases
    leftTightStrictReturnIntervalFrontier_common_or_residual
      ha' hc' hac' hFrontier with
    hCommon | hResidual
  · exact hCommon
  have hDesc :
      leftTightStrictReturnIntervalSubintervalDescendedResidual
        π.1 ha' hc' hac' :=
    leftTightStrictReturnIntervalResidual_descend_internal_right_subinterval
      ha' hc' hac' hResidual
  rcases
    (leftTightStrictReturnIntervalSubintervalDescendedResidual_iff
      ha' hc' hac').mp hDesc with
    hPrimitive | hInternal
  · exact
      hParentPrimitiveCommon
        (leftTightStrictReturnIntervalPrimitiveResidual_of_strictChildPrimitive
          (π := π.1) ha hc hac ha' hc' hac' ha_lt hc_lt hgap' hPrimitive)
  · exact
      hChildInternalCommon a' c' ha' hc' hac' ha_lt hc_lt hgap'
        hSame' hInternal hBlock

/-- Well-founded nonwrapping closure of the smaller internal-subinterval
branch from the parent primitive branch.

The recursive branch is the only nonlocal part of the smaller-child frontier.
An internal-subinterval residual first descends to a strictly shorter child
interval while preserving the parent side data.  The contour split on that
shorter interval either gives the desired common-cycle witness, a primitive
child branch absorbed by the parent primitive input, or another strictly
shorter internal-subinterval branch. -/
theorem leftTight_nonwrap_smallerInternal_common_of_parentPrimitive_wf
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hπNC : NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    {x : Fin (m + 1)}
    (hne : π.1 x ≠ x)
    (hskip : permCyclicPredecessorSkip π.1 x)
    (hnotDirect :
      ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)))
    (hPrimitiveCommon :
      ∀ a c : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hac : a < c,
          1 < c - a →
          π.1.SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          leftTightStrictReturnIntervalPrimitiveResidual π.1 ha hc hac →
          a = (π.1 x).val →
          c < x.val →
          (∀ z : Fin (m + 1),
            π.1.SameCycle z x →
            a < z.val →
            z.val < c →
            False) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hgap : 1 < c - a)
    (hT : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (haeq : a = (π.1 x).val)
    (hcx : c < x.val)
    (hfirst :
      ∀ z : Fin (m + 1),
        π.1.SameCycle z x →
        a < z.val →
        z.val < c →
        False)
    {a' c' : ℕ}
    (ha' : a' ∈ Finset.range (m + 1))
    (hc' : c' ∈ Finset.range (m + 1))
    (hac' : a' < c')
    (ha_lt : a < a')
    (hc_lt : c' < c)
    (hgap' : 1 < c' - a')
    (hSame' : π.1.SameCycle
      ⟨a', Finset.mem_range.mp ha'⟩
      ⟨c', Finset.mem_range.mp hc'⟩)
    (hInternal :
      leftTightStrictReturnIntervalInternalSubintervalResidual π.1 ha' hc' hac')
    (hNoX :
      ∀ z : Fin (m + 1),
        π.1.SameCycle z x →
        a' < z.val →
        z.val < c' →
        False)
    (hBlock :
      ∀ y : Fin (m + 1),
        π.1.SameCycle y
          ⟨a', Finset.mem_range.mp ha'⟩ →
        (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.1.SameCycle y z ∧
          (finRotate (m + 1) * π.1).SameCycle y z := by
  classical
  have hmain :
      ∀ n : ℕ,
        ∀ a0 c0 : ℕ,
        ∀ ha0 : a0 ∈ Finset.range (m + 1),
        ∀ hc0 : c0 ∈ Finset.range (m + 1),
        ∀ hac0 : a0 < c0,
          1 < c0 - a0 →
          π.1.SameCycle
            ⟨a0, Finset.mem_range.mp ha0⟩
            ⟨c0, Finset.mem_range.mp hc0⟩ →
          a0 = (π.1 x).val →
          c0 < x.val →
          (∀ z : Fin (m + 1),
            π.1.SameCycle z x →
            a0 < z.val →
            z.val < c0 →
            False) →
          ∀ a1 c1 : ℕ,
          ∀ ha1 : a1 ∈ Finset.range (m + 1),
          ∀ hc1 : c1 ∈ Finset.range (m + 1),
          ∀ hac1 : a1 < c1,
            a0 < a1 →
            c1 < c0 →
            1 < c1 - a1 →
            π.1.SameCycle
              ⟨a1, Finset.mem_range.mp ha1⟩
              ⟨c1, Finset.mem_range.mp hc1⟩ →
            c1 - a1 = n →
            leftTightStrictReturnIntervalInternalSubintervalResidual
              π.1 ha1 hc1 hac1 →
            (∀ z : Fin (m + 1),
              π.1.SameCycle z x →
              a1 < z.val →
              z.val < c1 →
              False) →
            (∀ y : Fin (m + 1),
              π.1.SameCycle y
                ⟨a1, Finset.mem_range.mp ha1⟩ →
              (a0 < y.val ∧ y.val < c0) ∧ ¬ π.1.SameCycle y x) →
            ∃ y z : Fin (m + 1),
              y ≠ z ∧
                π.1.SameCycle y z ∧
                  (finRotate (m + 1) * π.1).SameCycle y z := by
    intro n
    refine Nat.strong_induction_on n ?_
    intro n ih a0 c0 ha0 hc0 hac0 hgap0 hT0 haeq0 hcx0 hfirst0
      a1 c1 ha1 hc1 hac1 ha0_lt hc1_lt hgap1 hSame1 hlen
      hInternal1 hNoX1 hBlock1
    have hChildPrimitiveCommon :
        ∀ aP cP : ℕ,
        ∀ haP : aP ∈ Finset.range (m + 1),
        ∀ hcP : cP ∈ Finset.range (m + 1),
        ∀ hacP : aP < cP,
          1 < cP - aP →
          π.1.SameCycle
            ⟨aP, Finset.mem_range.mp haP⟩
            ⟨cP, Finset.mem_range.mp hcP⟩ →
          aP = (π.1 x).val →
          cP < x.val →
          (∀ z : Fin (m + 1),
            π.1.SameCycle z x →
            aP < z.val →
            z.val < cP →
            False) →
          ∀ aC cC : ℕ,
          ∀ haC : aC ∈ Finset.range (m + 1),
          ∀ hcC : cC ∈ Finset.range (m + 1),
          ∀ hacC : aC < cC,
            aP < aC →
            cC < cP →
            1 < cC - aC →
            π.1.SameCycle
              ⟨aC, Finset.mem_range.mp haC⟩
              ⟨cC, Finset.mem_range.mp hcC⟩ →
            leftTightStrictReturnIntervalPrimitiveResidual π.1 haC hcC hacC →
            (∀ z : Fin (m + 1),
              π.1.SameCycle z x →
              aC < z.val →
              z.val < cC →
              False) →
            (∀ y : Fin (m + 1),
              π.1.SameCycle y
                ⟨aC, Finset.mem_range.mp haC⟩ →
              (aP < y.val ∧ y.val < cP) ∧ ¬ π.1.SameCycle y x) →
            ∃ y z : Fin (m + 1),
              y ≠ z ∧
                π.1.SameCycle y z ∧
                  (finRotate (m + 1) * π.1).SameCycle y z := by
      intro aP cP haP hcP hacP hgapP hTP haeqP hcxP hfirstP
        aC cC haC hcC hacC haP_lt hcC_lt hgapC _hSameC
        hPrimitiveC _hNoXC _hBlockC
      exact
        hPrimitiveCommon aP cP haP hcP hacP hgapP hTP
          (leftTightStrictReturnIntervalPrimitiveResidual_of_strictChildPrimitive
            haP hcP hacP haC hcC hacC haP_lt hcC_lt hgapC hPrimitiveC)
          haeqP hcxP hfirstP
    rcases
      leftTightStrictReturnIntervalInternalSubintervalResidual_descend_preserves_parentBlock
        π hπNC ha0 hc0 hac0 ha1 hc1 hac1 ha0_lt hc1_lt hSame1
        hInternal1 hNoX1 hBlock1 with
      ⟨a2, c2, ha2, hc2, hac2, ha2_lt, hc2_lt, hgap2, hshort2,
        hSame2, hNoX2, hBlock2⟩
    have hRepeat2 : leftTightContourIntervalRepeat π.1 ha2 hc2 hac2 := by
      exact
        leftTight_contour_interval_sameCycle_exists_repeated_parity_sameCycle_of_one_lt_sub
          (m := m) (π := π.1) π.2 ha2 hc2 hac2 hSame2 hgap2
    rcases
      leftTightContourIntervalRepeat_common_or_strict_cases
        (m := m) (π := π.1) π.2 ha2 hc2 hac2 hgap2 hSame2 hRepeat2 with
      hCommon | hRest
    · exact hCommon
    · rcases hRest with hInternalS | hRest
      · exact
          hChildPrimitiveCommon a0 c0 ha0 hc0 hac0 hgap0 hT0 haeq0
            hcx0 hfirst0 a2 c2 ha2 hc2 hac2 ha2_lt hc2_lt hgap2 hSame2
            (Or.inl hInternalS) hNoX2 hBlock2
      · rcases hRest with hStartS | hRest
        · exact
            hChildPrimitiveCommon a0 c0 ha0 hc0 hac0 hgap0 hT0 haeq0
              hcx0 hfirst0 a2 c2 ha2 hc2 hac2 ha2_lt hc2_lt hgap2 hSame2
              (Or.inr (Or.inl hStartS)) hNoX2 hBlock2
        · rcases hRest with hEndS | hRest
          · exact
              hChildPrimitiveCommon a0 c0 ha0 hc0 hac0 hgap0 hT0 haeq0
                hcx0 hfirst0 a2 c2 ha2 hc2 hac2 ha2_lt hc2_lt hgap2 hSame2
                (Or.inr (Or.inr (Or.inl hEndS))) hNoX2 hBlock2
          · rcases hRest with hFixed | hInternalT
            · exact
                hChildPrimitiveCommon a0 c0 ha0 hc0 hac0 hgap0 hT0 haeq0
                  hcx0 hfirst0 a2 c2 ha2 hc2 hac2 ha2_lt hc2_lt hgap2 hSame2
                  (Or.inr (Or.inr (Or.inr (Or.inl hFixed)))) hNoX2 hBlock2
            · rcases hInternalT with ⟨r, s, hr, hs, hrs, hSameT⟩
              by_cases hadj : s = r + 1
              · have hAdjacent :
                    leftTightStrictReturnIntervalPrimitiveResidualAdjacentT
                      π.1 ha2 hc2 hac2 := by
                  refine ⟨r, ?_, ?_⟩
                  · omega
                  · subst s
                    simpa [Nat.add_assoc] using hSameT
                exact
                  hChildPrimitiveCommon a0 c0 ha0 hc0 hac0 hgap0 hT0 haeq0
                    hcx0 hfirst0 a2 c2 ha2 hc2 hac2 ha2_lt hc2_lt hgap2 hSame2
                    (Or.inr (Or.inr (Or.inr (Or.inr hAdjacent))))
                    hNoX2 hBlock2
              · have hInternal2 :
                    leftTightStrictReturnIntervalInternalSubintervalResidual
                      π.1 ha2 hc2 hac2 := by
                  exact ⟨r, s, hr, hs, hrs, by omega, hSameT⟩
                exact
                  ih (c2 - a2) (by omega)
                    a0 c0 ha0 hc0 hac0 hgap0 hT0 haeq0 hcx0 hfirst0
                    a2 c2 ha2 hc2 hac2 ha2_lt hc2_lt hgap2 hSame2 rfl
                    hInternal2 hNoX2 hBlock2
  exact
    hmain (c' - a') a c ha hc hac hgap hT haeq hcx hfirst
      a' c' ha' hc' hac' ha_lt hc_lt hgap' hSame' rfl
      hInternal hNoX hBlock

/-- A child interval whose block is off the skipped cycle contains no skipped
cycle point when the parent right endpoint is in that skipped cycle.

If a skipped-cycle point lay strictly between the child endpoints, noncrossing
would force the skipped-cycle block to be contained in the child interval.
But the parent right endpoint lies in the skipped cycle and strictly to the
right of the child interval, contradiction. -/
theorem leftTight_childInterval_no_xCycle_of_parentRightEndpoint_sameCycle
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hπNC : NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    {x : Fin (m + 1)}
    {a c a' c' : ℕ}
    (ha' : a' ∈ Finset.range (m + 1))
    (hc' : c' ∈ Finset.range (m + 1))
    (_hac' : a' < c')
    (hc : c ∈ Finset.range (m + 1))
    (hc_lt : c' < c)
    (hSame' :
      π.1.SameCycle
        ⟨a', Finset.mem_range.mp ha'⟩
        ⟨c', Finset.mem_range.mp hc'⟩)
    (hcx :
      π.1.SameCycle
        ⟨c, Finset.mem_range.mp hc⟩ x)
    (hBlock :
      ∀ y : Fin (m + 1),
        π.1.SameCycle y
          ⟨a', Finset.mem_range.mp ha'⟩ →
        (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x) :
    ∀ z : Fin (m + 1),
      π.1.SameCycle z x →
      a' < z.val →
      z.val < c' →
      False := by
  classical
  intro z hzx hzgt hzlt
  let A' : Fin (m + 1) := ⟨a', Finset.mem_range.mp ha'⟩
  let C' : Fin (m + 1) := ⟨c', Finset.mem_range.mp hc'⟩
  let C : Fin (m + 1) := ⟨c, Finset.mem_range.mp hc⟩
  let Pnc : NCPartition.NCPart (m + 1) :=
    ⟨leftTightCyclePartitionRange π, hπNC⟩
  have hAoff : ¬ π.1.SameCycle A' x := by
    exact (hBlock A' (Equiv.Perm.SameCycle.refl π.1 A')).2
  have hC'_mem :
      C'.val ∈ (leftTightCyclePartitionRange π).part A'.val := by
    have hA'range : A'.val ∈ Finset.range (m + 1) :=
      Finset.mem_range.mpr A'.2
    have hC'range : C'.val ∈ Finset.range (m + 1) :=
      Finset.mem_range.mpr C'.2
    exact
      (mem_leftTightCyclePartitionRange_part_iff π hA'range hC'range).mpr
        (by simpa [A', C'] using hSame')
  have hpart_ne :
      (leftTightCyclePartitionRange π).part A'.val ≠
        (leftTightCyclePartitionRange π).part z.val := by
    intro hpart
    have hzRange : z.val ∈ Finset.range (m + 1) :=
      Finset.mem_range.mpr z.2
    have hz_mem_self :
        z.val ∈ (leftTightCyclePartitionRange π).part z.val :=
      (leftTightCyclePartitionRange π).mem_part hzRange
    have hz_mem_A' :
        z.val ∈ (leftTightCyclePartitionRange π).part A'.val := by
      simpa [hpart] using hz_mem_self
    have hA'z : π.1.SameCycle A' z := by
      have hA'range : A'.val ∈ Finset.range (m + 1) :=
        Finset.mem_range.mpr A'.2
      exact
        (mem_leftTightCyclePartitionRange_part_iff π hA'range hzRange).mp
          (by simpa [A'] using hz_mem_A')
    exact hAoff (hA'z.trans hzx)
  have hsubset :
      ∀ y0 ∈ (leftTightCyclePartitionRange π).part z.val,
        A'.val ≤ y0 ∧ y0 ≤ C'.val := by
    exact
      Pnc.part_subset_Icc_of_between_distinct
        (by simpa [A'] using hzgt)
        (by simpa [C'] using hzlt)
        hC'_mem hpart_ne
  have hC_mem_z :
      C.val ∈ (leftTightCyclePartitionRange π).part z.val := by
    have hzRange : z.val ∈ Finset.range (m + 1) :=
      Finset.mem_range.mpr z.2
    have hCrange : C.val ∈ Finset.range (m + 1) :=
      Finset.mem_range.mpr C.2
    exact
      (mem_leftTightCyclePartitionRange_part_iff π hzRange hCrange).mpr
        (by simpa [C] using hzx.trans hcx.symm)
  have hclosed := hsubset C.val hC_mem_z
  have hc_le_c' : c ≤ c' := by
    simpa [C, C'] using hclosed.2
  omega

/-- Generic well-founded closure for a strict child internal-subinterval leaf.

The parent side data is used only through the parent primitive collision
supplier.  The recursive branch descends to a strictly shorter child interval
while preserving the full no-skipped-cycle invariant and the parent block
invariant. -/
theorem leftTight_smallerInternal_common_of_parentPrimitive_wf
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hπNC : NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    {x : Fin (m + 1)}
    {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hParentPrimitiveCommon :
      leftTightStrictReturnIntervalPrimitiveResidual π.1 ha hc hac →
        ∃ y z : Fin (m + 1),
          y ≠ z ∧
            π.1.SameCycle y z ∧
              (finRotate (m + 1) * π.1).SameCycle y z)
    {a' c' : ℕ}
    (ha' : a' ∈ Finset.range (m + 1))
    (hc' : c' ∈ Finset.range (m + 1))
    (hac' : a' < c')
    (ha_lt : a < a')
    (hc_lt : c' < c)
    (hgap' : 1 < c' - a')
    (hSame' : π.1.SameCycle
      ⟨a', Finset.mem_range.mp ha'⟩
      ⟨c', Finset.mem_range.mp hc'⟩)
    (hInternal :
      leftTightStrictReturnIntervalInternalSubintervalResidual π.1 ha' hc' hac')
    (hNoX :
      ∀ z : Fin (m + 1),
        π.1.SameCycle z x →
        a' < z.val →
        z.val < c' →
        False)
    (hBlock :
      ∀ y : Fin (m + 1),
        π.1.SameCycle y
          ⟨a', Finset.mem_range.mp ha'⟩ →
        (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.1.SameCycle y z ∧
          (finRotate (m + 1) * π.1).SameCycle y z := by
  classical
  have hmain :
      ∀ n : ℕ,
        ∀ a1 c1 : ℕ,
        ∀ ha1 : a1 ∈ Finset.range (m + 1),
        ∀ hc1 : c1 ∈ Finset.range (m + 1),
        ∀ hac1 : a1 < c1,
          a < a1 →
          c1 < c →
          1 < c1 - a1 →
          π.1.SameCycle
            ⟨a1, Finset.mem_range.mp ha1⟩
            ⟨c1, Finset.mem_range.mp hc1⟩ →
          c1 - a1 = n →
          leftTightStrictReturnIntervalInternalSubintervalResidual
            π.1 ha1 hc1 hac1 →
          (∀ z : Fin (m + 1),
            π.1.SameCycle z x →
            a1 < z.val →
            z.val < c1 →
            False) →
          (∀ y : Fin (m + 1),
            π.1.SameCycle y
              ⟨a1, Finset.mem_range.mp ha1⟩ →
            (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z := by
    intro n
    refine Nat.strong_induction_on n ?_
    intro n ih a1 c1 ha1 hc1 hac1 ha1_lt hc1_lt hgap1 hSame1
      hlen hInternal1 hNoX1 hBlock1
    rcases
      leftTightStrictReturnIntervalInternalSubintervalResidual_descend_preserves_parentBlock
        π hπNC ha hc hac ha1 hc1 hac1 ha1_lt hc1_lt hSame1
        hInternal1 hNoX1 hBlock1 with
      ⟨a2, c2, ha2, hc2, hac2, ha2_lt, hc2_lt, hgap2, hshort2,
        hSame2, hNoX2, hBlock2⟩
    have hRepeat2 : leftTightContourIntervalRepeat π.1 ha2 hc2 hac2 := by
      exact
        leftTight_contour_interval_sameCycle_exists_repeated_parity_sameCycle_of_one_lt_sub
          (m := m) (π := π.1) π.2 ha2 hc2 hac2 hSame2 hgap2
    rcases
      leftTightContourIntervalRepeat_common_or_strict_cases
        (m := m) (π := π.1) π.2 ha2 hc2 hac2 hgap2 hSame2 hRepeat2 with
      hCommon | hRest
    · exact hCommon
    · rcases hRest with hInternalS | hRest
      · exact
          hParentPrimitiveCommon
            (leftTightStrictReturnIntervalPrimitiveResidual_of_strictChildPrimitive
              (π := π.1) ha hc hac ha2 hc2 hac2 ha2_lt hc2_lt hgap2
              (Or.inl hInternalS))
      · rcases hRest with hStartS | hRest
        · exact
            hParentPrimitiveCommon
              (leftTightStrictReturnIntervalPrimitiveResidual_of_strictChildPrimitive
                (π := π.1) ha hc hac ha2 hc2 hac2 ha2_lt hc2_lt hgap2
                (Or.inr (Or.inl hStartS)))
        · rcases hRest with hEndS | hRest
          · exact
              hParentPrimitiveCommon
                (leftTightStrictReturnIntervalPrimitiveResidual_of_strictChildPrimitive
                  (π := π.1) ha hc hac ha2 hc2 hac2 ha2_lt hc2_lt hgap2
                  (Or.inr (Or.inr (Or.inl hEndS))))
          · rcases hRest with hFixed | hInternalT
            · exact
                hParentPrimitiveCommon
                  (leftTightStrictReturnIntervalPrimitiveResidual_of_strictChildPrimitive
                    (π := π.1) ha hc hac ha2 hc2 hac2 ha2_lt hc2_lt hgap2
                    (Or.inr (Or.inr (Or.inr (Or.inl hFixed)))))
            · rcases hInternalT with ⟨r, s, hr, hs, hrs, hSameT⟩
              by_cases hadj : s = r + 1
              · have hAdjacent :
                    leftTightStrictReturnIntervalPrimitiveResidualAdjacentT
                      π.1 ha2 hc2 hac2 := by
                  refine ⟨r, ?_, ?_⟩
                  · omega
                  · subst s
                    simpa [Nat.add_assoc] using hSameT
                exact
                  hParentPrimitiveCommon
                    (leftTightStrictReturnIntervalPrimitiveResidual_of_strictChildPrimitive
                      (π := π.1) ha hc hac ha2 hc2 hac2 ha2_lt hc2_lt hgap2
                      (Or.inr (Or.inr (Or.inr (Or.inr hAdjacent)))))
              · have hInternal2 :
                    leftTightStrictReturnIntervalInternalSubintervalResidual
                      π.1 ha2 hc2 hac2 := by
                  exact ⟨r, s, hr, hs, hrs, by omega, hSameT⟩
                exact
                  ih (c2 - a2) (by omega)
                    a2 c2 ha2 hc2 hac2 ha2_lt hc2_lt hgap2 hSame2 rfl
                    hInternal2 hNoX2 hBlock2
  exact
    hmain (c' - a') a' c' ha' hc' hac' ha_lt hc_lt hgap'
      hSame' rfl hInternal hNoX hBlock

/-- First nested contour interval in the nonwrapping predecessor-skip branch.

This packages
`permCyclicPredecessorSkip_nonwrap_nested_exists_first_sameCycle_gap` in the
form used by the Biane contour machinery: the first return after `π x` gives
a long same-`π` interval starting exactly at `(π x).val`, with no intermediate
same-cycle return to `x`, and left-tightness supplies the repeated-contour
obstruction on that interval. -/
theorem leftTight_nonwrap_nested_cyclicPredecessorSkip_exists_first_contourIntervalRepeat
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hpx : (π.1 x).val < x.val)
    (hbetween :
      ∃ z : Fin (m + 1),
        π.1.SameCycle z x ∧ (π.1 x).val < z.val ∧ z.val < x.val)
    (hnotDirect : ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x))) :
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        a = (π.1 x).val ∧
        c < x.val ∧
        1 < c - a ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ ∧
        leftTightContourIntervalRepeat π.1 ha hc hac ∧
        ∀ z : Fin (m + 1),
          π.1.SameCycle z x →
          a < z.val →
          z.val < c →
          False := by
  rcases
    permCyclicPredecessorSkip_nonwrap_nested_exists_first_sameCycle_gap
      π.1 hpx hbetween hnotDirect with
    ⟨c, hc, hpc, hcx, hgap, hSameC, hfirst⟩
  let a : ℕ := (π.1 x).val
  have ha : a ∈ Finset.range (m + 1) := Finset.mem_range.mpr (π.1 x).2
  have hac : a < c := by
    simpa [a] using hpc
  have hSame :
      π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
    have hA : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = π.1 x := by
      apply Fin.ext
      rfl
    have hApply := perm_apply_sameCycle_self π.1 x
    simpa [hA] using hApply.trans hSameC.symm
  refine ⟨a, c, ha, hc, hac, rfl, hcx, ?_, hSame, ?_, ?_⟩
  · simpa [a] using hgap
  · exact
      leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
        (m := m) (π := π.1) π.2 ha hc hac hSame (by simpa [a] using hgap)
  · intro z hzSame haz hzc
    exact hfirst z hzSame (by simpa [a] using haz) hzc

/-- First nested return in the wrap-above predecessor-skip branch.

If the wrapped skip has a same-`π` point strictly above `π x`, but the
immediate long-cycle successor `finRotate (π x)` is not in the `π`-cycle of
`x`, then the first same-cycle point above `π x` is separated from `π x` by a
gap of length at least two. -/
theorem permCyclicPredecessorSkip_wrapAbove_nested_exists_first_sameCycle_gap
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {x : Fin (m + 1)}
    (_hnlt : ¬ (π x).val < x.val)
    (habove :
      ∃ z : Fin (m + 1),
        π.SameCycle z x ∧ (π x).val < z.val)
    (hnotDirect : ¬ π.SameCycle x (finRotate (m + 1) (π x))) :
    ∃ c : ℕ,
      ∃ hc : c ∈ Finset.range (m + 1),
        (π x).val < c ∧
        1 < c - (π x).val ∧
        π.SameCycle ⟨c, Finset.mem_range.mp hc⟩ x ∧
        ∀ z : Fin (m + 1),
          π.SameCycle z x →
          (π x).val < z.val →
          z.val < c →
          False := by
  classical
  let P : ℕ → Prop := fun n =>
    ∃ z : Fin (m + 1),
      π.SameCycle z x ∧ (π x).val < z.val ∧ z.val = n
  have hExists : ∃ n : ℕ, P n := by
    rcases habove with ⟨z, hz, hpz⟩
    exact ⟨z.val, z, hz, hpz, rfl⟩
  let c : ℕ := Nat.find hExists
  have hcSpec : P c := by
    simpa [c] using Nat.find_spec hExists
  rcases hcSpec with ⟨w, hwSame, hpw, hwc⟩
  have hc : c ∈ Finset.range (m + 1) := by
    exact Finset.mem_range.mpr (by
      rw [← hwc]
      exact w.2)
  have hSameC :
      π.SameCycle ⟨c, Finset.mem_range.mp hc⟩ x := by
    have hcw : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = w := by
      apply Fin.ext
      exact hwc.symm
    simpa [hcw] using hwSame
  have hgap : 1 < c - (π x).val := by
    by_contra hnot
    have hle : c - (π x).val ≤ 1 := Nat.le_of_not_gt hnot
    have hsubpos : 0 < c - (π x).val := by omega
    have hc_eq : c = (π x).val + 1 := by omega
    have hpnotlast : π x ≠ Fin.last m := by
      intro hlast
      have hpval : (π x).val = m := by
        simpa using congrArg Fin.val hlast
      have hwlt := w.2
      omega
    have hrotval :
        (finRotate (m + 1) (π x)).val = (π x).val + 1 := by
      rw [finRotate_succ_apply]
      simp [Fin.val_add_one, hpnotlast]
    have hrot :
        (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) =
          finRotate (m + 1) (π x) := by
      apply Fin.ext
      rw [hrotval]
      exact hc_eq
    have hdirect : π.SameCycle x (finRotate (m + 1) (π x)) := by
      simpa [hrot] using hSameC.symm
    exact hnotDirect hdirect
  refine ⟨c, hc, ?_, hgap, hSameC, ?_⟩
  · simpa [← hwc] using hpw
  · intro z hzSame hpz hzc
    have hPz : P z.val := ⟨z, hzSame, hpz, rfl⟩
    have hmin : c ≤ z.val := Nat.find_min' hExists hPz
    omega

/-- Last nested return in the wrap-below predecessor-skip branch.

In the wrapping branch, nonfixedness and `¬ π x < x` imply `x < π x`.
If a same-`π` point lies below `x`, then the last such point is separated from
`π x` by a genuine gap.  The maximality is expressed as the absence of a
same-cycle return strictly between this point and `x`. -/
theorem permCyclicPredecessorSkip_wrapBelow_nested_exists_last_sameCycle_gap
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {x : Fin (m + 1)}
    (hnotfix : π x ≠ x)
    (hnlt : ¬ (π x).val < x.val)
    (hbelow :
      ∃ z : Fin (m + 1),
        π.SameCycle z x ∧ z.val < x.val) :
    ∃ a : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
        a < x.val ∧
        1 < (π x).val - a ∧
        π.SameCycle ⟨a, Finset.mem_range.mp ha⟩ x ∧
        ∀ z : Fin (m + 1),
          π.SameCycle z x →
          a < z.val →
          z.val < x.val →
          False := by
  classical
  have hneqVal : (π x).val ≠ x.val := by
    intro hval
    exact hnotfix (Fin.ext hval)
  have hxltpx : x.val < (π x).val := by
    omega
  let P : ℕ → Prop := fun n =>
    ∃ z : Fin (m + 1),
      π.SameCycle z x ∧ z.val < x.val ∧ x.val - z.val = n
  have hExists : ∃ n : ℕ, P n := by
    rcases hbelow with ⟨z, hz, hzx⟩
    exact ⟨x.val - z.val, z, hz, hzx, rfl⟩
  let n : ℕ := Nat.find hExists
  have hnSpec : P n := by
    simpa [n] using Nat.find_spec hExists
  rcases hnSpec with ⟨w, hwSame, hwx, hwn⟩
  let a : ℕ := w.val
  have ha : a ∈ Finset.range (m + 1) := Finset.mem_range.mpr w.2
  have hSameA :
      π.SameCycle ⟨a, Finset.mem_range.mp ha⟩ x := by
    have haw : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = w := by
      apply Fin.ext
      rfl
    simpa [haw] using hwSame
  have hgap : 1 < (π x).val - a := by
    dsimp [a]
    omega
  refine ⟨a, ha, ?_, hgap, hSameA, ?_⟩
  · simpa [a] using hwx
  · intro z hzSame haz hzx
    have hPz : P (x.val - z.val) := ⟨z, hzSame, hzx, rfl⟩
    have hmin : n ≤ x.val - z.val := Nat.find_min' hExists hPz
    dsimp [a] at haz
    omega

/-- First nested contour interval in the wrap-above predecessor-skip branch.

The first same-cycle point above `π x` gives a long same-`π` interval starting
at the original point `x`.  This is the wrapped counterpart of
`leftTight_nonwrap_nested_cyclicPredecessorSkip_exists_first_contourIntervalRepeat`. -/
theorem leftTight_wrapAbove_nested_cyclicPredecessorSkip_exists_first_contourIntervalRepeat
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hnotfix : π.1 x ≠ x)
    (hnlt : ¬ (π.1 x).val < x.val)
    (habove :
      ∃ z : Fin (m + 1),
        π.1.SameCycle z x ∧ (π.1 x).val < z.val)
    (hnotDirect : ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x))) :
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        a = x.val ∧
        (π.1 x).val < c ∧
        1 < c - a ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ ∧
        leftTightContourIntervalRepeat π.1 ha hc hac ∧
        ∀ z : Fin (m + 1),
          π.1.SameCycle z x →
          (π.1 x).val < z.val →
          z.val < c →
          False := by
  rcases
    permCyclicPredecessorSkip_wrapAbove_nested_exists_first_sameCycle_gap
      π.1 hnlt habove hnotDirect with
    ⟨c, hc, hpc, hgapAbove, hSameC, hfirst⟩
  let a : ℕ := x.val
  have ha : a ∈ Finset.range (m + 1) := Finset.mem_range.mpr x.2
  have hneqVal : (π.1 x).val ≠ x.val := by
    intro hval
    exact hnotfix (Fin.ext hval)
  have hxltpx : x.val < (π.1 x).val := by omega
  have hac : a < c := by
    dsimp [a]
    omega
  have hgap : 1 < c - a := by
    dsimp [a]
    omega
  have hSame :
      π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
    have hA : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = x := by
      apply Fin.ext
      rfl
    simpa [hA] using hSameC.symm
  refine ⟨a, c, ha, hc, hac, rfl, hpc, hgap, hSame, ?_, ?_⟩
  · exact
      leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
        (m := m) (π := π.1) π.2 ha hc hac hSame hgap
  · intro z hzSame hpz hzc
    exact hfirst z hzSame hpz hzc

/-- Last nested contour interval in the wrap-below predecessor-skip branch.

The last same-cycle point below `x` gives a long same-`π` interval ending at
`π x`, with no later same-cycle return before `x`; left-tightness supplies the
repeated-contour obstruction. -/
theorem leftTight_wrapBelow_nested_cyclicPredecessorSkip_exists_last_contourIntervalRepeat
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hnotfix : π.1 x ≠ x)
    (hnlt : ¬ (π.1 x).val < x.val)
    (hbelow :
      ∃ z : Fin (m + 1),
        π.1.SameCycle z x ∧ z.val < x.val) :
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        c = (π.1 x).val ∧
        a < x.val ∧
        1 < c - a ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ ∧
        leftTightContourIntervalRepeat π.1 ha hc hac ∧
        ∀ z : Fin (m + 1),
          π.1.SameCycle z x →
          a < z.val →
          z.val < x.val →
          False := by
  rcases
    permCyclicPredecessorSkip_wrapBelow_nested_exists_last_sameCycle_gap
      π.1 hnotfix hnlt hbelow with
    ⟨a, ha, hax, hgapToPx, hSameA, hlast⟩
  let c : ℕ := (π.1 x).val
  have hc : c ∈ Finset.range (m + 1) := Finset.mem_range.mpr (π.1 x).2
  have hac : a < c := by
    dsimp [c]
    omega
  have hgap : 1 < c - a := by
    dsimp [c]
    exact hgapToPx
  have hSame :
      π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
    have hC : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = π.1 x := by
      apply Fin.ext
      rfl
    have hApply := perm_apply_sameCycle_self π.1 x
    simpa [hC] using hSameA.trans hApply.symm
  refine ⟨a, c, ha, hc, hac, rfl, hax, hgap, hSame, ?_, ?_⟩
  · exact
      leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
        (m := m) (π := π.1) π.2 ha hc hac hSame hgap
  · intro z hzSame haz hzx
    exact hlast z hzSame haz hzx

/-- Branch-normalized contour interval for a genuinely nested predecessor skip.

After the direct-hit case is excluded, every nonfixed predecessor skip has a
canonical return interval in its branch: first return in the nonwrapping
branch, last return in the wrap-below branch, and first return in the
wrap-above branch.  Each interval already carries the left-tight repeated
contour obstruction. -/
theorem leftTight_nonfixed_nested_cyclicPredecessorSkip_exists_returnContourIntervalRepeat
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hnotfix : π.1 x ≠ x)
    (hskip : permCyclicPredecessorSkip π.1 x)
    (hnotDirect : ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x))) :
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        1 < c - a ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ ∧
        leftTightContourIntervalRepeat π.1 ha hc hac ∧
        ((a = (π.1 x).val ∧
            c < x.val ∧
            ∀ z : Fin (m + 1),
              π.1.SameCycle z x →
              a < z.val →
              z.val < c →
              False) ∨
          (c = (π.1 x).val ∧
            a < x.val ∧
            ∀ z : Fin (m + 1),
              π.1.SameCycle z x →
              a < z.val →
              z.val < x.val →
              False) ∨
          (a = x.val ∧
            (π.1 x).val < c ∧
            ∀ z : Fin (m + 1),
              π.1.SameCycle z x →
              (π.1 x).val < z.val →
              z.val < c →
              False)) := by
  rcases hskip with hNonwrap | hWrap
  · rcases hNonwrap with ⟨hpx, hbetween⟩
    rcases
      leftTight_nonwrap_nested_cyclicPredecessorSkip_exists_first_contourIntervalRepeat
        π hpx hbetween hnotDirect with
      ⟨a, c, ha, hc, hac, haeq, hcx, hgap, hSame, hRepeat, hfirst⟩
    refine ⟨a, c, ha, hc, hac, hgap, hSame, hRepeat, ?_⟩
    left
    exact ⟨haeq, hcx, hfirst⟩
  · rcases hWrap with ⟨hnlt, hbad⟩
    rcases hbad with hBelow | hAbove
    · rcases
        leftTight_wrapBelow_nested_cyclicPredecessorSkip_exists_last_contourIntervalRepeat
          π hnotfix hnlt hBelow with
        ⟨a, c, ha, hc, hac, hceq, hax, hgap, hSame, hRepeat, hlast⟩
      refine ⟨a, c, ha, hc, hac, hgap, hSame, hRepeat, ?_⟩
      right
      left
      exact ⟨hceq, hax, hlast⟩
    · rcases
        leftTight_wrapAbove_nested_cyclicPredecessorSkip_exists_first_contourIntervalRepeat
          π hnotfix hnlt hAbove hnotDirect with
        ⟨a, c, ha, hc, hac, haeq, hpxc, hgap, hSame, hRepeat, hfirst⟩
      refine ⟨a, c, ha, hc, hac, hgap, hSame, hRepeat, ?_⟩
      right
      right
      exact ⟨haeq, hpxc, hfirst⟩

/-- A nonwrapping predecessor skip in a left-tight permutation triggers the
same repeated-contour obstruction as any longer same-cycle interval.

This is the bridge between the sharpened no-skip leaf and the Biane contour
machinery: if `π x < x` but another point of the `π`-cycle lies strictly
between `π x` and `x`, then the interval contour from `π x` to `x` has a
repeated left `(finRotate * π)` class or a repeated right `π` class. -/
theorem leftTight_nonwrap_cyclicPredecessorSkip_exists_repeated_parity_sameCycle
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hpx : (π.1 x).val < x.val)
    (hbetween :
      ∃ z : Fin (m + 1),
        π.1.SameCycle z x ∧ (π.1 x).val < z.val ∧ z.val < x.val) :
    (∃ r s : ℕ,
      ∃ hr : r ≤ x.val - (π.1 x).val,
      ∃ hs : s ≤ x.val - (π.1 x).val,
      r < s ∧
      (finRotate (m + 1) * π.1).SameCycle
        ⟨(π.1 x).val + r, by
          omega⟩
        ⟨(π.1 x).val + s, by
          omega⟩) ∨
    (∃ r s : ℕ,
      ∃ hr : r < x.val - (π.1 x).val,
      ∃ hs : s < x.val - (π.1 x).val,
      r < s ∧
      π.1.SameCycle
        ⟨(π.1 x).val + r, by
          omega⟩
        ⟨(π.1 x).val + s, by
          omega⟩) := by
  let a : ℕ := (π.1 x).val
  let c : ℕ := x.val
  have ha : a ∈ Finset.range (m + 1) := by
    exact Finset.mem_range.mpr (π.1 x).2
  have hc : c ∈ Finset.range (m + 1) := by
    exact Finset.mem_range.mpr x.2
  have hac : a < c := by
    simpa [a, c] using hpx
  have hgap : 1 < c - a := by
    rcases hbetween with ⟨z, _hzSame, haz, hzc⟩
    dsimp [a, c]
    omega
  have hT : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩ := by
    have hApply := perm_apply_sameCycle_self π.1 x
    have hA : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = π.1 x := by
      apply Fin.ext
      rfl
    have hC : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = x := by
      apply Fin.ext
      rfl
    simpa [hA, hC] using hApply
  simpa [a, c] using
    leftTight_contour_interval_sameCycle_exists_repeated_parity_sameCycle_of_one_lt_sub
      (m := m) (π := π.1) π.2 ha hc hac hT hgap

/-- A wrapping predecessor skip in a left-tight permutation also triggers a
long same-cycle interval with a repeated-contour obstruction.

If `π x` is not below `x` and `x` is not fixed, then `x < π x`.  A forbidden
cycle point below `x` gives the long interval from that point to `π x`; a
forbidden cycle point above `π x` gives the long interval from `x` to that
point. -/
theorem leftTight_wrap_cyclicPredecessorSkip_exists_contourIntervalRepeat
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hnotfix : π.1 x ≠ x)
    (hwrap : ¬ (π.1 x).val < x.val)
    (hbad :
      (∃ z : Fin (m + 1), π.1.SameCycle z x ∧ z.val < x.val) ∨
        ∃ z : Fin (m + 1), π.1.SameCycle z x ∧ (π.1 x).val < z.val) :
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        1 < c - a ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ ∧
        leftTightContourIntervalRepeat π.1 ha hc hac := by
  have hneqVal : (π.1 x).val ≠ x.val := by
    intro hval
    exact hnotfix (Fin.ext hval)
  have hxltpx : x.val < (π.1 x).val := by
    omega
  rcases hbad with hBelow | hAbove
  · rcases hBelow with ⟨z, hzx, hzltx⟩
    let a : ℕ := z.val
    let c : ℕ := (π.1 x).val
    have ha : a ∈ Finset.range (m + 1) := Finset.mem_range.mpr z.2
    have hc : c ∈ Finset.range (m + 1) := Finset.mem_range.mpr (π.1 x).2
    have hac : a < c := by
      dsimp [a, c]
      omega
    have hgap : 1 < c - a := by
      dsimp [a, c]
      omega
    have hT : π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
      have hApply := perm_apply_sameCycle_self π.1 x
      have hA : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = z := by
        apply Fin.ext
        rfl
      have hC : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = π.1 x := by
        apply Fin.ext
        rfl
      have hTzc : π.1.SameCycle z (π.1 x) := hzx.trans hApply.symm
      simpa [hA, hC] using hTzc
    exact
      ⟨a, c, ha, hc, hac, hgap, hT,
        leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
          (m := m) (π := π.1) π.2 ha hc hac hT hgap⟩
  · rcases hAbove with ⟨z, hzx, hpxltz⟩
    let a : ℕ := x.val
    let c : ℕ := z.val
    have ha : a ∈ Finset.range (m + 1) := Finset.mem_range.mpr x.2
    have hc : c ∈ Finset.range (m + 1) := Finset.mem_range.mpr z.2
    have hac : a < c := by
      dsimp [a, c]
      omega
    have hgap : 1 < c - a := by
      dsimp [a, c]
      omega
    have hT : π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
      have hA : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = x := by
        apply Fin.ext
        rfl
      have hC : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = z := by
        apply Fin.ext
        rfl
      simpa [hA, hC] using hzx.symm
    exact
      ⟨a, c, ha, hc, hac, hgap, hT,
        leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
          (m := m) (π := π.1) π.2 ha hc hac hT hgap⟩

/-- Tied predecessor-skip obstruction.

The basic repeated-contour extractor
`leftTight_nonfixed_cyclicPredecessorSkip_exists_contourIntervalRepeat`
forgets where the interval came from.  This sharpened form keeps the link to
the original skip witness.  In the nonwrapping branch the interval is exactly
`[(π x).val, x.val]`; in the wrapping-below branch it ends at `(π x).val`
and starts below `x`; in the wrapping-above branch it starts at `x.val` and
ends above `(π x).val`.

This is not yet the Biane collision theorem.  It is the structural bookkeeping
needed so the remaining collision leaf is tied to the skip that generated it,
rather than to an arbitrary charged interval. -/
theorem leftTight_nonfixed_cyclicPredecessorSkip_exists_tied_contourIntervalRepeat
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hnotfix : π.1 x ≠ x)
    (hskip : permCyclicPredecessorSkip π.1 x) :
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        1 < c - a ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ ∧
        leftTightContourIntervalRepeat π.1 ha hc hac ∧
        ((a = (π.1 x).val ∧ c = x.val) ∨
          (c = (π.1 x).val ∧ a < x.val) ∨
          (a = x.val ∧ (π.1 x).val < c)) := by
  rcases hskip with hNonwrap | hWrap
  · rcases hNonwrap with ⟨hpx, hbetween⟩
    let a : ℕ := (π.1 x).val
    let c : ℕ := x.val
    have ha : a ∈ Finset.range (m + 1) :=
      Finset.mem_range.mpr (π.1 x).2
    have hc : c ∈ Finset.range (m + 1) :=
      Finset.mem_range.mpr x.2
    have hac : a < c := by
      simpa [a, c] using hpx
    have hgap : 1 < c - a := by
      rcases hbetween with ⟨z, _hzSame, haz, hzc⟩
      dsimp [a, c]
      omega
    have hT : π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
      have hApply := perm_apply_sameCycle_self π.1 x
      have hA : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = π.1 x := by
        apply Fin.ext
        rfl
      have hC : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = x := by
        apply Fin.ext
        rfl
      simpa [hA, hC] using hApply
    refine ⟨a, c, ha, hc, hac, hgap, hT, ?_, ?_⟩
    · exact
        leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
          (m := m) (π := π.1) π.2 ha hc hac hT hgap
    · left
      exact ⟨rfl, rfl⟩
  · rcases hWrap with ⟨hwrap, hbad⟩
    have hneqVal : (π.1 x).val ≠ x.val := by
      intro hval
      exact hnotfix (Fin.ext hval)
    have hxltpx : x.val < (π.1 x).val := by
      omega
    rcases hbad with hBelow | hAbove
    · rcases hBelow with ⟨z, hzx, hzltx⟩
      let a : ℕ := z.val
      let c : ℕ := (π.1 x).val
      have ha : a ∈ Finset.range (m + 1) := Finset.mem_range.mpr z.2
      have hc : c ∈ Finset.range (m + 1) :=
        Finset.mem_range.mpr (π.1 x).2
      have hac : a < c := by
        dsimp [a, c]
        omega
      have hgap : 1 < c - a := by
        dsimp [a, c]
        omega
      have hT : π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ := by
        have hApply := perm_apply_sameCycle_self π.1 x
        have hA : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = z := by
          apply Fin.ext
          rfl
        have hC : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = π.1 x := by
          apply Fin.ext
          rfl
        have hTzc : π.1.SameCycle z (π.1 x) := hzx.trans hApply.symm
        simpa [hA, hC] using hTzc
      refine ⟨a, c, ha, hc, hac, hgap, hT, ?_, ?_⟩
      · exact
          leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
            (m := m) (π := π.1) π.2 ha hc hac hT hgap
      · right
        left
        exact ⟨rfl, by simpa [a] using hzltx⟩
    · rcases hAbove with ⟨z, hzx, hpxltz⟩
      let a : ℕ := x.val
      let c : ℕ := z.val
      have ha : a ∈ Finset.range (m + 1) := Finset.mem_range.mpr x.2
      have hc : c ∈ Finset.range (m + 1) := Finset.mem_range.mpr z.2
      have hac : a < c := by
        dsimp [a, c]
        omega
      have hgap : 1 < c - a := by
        dsimp [a, c]
        omega
      have hT : π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ := by
        have hA : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = x := by
          apply Fin.ext
          rfl
        have hC : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = z := by
          apply Fin.ext
          rfl
        simpa [hA, hC] using hzx.symm
      refine ⟨a, c, ha, hc, hac, hgap, hT, ?_, ?_⟩
      · exact
          leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
            (m := m) (π := π.1) π.2 ha hc hac hT hgap
      · right
        right
        exact ⟨rfl, by simpa [c] using hpxltz⟩

/-- Unified predecessor-skip obstruction.

Every non-fixed failure of the cyclic predecessor law in a left-tight
permutation produces a long same-cycle interval whose Biane contour repeats a
left or right cycle class.  This is the exact single obstruction left by the
two skip branches. -/
theorem leftTight_nonfixed_cyclicPredecessorSkip_exists_contourIntervalRepeat
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hnotfix : π.1 x ≠ x)
    (hskip : permCyclicPredecessorSkip π.1 x) :
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        1 < c - a ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ ∧
        leftTightContourIntervalRepeat π.1 ha hc hac := by
  rcases hskip with hNonwrap | hWrap
  · rcases hNonwrap with ⟨hpx, hbetween⟩
    let a : ℕ := (π.1 x).val
    let c : ℕ := x.val
    have ha : a ∈ Finset.range (m + 1) :=
      Finset.mem_range.mpr (π.1 x).2
    have hc : c ∈ Finset.range (m + 1) :=
      Finset.mem_range.mpr x.2
    have hac : a < c := by
      simpa [a, c] using hpx
    have hgap : 1 < c - a := by
      rcases hbetween with ⟨z, _hzSame, haz, hzc⟩
      dsimp [a, c]
      omega
    have hT : π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
      have hApply := perm_apply_sameCycle_self π.1 x
      have hA : (⟨a, Finset.mem_range.mp ha⟩ : Fin (m + 1)) = π.1 x := by
        apply Fin.ext
        rfl
      have hC : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = x := by
        apply Fin.ext
        rfl
      simpa [hA, hC] using hApply
    exact
      ⟨a, c, ha, hc, hac, hgap, hT,
        leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
          (m := m) (π := π.1) π.2 ha hc hac hT hgap⟩
  · rcases hWrap with ⟨hwrap, hbad⟩
    exact
      leftTight_wrap_cyclicPredecessorSkip_exists_contourIntervalRepeat
        π hnotfix hwrap hbad

/-- Minimal long interval extracted from a nonfixed predecessor skip.

The earlier skip obstruction produces some long same-`π` interval whose
contour repeats.  This form chooses the interval with minimal length among all
long same-`π` intervals.  The contour repeat is then recovered from left
tightness, while the output gives the exact `hNoShorter` premise used by the
minimal-contour frontier. -/
theorem leftTight_nonfixed_cyclicPredecessorSkip_exists_minimal_contourIntervalRepeat
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hnotfix : π.1 x ≠ x)
    (hskip : permCyclicPredecessorSkip π.1 x) :
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        1 < c - a ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ ∧
        leftTightContourIntervalRepeat π.1 ha hc hac ∧
        ∀ a' c' : ℕ,
          ∀ ha' : a' ∈ Finset.range (m + 1),
          ∀ hc' : c' ∈ Finset.range (m + 1),
          ∀ _hac' : a' < c',
            1 < c' - a' →
            c' - a' < c - a →
            ¬ π.1.SameCycle
              ⟨a', Finset.mem_range.mp ha'⟩
              ⟨c', Finset.mem_range.mp hc'⟩ := by
  classical
  let P : ℕ → Prop := fun n =>
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        1 < c - a ∧
        c - a = n ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩
  have hExistsP : ∃ n : ℕ, P n := by
    rcases
      leftTight_nonfixed_cyclicPredecessorSkip_exists_contourIntervalRepeat
        π hnotfix hskip with
      ⟨a, c, ha, hc, hac, hgap, hSame, _hRepeat⟩
    exact ⟨c - a, a, c, ha, hc, hac, hgap, rfl, hSame⟩
  let n : ℕ := Nat.find hExistsP
  have hnSpec : P n := by
    simpa [n] using Nat.find_spec hExistsP
  rcases hnSpec with ⟨a, c, ha, hc, hac, hgap, hlen, hSame⟩
  have hRepeat : leftTightContourIntervalRepeat π.1 ha hc hac := by
    exact
      leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
        (m := m) (π := π.1) π.2 ha hc hac hSame hgap
  refine ⟨a, c, ha, hc, hac, hgap, hSame, hRepeat, ?_⟩
  intro a' c' ha' hc' _hac' hgap' hshort hSame'
  have hPshort : P (c' - a') := by
    exact ⟨a', c', ha', hc', _hac', hgap', rfl, hSame'⟩
  have hmin : n ≤ c' - a' := Nat.find_min' hExistsP hPshort
  have hshortN : c' - a' < n := by
    simpa [hlen] using hshort
  exact (not_le_of_gt hshortN) hmin

/-- Minimal-interval branch of the repeated-contour obstruction.

If a longer same-cycle interval contains no strictly internal repeated
`π`-cycle class, then the repeated contour vertex supplied by tree
non-simplicity must occur at even times, hence gives a repeated
`(finRotate * π)` class. -/
theorem leftTight_contour_interval_sameCycle_exists_left_repeat_of_no_internal_right_repeat
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a)
    (hNoRight :
      ∀ r s : ℕ,
        ∀ hr : r < c - a,
        ∀ hs : s < c - a,
          r < s →
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩) :
    ∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
      r < s ∧
      (finRotate (m + 1) * π).SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ := by
  rcases
    leftTight_contour_interval_sameCycle_exists_repeated_parity_sameCycle_of_one_lt_sub
      hleft ha hc hac_lt hT hgap with
    hLeft | hRight
  · exact hLeft
  · rcases hRight with ⟨r, s, hr, hs, hrs, hSame⟩
    exact False.elim ((hNoRight r s hr hs hrs) hSame)

/-- Trichotomy form of the minimal-interval left-repeat obstruction.

If a longer same-cycle interval has no strictly internal repeated `π` class,
then the forced repeated `(finRotate * π)` class either touches the left
endpoint, touches the right endpoint, or is genuinely internal to the
interval.  The future minimal-crossing step has to rule out or exploit these
three alternatives. -/
theorem leftTight_contour_interval_sameCycle_left_repeat_trichotomy_of_no_internal_right_repeat
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a)
    (hNoRight :
      ∀ r s : ℕ,
        ∀ hr : r < c - a,
        ∀ hs : s < c - a,
          r < s →
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩) :
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        0 < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        r < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) ∨
    (∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
        0 < r ∧
        s < c - a ∧
        r < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) := by
  rcases
    leftTight_contour_interval_sameCycle_exists_left_repeat_of_no_internal_right_repeat
      hleft ha hc hac_lt hT hgap hNoRight with
    ⟨r, s, hr, hs, hrs, hSame⟩
  by_cases hr0 : r = 0
  · subst r
    left
    refine ⟨s, hs, by omega, ?_⟩
    simpa using hSame
  · have hrpos : 0 < r := by omega
    by_cases hsend : s = c - a
    · subst s
      right
      left
      refine ⟨r, hr, by omega, ?_⟩
      have hfin :
          (⟨a + (c - a), by
            have hc' := Finset.mem_range.mp hc
            omega⟩ : Fin (m + 1)) =
          ⟨c, Finset.mem_range.mp hc⟩ := by
        apply Fin.ext
        exact Nat.add_sub_of_le hac_lt.le
      simpa [hfin] using hSame
    · have hslt : s < c - a := by omega
      right
      right
      exact ⟨r, s, hr, hs, hrpos, hslt, hrs, hSame⟩

/-- Endpoint-touching form of the minimal-interval branch.

If a longer same-cycle interval has no strictly internal repeated `π` class
and no strictly internal repeated `(finRotate * π)` class, then the repeated
left class forced by the contour obstruction touches at least one endpoint of
the interval.  This is the exact arithmetic extraction still needed before the
boundary pair in `leftTight_bianeAdjacentLinks` can be identified. -/
theorem leftTight_contour_interval_sameCycle_exists_left_repeat_touching_endpoint
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a)
    (hNoRight :
      ∀ r s : ℕ,
        ∀ hr : r < c - a,
        ∀ hs : s < c - a,
          r < s →
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftInterior :
      ∀ r s : ℕ,
        ∀ hr : r ≤ c - a,
        ∀ hs : s ≤ c - a,
          0 < r →
          s < c - a →
          r < s →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩) :
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        0 < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        r < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) := by
  rcases
    leftTight_contour_interval_sameCycle_left_repeat_trichotomy_of_no_internal_right_repeat
      hleft ha hc hac_lt hT hgap hNoRight with
    hLeft | hRightOrInterior
  · exact Or.inl hLeft
  · rcases hRightOrInterior with hRight | hInterior
    · exact Or.inr hRight
    · rcases hInterior with ⟨r, s, hr, hs, hrpos, hslt, hrs, hSame⟩
      exact False.elim
        ((hNoLeftInterior r s hr hs hrpos hslt hrs) hSame)

/-- Adjacent endpoint extraction from the minimal-interval branch.

Once internal `π` repeats, internal `(finRotate * π)` repeats, and
non-adjacent endpoint-touching `(finRotate * π)` repeats have been ruled out,
the endpoint-touching repeat supplied by the contour obstruction is genuinely
adjacent to one endpoint of the interval. -/
theorem leftTight_contour_interval_sameCycle_exists_adjacent_left_repeat
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a)
    (hNoRight :
      ∀ r s : ℕ,
        ∀ hr : r < c - a,
        ∀ hs : s < c - a,
          r < s →
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftInterior :
      ∀ r s : ℕ,
        ∀ hr : r ≤ c - a,
        ∀ hs : s ≤ c - a,
          0 < r →
          s < c - a →
          r < s →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftStartFar :
      ∀ s : ℕ,
        ∀ hs : s ≤ c - a,
          1 < s →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftEndFar :
      ∀ r : ℕ,
        ∀ hr : r ≤ c - a,
          r + 1 < c - a →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨c, Finset.mem_range.mp hc⟩) :
    (finRotate (m + 1) * π).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ ∨
      (finRotate (m + 1) * π).SameCycle
        ⟨c - 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
  rcases
    leftTight_contour_interval_sameCycle_exists_left_repeat_touching_endpoint
      hleft ha hc hac_lt hT hgap hNoRight hNoLeftInterior with
    hLeft | hRight
  · rcases hLeft with ⟨s, hs, hspos, hSame⟩
    by_cases hsone : s = 1
    · left
      subst s
      simpa using hSame
    · exact False.elim ((hNoLeftStartFar s hs (by omega)) hSame)
  · rcases hRight with ⟨r, hr, hrlt, hSame⟩
    by_cases hrAdj : r + 1 = c - a
    · right
      have hval : a + r = c - 1 := by
        omega
      have hfin :
          (⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ : Fin (m + 1)) =
          ⟨c - 1, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ := by
        apply Fin.ext
        exact hval
      simpa [hfin] using hSame
    · exact False.elim ((hNoLeftEndFar r hr (by omega)) hSame)

/-- Minimal-interval adjacent-repeat branch reduced to a fixed predecessor of
the right endpoint.

Under the hypotheses that force an adjacent left repeat, the start-endpoint
repeat is impossible by `leftTight_not_start_adjacent_left_repeat...`.
Therefore the remaining end-endpoint repeat forces `c-1` to be fixed by `π`.
-/
theorem leftTight_contour_interval_sameCycle_end_pred_fixed_of_adjacent_left_repeat
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a)
    (hNoRight :
      ∀ r s : ℕ,
        ∀ hr : r < c - a,
        ∀ hs : s < c - a,
          r < s →
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftInterior :
      ∀ r s : ℕ,
        ∀ hr : r ≤ c - a,
        ∀ hs : s ≤ c - a,
          0 < r →
          s < c - a →
          r < s →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftStartFar :
      ∀ s : ℕ,
        ∀ hs : s ≤ c - a,
          1 < s →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftEndFar :
      ∀ r : ℕ,
        ∀ hr : r ≤ c - a,
          r + 1 < c - a →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨c, Finset.mem_range.mp hc⟩) :
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ := by
  rcases
    leftTight_contour_interval_sameCycle_exists_adjacent_left_repeat
      hleft ha hc hac_lt hT hgap hNoRight hNoLeftInterior
      hNoLeftStartFar hNoLeftEndFar with
    hStart | hEnd
  · exact False.elim
      (leftTight_not_start_adjacent_left_repeat_of_sameCycle_one_lt_sub
        hleft ha hc hac_lt hT hgap hStart)
  · let x : Fin (m + 1) :=
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩
    have hrot :
