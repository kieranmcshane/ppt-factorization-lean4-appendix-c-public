      ⟨c, Finset.mem_range.mp hc⟩)
    (_hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp _hd⟩)
    (_hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hT_a1_b :
      π.1.SameCycle
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hT_a1_b_to_S_a_a1 :
      π.1.SameCycle
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨b, Finset.mem_range.mp hb⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩ := by
  have hac_lt : a < c := by omega
  have hgap_lt : 1 < c - a := by omega
  have hS_a_a1 :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
