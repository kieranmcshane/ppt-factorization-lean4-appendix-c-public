        D ^ (m + 3) * (c * D ^ (m + 1)) := by
    calc
      c * D ^ (2 * (m + 1) + 2)
          = c * (D ^ (m + 3) * D ^ (m + 1)) := by
              rw [← pow_add, hExp]
      _ = D ^ (m + 3) * (c * D ^ (m + 1)) := by ring
  calc
    c * D ^ (2 * (m + 1) + 2) =
        D ^ (m + 3) * (c * D ^ (m + 1)) := hleft
    _ ≤ A ^ (m + 3) * B ^ (m + 1) := hprod

