/-- Defect-sensitive two-base analytic bound.

This lifts the common-base algebra to the actual Wick term.  If both analytic
bases are bounded by a common nonnegative base `D`, then the original
`d, t`-term is bounded by the same defect power.  The only mathematical input
still hidden in this bridge is the weighted-rank budget. -/
theorem wickAnalyticWeight_le_commonBase_defectPower
    {m Δ : ℕ} {d t D : ℝ} {π : Equiv.Perm (Fin (m + 1))}
    (hd0 : 0 ≤ d) (ht0 : 0 ≤ t) (hdD : d ≤ D) (htD : t ≤ D)
    (hRank : wickWeightedRank π ≤ 2 * (m + 1) + 2)
    (hΔ : wickDefect π = Δ) :
    d ^ (wickLeftClassCount π + wickRightClassCount π) *
        t ^ (2 * wickColumnClassCount π) ≤
      D ^ (2 * (m + 1) + 2 - Δ) := by
  have hD0 : 0 ≤ D := le_trans hd0 hdD
  have hdPow :
      d ^ (wickLeftClassCount π + wickRightClassCount π) ≤
        D ^ (wickLeftClassCount π + wickRightClassCount π) :=
    pow_le_pow_left₀ hd0 hdD _
  have htPow :
      t ^ (2 * wickColumnClassCount π) ≤
        D ^ (2 * wickColumnClassCount π) :=
    pow_le_pow_left₀ ht0 htD _
  calc
    d ^ (wickLeftClassCount π + wickRightClassCount π) *
        t ^ (2 * wickColumnClassCount π) ≤
      D ^ (wickLeftClassCount π + wickRightClassCount π) *
        D ^ (2 * wickColumnClassCount π) := by
          exact mul_le_mul hdPow htPow (pow_nonneg ht0 _)
            (pow_nonneg hD0 _)
    _ = D ^ (2 * (m + 1) + 2 - Δ) := by
          exact wickAnalyticWeight_commonBase_eq_defectPower
            (m := m) (Δ := Δ) (D := D) (π := π) hRank hΔ

/-- Closed defect-sensitive two-base analytic bound. -/
theorem wickAnalyticWeight_le_commonBase_defectPower_closed
    {m Δ : ℕ} {d t D : ℝ} {π : Equiv.Perm (Fin (m + 1))}
    (hd0 : 0 ≤ d) (ht0 : 0 ≤ t) (hdD : d ≤ D) (htD : t ≤ D)
    (hΔ : wickDefect π = Δ) :
    d ^ (wickLeftClassCount π + wickRightClassCount π) *
        t ^ (2 * wickColumnClassCount π) ≤
      D ^ (2 * (m + 1) + 2 - Δ) :=
  wickAnalyticWeight_le_commonBase_defectPower
    (m := m) (Δ := Δ) (d := d) (t := t) (D := D) (π := π)
    hd0 ht0 hdD htD (wickWeightedRank_le_two_mul_add_two π) hΔ

/-- Per-defect term envelope obtained from a global weighted-rank budget.

This is the sharp replacement for `wickDefectSlice_term_bound_crude_max`: it
uses the defect value instead of bounding every term by the same maximum
exponent. -/
theorem wickDefectSlice_term_bound_commonBase_defectPower
    {m : ℕ} {d t D : ℝ}
    (hd0 : 0 ≤ d) (ht0 : 0 ≤ t) (hdD : d ≤ D) (htD : t ≤ D)
    (hRank : ∀ π : Equiv.Perm (Fin (m + 1)),
      wickWeightedRank π ≤ 2 * (m + 1) + 2) :
    ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ π : Equiv.Perm (Fin (m + 1)), wickDefect π = Δ →
        d ^ (wickLeftClassCount π + wickRightClassCount π) *
          t ^ (2 * wickColumnClassCount π) ≤
            D ^ (2 * (m + 1) + 2 - Δ) := by
  intro Δ hΔ π hπ
  exact wickAnalyticWeight_le_commonBase_defectPower
    (m := m) (Δ := Δ) (d := d) (t := t) (D := D) (π := π)
    hd0 ht0 hdD htD (hRank π) hπ

/-- Closed per-defect term envelope obtained from the proved Cayley rank
budget. -/
theorem wickDefectSlice_term_bound_commonBase_defectPower_closed
    {m : ℕ} {d t D : ℝ}
    (hd0 : 0 ≤ d) (ht0 : 0 ≤ t) (hdD : d ≤ D) (htD : t ≤ D) :
    ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ π : Equiv.Perm (Fin (m + 1)), wickDefect π = Δ →
        d ^ (wickLeftClassCount π + wickRightClassCount π) *
          t ^ (2 * wickColumnClassCount π) ≤
            D ^ (2 * (m + 1) + 2 - Δ) := by
  intro Δ hΔ π hπ
  exact wickAnalyticWeight_le_commonBase_defectPower_closed
    (m := m) (Δ := Δ) (d := d) (t := t) (D := D) (π := π)
    hd0 ht0 hdD htD hπ

/-- Prop 7.3 count envelope plus a defect-sensitive common-base term envelope
reduces the graduate relation-counting input to one scalar defect sum.

The remaining theorem-strength inputs are now exactly visible: the
fixed-defect count bound, the weighted-rank budget, and the scalar defect-sum
comparison. -/
theorem aubrunGraduateRelationCounting_of_prop73CountAndCommonBaseDefectEnvelope
    {Q : ℕ → ℝ} {d s D : ℝ} {m : ℕ}
    (hd0 : 0 ≤ d) (hsqrt0 : 0 ≤ Real.sqrt s)
    (hdD : d ≤ D) (hsqrtD : Real.sqrt s ≤ D)
    (hRank : ∀ π : Equiv.Perm (Fin (m + 1)),
      wickWeightedRank π ≤ 2 * (m + 1) + 2)
    (hCount : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ)
    (hEnvelope :
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        aubrunFixedDefectCountEnvelope m Δ *
          D ^ (2 * (m + 1) + 2 - Δ)) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  apply aubrunGraduateRelationCounting_of_prop73CountAndTermBounds
    (B := fun Δ => D ^ (2 * (m + 1) + 2 - Δ))
  · exact hCount
  · intro Δ hΔ
    exact pow_nonneg (le_trans hd0 hdD) _
  · exact wickDefectSlice_term_bound_commonBase_defectPower
      (m := m) (d := d) (t := Real.sqrt s) (D := D)
      hd0 hsqrt0 hdD hsqrtD hRank
  · exact hEnvelope

/-- Same defect-sensitive common-base endpoint, but with the weighted-rank
budget supplied by the two standard cycle-count inequalities for the full
rotation and its inverse. -/
theorem aubrunGraduateRelationCounting_of_prop73CountAndCyclePairBounds
    {Q : ℕ → ℝ} {d s D : ℝ} {m : ℕ}
    (hd0 : 0 ≤ d) (hsqrt0 : 0 ≤ Real.sqrt s)
    (hdD : d ≤ D) (hsqrtD : Real.sqrt s ≤ D)
    (hCycleLeft : ∀ π : Equiv.Perm (Fin (m + 1)),
      permCycleClassCount π +
        permCycleClassCount (finRotate (m + 1) * π) ≤ (m + 1) + 1)
    (hCycleRight : ∀ π : Equiv.Perm (Fin (m + 1)),
      permCycleClassCount π +
        permCycleClassCount (π * (finRotate (m + 1)).symm) ≤ (m + 1) + 1)
    (hCount : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ)
    (hEnvelope :
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        aubrunFixedDefectCountEnvelope m Δ *
          D ^ (2 * (m + 1) + 2 - Δ)) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  exact aubrunGraduateRelationCounting_of_prop73CountAndCommonBaseDefectEnvelope
    (Q := Q) (d := d) (s := s) (D := D) (m := m)
    hd0 hsqrt0 hdD hsqrtD
    (fun π => wickWeightedRank_le_of_cyclePairBounds π
      (hCycleLeft π) (hCycleRight π))
    hCount hEnvelope

/-- Prop 7.3 count envelope plus the closed Cayley rank budget and one scalar
defect-sum envelope. -/
theorem aubrunGraduateRelationCounting_of_prop73CountAndCayleyRankBudget
    {Q : ℕ → ℝ} {d s D : ℝ} {m : ℕ}
    (hd0 : 0 ≤ d) (hsqrt0 : 0 ≤ Real.sqrt s)
    (hdD : d ≤ D) (hsqrtD : Real.sqrt s ≤ D)
    (hCount : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤
