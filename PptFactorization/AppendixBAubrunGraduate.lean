              ∃ y z : Fin (m + 1),
                y ≠ z ∧
                  π.1.SameCycle y z ∧
                    (finRotate (m + 1) * π.1).SameCycle y z)
    (hFixedPredCommon :
      ∀ a c : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ _ : a < c,
          1 < c - a →
          π.1.SameCycle
