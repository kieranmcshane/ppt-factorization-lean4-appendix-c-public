/-- A complex trace-moment bound gives the corresponding real trace-moment
bound, once the complex trace integrability needed to commute real part with
Bochner integration is available. -/
theorem AubrunOffDiagonalTraceMomentPowerRealBound_of_complex_bound
    {m : ℕ} {B : ℝ}
    (hTraceComplexIntegrable :
      Integrable
        (fun ω : Ω p q σ =>
          ((wishartGammaOffDiagonal (p := p) (q := q) (σ := σ)
              (gaussianMatrix p q σ ω)) ^ m).trace)
        (gaussianMeasure p q σ))
    (hComplex :
      AubrunOffDiagonalTraceMomentPowerBound
        (p := p) (q := q) (σ := σ) m B) :
    AubrunOffDiagonalTraceMomentPowerRealBound
      (p := p) (q := q) (σ := σ) m B := by
  unfold AubrunOffDiagonalTraceMomentPowerRealBound
  unfold gaussianWishartGammaOffDiagonalTraceMomentPowerReal
  calc
    (∫ ω : Ω p q σ,
      RCLike.re
        (((wishartGammaOffDiagonal (p := p) (q := q) (σ := σ)
            (gaussianMatrix p q σ ω)) ^ m).trace)
        ∂gaussianMeasure p q σ)
        =
      RCLike.re
        (∫ ω : Ω p q σ,
          ((wishartGammaOffDiagonal (p := p) (q := q) (σ := σ)
              (gaussianMatrix p q σ ω)) ^ m).trace
          ∂gaussianMeasure p q σ) := by
          exact integral_re hTraceComplexIntegrable
    _ ≤
      ‖∫ ω : Ω p q σ,
          ((wishartGammaOffDiagonal (p := p) (q := q) (σ := σ)
              (gaussianMatrix p q σ ω)) ^ m).trace
          ∂gaussianMeasure p q σ‖ :=
          RCLike.re_le_norm _
    _ ≤ B := by
          simpa [AubrunOffDiagonalTraceMomentPowerBound,
            gaussianWishartGammaOffDiagonalTraceMomentPower] using hComplex

/-- Concrete real trace-moment version of the graduate-counting Aubrun bound. -/
theorem AubrunTraceMomentPowerRealBound_concrete_of_graduate_relation_counting
    {dNat sNat : ℕ} {Q : ℕ → ℝ} (m : ℕ)
    (hTraceComplexIntegrable :
      Integrable
        (fun ω : Ω (Fin dNat) (Fin dNat) (Fin sNat) =>
          ((wishartGammaOffDiagonal
              (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
              (gaussianMatrix (Fin dNat) (Fin dNat) (Fin sNat) ω)) ^
            (m + 1)).trace)
        (gaussianMeasure (Fin dNat) (Fin dNat) (Fin sNat)))
    (hRel :
      AubrunGraduateRelationCounting
        Q (dNat : ℝ) (sNat : ℝ) m) :
    AubrunOffDiagonalTraceMomentPowerRealBound
      (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat) (m + 1)
      (aubrunOffDiagonalTraceMomentEnvelope
        Q (dNat : ℝ) (sNat : ℝ) (m + 1)) := by
  exact AubrunOffDiagonalTraceMomentPowerRealBound_of_complex_bound
    (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
    (m := m + 1)
    hTraceComplexIntegrable
    (AubrunTraceMomentPowerBound_concrete_of_graduate_relation_counting
      (dNat := dNat) (sNat := sNat) (Q := Q) m hRel)

/-- Taking the `m`-th root of Aubrun's trace envelope gives exactly the
operator-norm expectation envelope used in Appendix B. -/
theorem rpow_aubrunOffDiagonalTraceMomentEnvelope_eq_expectationEnvelope
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ}
    (hm : m ≠ 0) (hs : 0 < s)
    (hdQ : 0 ≤ d + Q m)
    (hsQ : 0 ≤ Real.sqrt s + Q m) :
    Real.rpow (aubrunOffDiagonalTraceMomentEnvelope Q d s m)
        ((m : ℝ)⁻¹) =
      aubrunOffDiagonalExpectationEnvelope Q d s m := by
  have ha : 0 ≤ 2 / s := div_nonneg (by norm_num) hs.le
  have haPow : 0 ≤ (2 / s) ^ m := pow_nonneg ha _
  have hbPow : 0 ≤ (d + Q m) ^ (m + 2) := pow_nonneg hdQ _
  have hcPow : 0 ≤ (Real.sqrt s + Q m) ^ m := pow_nonneg hsQ _
  have hmReal : (m : ℝ) ≠ 0 := by exact_mod_cast hm
  unfold aubrunOffDiagonalTraceMomentEnvelope
  unfold aubrunOffDiagonalExpectationEnvelope
  change
    (((2 / s) ^ m * (d + Q m) ^ (m + 2) *
        (Real.sqrt s + Q m) ^ m) ^ ((m : ℝ)⁻¹)) =
      2 / s * (d + Q m) ^ (1 + 2 / (m : ℝ)) *
        (Real.sqrt s + Q m)
  rw [Real.mul_rpow (mul_nonneg haPow hbPow) hcPow]
  rw [Real.mul_rpow haPow hbPow]
  rw [Real.pow_rpow_inv_natCast ha hm]
  rw [Real.pow_rpow_inv_natCast hsQ hm]
  rw [← Real.rpow_natCast]
  rw [← Real.rpow_mul hdQ]
  have hexp :
      ((m + 2 : ℕ) : ℝ) * (m : ℝ)⁻¹ =
        1 + 2 / (m : ℝ) := by
    rw [Nat.cast_add, Nat.cast_ofNat]
    field_simp [hmReal]
  rw [hexp]

/-- Full operator-norm extraction from the graduate Aubrun relation count:
the trace-moment estimate is converted into `E ‖Z‖∞` at the exact Aubrun
envelope.  The remaining hypotheses are the standard finite Gaussian
integrability facts for the chosen moment and the scalar positivity conditions
needed by real powers. -/
theorem gaussianWishartGammaOffDiagonalOpNormMean_le_expectationEnvelope_of_graduate_relation_counting
    {dNat sNat : ℕ} {Q : ℕ → ℝ} {k : ℕ}
    (hkpos : 0 < k) (hkEven : Even k)
    (hsPos : 0 < (sNat : ℝ))
    (hdQ : 0 ≤ (dNat : ℝ) + Q k)
    (hsQ : 0 ≤ Real.sqrt (sNat : ℝ) + Q k)
    (hMemLp :
      MemLp
        (fun ω : Ω (Fin dNat) (Fin dNat) (Fin sNat) =>
          opNorm
            (wishartGammaOffDiagonal
              (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
              (gaussianMatrix (Fin dNat) (Fin dNat) (Fin sNat) ω)))
        (k : ℝ≥0∞) (gaussianMeasure (Fin dNat) (Fin dNat) (Fin sNat)))
    (hTraceComplexIntegrable :
      Integrable
        (fun ω : Ω (Fin dNat) (Fin dNat) (Fin sNat) =>
          ((wishartGammaOffDiagonal
              (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
              (gaussianMatrix (Fin dNat) (Fin dNat) (Fin sNat) ω)) ^ k).trace)
        (gaussianMeasure (Fin dNat) (Fin dNat) (Fin sNat)))
    (hRel :
      AubrunGraduateRelationCounting
        Q (dNat : ℝ) (sNat : ℝ) (k - 1)) :
    gaussianWishartGammaOffDiagonalOpNormMean
        (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat) ≤
      aubrunOffDiagonalExpectationEnvelope Q (dNat : ℝ) (sNat : ℝ) k := by
  have hkSub : k - 1 + 1 = k := Nat.sub_add_cancel hkpos
  have hTraceRealIntegrable :
      Integrable
        (fun ω : Ω (Fin dNat) (Fin dNat) (Fin sNat) =>
          RCLike.re
            (((wishartGammaOffDiagonal
                (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
                (gaussianMatrix (Fin dNat) (Fin dNat) (Fin sNat) ω)) ^
              k).trace))
        (gaussianMeasure (Fin dNat) (Fin dNat) (Fin sNat)) := by
    exact ContinuousLinearMap.integrable_comp (RCLike.reCLM : ℂ →L[ℝ] ℝ)
      hTraceComplexIntegrable
  have hTraceReal :
      AubrunOffDiagonalTraceMomentPowerRealBound
        (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat) k
        (aubrunOffDiagonalTraceMomentEnvelope
          Q (dNat : ℝ) (sNat : ℝ) k) := by
    simpa [hkSub] using
      AubrunTraceMomentPowerRealBound_concrete_of_graduate_relation_counting
        (dNat := dNat) (sNat := sNat) (Q := Q) (m := k - 1)
        (by simpa [hkSub] using hTraceComplexIntegrable)
        hRel
  have hRoot :=
    gaussianWishartGammaOffDiagonalOpNormMean_le_rpow_of_traceMomentPowerRealBound
      (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
      (m := k) hkEven hkpos
      hMemLp.aestronglyMeasurable hMemLp hTraceRealIntegrable hTraceReal
  calc
    gaussianWishartGammaOffDiagonalOpNormMean
        (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
        ≤ Real.rpow
            (aubrunOffDiagonalTraceMomentEnvelope
              Q (dNat : ℝ) (sNat : ℝ) k)
            ((k : ℝ)⁻¹) := hRoot
    _ = aubrunOffDiagonalExpectationEnvelope Q (dNat : ℝ) (sNat : ℝ) k := by
          exact rpow_aubrunOffDiagonalTraceMomentEnvelope_eq_expectationEnvelope
            (Q := Q) (d := (dNat : ℝ)) (s := (sNat : ℝ))
            (m := k) (Nat.ne_of_gt hkpos) hsPos hdQ hsQ

/-- Packaged chosen-moment Aubrun extraction.  This is the direct object used
downstream by the Appendix B pipeline: graduate relation counting at the
chosen logarithmic even moment plus the scalar envelope estimate give
`E ‖Z‖∞ ≤ Cλ`. -/
theorem AubrunOffDiagonalExpectationDerivation_concrete_of_graduate_relation_counting
    {dNat sNat : ℕ} {Q : ℕ → ℝ} {d s C_lam : ℝ}
    (hsPos : 0 < (sNat : ℝ))
    (hdQ :
      0 ≤ (dNat : ℝ) + Q (aubrunEvenMomentParameter dNat))
    (hsQ :
      0 ≤ Real.sqrt (sNat : ℝ) + Q (aubrunEvenMomentParameter dNat))
    (hMemLp :
      MemLp
        (fun ω : Ω (Fin dNat) (Fin dNat) (Fin sNat) =>
          opNorm
            (wishartGammaOffDiagonal
              (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
              (gaussianMatrix (Fin dNat) (Fin dNat) (Fin sNat) ω)))
        (aubrunEvenMomentParameter dNat : ℝ≥0∞)
        (gaussianMeasure (Fin dNat) (Fin dNat) (Fin sNat)))
    (hTraceComplexIntegrable :
      Integrable
        (fun ω : Ω (Fin dNat) (Fin dNat) (Fin sNat) =>
          ((wishartGammaOffDiagonal
              (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
              (gaussianMatrix (Fin dNat) (Fin dNat) (Fin sNat) ω)) ^
            aubrunEvenMomentParameter dNat).trace)
        (gaussianMeasure (Fin dNat) (Fin dNat) (Fin sNat)))
    (hRel :
      AubrunGraduateRelationCounting
        Q (dNat : ℝ) (sNat : ℝ)
          (aubrunEvenMomentParameter dNat - 1))
    (hEnvelope :
      aubrunOffDiagonalExpectationEnvelope Q d s
          (aubrunEvenMomentParameter dNat) ≤ C_lam)
    (hEnvelopeModel :
      aubrunOffDiagonalExpectationEnvelope Q (dNat : ℝ) (sNat : ℝ)
          (aubrunEvenMomentParameter dNat) ≤
        aubrunOffDiagonalExpectationEnvelope Q d s
          (aubrunEvenMomentParameter dNat)) :
    AubrunOffDiagonalExpectationDerivation
      (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat)
      Q dNat d s C_lam where
  momentExtraction := by
    exact
      (gaussianWishartGammaOffDiagonalOpNormMean_le_expectationEnvelope_of_graduate_relation_counting
        (dNat := dNat) (sNat := sNat) (Q := Q)
        (k := aubrunEvenMomentParameter dNat)
        (aubrunEvenMomentParameter_pos dNat)
        (aubrunEvenMomentParameter_even dNat)
        hsPos hdQ hsQ hMemLp hTraceComplexIntegrable hRel).trans
        hEnvelopeModel
  envelopeBound := hEnvelope

end AppendixB
