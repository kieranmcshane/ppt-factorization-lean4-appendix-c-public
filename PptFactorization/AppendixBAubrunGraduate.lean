    exact_mod_cast hcountNat
  have henv : (32 : ℝ) = aubrunFixedDefectCountEnvelope 4 0 := by
    unfold aubrunFixedDefectCountEnvelope aubrunProposition73P
    norm_num
  simpa [henv] using hcountReal

/-- The full `m = 4` tight-range count is closed outright.  This remains a
