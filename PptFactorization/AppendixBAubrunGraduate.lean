    {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hgap : 1 < c - a)
    (hT : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hOpen :
      leftTightStrictReturnIntervalOpenInternalSubintervalResidual π.1 ha hc hac)
