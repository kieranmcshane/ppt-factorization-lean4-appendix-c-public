/-- The explicit polynomial `P(k)` obtained from the fixed-defect count
`N_Δ ≤ 2^k (2k)^(36Δ)` in Aubrun's Proposition 7.3. -/
def aubrunProposition73P (k : ℕ) : ℝ :=
  (2 * k : ℝ) ^ 36

/-- The corresponding polynomial `Q(k) = C₀ k P(k)` used right after
Proposition 7.3 in Aubrun's proof of Proposition 7.1. -/
def aubrunProposition71Q (C0 : ℝ) (k : ℕ) : ℝ :=
  C0 * (k : ℝ) * aubrunProposition73P k

@[simp] theorem aubrunProposition71Q_eq (C0 : ℝ) (k : ℕ) :
    aubrunProposition71Q C0 k =
      C0 * (k : ℝ) * (2 * k : ℝ) ^ 36 := by
  simp [aubrunProposition71Q, aubrunProposition73P]

/-- Same polynomial, expanded into the more obviously polynomial form
`C₀ 2^36 k^37`. -/
theorem aubrunProposition71Q_eq_monomial (C0 : ℝ) (k : ℕ) :
    aubrunProposition71Q C0 k =
      (C0 * (2 : ℝ) ^ 36) * (k : ℝ) ^ 37 := by
  rw [aubrunProposition71Q_eq]
  calc
    C0 * (k : ℝ) * (2 * k : ℝ) ^ 36
        = C0 * (k : ℝ) * ((2 : ℝ) ^ 36 * (k : ℝ) ^ 36) := by
            rw [mul_pow]
    _ = (C0 * (2 : ℝ) ^ 36) * (k : ℝ) ^ 37 := by
          ring_nf

/-- Positivity of the explicit `P(k)`. -/
theorem aubrunProposition73P_nonneg (k : ℕ) :
    0 ≤ aubrunProposition73P k := by
  simp [aubrunProposition73P]

/-- Positivity of the explicit `Q(k)` as soon as `C₀ ≥ 0`. -/
theorem aubrunProposition71Q_nonneg {C0 : ℝ} (hC0 : 0 ≤ C0) (k : ℕ) :
    0 ≤ aubrunProposition71Q C0 k := by
  have hk : 0 ≤ (k : ℝ) := by positivity
  exact mul_nonneg (mul_nonneg hC0 hk) (aubrunProposition73P_nonneg k)

/-- For the canonical choice `C₀=1`, Aubrun's `Q(k)=kP(k)` dominates `P(k)`
as soon as `k ≥ 1`. -/
theorem aubrunProposition73P_le_Qone (k : ℕ) (hk : 1 ≤ k) :
    aubrunProposition73P k ≤ aubrunProposition71Q 1 k := by
  have hk_real : (1 : ℝ) ≤ (k : ℝ) := by exact_mod_cast hk
  have hP0 : 0 ≤ aubrunProposition73P k :=
    aubrunProposition73P_nonneg k
  calc
    aubrunProposition73P k ≤ (k : ℝ) * aubrunProposition73P k :=
      le_mul_of_one_le_left hP0 hk_real
    _ = aubrunProposition71Q 1 k := by
      simp [aubrunProposition71Q]

/-- Any fixed power of the shifted logarithm is negligible compared with the
dimension parameter `d`.

This is the reusable analytic leaf behind the canonical Aubrun even-moment
choice: after reducing a polynomial counting loss to a fixed power of
`log(d+2)`, division by `d` tends to zero. -/
theorem tendsto_log_add_two_pow_div_natCast_zero (n : ℕ) :
    Filter.Tendsto
      (fun d : ℕ => Real.log ((d : ℝ) + 2) ^ n / (d : ℝ))
      Filter.atTop (nhds 0) := by
  have hShift :
      Filter.Tendsto (fun d : ℕ => (d : ℝ) + 2) Filter.atTop Filter.atTop := by
    exact Filter.Tendsto.atTop_add
      (tendsto_natCast_atTop_atTop :
        Filter.Tendsto (fun d : ℕ => (d : ℝ)) Filter.atTop Filter.atTop)
      tendsto_const_nhds
  have hLog :
      (fun d : ℕ => Real.log ((d : ℝ) + 2) ^ n) =o[Filter.atTop]
        (fun d : ℕ => (d : ℝ) + 2) := by
    simpa [Function.comp_def] using
      (Real.isLittleO_pow_log_id_atTop (n := n)).comp_tendsto hShift
  have hShiftBigO :
      (fun d : ℕ => ((d : ℝ) + 2)) =O[Filter.atTop]
        (fun d : ℕ => (d : ℝ)) := by
    refine Asymptotics.IsBigOWith.isBigO (c := 3) ?_
    rw [Asymptotics.isBigOWith_iff]
    filter_upwards
      [show ∀ᶠ d : ℕ in Filter.atTop, 1 ≤ d by
        rw [Filter.eventually_atTop]
        exact ⟨1, fun b hb => hb⟩] with d hd
    rw [Real.norm_eq_abs, Real.norm_eq_abs]
    have hd0 : 0 ≤ (d : ℝ) := by positivity
    have hd1 : (1 : ℝ) ≤ d := by exact_mod_cast hd
    rw [abs_of_nonneg (add_nonneg hd0 (by norm_num)), abs_of_nonneg hd0]
    nlinarith
  exact (hLog.trans_isBigO hShiftBigO).tendsto_div_nhds_zero

/-- If a nonnegative sequence is eventually bounded by a fixed multiple of a
fixed shifted-logarithm power, then it is negligible after division by `d`. -/
theorem tendsto_div_natCast_zero_of_eventually_le_const_mul_log_add_two_pow
    {f : ℕ → ℝ} {C : ℝ} (n : ℕ)
    (hf_nonneg : ∀ᶠ d in Filter.atTop, 0 ≤ f d)
    (hf_le : ∀ᶠ d in Filter.atTop,
      f d ≤ C * Real.log ((d : ℝ) + 2) ^ n) :
    Filter.Tendsto (fun d : ℕ => f d / (d : ℝ)) Filter.atTop (nhds 0) := by
  have hdpos : ∀ᶠ d : ℕ in Filter.atTop, 0 < (d : ℝ) := by
    rw [Filter.eventually_atTop]
    exact ⟨1, fun d hd => by exact_mod_cast hd⟩
  have hlower : ∀ᶠ d : ℕ in Filter.atTop, 0 ≤ f d / (d : ℝ) := by
    filter_upwards [hf_nonneg, hdpos] with d hf hd
    exact div_nonneg hf hd.le
  have hupper :
      ∀ᶠ d : ℕ in Filter.atTop,
        f d / (d : ℝ) ≤ C * (Real.log ((d : ℝ) + 2) ^ n / (d : ℝ)) := by
    filter_upwards [hf_le, hdpos] with d hle hd
    calc
      f d / (d : ℝ) ≤ (C * Real.log ((d : ℝ) + 2) ^ n) / (d : ℝ) :=
        div_le_div_of_nonneg_right hle hd.le
      _ = C * (Real.log ((d : ℝ) + 2) ^ n / (d : ℝ)) := by ring
  have hbound_tendsto :
      Filter.Tendsto
        (fun d : ℕ => C * (Real.log ((d : ℝ) + 2) ^ n / (d : ℝ)))
        Filter.atTop (nhds 0) := by
    simpa using (tendsto_log_add_two_pow_div_natCast_zero n).const_mul C
  exact squeeze_zero' hlower hupper hbound_tendsto

/-- The concrete even moment parameter is eventually bounded by a fixed
multiple of `log(d+2)^2`. -/
theorem eventually_aubrunEvenMomentParameter_le_six_mul_log_add_two_sq :
    ∀ᶠ d : ℕ in Filter.atTop,
      (aubrunEvenMomentParameter d : ℝ) ≤
        6 * Real.log ((d : ℝ) + 2) ^ 2 := by
  rw [Filter.eventually_atTop]
  refine ⟨1, fun d hd => ?_⟩
  have hlog1 : (1 : ℝ) ≤ Real.log ((d : ℝ) + 2) := by
    rw [Real.le_log_iff_exp_le (by positivity : 0 < (d : ℝ) + 2)]
    have h3 : (3 : ℝ) ≤ (d : ℝ) + 2 := by
      exact_mod_cast (show 3 ≤ d + 2 by omega)
    exact (le_of_lt Real.exp_one_lt_three).trans h3
  have hsq_nonneg : 0 ≤ Real.log ((d : ℝ) + 2) ^ 2 := by positivity
  have hceil : (⌈(Real.log ((d : ℝ) + 2)) ^ 2⌉₊ : ℝ) ≤
      Real.log ((d : ℝ) + 2) ^ 2 + 1 := by
    have hceilNat : ⌈(Real.log ((d : ℝ) + 2)) ^ 2⌉₊ ≤
        ⌊(Real.log ((d : ℝ) + 2)) ^ 2⌋₊ + 1 :=
      Nat.ceil_le_floor_add_one _
    have hceilReal : (⌈(Real.log ((d : ℝ) + 2)) ^ 2⌉₊ : ℝ) ≤
        (⌊(Real.log ((d : ℝ) + 2)) ^ 2⌋₊ + 1 : ℕ) := by
      exact_mod_cast hceilNat
    have hfloor : (⌊(Real.log ((d : ℝ) + 2)) ^ 2⌋₊ : ℝ) ≤
        Real.log ((d : ℝ) + 2) ^ 2 := Nat.floor_le hsq_nonneg
    calc
      (⌈(Real.log ((d : ℝ) + 2)) ^ 2⌉₊ : ℝ) ≤
          (⌊(Real.log ((d : ℝ) + 2)) ^ 2⌋₊ + 1 : ℕ) := hceilReal
      _ = (⌊(Real.log ((d : ℝ) + 2)) ^ 2⌋₊ : ℝ) + 1 := by norm_num
      _ ≤ Real.log ((d : ℝ) + 2) ^ 2 + 1 := by linarith
  unfold aubrunEvenMomentParameter
  have hlogsq_ge1 : (1 : ℝ) ≤ Real.log ((d : ℝ) + 2) ^ 2 := by nlinarith
  norm_num
  nlinarith [hceil, hlogsq_ge1]

/-- The concrete Aubrun polynomial loss evaluated at the canonical even moment
choice is eventually bounded by a fixed power of `log(d+2)`. -/
theorem eventually_aubrunProposition73P_evenMoment_le_const_mul_log_add_two_pow :
    ∀ᶠ d : ℕ in Filter.atTop,
      aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) ≤
        12 ^ (36 : ℕ) * Real.log ((d : ℝ) + 2) ^ (72 : ℕ) := by
  filter_upwards [eventually_aubrunEvenMomentParameter_le_six_mul_log_add_two_sq]
    with d hk_le
  have htwo_eq : 2 * (((aubrunEvenMomentParameter d - 1 : ℕ) : ℝ) + 1) =
      2 * (aubrunEvenMomentParameter d : ℝ) := by
    have hpos : 1 ≤ aubrunEvenMomentParameter d := by
      exact Nat.succ_le_of_lt (aubrunEvenMomentParameter_pos d)
    have hcast_sub : ((aubrunEvenMomentParameter d - 1 : ℕ) : ℝ) =
        (aubrunEvenMomentParameter d : ℝ) - 1 := by
      rw [Nat.cast_sub hpos]
      norm_num
    rw [hcast_sub]
    ring
  have htwo_le : 2 * (((aubrunEvenMomentParameter d - 1 : ℕ) : ℝ) + 1) ≤
      12 * Real.log ((d : ℝ) + 2) ^ 2 := by
    rw [htwo_eq]
    nlinarith
  have hbase_nonneg :
      0 ≤ 2 * (((aubrunEvenMomentParameter d - 1 : ℕ) : ℝ) + 1) := by
    positivity
  have hpow := pow_le_pow_left₀ hbase_nonneg htwo_le (36 : ℕ)
  calc
    aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1)
        = (2 * (((aubrunEvenMomentParameter d - 1 : ℕ) : ℝ) + 1)) ^
            (36 : ℕ) := by
          simp [aubrunProposition73P]
    _ ≤ (12 * Real.log ((d : ℝ) + 2) ^ 2) ^ (36 : ℕ) := hpow
    _ = 12 ^ (36 : ℕ) * Real.log ((d : ℝ) + 2) ^ (72 : ℕ) := by ring

/-- The concrete Aubrun polynomial loss for the canonical even moment is
negligible compared with the dimension parameter `d`. -/
theorem tendsto_aubrunProposition73P_evenMoment_div_natCast_zero :
    Filter.Tendsto
      (fun d : ℕ =>
        aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) / (d : ℝ))
      Filter.atTop (nhds 0) := by
  exact
    tendsto_div_natCast_zero_of_eventually_le_const_mul_log_add_two_pow
      (f := fun d =>
