/-- If the `m = 7` simultaneous-geodesic formula count is `323`, then the
uniform zero-defect bound by `2^(m+1)` is impossible.

This is the checked no-go form of the Motzkin warning: the finite count itself
is kept as the explicit remaining input rather than hidden behind native
computation. -/
theorem not_forall_card_WickCyclePairTightClass_le_two_pow_of_formula_seven_eq_323
    (h7 : Fintype.card (WickCyclePairTightClassFormula 7) = 323) :
    ¬ (∀ m : ℕ,
      Fintype.card (WickCyclePairTightClass m) ≤ 2 ^ (m + 1)) := by
  intro h
  have hseven := h 7
  rw [card_WickCyclePairTightClass_eq_formula, h7] at hseven
  norm_num at hseven

/-- The same obstruction in the actual fixed-defect-count language: once the
`m = 7` formula count is `323`, Aubrun's current zero-defect envelope
`2^(m+1)` cannot hold for every Wick length. -/
theorem not_forall_wickPermutationDefectCount_zero_le_fixedEnvelope_of_formula_seven_eq_323
    (h7 : Fintype.card (WickCyclePairTightClassFormula 7) = 323) :
    ¬ (∀ m : ℕ,
      (wickPermutationDefectCount m 0 : ℝ) ≤
        aubrunFixedDefectCountEnvelope m 0) := by
  intro h
  have hseven := h 7
  rw [wickPermutationDefectCount_zero_eq_card_cyclePairTightClass,
    card_WickCyclePairTightClass_eq_formula, h7] at hseven
  unfold aubrunFixedDefectCountEnvelope aubrunProposition73P at hseven
  norm_num at hseven

/-- The length-four one-sided geodesic count follows from the two standard
cycle-count slices: one identity-like slice of size at most `1` and one
transposition-like slice of size at most `6`. -/
theorem card_WickCycleLeftTightClass_three_le_of_cycleCountSlices
    (h4 : Fintype.card (PermCycleCountClass 4 4) ≤ 1)
    (h3 : Fintype.card (PermCycleCountClass 4 3) ≤ 6) :
    Fintype.card (WickCycleLeftTightClass 3) ≤ 16 := by
  classical
  let U : Finset (Equiv.Perm (Fin 4)) := Finset.univ
  let P : Equiv.Perm (Fin 4) → Prop := fun π =>
    permCycleClassCount π + permCycleClassCount (finRotate 4 * π) = 5
  let C4 : Equiv.Perm (Fin 4) → Prop := fun π => permCycleClassCount π = 4
  let C3 : Equiv.Perm (Fin 4) → Prop := fun π => permCycleClassCount π = 3
  let L3 : Equiv.Perm (Fin 4) → Prop := fun π =>
    permCycleClassCount (finRotate 4 * π) = 3
  let L4 : Equiv.Perm (Fin 4) → Prop := fun π =>
    permCycleClassCount (finRotate 4 * π) = 4
  have hsubset :
      U.filter P ⊆
        ((U.filter C4 ∪ U.filter C3) ∪ U.filter L3) ∪ U.filter L4 := by
    intro π hπ
    simp only [Finset.mem_filter] at hπ
    simp only [Finset.mem_union, Finset.mem_filter]
    have hpos : 0 < permCycleClassCount π :=
      permCycleClassCount_pos_of_nonempty π
    have hle : permCycleClassCount π ≤ 4 := by
      simpa using permCycleClassCount_le_card π
    rcases hπ with ⟨_hπU, hP⟩
    by_cases hπ4 : permCycleClassCount π = 4
    · exact Or.inl (Or.inl (Or.inl ⟨Finset.mem_univ π, hπ4⟩))
    by_cases hπ3 : permCycleClassCount π = 3
    · exact Or.inl (Or.inl (Or.inr ⟨Finset.mem_univ π, hπ3⟩))
    by_cases hπ2 : permCycleClassCount π = 2
    · have hL3 : permCycleClassCount (finRotate 4 * π) = 3 := by omega
      exact Or.inl (Or.inr ⟨Finset.mem_univ π, hL3⟩)
    · have hπ1 : permCycleClassCount π = 1 := by omega
      have hL4 : permCycleClassCount (finRotate 4 * π) = 4 := by omega
      exact Or.inr ⟨Finset.mem_univ π, hL4⟩
  have hcardP :
      (U.filter P).card ≤
        (((U.filter C4 ∪ U.filter C3) ∪ U.filter L3) ∪ U.filter L4).card :=
    Finset.card_le_card hsubset
  have hcardUnion :
      (((U.filter C4 ∪ U.filter C3) ∪ U.filter L3) ∪ U.filter L4).card ≤
        (U.filter C4).card + (U.filter C3).card +
          (U.filter L3).card + (U.filter L4).card := by
    calc
      (((U.filter C4 ∪ U.filter C3) ∪ U.filter L3) ∪ U.filter L4).card ≤
          ((U.filter C4 ∪ U.filter C3) ∪ U.filter L3).card +
            (U.filter L4).card := Finset.card_union_le _ _
      _ ≤ ((U.filter C4 ∪ U.filter C3).card + (U.filter L3).card) +
            (U.filter L4).card := by
              exact Nat.add_le_add_right (Finset.card_union_le _ _) _
      _ ≤ (((U.filter C4).card + (U.filter C3).card) + (U.filter L3).card) +
            (U.filter L4).card := by
              exact Nat.add_le_add_right
                (Nat.add_le_add_right (Finset.card_union_le _ _) _) _
      _ = (U.filter C4).card + (U.filter C3).card +
            (U.filter L3).card + (U.filter L4).card := by omega
  have hC4 :
      (U.filter C4).card = Fintype.card (PermCycleCountClass 4 4) := by
    simpa [U, C4, PermCycleCountClass] using
      (Fintype.card_subtype
        (fun π : Equiv.Perm (Fin 4) => permCycleClassCount π = 4)).symm
  have hC3 :
      (U.filter C3).card = Fintype.card (PermCycleCountClass 4 3) := by
    simpa [U, C3, PermCycleCountClass] using
      (Fintype.card_subtype
        (fun π : Equiv.Perm (Fin 4) => permCycleClassCount π = 3)).symm
  have hL3 :
      (U.filter L3).card = Fintype.card (LeftProductCycleCountClass 4 3) := by
    simpa [U, L3, LeftProductCycleCountClass] using
      (Fintype.card_subtype
        (fun π : Equiv.Perm (Fin 4) =>
          permCycleClassCount (finRotate 4 * π) = 3)).symm
  have hL4 :
      (U.filter L4).card = Fintype.card (LeftProductCycleCountClass 4 4) := by
    simpa [U, L4, LeftProductCycleCountClass] using
      (Fintype.card_subtype
        (fun π : Equiv.Perm (Fin 4) =>
          permCycleClassCount (finRotate 4 * π) = 4)).symm
  have hL3bound : (U.filter L3).card ≤ 6 := by
    rw [hL3, card_leftProductCycleCountClass_eq]
    exact h3
  have hL4bound : (U.filter L4).card ≤ 1 := by
    rw [hL4, card_leftProductCycleCountClass_eq]
    exact h4
  have hC3bound : (U.filter C3).card ≤ 6 := by
    rw [hC3]
    exact h3
  have hC4bound : (U.filter C4).card ≤ 1 := by
    rw [hC4]
    exact h4
  have hPbound : (U.filter P).card ≤ 16 := by
    linarith
  change Fintype.card {π : Equiv.Perm (Fin 4) // P π} ≤ 16
  rw [Fintype.card_subtype]
  simpa [U] using hPbound

