        s < c - a ∧
        r < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        1 < s ∧
        s < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        0 < r ∧
        r + 1 < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) ∨
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ ∨
    (∃ r : ℕ,
      ∃ hr : r + 1 < c - a,
        π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + (r + 1), by
            have hc' := Finset.mem_range.mp hc
