/-- The concrete interval contour walk supplies reachability in the original
incidence tree. -/
theorem finRotate_mul_perm_incidence_contour_interval_left_reachable
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a ≤ c) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Reachable
        (Sum.inl (Quotient.mk'' ⟨a, Finset.mem_range.mp ha⟩ :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))))
        (Sum.inl (Quotient.mk'' ⟨c, Finset.mem_range.mp hc⟩ :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)))) :=
  (finRotate_mul_perm_incidence_contour_interval_left_walk π ha hc hac).reachable

/-- Concrete interval form of contour reachability: if `a ≤ c` in the
ordinary range order, the incidence edges at `a` and `c` are connected by the
long-cycle contour in the line graph. -/
theorem leftTight_incidenceLineGraph_contour_interval_reachable
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a ≤ c) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).lineGraph.Reachable
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π)
          ⟨a, Finset.mem_range.mp ha⟩)
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π)
          ⟨c, Finset.mem_range.mp hc⟩) := by
  have hpow :=
    leftTight_incidenceLineGraph_contour_pow_reachable
      (m := m) (π := π) hleft ⟨a, Finset.mem_range.mp ha⟩ (c - a)
  have hadd : a + (c - a) < m + 1 := by
    have hc' := Finset.mem_range.mp hc
    omega
  have hrot :
      (((finRotate (m + 1)) ^ (c - a)) ⟨a, Finset.mem_range.mp ha⟩ :
        Fin (m + 1)) = ⟨c, Finset.mem_range.mp hc⟩ := by
    have hformula :=
      finRotate_pow_apply_of_add_lt
        (n := m + 1) (a := a) (k := c - a)
        (Finset.mem_range.mp ha) hadd
    apply Fin.ext
    have hval := congrArg Fin.val hformula
    simp at hval ⊢
    omega
  simpa [hrot] using hpow

/-- A nontrivial `π`-cycle link cannot also be a
`(finRotate * π)`-cycle link in the left-tight case. -/
theorem leftTight_not_sameCycle_both_of_lt
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩) :
    ¬ (finRotate (m + 1) * π).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
  intro hS
  have heq := leftTight_cycle_intersection_subsingleton hleft hT hS
  have hval : a = c := congrArg Fin.val heq
  omega

/-- Natural-index form of the direct incidence-tree path supplied by a
`π`-cycle link. -/
def leftTight_incidenceGraph_left_walk_of_sameCycle
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
