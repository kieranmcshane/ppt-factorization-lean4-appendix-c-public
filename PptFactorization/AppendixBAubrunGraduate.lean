/-- The concrete Aubrun `Q(k)=kP(k)` loss for the canonical even moment is
eventually bounded by a fixed power of `log(d+2)`. -/
theorem eventually_aubrunProposition71Q_evenMoment_le_const_mul_log_add_two_pow :
    ∀ᶠ d : ℕ in Filter.atTop,
      aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1) ≤
        (6 * 12 ^ (36 : ℕ)) *
          Real.log ((d : ℝ) + 2) ^ (74 : ℕ) := by
  filter_upwards
    [eventually_aubrunEvenMomentParameter_le_six_mul_log_add_two_sq,
      eventually_aubrunProposition73P_evenMoment_le_const_mul_log_add_two_pow]
    with d hk_le hP_le
  have hpos : 1 ≤ aubrunEvenMomentParameter d := by
    exact Nat.succ_le_of_lt (aubrunEvenMomentParameter_pos d)
  have hk_cast :
      (((aubrunEvenMomentParameter d - 1 : ℕ) : ℝ) + 1) =
        (aubrunEvenMomentParameter d : ℝ) := by
    rw [Nat.cast_sub hpos]
    norm_num
  have hlog_nonneg : 0 ≤ Real.log ((d : ℝ) + 2) := by
    have hd0 : 0 ≤ (d : ℝ) := by positivity
    exact Real.log_nonneg (by nlinarith)
  have hP_nonneg :
      0 ≤ aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) :=
