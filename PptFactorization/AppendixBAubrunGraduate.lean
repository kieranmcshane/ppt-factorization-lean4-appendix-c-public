            (finRotate (2 + 1) * π.1).SameCycle y z) := by
    change ¬ (∃ y z : Fin 3,
      y ≠ z ∧
        Equiv.Perm.SameCycle ((finRotate 3).symm : Equiv.Perm (Fin 3)) y z ∧
          Equiv.Perm.SameCycle
            (finRotate 3 * (finRotate 3).symm : Equiv.Perm (Fin 3)) y z)
    decide
  exact hNoCommon (h 2 π hNC 0 2 ha hc hac hgap hT hPrimitive)

/-- Formula-based version of the one-sided long-cycle geodesic class. -/
def WickCycleLeftTightClassFormula (m : ℕ) :=
  {π : Equiv.Perm (Fin (m + 1)) //
    cycleCountFormula π +
      cycleCountFormula (finRotate (m + 1) * π) = (m + 1) + 1}

instance (m : ℕ) : Fintype (WickCycleLeftTightClassFormula m) := by
  unfold WickCycleLeftTightClassFormula
  infer_instance

/-- The formula-based one-sided class is equivalent to the quotient-cycle
definition. -/
noncomputable def cycleLeftTightClassFormulaEquiv (m : ℕ) :
    WickCycleLeftTightClass m ≃ WickCycleLeftTightClassFormula m where
  toFun := fun π => ⟨π.1, by
    simpa [WickCycleLeftTightClassFormula, cycleCountFormula,
      permCycleClassCount_eq_card_sub_cycleType_sum_add_cycleType_card] using π.2⟩
  invFun := fun π => ⟨π.1, by
    simpa [WickCycleLeftTightClassFormula, cycleCountFormula,
      permCycleClassCount_eq_card_sub_cycleType_sum_add_cycleType_card] using π.2⟩
  left_inv := by
    intro π
    rfl
  right_inv := by
    intro π
    rfl

/-- The one-sided long-cycle geodesic count may be computed through
cycle-type formulas. -/
theorem card_WickCycleLeftTightClass_eq_formula (m : ℕ) :
    Fintype.card (WickCycleLeftTightClass m) =
      Fintype.card (WickCycleLeftTightClassFormula m) :=
  Fintype.card_congr (cycleLeftTightClassFormulaEquiv m)

