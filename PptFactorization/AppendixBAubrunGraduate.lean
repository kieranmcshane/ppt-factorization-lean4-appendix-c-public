Catalan size `C₄ = 14`. -/
theorem card_WickCycleLeftTightClass_three_eq_fourteen :
    Fintype.card (WickCycleLeftTightClass 3) = 14 := by
  rw [card_WickCycleLeftTightClass_eq_formula]
  decide

/-- Formula-based version of the simultaneous Cayley-geodesic class.

This is equivalent to `WickCyclePairTightClass`; it only replaces quotient
cycle-class counts by the computable cycle-type formula. -/
def WickCyclePairTightClassFormula (m : ℕ) :=
  {π : Equiv.Perm (Fin (m + 1)) //
    cycleCountFormula π +
        cycleCountFormula (finRotate (m + 1) * π) = (m + 1) + 1 ∧
      cycleCountFormula π +
        cycleCountFormula (π * (finRotate (m + 1)).symm) = (m + 1) + 1}

instance (m : ℕ) : Fintype (WickCyclePairTightClassFormula m) := by
  unfold WickCyclePairTightClassFormula
  infer_instance

noncomputable def cyclePairTightClassFormulaEquiv (m : ℕ) :
    WickCyclePairTightClass m ≃ WickCyclePairTightClassFormula m where
  toFun := fun π => ⟨π.1, by
    simpa [WickCyclePairTightClassFormula, cycleCountFormula,
      permCycleClassCount_eq_card_sub_cycleType_sum_add_cycleType_card] using π.2⟩
  invFun := fun π => ⟨π.1, by
    simpa [WickCyclePairTightClassFormula, cycleCountFormula,
      permCycleClassCount_eq_card_sub_cycleType_sum_add_cycleType_card] using π.2⟩
  left_inv := by
    intro π
    rfl
  right_inv := by
    intro π
    rfl

theorem card_WickCyclePairTightClass_eq_formula (m : ℕ) :
    Fintype.card (WickCyclePairTightClass m) =
      Fintype.card (WickCyclePairTightClassFormula m) :=
