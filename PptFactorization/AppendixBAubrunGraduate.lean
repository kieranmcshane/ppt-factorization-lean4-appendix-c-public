/-- In the left-tight incidence tree, every simple walk between the two
endpoint left-vertices of a nontrivial `π`-cycle link is the direct length-two
walk through the common `π`-class. -/
theorem leftTight_incidenceGraph_left_walk_unique_of_sameCycle
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    {p : (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Walk
        (Sum.inl (Quotient.mk'' ⟨a, Finset.mem_range.mp ha⟩ :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))))
        (Sum.inl (Quotient.mk'' ⟨c, Finset.mem_range.mp hc⟩ :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))))}
    (hp : p.IsPath) :
    p = leftTight_incidenceGraph_left_walk_of_sameCycle π ha hc hT := by
  let u : Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
      Quotient (Equiv.Perm.SameCycle.setoid π) :=
    Sum.inl (Quotient.mk'' ⟨a, Finset.mem_range.mp ha⟩)
  let v : Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
      Quotient (Equiv.Perm.SameCycle.setoid π) :=
    Sum.inl (Quotient.mk'' ⟨c, Finset.mem_range.mp hc⟩)
  rcases leftTight_incidenceGraph_existsUnique_isPath
      (m := m) (π := π) hleft u v with
    ⟨w, hw, huniq⟩
  have hdirect :
      (leftTight_incidenceGraph_left_walk_of_sameCycle π ha hc hT).IsPath :=
    leftTight_incidenceGraph_left_walk_of_sameCycle_isPath
      hleft ha hc hac_lt hT
  exact (huniq p hp).trans (huniq
    (leftTight_incidenceGraph_left_walk_of_sameCycle π ha hc hT) hdirect).symm

/-- A nontrivial `(finRotate * π)`-cycle link cannot also be a `π`-cycle link
