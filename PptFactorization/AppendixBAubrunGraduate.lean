    (∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
        0 < r ∧
        s < c - a ∧
        r < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        1 < s ∧
        s < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        0 < r ∧
        r + 1 < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) ∨
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ := by
  rcases
    leftTight_contour_interval_sameCycle_frontier_of_no_internal_right_repeat
      hleft ha hc hac_lt hT hgap hNoRight with
    hInterior | hStartOrEndOrFixed
  · left
    exact hInterior
  · rcases hStartOrEndOrFixed with hStart | hEndOrFixed
    · rcases hStart with ⟨s, hs, hsfar, hSame⟩
      by_cases hsend : s = c - a
      · have hfin :
            (⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          apply Fin.ext
