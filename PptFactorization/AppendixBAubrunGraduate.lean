          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)) =
          ⟨a + 1, Finset.mem_range.mp ha1⟩ := by
      apply Fin.ext
      rfl
    simpa [hleft] using hS_a1_b')

/-- The left gap-three/end-adjacent branch `π(a+1,b)` is absorbed by the
