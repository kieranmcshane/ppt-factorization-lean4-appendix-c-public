/-- Closed canonical `Q`-ratio supplier: for every fixed positive `ρ`,
eventually `Q(k(d))≤ρd`. -/
theorem eventually_aubrunProposition71Q_evenMoment_le_rho_mul_natCast
    {ρ : ℝ} (hρ : 0 < ρ) :
    ∀ᶠ d in Filter.atTop,
      aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1) ≤
        ρ * (d : ℝ) := by
  have hDpos : ∀ᶠ d : ℕ in Filter.atTop, 0 < (d : ℝ) := by
    rw [Filter.eventually_atTop]
    exact ⟨1, fun d hd => by exact_mod_cast hd⟩
  have hlt :
      ∀ᶠ d : ℕ in Filter.atTop,
        aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1) /
            (d : ℝ) < ρ :=
    tendsto_aubrunProposition71Q_evenMoment_div_natCast_zero.eventually
      (eventually_lt_nhds hρ)
  filter_upwards [hDpos, hlt] with d hd hlt_d
  exact le_of_lt ((div_lt_iff₀ hd).mp hlt_d)

/-- If the two analytic bases have a linear gap, Aubrun's canonical
`Q(k(d))` loss is eventually too small to make the max-base `Q`-close branch
available.

This is the asymptotic obstruction behind the max-base diagnostic: the
canonical `Q(k(d))` is polylogarithmic in `d`, whereas a fixed positive
fraction of `d` wins eventually. -/
theorem eventually_aubrunProposition71Q_evenMoment_lt_linear_gap
    {sNat : ℕ → ℕ} {c : ℝ} (hc : 0 < c)
    (hgap : ∀ᶠ d : ℕ in Filter.atTop,
      c * (d : ℝ) ≤ |(d : ℝ) - Real.sqrt ((sNat d : ℕ) : ℝ)|) :
    ∀ᶠ d : ℕ in Filter.atTop,
      aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1) <
        |(d : ℝ) - Real.sqrt ((sNat d : ℕ) : ℝ)| := by
  have hhalf : 0 < c / 2 := by positivity
  have hQ :=
    eventually_aubrunProposition71Q_evenMoment_le_rho_mul_natCast hhalf
  have hdpos : ∀ᶠ d : ℕ in Filter.atTop, 0 < (d : ℝ) := by
    rw [Filter.eventually_atTop]
    exact ⟨1, fun d hd => by exact_mod_cast hd⟩
  filter_upwards [hQ, hgap, hdpos] with d hQd hgapd hdd
  have hstrict : (c / 2) * (d : ℝ) < c * (d : ℝ) := by
    nlinarith
  exact lt_of_le_of_lt hQd (lt_of_lt_of_le hstrict hgapd)

/-- Linear base gaps eventually rule out the max-base cross-comparison branch.

Equivalently, the `Q`-close max-base route cannot close a generic balanced
path whose two analytic bases stay separated by a fixed positive fraction of
`d`. -/
theorem eventually_aubrun_maxBase_crossComparisons_impossible_of_linear_gap
    {sNat : ℕ → ℕ} {c : ℝ} (hc : 0 < c)
    (hgap : ∀ᶠ d : ℕ in Filter.atTop,
      c * (d : ℝ) ≤ |(d : ℝ) - Real.sqrt ((sNat d : ℕ) : ℝ)|) :
    ∀ᶠ d : ℕ in Filter.atTop,
      ¬ (Real.sqrt ((sNat d : ℕ) : ℝ) ≤ (d : ℝ) +
            aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1) ∧
          (d : ℝ) ≤ Real.sqrt ((sNat d : ℕ) : ℝ) +
            aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1)) := by
  have hQgap :=
    eventually_aubrunProposition71Q_evenMoment_lt_linear_gap
      (sNat := sNat) hc hgap
  filter_upwards [hQgap] with d hQgap_d hCross
  have hclose :
      |(d : ℝ) - Real.sqrt ((sNat d : ℕ) : ℝ)| ≤
        aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1) := by
    rw [abs_sub_le_iff]
    constructor <;> linarith
  exact not_lt_of_ge hclose hQgap_d

/-- A limiting ratio `sqrt(s(d))/d → L ≠ 1` gives a linear gap between the
two analytic bases. -/
theorem eventually_linear_gap_of_tendsto_sqrt_sample_div_natCast_ne_one
    {sNat : ℕ → ℕ} {L : ℝ} (hL : L ≠ 1)
    (hT : Filter.Tendsto
      (fun d : ℕ => Real.sqrt ((sNat d : ℕ) : ℝ) / (d : ℝ))
      Filter.atTop (nhds L)) :
    ∃ c : ℝ, 0 < c ∧
      ∀ᶠ d : ℕ in Filter.atTop,
        c * (d : ℝ) ≤
          |(d : ℝ) - Real.sqrt ((sNat d : ℕ) : ℝ)| := by
  let c : ℝ := |1 - L| / 2
  have hc : 0 < c := by
    have hpos : 0 < |1 - L| := by
      exact abs_pos.mpr (sub_ne_zero.mpr hL.symm)
    positivity
  refine ⟨c, hc, ?_⟩
  have hnear : ∀ᶠ d : ℕ in Filter.atTop,
      Real.sqrt ((sNat d : ℕ) : ℝ) / (d : ℝ) ∈ Metric.ball L c := by
    exact hT.eventually (Metric.ball_mem_nhds L hc)
  have hdpos : ∀ᶠ d : ℕ in Filter.atTop, 0 < (d : ℝ) := by
    rw [Filter.eventually_atTop]
    exact ⟨1, fun d hd => by exact_mod_cast hd⟩
  filter_upwards [hnear, hdpos] with d hnear_d hd
  let r : ℝ := Real.sqrt ((sNat d : ℕ) : ℝ) / (d : ℝ)
  have hnear_abs : |r - L| < c := by
    simpa [r, Metric.mem_ball, Real.dist_eq] using hnear_d
  have htri : |1 - L| ≤ |1 - r| + |r - L| := by
    calc
      |1 - L| = |(1 - r) - (L - r)| := by ring_nf
      _ ≤ |1 - r| + |L - r| := abs_sub (1 - r) (L - r)
      _ = |1 - r| + |r - L| := by rw [abs_sub_comm L r]
  have hcr : c ≤ |1 - r| := by
    unfold c at hnear_abs ⊢
    nlinarith
  have hmul : c * (d : ℝ) ≤ |1 - r| * (d : ℝ) := by
    exact mul_le_mul_of_nonneg_right hcr hd.le
  have hrewrite :
      |1 - r| * (d : ℝ) =
        |(d : ℝ) - Real.sqrt ((sNat d : ℕ) : ℝ)| := by
    have hdne : (d : ℝ) ≠ 0 := ne_of_gt hd
    unfold r
    calc
      |1 - Real.sqrt ((sNat d : ℕ) : ℝ) / (d : ℝ)| * (d : ℝ)
          = |(1 - Real.sqrt ((sNat d : ℕ) : ℝ) / (d : ℝ)) *
              (d : ℝ)| := by
              rw [abs_mul, abs_of_pos hd]
      _ = |(d : ℝ) - Real.sqrt ((sNat d : ℕ) : ℝ)| := by
              congr 1
              field_simp [hdne]
  exact hmul.trans_eq hrewrite

/-- Ratio-limit form of the max-base obstruction: away from the square case
`sqrt(s(d))/d → 1`, the `Q`-close cross-comparison branch is eventually
impossible. -/
theorem eventually_aubrun_maxBase_crossComparisons_impossible_of_sqrt_ratio_ne_one
    {sNat : ℕ → ℕ} {L : ℝ} (hL : L ≠ 1)
    (hT : Filter.Tendsto
      (fun d : ℕ => Real.sqrt ((sNat d : ℕ) : ℝ) / (d : ℝ))
      Filter.atTop (nhds L)) :
    ∀ᶠ d : ℕ in Filter.atTop,
      ¬ (Real.sqrt ((sNat d : ℕ) : ℝ) ≤ (d : ℝ) +
            aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1) ∧
          (d : ℝ) ≤ Real.sqrt ((sNat d : ℕ) : ℝ) +
            aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1)) := by
  rcases
    eventually_linear_gap_of_tendsto_sqrt_sample_div_natCast_ne_one
      (sNat := sNat) hL hT with
    ⟨c, hc, hgap⟩
  exact
    eventually_aubrun_maxBase_crossComparisons_impossible_of_linear_gap
      (sNat := sNat) hc hgap

/-- Square-root adapter for the usual balanced sample-size ratio. -/
theorem tendsto_sqrt_sample_div_natCast_of_tendsto_sample_div_natCast_sq
    {sNat : ℕ → ℕ} {lam : ℝ}
    (hRatio : Filter.Tendsto
      (fun d : ℕ => ((sNat d : ℕ) : ℝ) / (d : ℝ) ^ 2)
      Filter.atTop (nhds lam)) :
    Filter.Tendsto
      (fun d : ℕ => Real.sqrt ((sNat d : ℕ) : ℝ) / (d : ℝ))
      Filter.atTop (nhds (Real.sqrt lam)) := by
  have hsqrtRatio : Filter.Tendsto
      (fun d : ℕ => Real.sqrt (((sNat d : ℕ) : ℝ) / (d : ℝ) ^ 2))
      Filter.atTop (nhds (Real.sqrt lam)) := by
    simpa [Function.comp_def] using
      (Real.continuous_sqrt.tendsto lam).comp hRatio
  have heq :
      (fun d : ℕ =>
        Real.sqrt (((sNat d : ℕ) : ℝ) / (d : ℝ) ^ 2)) =ᶠ[Filter.atTop]
      (fun d : ℕ =>
        Real.sqrt ((sNat d : ℕ) : ℝ) / (d : ℝ)) := by
    filter_upwards
      [show ∀ᶠ d : ℕ in Filter.atTop, 0 < (d : ℝ) by
        rw [Filter.eventually_atTop]
        exact ⟨1, fun d hd => by exact_mod_cast hd⟩] with d hd
    have hs_nonneg : 0 ≤ ((sNat d : ℕ) : ℝ) := by positivity
    calc
      Real.sqrt (((sNat d : ℕ) : ℝ) / (d : ℝ) ^ 2)
          = Real.sqrt ((sNat d : ℕ) : ℝ) /
              Real.sqrt ((d : ℝ) ^ 2) := by
              rw [Real.sqrt_div hs_nonneg]
      _ = Real.sqrt ((sNat d : ℕ) : ℝ) / (d : ℝ) := by
              rw [Real.sqrt_sq_eq_abs, abs_of_pos hd]
  exact hsqrtRatio.congr' heq

/-- Balanced-ratio form of the max-base obstruction: if
`s(d)/d^2 → λ` with `λ ≠ 1`, then the max-base `Q`-close branch is eventually
impossible. -/
theorem eventually_aubrun_maxBase_crossComparisons_impossible_of_sample_ratio_ne_one
    {sNat : ℕ → ℕ} {lam : ℝ} (hlam0 : 0 ≤ lam) (hlam : lam ≠ 1)
    (hRatio : Filter.Tendsto
      (fun d : ℕ => ((sNat d : ℕ) : ℝ) / (d : ℝ) ^ 2)
      Filter.atTop (nhds lam)) :
    ∀ᶠ d : ℕ in Filter.atTop,
      ¬ (Real.sqrt ((sNat d : ℕ) : ℝ) ≤ (d : ℝ) +
            aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1) ∧
          (d : ℝ) ≤ Real.sqrt ((sNat d : ℕ) : ℝ) +
            aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1)) := by
  have hsqrt_ne : Real.sqrt lam ≠ 1 := by
    intro hsqrt
    have hlam_eq : lam = 1 := by
      calc
        lam = Real.sqrt lam ^ 2 := by rw [Real.sq_sqrt hlam0]
        _ = 1 ^ 2 := by rw [hsqrt]
        _ = 1 := by norm_num
    exact hlam hlam_eq
  exact
    eventually_aubrun_maxBase_crossComparisons_impossible_of_sqrt_ratio_ne_one
      (sNat := sNat) hsqrt_ne
      (tendsto_sqrt_sample_div_natCast_of_tendsto_sample_div_natCast_sq
        (sNat := sNat) hRatio)

/-- The fixed-`ρ` max-base quadratic-gain condition is eventually impossible
for Aubrun's canonical logarithmic moment choice.

The reason is scale-theoretic: the left side contains the fixed inflation
factor `(1-ρ)⁻¹>1` on at least `d²`, while the right side is only
`(d+Q(k(d)))²` with `Q(k(d))=o(d)`. -/
theorem eventually_aubrun_maxBase_quadraticGain_impossible
    {S : ℕ → ℝ} {ρ : ℝ} (hρpos : 0 < ρ) (hρ1 : ρ < 1) :
    ∀ᶠ d : ℕ in Filter.atTop,
      ¬ ((1 - ρ)⁻¹ * max (d : ℝ) (S d) ^ 2 ≤
        ((d : ℝ) +
          aubrunProposition71Q 1
            ((aubrunEvenMomentParameter d - 1) + 1)) ^ 2) := by
  let η : ℝ := ρ / 4
  have hηpos : 0 < η := by positivity
  have hQ :=
    eventually_aubrunProposition71Q_evenMoment_le_rho_mul_natCast hηpos
  have hdpos : ∀ᶠ d : ℕ in Filter.atTop, 0 < (d : ℝ) := by
    rw [Filter.eventually_atTop]
    exact ⟨1, fun d hd => by exact_mod_cast hd⟩
  have hQnonneg : ∀ d : ℕ,
      0 ≤ aubrunProposition71Q 1
        ((aubrunEvenMomentParameter d - 1) + 1) := by
    intro d
    exact aubrunProposition71Q_nonneg (by norm_num) _
  have hmargin : (1 + η) ^ 2 < (1 - ρ)⁻¹ := by
    have hdenpos : 0 < 1 - ρ := by linarith
    rw [inv_eq_one_div]
    rw [lt_div_iff₀ hdenpos]
    unfold η
    have hpoly :
        (1 + ρ / 4) ^ 2 * (1 - ρ) =
          1 - ρ / 2 - 7 * ρ ^ 2 / 16 - ρ ^ 3 / 16 := by
      ring
    rw [hpoly]
    have hρsq_nonneg : 0 ≤ ρ ^ 2 := by positivity
    have hρcube_pos : 0 < ρ ^ 3 := by positivity
    nlinarith
  filter_upwards [hQ, hdpos] with d hQd hd hQuad
  let Qd : ℝ :=
    aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1)
  have hQd_nonneg : 0 ≤ Qd := by
    unfold Qd
    exact hQnonneg d
  have hQd_le : Qd ≤ η * (d : ℝ) := by
    unfold Qd
    exact hQd
  have hbase_le : (d : ℝ) + Qd ≤ (1 + η) * (d : ℝ) := by
    nlinarith
  have hbase_nonneg : 0 ≤ (d : ℝ) + Qd := by positivity
  have hbase_sq_le :
      ((d : ℝ) + Qd) ^ 2 ≤ ((1 + η) * (d : ℝ)) ^ 2 := by
    exact pow_le_pow_left₀ hbase_nonneg hbase_le 2
  have hd_sq_pos : 0 < (d : ℝ) ^ 2 := sq_pos_of_pos hd
  have hupper :
      ((d : ℝ) + Qd) ^ 2 <
        (1 - ρ)⁻¹ * (d : ℝ) ^ 2 := by
    have hmul :
        ((1 + η) * (d : ℝ)) ^ 2 <
          (1 - ρ)⁻¹ * (d : ℝ) ^ 2 := by
      calc
        ((1 + η) * (d : ℝ)) ^ 2 =
            (1 + η) ^ 2 * (d : ℝ) ^ 2 := by ring
        _ < (1 - ρ)⁻¹ * (d : ℝ) ^ 2 := by
            exact mul_lt_mul_of_pos_right hmargin hd_sq_pos
    exact lt_of_le_of_lt hbase_sq_le hmul
  have hmax_sq_ge : (d : ℝ) ^ 2 ≤ max (d : ℝ) (S d) ^ 2 := by
    have hmax_ge : (d : ℝ) ≤ max (d : ℝ) (S d) := le_max_left _ _
    exact pow_le_pow_left₀ hd.le hmax_ge 2
  have hinv_nonneg : 0 ≤ (1 - ρ)⁻¹ := by
    exact inv_nonneg.mpr (by linarith : 0 ≤ 1 - ρ)
  have hlower :
      (1 - ρ)⁻¹ * (d : ℝ) ^ 2 ≤
        (1 - ρ)⁻¹ * max (d : ℝ) (S d) ^ 2 := by
    exact mul_le_mul_of_nonneg_left hmax_sq_ge hinv_nonneg
  have hbad :
      (1 - ρ)⁻¹ * (d : ℝ) ^ 2 ≤ ((d : ℝ) + Qd) ^ 2 := by
    exact le_trans hlower hQuad
  exact not_lt_of_ge hbad hupper

/-- Ratio-to-zero adapter for Aubrun's Proposition 7.3 polynomial.

If `P(κ(d))/D(d)` tends to zero and `D(d)` is eventually positive, then every
fixed positive ratio budget `ρ` eventually dominates `P(κ(d))` by `ρD(d)`.
This is the scalar adapter needed by the defect-ratio endpoints. -/
theorem eventually_aubrunProposition73P_le_rho_mul_of_tendsto_ratio_zero
    {κ : ℕ → ℕ} {D : ℕ → ℝ} {ρ : ℝ}
    (hρ : 0 < ρ)
    (hDpos : ∀ᶠ d in Filter.atTop, 0 < D d)
    (hRatio :
      Filter.Tendsto (fun d : ℕ => aubrunProposition73P (κ d) / D d)
        Filter.atTop (nhds 0)) :
    ∀ᶠ d in Filter.atTop, aubrunProposition73P (κ d) ≤ ρ * D d := by
  have hlt :
      ∀ᶠ d : ℕ in Filter.atTop, aubrunProposition73P (κ d) / D d < ρ :=
    hRatio.eventually (eventually_lt_nhds hρ)
  filter_upwards [hDpos, hlt] with d hD hlt_d
  exact le_of_lt ((div_lt_iff₀ hD).mp hlt_d)

/-- Canonical even-moment specialization of the ratio-to-zero adapter. -/
theorem eventually_aubrunProposition73P_evenMoment_le_rho_mul_of_tendsto_ratio_zero
    {D : ℕ → ℝ} {ρ : ℝ}
    (hρ : 0 < ρ)
    (hDpos : ∀ᶠ d in Filter.atTop, 0 < D d)
    (hRatio :
      Filter.Tendsto
        (fun d : ℕ =>
          aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) / D d)
        Filter.atTop (nhds 0)) :
    ∀ᶠ d in Filter.atTop,
      aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) ≤
        ρ * D d :=
  eventually_aubrunProposition73P_le_rho_mul_of_tendsto_ratio_zero
    (κ := fun d => (aubrunEvenMomentParameter d - 1) + 1)
    (D := D) hρ hDpos hRatio

/-- Canonical even-moment specialization with the denominator `d`. -/
theorem eventually_aubrunProposition73P_evenMoment_le_rho_mul_natCast_of_tendsto_div_natCast_zero
    {ρ : ℝ} (hρ : 0 < ρ)
    (hRatio :
      Filter.Tendsto
        (fun d : ℕ =>
          aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) /
            (d : ℝ))
        Filter.atTop (nhds 0)) :
    ∀ᶠ d in Filter.atTop,
      aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) ≤
        ρ * (d : ℝ) := by
  have hDpos : ∀ᶠ d : ℕ in Filter.atTop, 0 < (d : ℝ) := by
    rw [Filter.eventually_atTop]
    exact ⟨1, fun d hd => by exact_mod_cast hd⟩
  exact
    eventually_aubrunProposition73P_evenMoment_le_rho_mul_of_tendsto_ratio_zero
      (D := fun d => (d : ℝ)) hρ hDpos hRatio

/-- If `P(k(d))/d→0`, then the same polynomial is eventually below
`ρ max(d,S(d))` for any second nonnegative-or-negative scale `S`; no
assumption on `S` is needed because `d≤max(d,S(d))`. -/
theorem eventually_aubrunProposition73P_evenMoment_le_rho_mul_max_natCast_of_tendsto_div_natCast_zero
    {S : ℕ → ℝ} {ρ : ℝ} (hρ : 0 < ρ)
    (hRatio :
      Filter.Tendsto
        (fun d : ℕ =>
          aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) /
            (d : ℝ))
        Filter.atTop (nhds 0)) :
    ∀ᶠ d in Filter.atTop,
      aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) ≤
        ρ * max (d : ℝ) (S d) := by
  have hP :=
    eventually_aubrunProposition73P_evenMoment_le_rho_mul_natCast_of_tendsto_div_natCast_zero
      hρ hRatio
  filter_upwards [hP] with d hP_d
  exact hP_d.trans
    (mul_le_mul_of_nonneg_left (le_max_left (d : ℝ) (S d)) hρ.le)

/-- Closed canonical ratio supplier: the concrete logarithmic moment choice
makes `P(k(d))≤ρd` eventually for every fixed positive `ρ`. -/
theorem eventually_aubrunProposition73P_evenMoment_le_rho_mul_natCast
    {ρ : ℝ} (hρ : 0 < ρ) :
    ∀ᶠ d in Filter.atTop,
      aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) ≤
        ρ * (d : ℝ) :=
  eventually_aubrunProposition73P_evenMoment_le_rho_mul_natCast_of_tendsto_div_natCast_zero
    hρ tendsto_aubrunProposition73P_evenMoment_div_natCast_zero

/-- Direct canonical supplier for the close-window endpoints' side condition:
eventually `P(k(d))≤d`. -/
theorem eventually_aubrunProposition73P_evenMoment_le_natCast :
    ∀ᶠ d in Filter.atTop,
      aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) ≤
        (d : ℝ) := by
  have h :=
    eventually_aubrunProposition73P_evenMoment_le_rho_mul_natCast
      (ρ := 1) (by norm_num)
  filter_upwards [h] with d hd
  simpa using hd

/-- Closed max-base ratio supplier: `P(k(d))≤ρ max(d,S(d))` eventually follows
from the concrete logarithmic moment choice, with no assumption on `S`. -/
theorem eventually_aubrunProposition73P_evenMoment_le_rho_mul_max_natCast
    {S : ℕ → ℝ} {ρ : ℝ} (hρ : 0 < ρ) :
    ∀ᶠ d in Filter.atTop,
      aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) ≤
        ρ * max (d : ℝ) (S d) :=
  eventually_aubrunProposition73P_evenMoment_le_rho_mul_max_natCast_of_tendsto_div_natCast_zero
    (S := S) hρ tendsto_aubrunProposition73P_evenMoment_div_natCast_zero

/-- Aubrun's fixed-defect count envelope from Proposition 7.3, written in the
`m`-parameter used by Wick permutations (`k = m + 1`). -/
def aubrunFixedDefectCountEnvelope (m Δ : ℕ) : ℝ :=
  (2 : ℝ) ^ (m + 1) * aubrunProposition73P (m + 1) ^ Δ

/-- Nonnegativity of the fixed-defect count envelope. -/
theorem aubrunFixedDefectCountEnvelope_nonneg (m Δ : ℕ) :
    0 ≤ aubrunFixedDefectCountEnvelope m Δ := by
  unfold aubrunFixedDefectCountEnvelope
  exact mul_nonneg (by positivity)
    (pow_nonneg (aubrunProposition73P_nonneg (m + 1)) Δ)

/-- At Wick length one (`m = 0`), every permutation has zero Aubrun defect.

This is the base case of the fixed-defect counting problem.  It uses the
already-closed rank lower bound through `wickDefect_le_two_mul`. -/
theorem wickDefect_eq_zero_of_m_zero
    (π : Equiv.Perm (Fin (0 + 1))) : wickDefect π = 0 := by
  have h := wickDefect_le_two_mul (m := 0) π
  omega

/-- At Wick length one (`m = 0`), the defect-zero class contains exactly the
unique permutation of `Fin 1`. -/
theorem wickPermutationDefectCount_zero_zero :
    wickPermutationDefectCount 0 0 = 1 := by
  classical
  rw [wickPermutationDefectCount]
  have hfilter :
      (Finset.univ.filter fun π : Equiv.Perm (Fin (0 + 1)) =>
          wickDefect π = 0) =
        (Finset.univ : Finset (Equiv.Perm (Fin (0 + 1)))) := by
    ext π
    simp only [Finset.mem_filter, Finset.mem_univ, true_and]
    exact ⟨fun _ => trivial, fun _ => wickDefect_eq_zero_of_m_zero π⟩
  rw [hfilter]
  simp

/-- Aubrun's fixed-defect count envelope is closed on the tight defect range
in the base case `m = 0`. -/
theorem wickPermutationDefectCount_zero_tightRange_le_fixedEnvelope :
    ∀ Δ ∈ Finset.range (2 * 0 + 1),
      (wickPermutationDefectCount 0 Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope 0 Δ := by
  intro Δ hΔ
  have hΔlt : Δ < 1 := by
    simpa using Finset.mem_range.mp hΔ
  have hΔ0 : Δ = 0 := by omega
  subst Δ
  rw [wickPermutationDefectCount_zero_zero]
  unfold aubrunFixedDefectCountEnvelope aubrunProposition73P
  norm_num

/-- A fixed-defect slice is bounded by the total number of Wick permutations. -/
theorem wickPermutationDefectCount_le_perm_card (m Δ : ℕ) :
    wickPermutationDefectCount m Δ ≤
      Fintype.card (Equiv.Perm (Fin (m + 1))) := by
  classical
  rw [wickPermutationDefectCount]
  exact Finset.card_filter_le _ _

/-- Crude universal fixed-defect count bound by `(m+1)!`.

This is not sharp enough for `U-AUB-02` in general, but it closes the first
nontrivial Wick length and is a useful sanity bound for small slices. -/
theorem wickPermutationDefectCount_le_factorial (m Δ : ℕ) :
    wickPermutationDefectCount m Δ ≤ (m + 1).factorial := by
  calc
    wickPermutationDefectCount m Δ ≤
        Fintype.card (Equiv.Perm (Fin (m + 1))) :=
      wickPermutationDefectCount_le_perm_card m Δ
    _ = (m + 1).factorial := by
      rw [Fintype.card_perm, Fintype.card_fin]

/-- Aubrun's fixed-defect count envelope is closed on the tight defect range
in the first nontrivial Wick length `m = 1`.

Here the crude count `|S_2|=2` is already dominated by the fixed-defect
envelope, whose leading factor is `2^(1+1)=4`. -/
theorem wickPermutationDefectCount_one_tightRange_le_fixedEnvelope :
    ∀ Δ ∈ Finset.range (2 * 1 + 1),
      (wickPermutationDefectCount 1 Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope 1 Δ := by
  intro Δ _hΔ
  have hcountNat : wickPermutationDefectCount 1 Δ ≤ 2 := by
    simpa using wickPermutationDefectCount_le_factorial 1 Δ
  have hcountReal : (wickPermutationDefectCount 1 Δ : ℝ) ≤ 2 := by
    exact_mod_cast hcountNat
  have henv : (2 : ℝ) ≤ aubrunFixedDefectCountEnvelope 1 Δ := by
    unfold aubrunFixedDefectCountEnvelope aubrunProposition73P
    have hpow :
        (1 : ℝ) ≤ ((2 * ((1 + 1 : ℕ) : ℝ)) ^ 36) ^ Δ := by
      exact one_le_pow₀
        (by norm_num : (1 : ℝ) ≤ (2 * ((1 + 1 : ℕ) : ℝ)) ^ 36)
    calc
      (2 : ℝ) ≤ 2 ^ (1 + 1) * 1 := by norm_num
      _ ≤ 2 ^ (1 + 1) * ((2 * ((1 + 1 : ℕ) : ℝ)) ^ 36) ^ Δ := by
        exact mul_le_mul_of_nonneg_left hpow (by norm_num)
  exact hcountReal.trans henv

/-- Aubrun's fixed-defect count envelope is closed on the tight defect range
in Wick length `m = 2`.

The same crude count still suffices here: each defect slice has at most
`|S_3|=6` elements, while the fixed-defect envelope has leading factor
`2^(2+1)=8`. -/
theorem wickPermutationDefectCount_two_tightRange_le_fixedEnvelope :
    ∀ Δ ∈ Finset.range (2 * 2 + 1),
      (wickPermutationDefectCount 2 Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope 2 Δ := by
  intro Δ _hΔ
  have hcountNat : wickPermutationDefectCount 2 Δ ≤ 6 := by
    simpa using wickPermutationDefectCount_le_factorial 2 Δ
  have hcountReal : (wickPermutationDefectCount 2 Δ : ℝ) ≤ 6 := by
    exact_mod_cast hcountNat
  have henv : (6 : ℝ) ≤ aubrunFixedDefectCountEnvelope 2 Δ := by
    unfold aubrunFixedDefectCountEnvelope aubrunProposition73P
    have hpow :
        (1 : ℝ) ≤ ((2 * ((2 + 1 : ℕ) : ℝ)) ^ 36) ^ Δ := by
      exact one_le_pow₀
        (by norm_num : (1 : ℝ) ≤ (2 * ((2 + 1 : ℕ) : ℝ)) ^ 36)
    calc
      (6 : ℝ) ≤ 2 ^ (2 + 1) * 1 := by norm_num
      _ ≤ 2 ^ (2 + 1) * ((2 * ((2 + 1 : ℕ) : ℝ)) ^ 36) ^ Δ := by
        exact mul_le_mul_of_nonneg_left hpow (by norm_num)
  exact hcountReal.trans henv

/-- In Wick length `m = 3`, every positive-defect tight slice is already
dominated by Aubrun's fixed-defect envelope.

The crude count gives at most `|S_4|=24` permutations in any slice.  For
`Δ≥1`, the defect-power factor in the envelope contributes at least `2`, so
the envelope is at least `2^(3+1)*2=32`.  The remaining `m=3` obstruction is
therefore only the zero-defect slice. -/
theorem wickPermutationDefectCount_three_posDefect_tightRange_le_fixedEnvelope :
    ∀ Δ ∈ Finset.range (2 * 3 + 1), 0 < Δ →
      (wickPermutationDefectCount 3 Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope 3 Δ := by
  intro Δ _hΔ hΔpos
  have hcountNat : wickPermutationDefectCount 3 Δ ≤ 24 := by
    simpa using wickPermutationDefectCount_le_factorial 3 Δ
  have hcountReal : (wickPermutationDefectCount 3 Δ : ℝ) ≤ 24 := by
    exact_mod_cast hcountNat
  have henv : (24 : ℝ) ≤ aubrunFixedDefectCountEnvelope 3 Δ := by
    unfold aubrunFixedDefectCountEnvelope aubrunProposition73P
    let base : ℝ := (2 * ((3 + 1 : ℕ) : ℝ)) ^ 36
    have hbase2 : (2 : ℝ) ≤ base := by
      dsimp [base]
      norm_num
    have hbase0 : 0 ≤ base := by
      dsimp [base]
      positivity
    have hpow : (2 : ℝ) ≤ base ^ Δ := by
      cases Δ with
      | zero => omega
      | succ n =>
          rw [pow_succ]
          have htail : (1 : ℝ) ≤ base ^ n :=
            one_le_pow₀ (by linarith : (1 : ℝ) ≤ base)
          nlinarith
    calc
      (24 : ℝ) ≤ 2 ^ (3 + 1) * 2 := by norm_num
      _ ≤ 2 ^ (3 + 1) * base ^ Δ := by
        exact mul_le_mul_of_nonneg_left hpow (by norm_num)
  exact hcountReal.trans henv

/-- Trivial Aubrun innovation fiber for the base Wick length `m = 0`.

The only nonempty fiber sits over the full innovation set `I = univ`.  This
keeps the base case aligned with the same fiber interface used by the general
`U-AUB-02` branch. -/
abbrev aubrunBaseFiber (_Δ : ℕ) (I : Finset (Fin (0 + 1))) : Type :=
  {_u : Unit // I = Finset.univ}

/-- Trivial left/right compatible-couple type for the base Wick length. -/
abbrev aubrunBaseCouples (_Δ : ℕ) (_I : Finset (Fin (0 + 1))) : Type := Unit

noncomputable instance aubrunBaseFiber_fintype
    (Δ : ℕ) (I : Finset (Fin (0 + 1))) :
    Fintype (aubrunBaseFiber Δ I) := by
  unfold aubrunBaseFiber
  infer_instance

instance aubrunBaseCouples_fintype
    (Δ : ℕ) (I : Finset (Fin (0 + 1))) :
    Fintype (aubrunBaseCouples Δ I) := by
  unfold aubrunBaseCouples
  infer_instance

/-- Base-case defect-class encoding into the trivial innovation fiber. -/
noncomputable def aubrunBase_defectEncode
    (Δ : ℕ) (_hΔ : Δ ∈ Finset.range (2 * 0 + 1)) :
    WickPermutationDefectClass 0 Δ ↪ Sigma (aubrunBaseFiber Δ) :=
  {
    toFun := fun _ => ⟨Finset.univ, ⟨(), rfl⟩⟩
    inj' := by
      intro x y _hxy
      apply Subtype.ext
      apply Equiv.ext
      intro i
      have hx : x.1 i = 0 := by
        simpa using Fin.fin_one_eq_zero (x.1 i)
      have hy : y.1 i = 0 := by
        simpa using Fin.fin_one_eq_zero (y.1 i)
      rw [hx, hy]
  }

/-- Base-case fiber-to-compatible-couples encoding. -/
noncomputable def aubrunBase_encode
    (Δ : ℕ) (_hΔ : Δ ∈ Finset.range (2 * 0 + 1))
    (I : Finset (Fin (0 + 1))) :
    aubrunBaseFiber Δ I ↪ aubrunBaseCouples Δ I × aubrunBaseCouples Δ I :=
  {
    toFun := fun _ => ((), ())
    inj' := by
      intro x y _hxy
      apply Subtype.ext
      rfl
  }

/-- The base-case compatible-couple count satisfies Aubrun's left-couple
envelope. -/
theorem aubrunBase_leftCouples_bound :
    ∀ Δ ∈ Finset.range (2 * 0 + 1),
      ∀ I : Finset (Fin (0 + 1)),
        Fintype.card (aubrunBaseCouples Δ I) ≤
          (2 * (0 + 1)) ^ (9 * compatibilityDefect (0 + 1) I) := by
  intro Δ _hΔ I
  change 1 ≤ 2 ^ (9 * compatibilityDefect (0 + 1) I)
  exact Nat.one_le_pow (9 * compatibilityDefect (0 + 1) I) 2 (by norm_num)

/-- The base-case compatible-couple count satisfies Aubrun's right-couple
envelope. -/
theorem aubrunBase_rightCouples_bound :
    ∀ Δ ∈ Finset.range (2 * 0 + 1),
      ∀ I : Finset (Fin (0 + 1)),
        Fintype.card (aubrunBaseCouples Δ I) ≤
          (2 * (0 + 1)) ^ (9 * compatibilityDefect (0 + 1) I) :=
  aubrunBase_leftCouples_bound

/-- The base-case fiber satisfies Aubrun's large-innovation inequality. -/
theorem aubrunBase_largeInnovation_bound :
    ∀ Δ ∈ Finset.range (2 * 0 + 1),
      ∀ I : Finset (Fin (0 + 1)),
        Fintype.card (aubrunBaseFiber Δ I) ≠ 0 →
          (0 + 1) ≤ 2 * I.card + 2 * Δ := by
  intro Δ hΔ I hNonzero
  have hΔ0 : Δ = 0 := by
    have hlt : Δ < 1 := by
      simpa using Finset.mem_range.mp hΔ
    omega
  subst Δ
  by_cases hI : I = Finset.univ
  · subst I
    simp
  · exfalso
    apply hNonzero
    letI : IsEmpty (aubrunBaseFiber 0 I) := ⟨fun x => hI x.2⟩
    exact Fintype.card_eq_zero (α := aubrunBaseFiber 0 I)

/-- Real-valued version of the embedding-to-sigma fixed-defect count bridge,
with the right-hand side written as Aubrun's Proposition 7.3 envelope. -/
theorem wickPermutationDefectCount_real_le_fixedEnvelope_of_embedding_to_sigma
    {m Δ : ℕ}
    {Fiber LeftCouples RightCouples : Finset (Fin (m + 1)) → Type*}
    [∀ I, Fintype (Fiber I)]
    [∀ I, Fintype (LeftCouples I)]
    [∀ I, Fintype (RightCouples I)]
    (defectEncode :
      WickPermutationDefectClass m Δ ↪ Sigma Fiber)
    (encode :
      ∀ I : Finset (Fin (m + 1)),
        Fiber I ↪ LeftCouples I × RightCouples I)
    (hLeft :
      ∀ I : Finset (Fin (m + 1)),
        Fintype.card (LeftCouples I) ≤
          (2 * (m + 1)) ^ (9 * compatibilityDefect (m + 1) I))
    (hRight :
      ∀ I : Finset (Fin (m + 1)),
        Fintype.card (RightCouples I) ≤
          (2 * (m + 1)) ^ (9 * compatibilityDefect (m + 1) I))
    (hLarge :
      ∀ I : Finset (Fin (m + 1)),
        Fintype.card (Fiber I) ≠ 0 → (m + 1) ≤ 2 * I.card + 2 * Δ) :
    (wickPermutationDefectCount m Δ : ℝ) ≤
      aubrunFixedDefectCountEnvelope m Δ := by
  have hnat := wickPermutationDefectCount_le_of_embedding_to_sigma
    (m := m) (Δ := Δ) (Fiber := Fiber) (LeftCouples := LeftCouples)
    (RightCouples := RightCouples) defectEncode encode hLeft hRight hLarge
  calc
    (wickPermutationDefectCount m Δ : ℝ) ≤
        (2 ^ (m + 1) * (2 * (m + 1)) ^ (36 * Δ) : ℕ) := by
          exact_mod_cast hnat
    _ = aubrunFixedDefectCountEnvelope m Δ := by
          unfold aubrunFixedDefectCountEnvelope aubrunProposition73P
          norm_num
          rw [pow_mul]

/-- One-slice tight Aubrun innovation-fiber package.

This packages the actual data needed on a fixed defect slice: an encoding of
defect-`Δ` Wick permutations into innovation fibers, an injection from each
fiber to left/right compatible-couple data, the two couple-count estimates, and
the large-innovation inequality.  Constructing this package for every
`Δ ≤ 2m` is the current fiber branch of `U-AUB-02`. -/
structure TightAubrunInnovationFiberPackage (m Δ : ℕ) where
  Fiber : Finset (Fin (m + 1)) → Type
  LeftCouples : Finset (Fin (m + 1)) → Type
  RightCouples : Finset (Fin (m + 1)) → Type
  fiberFintype : ∀ I, Fintype (Fiber I)
  leftFintype : ∀ I, Fintype (LeftCouples I)
  rightFintype : ∀ I, Fintype (RightCouples I)
  defectEncode :
    WickPermutationDefectClass m Δ ↪ Sigma Fiber
  encode :
    ∀ I : Finset (Fin (m + 1)),
      Fiber I ↪ LeftCouples I × RightCouples I
  left_card_le :
    ∀ I : Finset (Fin (m + 1)),
      Fintype.card (LeftCouples I) ≤
        (2 * (m + 1)) ^ (9 * compatibilityDefect (m + 1) I)
  right_card_le :
    ∀ I : Finset (Fin (m + 1)),
      Fintype.card (RightCouples I) ≤
        (2 * (m + 1)) ^ (9 * compatibilityDefect (m + 1) I)
  large_innovation :
    ∀ I : Finset (Fin (m + 1)),
      Fintype.card (Fiber I) ≠ 0 → (m + 1) ≤ 2 * I.card + 2 * Δ

/-- A one-slice tight Aubrun innovation-fiber package implies the fixed-defect
count envelope for that slice. -/
theorem wickPermutationDefectCount_real_le_fixedEnvelope_of_tightFiberPackage
    {m Δ : ℕ} (pkg : TightAubrunInnovationFiberPackage m Δ) :
    (wickPermutationDefectCount m Δ : ℝ) ≤
      aubrunFixedDefectCountEnvelope m Δ := by
  letI : ∀ I, Fintype (pkg.Fiber I) := pkg.fiberFintype
  letI : ∀ I, Fintype (pkg.LeftCouples I) := pkg.leftFintype
  letI : ∀ I, Fintype (pkg.RightCouples I) := pkg.rightFintype
  exact
    wickPermutationDefectCount_real_le_fixedEnvelope_of_embedding_to_sigma
      (m := m) (Δ := Δ)
      (Fiber := pkg.Fiber)
      (LeftCouples := pkg.LeftCouples)
      (RightCouples := pkg.RightCouples)
      pkg.defectEncode pkg.encode pkg.left_card_le pkg.right_card_le
      pkg.large_innovation

/-- The base case of the tight-range fixed-defect count estimate, proved
through the same innovation-fiber bridge as the general Aubrun branch. -/
theorem wickPermutationDefectCount_zero_tightRange_le_fixedEnvelope_of_baseFiber :
    ∀ Δ ∈ Finset.range (2 * 0 + 1),
      (wickPermutationDefectCount 0 Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope 0 Δ := by
  intro Δ hΔ
  exact
    wickPermutationDefectCount_real_le_fixedEnvelope_of_embedding_to_sigma
      (m := 0) (Δ := Δ)
      (Fiber := aubrunBaseFiber Δ)
      (LeftCouples := aubrunBaseCouples Δ)
      (RightCouples := aubrunBaseCouples Δ)
      (aubrunBase_defectEncode Δ hΔ)
      (aubrunBase_encode Δ hΔ)
      (aubrunBase_leftCouples_bound Δ hΔ)
      (aubrunBase_rightCouples_bound Δ hΔ)
      (aubrunBase_largeInnovation_bound Δ hΔ)

/-- The base Wick length supplies the one-slice tight fiber package. -/
noncomputable def aubrunBase_tightFiberPackage
    (Δ : ℕ) (hΔ : Δ ∈ Finset.range (2 * 0 + 1)) :
    TightAubrunInnovationFiberPackage 0 Δ where
  Fiber := aubrunBaseFiber Δ
  LeftCouples := aubrunBaseCouples Δ
  RightCouples := aubrunBaseCouples Δ
  fiberFintype := aubrunBaseFiber_fintype Δ
  leftFintype := aubrunBaseCouples_fintype Δ
  rightFintype := aubrunBaseCouples_fintype Δ
  defectEncode := aubrunBase_defectEncode Δ hΔ
  encode := aubrunBase_encode Δ hΔ
  left_card_le := aubrunBase_leftCouples_bound Δ hΔ
  right_card_le := aubrunBase_rightCouples_bound Δ hΔ
  large_innovation := aubrunBase_largeInnovation_bound Δ hΔ

/-- Base-case count closure through the packaged tight fiber interface. -/
theorem wickPermutationDefectCount_zero_tightRange_le_fixedEnvelope_of_tightFiberPackage :
    ∀ Δ ∈ Finset.range (2 * 0 + 1),
      (wickPermutationDefectCount 0 Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope 0 Δ := by
  intro Δ hΔ
  exact
    wickPermutationDefectCount_real_le_fixedEnvelope_of_tightFiberPackage
      (aubrunBase_tightFiberPackage Δ hΔ)

/-- A tight-range family of one-slice innovation-fiber packages supplies the
fixed-defect count estimate on the whole tight range. -/
theorem wickPermutationDefectCount_tightRange_le_fixedEnvelope_of_tightFiberPackages
    {m : ℕ}
    (pkg : ∀ Δ ∈ Finset.range (2 * m + 1),
      TightAubrunInnovationFiberPackage m Δ) :
    ∀ Δ ∈ Finset.range (2 * m + 1),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ := by
  intro Δ hΔ
  exact wickPermutationDefectCount_real_le_fixedEnvelope_of_tightFiberPackage
    (pkg Δ hΔ)

/-- The graduate relation-counting input follows from Aubrun's fixed-defect
count envelope, a per-defect term envelope, and the resulting scalar sum. -/
theorem aubrunGraduateRelationCounting_of_prop73CountAndTermBounds
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ} {B : ℕ → ℝ}
    (hCount : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ)
    (hBnonneg : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3), 0 ≤ B Δ)
    (hTerm : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ π : Equiv.Perm (Fin (m + 1)), wickDefect π = Δ →
        d ^ (wickLeftClassCount π + wickRightClassCount π) *
          Real.sqrt s ^ (2 * wickColumnClassCount π) ≤ B Δ)
    (hEnvelope :
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        aubrunFixedDefectCountEnvelope m Δ * B Δ) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m :=
  aubrunGraduateRelationCounting_of_defectCountAndTermBounds
    (Q := Q) (d := d) (s := s) (m := m)
    (C := fun Δ => aubrunFixedDefectCountEnvelope m Δ) (B := B)
    hCount hBnonneg hTerm hEnvelope

/-- Crude analytic envelope for one Wick term, using only the elementary class
count bounds.

This is not the sharp Aubrun defect-sensitive term envelope, but it packages
the reusable monotonicity step: once the bases are at least one, the largest
possible exponents dominate every Wick term. -/
theorem wickAnalyticWeight_le_crude_max
    {m : ℕ} {d t : ℝ}
    (hd : 1 ≤ d) (ht : 1 ≤ t)
    (π : Equiv.Perm (Fin (m + 1))) :
    d ^ (wickLeftClassCount π + wickRightClassCount π) *
        t ^ (2 * wickColumnClassCount π) ≤
      d ^ (2 * (m + 1)) * t ^ (2 * (m + 1)) := by
  have hLR : wickLeftClassCount π + wickRightClassCount π ≤ 2 * (m + 1) := by
    have hL := wickLeftClassCount_le m π
    have hR := wickRightClassCount_le m π
    omega
  have hC : 2 * wickColumnClassCount π ≤ 2 * (m + 1) := by
    have hCol := wickColumnClassCount_le m π
    omega
  have hdPow :
      d ^ (wickLeftClassCount π + wickRightClassCount π) ≤
        d ^ (2 * (m + 1)) :=
    pow_le_pow_right₀ hd hLR
  have htPow :
      t ^ (2 * wickColumnClassCount π) ≤ t ^ (2 * (m + 1)) :=
    pow_le_pow_right₀ ht hC
  exact mul_le_mul hdPow htPow (pow_nonneg (le_trans zero_le_one ht) _)
    (pow_nonneg (le_trans zero_le_one hd) _)

/-- Crude per-defect term envelope obtained from the class-count bounds. -/
theorem wickDefectSlice_term_bound_crude_max
    {m : ℕ} {d s : ℝ}
    (hd : 1 ≤ d) (hsqrt : 1 ≤ Real.sqrt s) :
    ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ π : Equiv.Perm (Fin (m + 1)), wickDefect π = Δ →
        d ^ (wickLeftClassCount π + wickRightClassCount π) *
          Real.sqrt s ^ (2 * wickColumnClassCount π) ≤
            d ^ (2 * (m + 1)) * Real.sqrt s ^ (2 * (m + 1)) := by
  intro Δ hΔ π hπ
  exact wickAnalyticWeight_le_crude_max (m := m) (d := d)
    (t := Real.sqrt s) hd hsqrt π

/-- Prop 7.3 count envelope plus the crude maximum-exponent term envelope
reduces the graduate relation-counting input to one scalar sum.

This is a deliberately crude specialization: the sharp Aubrun route should use
a defect-sensitive term envelope, but this wrapper removes the elementary term
plumbing when the crude envelope is sufficient for diagnostics. -/
theorem aubrunGraduateRelationCounting_of_prop73CountAndCrudeTermEnvelope
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ}
    (hd : 1 ≤ d) (hsqrt : 1 ≤ Real.sqrt s)
    (hCount : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ)
    (hEnvelope :
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        aubrunFixedDefectCountEnvelope m Δ *
          (d ^ (2 * (m + 1)) * Real.sqrt s ^ (2 * (m + 1)))) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  apply aubrunGraduateRelationCounting_of_prop73CountAndTermBounds
    (B := fun _Δ => d ^ (2 * (m + 1)) * Real.sqrt s ^ (2 * (m + 1)))
  · exact hCount
  · intro Δ hΔ
    exact mul_nonneg (pow_nonneg (le_trans zero_le_one hd) _)
      (pow_nonneg (le_trans zero_le_one hsqrt) _)
  · exact wickDefectSlice_term_bound_crude_max (m := m) (d := d) (s := s)
      hd hsqrt
  · exact hEnvelope

/-- The crude-term scalar sum factors because the crude term envelope is
independent of the defect parameter. -/
theorem aubrunFixedDefectCountEnvelope_sum_mul_const (m : ℕ) (K : ℝ) :
    Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
      aubrunFixedDefectCountEnvelope m Δ * K) =
    (Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
      aubrunFixedDefectCountEnvelope m Δ)) * K := by
  simp [Finset.sum_mul]

/-- Factored version of
`aubrunGraduateRelationCounting_of_prop73CountAndCrudeTermEnvelope`. -/
theorem aubrunGraduateRelationCounting_of_prop73CountAndCrudeTermEnvelope_factored
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ}
    (hd : 1 ≤ d) (hsqrt : 1 ≤ Real.sqrt s)
    (hCount : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ)
    (hEnvelope :
      (Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        aubrunFixedDefectCountEnvelope m Δ)) *
          (d ^ (2 * (m + 1)) * Real.sqrt s ^ (2 * (m + 1))) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  apply aubrunGraduateRelationCounting_of_prop73CountAndCrudeTermEnvelope
    (hd := hd) (hsqrt := hsqrt) (hCount := hCount)
  simpa [aubrunFixedDefectCountEnvelope_sum_mul_const] using hEnvelope

/-- Aubrun's Proposition 7.3 polynomial envelope is at least one for every
positive moment parameter. -/
theorem aubrunProposition73P_one_le (k : ℕ) (hk : 1 ≤ k) :
    1 ≤ aubrunProposition73P k := by
  unfold aubrunProposition73P
  have hbaseNat : 1 ≤ 2 * k := by omega
  have hbase : (1 : ℝ) ≤ (2 * k : ℝ) := by exact_mod_cast hbaseNat
  simpa using (one_le_pow₀ hbase : (1 : ℝ) ≤ (2 * k : ℝ) ^ 36)

/-- Each fixed-defect count envelope is bounded by the last envelope in the
finite defect range. -/
theorem aubrunFixedDefectCountEnvelope_le_last {m Δ : ℕ}
    (hΔ : Δ ∈ Finset.range (2 * (m + 1) + 3)) :
    aubrunFixedDefectCountEnvelope m Δ ≤
      (2 : ℝ) ^ (m + 1) *
        aubrunProposition73P (m + 1) ^ (2 * (m + 1) + 2) := by
  have hP : 1 ≤ aubrunProposition73P (m + 1) :=
    aubrunProposition73P_one_le (m + 1) (Nat.succ_le_succ (Nat.zero_le m))
  have hΔle : Δ ≤ 2 * (m + 1) + 2 := by
    exact Nat.lt_succ_iff.mp (Finset.mem_range.mp hΔ)
  unfold aubrunFixedDefectCountEnvelope
  exact mul_le_mul_of_nonneg_left (pow_le_pow_right₀ hP hΔle) (by positivity)

/-- The finite sum of fixed-defect count envelopes is bounded by the number of
defect values times the last envelope in the range. -/
theorem aubrunFixedDefectCountEnvelope_sum_le_card_mul_last (m : ℕ) :
    Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
      aubrunFixedDefectCountEnvelope m Δ) ≤
    (2 * (m + 1) + 3 : ℝ) *
      ((2 : ℝ) ^ (m + 1) *
        aubrunProposition73P (m + 1) ^ (2 * (m + 1) + 2)) := by
  have hsum :=
    Finset.sum_le_card_nsmul
      (s := Finset.range (2 * (m + 1) + 3))
      (f := fun Δ => aubrunFixedDefectCountEnvelope m Δ)
      (n := (2 : ℝ) ^ (m + 1) *
        aubrunProposition73P (m + 1) ^ (2 * (m + 1) + 2))
      (by
        intro Δ hΔ
        exact aubrunFixedDefectCountEnvelope_le_last (m := m) hΔ)
  simpa [nsmul_eq_mul] using hsum

/-- On actual defect support, the fixed-defect envelope is bounded by the
tighter top exponent `2m`, using `Δ ≤ 2m`. -/
theorem aubrunFixedDefectCountEnvelope_le_supportLast {m Δ : ℕ}
    (hΔ : Δ ∈ wickDefectSupport m) :
    aubrunFixedDefectCountEnvelope m Δ ≤
      (2 : ℝ) ^ (m + 1) *
        aubrunProposition73P (m + 1) ^ (2 * m) := by
  have hP : 1 ≤ aubrunProposition73P (m + 1) :=
    aubrunProposition73P_one_le (m + 1) (Nat.succ_le_succ (Nat.zero_le m))
  have hΔle : Δ ≤ 2 * m := by
    exact Nat.lt_succ_iff.mp
      (Finset.mem_range.mp (wickDefectSupport_subset_tightRange m hΔ))
  unfold aubrunFixedDefectCountEnvelope
  exact mul_le_mul_of_nonneg_left (pow_le_pow_right₀ hP hΔle) (by positivity)

/-- The actual-support sum of fixed-defect envelopes uses both fewer defect
values and the tighter top exponent `2m`. -/
theorem aubrunFixedDefectCountEnvelope_support_sum_le_card_mul_tightLast
    (m : ℕ) :
    Finset.sum (wickDefectSupport m) (fun Δ =>
      aubrunFixedDefectCountEnvelope m Δ) ≤
    (2 * m + 1 : ℝ) *
      ((2 : ℝ) ^ (m + 1) *
        aubrunProposition73P (m + 1) ^ (2 * m)) := by
  have hsum :=
    Finset.sum_le_card_nsmul
      (s := wickDefectSupport m)
      (f := fun Δ => aubrunFixedDefectCountEnvelope m Δ)
      (n := (2 : ℝ) ^ (m + 1) *
        aubrunProposition73P (m + 1) ^ (2 * m))
      (by
        intro Δ hΔ
        exact aubrunFixedDefectCountEnvelope_le_supportLast (m := m) hΔ)
  have hcardNat : (wickDefectSupport m).card ≤ 2 * m + 1 := by
    calc
      (wickDefectSupport m).card ≤ (Finset.range (2 * m + 1)).card :=
        Finset.card_le_card (wickDefectSupport_subset_tightRange m)
      _ = 2 * m + 1 := by simp
  have hlast_nonneg :
      0 ≤ (2 : ℝ) ^ (m + 1) *
        aubrunProposition73P (m + 1) ^ (2 * m) :=
    mul_nonneg (by positivity)
      (pow_nonneg (aubrunProposition73P_nonneg (m + 1)) _)
  calc
    Finset.sum (wickDefectSupport m) (fun Δ =>
        aubrunFixedDefectCountEnvelope m Δ) ≤
      ((wickDefectSupport m).card : ℝ) *
        ((2 : ℝ) ^ (m + 1) *
          aubrunProposition73P (m + 1) ^ (2 * m)) := by
          simpa [nsmul_eq_mul] using hsum
    _ ≤ (2 * m + 1 : ℝ) *
        ((2 : ℝ) ^ (m + 1) *
          aubrunProposition73P (m + 1) ^ (2 * m)) := by
            exact mul_le_mul_of_nonneg_right (by exact_mod_cast hcardNat)
              hlast_nonneg

/-- If the common analytic base dominates Aubrun's fixed-defect polynomial, then
each support-restricted count term loses no extra top-defect polynomial factor:
`P^Δ D^(N-Δ) ≤ D^N`. -/
theorem aubrunFixedDefectCountEnvelope_mul_commonBasePower_le_two_mul_commonBase
    {m Δ : ℕ} {D : ℝ} (hD : 1 ≤ D)
    (hP_D : aubrunProposition73P (m + 1) ≤ D)
    (hΔ : Δ ∈ wickDefectSupport m) :
    aubrunFixedDefectCountEnvelope m Δ *
        D ^ (2 * (m + 1) + 2 - Δ) ≤
      (2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2) := by
  have hD0 : 0 ≤ D := le_trans zero_le_one hD
  have hP0 : 0 ≤ aubrunProposition73P (m + 1) :=
    aubrunProposition73P_nonneg (m + 1)
  have hΔle : Δ ≤ 2 * (m + 1) + 2 := by
    have hΔle_tight : Δ ≤ 2 * m := by
      exact Nat.lt_succ_iff.mp
        (Finset.mem_range.mp (wickDefectSupport_subset_tightRange m hΔ))
    omega
  have hPpow :
      aubrunProposition73P (m + 1) ^ Δ ≤ D ^ Δ :=
    pow_le_pow_left₀ hP0 hP_D Δ
  have hmul :
      aubrunProposition73P (m + 1) ^ Δ *
          D ^ (2 * (m + 1) + 2 - Δ) ≤
        D ^ Δ * D ^ (2 * (m + 1) + 2 - Δ) :=
    mul_le_mul_of_nonneg_right hPpow
      (pow_nonneg hD0 _)
  calc
    aubrunFixedDefectCountEnvelope m Δ *
        D ^ (2 * (m + 1) + 2 - Δ)
        = (2 : ℝ) ^ (m + 1) *
            (aubrunProposition73P (m + 1) ^ Δ *
              D ^ (2 * (m + 1) + 2 - Δ)) := by
            simp [aubrunFixedDefectCountEnvelope, mul_assoc]
    _ ≤ (2 : ℝ) ^ (m + 1) *
          (D ^ Δ * D ^ (2 * (m + 1) + 2 - Δ)) := by
          exact mul_le_mul_of_nonneg_left hmul (by positivity)
    _ = (2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2) := by
          have hExp : Δ + (2 * (m + 1) + 2 - Δ) = 2 * (m + 1) + 2 :=
            Nat.add_sub_of_le hΔle
          rw [← pow_add, hExp]

/-- Support-restricted defect sum with the polynomial factor absorbed into the
common base `D`. -/
theorem aubrunFixedDefectCountEnvelope_support_sum_mul_commonBasePower_le_card_mul_commonBase
    (m : ℕ) {D : ℝ} (hD : 1 ≤ D)
    (hP_D : aubrunProposition73P (m + 1) ≤ D) :
    Finset.sum (wickDefectSupport m) (fun Δ =>
      aubrunFixedDefectCountEnvelope m Δ *
        D ^ (2 * (m + 1) + 2 - Δ)) ≤
    (2 * m + 1 : ℝ) *
      ((2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2)) := by
  have hsum :=
    Finset.sum_le_card_nsmul
      (s := wickDefectSupport m)
      (f := fun Δ =>
        aubrunFixedDefectCountEnvelope m Δ *
          D ^ (2 * (m + 1) + 2 - Δ))
      (n := (2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2))
      (by
        intro Δ hΔ
        exact
          aubrunFixedDefectCountEnvelope_mul_commonBasePower_le_two_mul_commonBase
            (m := m) (D := D) hD hP_D hΔ)
  have hcardNat : (wickDefectSupport m).card ≤ 2 * m + 1 := by
    calc
      (wickDefectSupport m).card ≤ (Finset.range (2 * m + 1)).card :=
        Finset.card_le_card (wickDefectSupport_subset_tightRange m)
      _ = 2 * m + 1 := by simp
  have hlast_nonneg :
      0 ≤ (2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2) :=
    mul_nonneg (by positivity)
      (pow_nonneg (le_trans zero_le_one hD) _)
  calc
    Finset.sum (wickDefectSupport m) (fun Δ =>
        aubrunFixedDefectCountEnvelope m Δ *
          D ^ (2 * (m + 1) + 2 - Δ)) ≤
      ((wickDefectSupport m).card : ℝ) *
        ((2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2)) := by
          simpa [nsmul_eq_mul] using hsum
    _ ≤ (2 * m + 1 : ℝ) *
        ((2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2)) := by
          exact mul_le_mul_of_nonneg_right (by exact_mod_cast hcardNat)
            hlast_nonneg

/-- The support-restricted finite ratio sum
`Σ_{Δ∈support} ρ^Δ`.  This keeps the defect decay visible instead of replacing
it by the cardinality of the support. -/
noncomputable def aubrunDefectRatioSupportSum (m : ℕ) (ρ : ℝ) : ℝ :=
  Finset.sum (wickDefectSupport m) (fun Δ => ρ ^ Δ)

/-- The support ratio sum is bounded by the full geometric tail over the tight
support range. -/
theorem aubrunDefectRatioSupportSum_le_range_sum
    (m : ℕ) {ρ : ℝ} (hρ0 : 0 ≤ ρ) :
    aubrunDefectRatioSupportSum m ρ ≤
      Finset.sum (Finset.range (2 * m + 1)) (fun Δ => ρ ^ Δ) := by
  unfold aubrunDefectRatioSupportSum
  exact
    Finset.sum_le_sum_of_subset_of_nonneg
      (wickDefectSupport_subset_tightRange m)
      (by
        intro Δ hΔrange hΔsupport
        exact pow_nonneg hρ0 Δ)

/-- Finite geometric prefix with the zero term isolated.

For `0≤ρ≤1`, all positive powers are bounded by `ρ`, so
`1 + ρ + ... + ρ^N ≤ 1 + Nρ`. -/
theorem finiteGeometric_range_sum_le_one_add_nat_mul
    (N : ℕ) {ρ : ℝ} (hρ0 : 0 ≤ ρ) (hρ1 : ρ ≤ 1) :
    Finset.sum (Finset.range (N + 1)) (fun Δ => ρ ^ Δ) ≤
      1 + (N : ℝ) * ρ := by
  rw [Finset.sum_range_succ']
  have hterm : ∀ k ∈ Finset.range N, ρ ^ (k + 1) ≤ ρ := by
    intro k hk
    rw [pow_succ]
    calc
      ρ ^ k * ρ ≤ 1 * ρ := by
        exact mul_le_mul_of_nonneg_right (pow_le_one₀ hρ0 hρ1) hρ0
      _ = ρ := by ring
  have hsum :
      Finset.sum (Finset.range N) (fun k => ρ ^ (k + 1)) ≤
        Finset.sum (Finset.range N) (fun _k => ρ) :=
    Finset.sum_le_sum hterm
  calc
    Finset.sum (Finset.range N) (fun k => ρ ^ (k + 1)) + ρ ^ 0
        = Finset.sum (Finset.range N) (fun k => ρ ^ (k + 1)) + 1 := by
          simp
    _ ≤ Finset.sum (Finset.range N) (fun _k => ρ) + 1 := by
          simpa [add_comm] using add_le_add_right hsum 1
    _ = 1 + (N : ℝ) * ρ := by
          simp [Finset.sum_const, nsmul_eq_mul]
          ring

/-- Variable-ratio support-sum bound.

This keeps the finite support size visible and is useful when the ratio itself
depends on `d` and tends to zero: the support sum is then bounded by
`1 + 2mρ`, rather than by a fixed infinite-geometric constant. -/
theorem aubrunDefectRatioSupportSum_le_one_add_two_mul
    (m : ℕ) {ρ : ℝ} (hρ0 : 0 ≤ ρ) (hρ1 : ρ ≤ 1) :
    aubrunDefectRatioSupportSum m ρ ≤ 1 + (2 * m : ℝ) * ρ := by
  calc
    aubrunDefectRatioSupportSum m ρ ≤
        Finset.sum (Finset.range (2 * m + 1)) (fun Δ => ρ ^ Δ) :=
      aubrunDefectRatioSupportSum_le_range_sum m hρ0
    _ ≤ 1 + (2 * m : ℝ) * ρ := by
      simpa [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm] using
        finiteGeometric_range_sum_le_one_add_nat_mul (2 * m) hρ0 hρ1

/-- If `0 ≤ ρ < 1`, the support ratio sum is bounded by the infinite geometric
series constant `(1-ρ)⁻¹`. -/
theorem aubrunDefectRatioSupportSum_le_inv_one_sub
    (m : ℕ) {ρ : ℝ} (hρ0 : 0 ≤ ρ) (hρ1 : ρ < 1) :
    aubrunDefectRatioSupportSum m ρ ≤ (1 - ρ)⁻¹ := by
  have hρne : ρ ≠ 1 := ne_of_lt hρ1
  have hden_pos : 0 < 1 - ρ := sub_pos.mpr hρ1
  have hpow_nonneg : 0 ≤ ρ ^ (2 * m + 1) := pow_nonneg hρ0 _
  have hpow_le_one : ρ ^ (2 * m + 1) ≤ 1 :=
    pow_le_one₀ hρ0 hρ1.le
  have hgeom :
      Finset.sum (Finset.range (2 * m + 1)) (fun Δ => ρ ^ Δ) =
        (1 - ρ ^ (2 * m + 1)) / (1 - ρ) := by
    have h := geom_sum_Ico' (x := ρ) hρne (m := 0) (n := 2 * m + 1) (Nat.zero_le _)
    simpa using h
  have hfinite_le :
      Finset.sum (Finset.range (2 * m + 1)) (fun Δ => ρ ^ Δ) ≤
        (1 - ρ)⁻¹ := by
    rw [hgeom]
    rw [div_eq_mul_inv]
    have hinv_nonneg : 0 ≤ (1 - ρ)⁻¹ := inv_nonneg.mpr hden_pos.le
    have hnum_le : 1 - ρ ^ (2 * m + 1) ≤ 1 := by linarith
    calc
      (1 - ρ ^ (2 * m + 1)) * (1 - ρ)⁻¹ ≤
          1 * (1 - ρ)⁻¹ :=
        mul_le_mul_of_nonneg_right hnum_le hinv_nonneg
      _ = (1 - ρ)⁻¹ := by ring
  exact le_trans (aubrunDefectRatioSupportSum_le_range_sum m hρ0) hfinite_le

/-- A scalar envelope helper for the geometric-ratio endpoint.

The whole factor `(1-ρ)⁻¹` can be paid by two powers of the first analytic
base.  The remaining `k` powers are supplied by the two base comparisons
`D≤A` and `D≤B`. -/
theorem geometricRatio_commonBaseEnvelope_of_quadraticGain
    {k : ℕ} {c D A B : ℝ}
    (hc0 : 0 ≤ c) (hD0 : 0 ≤ D) (hDA : D ≤ A) (hDB : D ≤ B)
    (hQuad : c * D ^ 2 ≤ A ^ 2) :
    c * D ^ (2 * k + 2) ≤ A ^ (k + 2) * B ^ k := by
  have hA0 : 0 ≤ A := le_trans hD0 hDA
  have hB0 : 0 ≤ B := le_trans hD0 hDB
  have hDkA : D ^ k ≤ A ^ k := pow_le_pow_left₀ hD0 hDA k
  have hDkB : D ^ k ≤ B ^ k := pow_le_pow_left₀ hD0 hDB k
  have hFirst :
      (c * D ^ 2) * D ^ k ≤ A ^ 2 * A ^ k := by
    exact mul_le_mul hQuad hDkA (pow_nonneg hD0 k) (sq_nonneg A)
  have hFirstNonneg : 0 ≤ (c * D ^ 2) * D ^ k := by
    exact mul_nonneg (mul_nonneg hc0 (pow_nonneg hD0 2)) (pow_nonneg hD0 k)
  have hTargetNonneg : 0 ≤ A ^ 2 * A ^ k := by
    exact mul_nonneg (pow_nonneg hA0 2) (pow_nonneg hA0 k)
  have hAll :
      ((c * D ^ 2) * D ^ k) * D ^ k ≤
        (A ^ 2 * A ^ k) * B ^ k := by
    exact mul_le_mul hFirst hDkB (pow_nonneg hD0 k) hTargetNonneg
  calc
    c * D ^ (2 * k + 2)
        = ((c * D ^ 2) * D ^ k) * D ^ k := by
            have hExp : 2 * k + 2 = 2 + k + k := by omega
            rw [hExp, pow_add, pow_add]
            ring
    _ ≤ (A ^ 2 * A ^ k) * B ^ k := hAll
    _ = A ^ (k + 2) * B ^ k := by
          rw [← pow_add]
          ring_nf

/-- The geometric-ratio scalar leaf follows from one quadratic gain condition
on the first Aubrun base. -/
theorem aubrun_geometricRatio_scalarEnvelope_of_quadraticGain
    {m : ℕ} {ρ D d s Q : ℝ}
    (hρ1 : ρ < 1)
    (hD0 : 0 ≤ D)
    (hdD : D ≤ d + Q) (hsqrtD : D ≤ Real.sqrt s + Q)
    (hQuad : (1 - ρ)⁻¹ * D ^ 2 ≤ (d + Q) ^ 2) :
    (1 - ρ)⁻¹ * D ^ (2 * (m + 1) + 2) ≤
      (d + Q) ^ (m + 3) * (Real.sqrt s + Q) ^ (m + 1) := by
  have hc0 : 0 ≤ (1 - ρ)⁻¹ := by
    exact inv_nonneg.mpr (sub_nonneg.mpr hρ1.le)
  simpa [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm] using
    geometricRatio_commonBaseEnvelope_of_quadraticGain
      (k := m + 1) (c := (1 - ρ)⁻¹) (D := D)
      (A := d + Q) (B := Real.sqrt s + Q)
      hc0 hD0 hdD hsqrtD hQuad

/-- The two cross-base comparisons used by the max-base route force the two
analytic bases to be close. -/
theorem crossBaseComparisons_imply_abs_sub_le
    {a b Q : ℝ} (hba : b ≤ a + Q) (hab : a ≤ b + Q) :
    |a - b| ≤ Q := by
  rw [abs_sub_le_iff]
  constructor <;> linarith

/-- Contrapositive diagnostic: if the two bases differ by more than `Q`, the
max-base cross comparisons cannot both hold. -/
theorem crossBaseComparisons_impossible_of_abs_gt
    {a b Q : ℝ} (hba : b ≤ a + Q) (hab : a ≤ b + Q)
    (hgap : Q < |a - b|) : False :=
  not_lt_of_ge (crossBaseComparisons_imply_abs_sub_le hba hab) hgap

/-- Support-restricted defect sum with a genuine ratio loss.

If `P(k) ≤ ρD`, then the fixed-defect factor contributes `(P/D)^Δ` and the
whole support sum is bounded by the finite ratio sum
`Σ_{Δ∈support} ρ^Δ` times the common base.  This is the defect-sensitive scalar
shape left after the coarse common-base routes are ruled out. -/
theorem aubrunFixedDefectCountEnvelope_support_sum_mul_commonBasePower_le_ratioSum_commonBase
    (m : ℕ) {D ρ : ℝ} (hD0 : 0 ≤ D) (hρ0 : 0 ≤ ρ)
    (hP_ρD : aubrunProposition73P (m + 1) ≤ ρ * D) :
    Finset.sum (wickDefectSupport m) (fun Δ =>
      aubrunFixedDefectCountEnvelope m Δ *
        D ^ (2 * (m + 1) + 2 - Δ)) ≤
    ((2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2)) *
      aubrunDefectRatioSupportSum m ρ := by
  have hρD0 : 0 ≤ ρ * D := mul_nonneg hρ0 hD0
  have hP0 : 0 ≤ aubrunProposition73P (m + 1) :=
    aubrunProposition73P_nonneg (m + 1)
  have hterm :
      ∀ Δ ∈ wickDefectSupport m,
        aubrunFixedDefectCountEnvelope m Δ *
            D ^ (2 * (m + 1) + 2 - Δ) ≤
          ((2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2)) *
            ρ ^ Δ := by
    intro Δ hΔ
    have hΔle : Δ ≤ 2 * (m + 1) + 2 := by
      have hΔle_tight : Δ ≤ 2 * m := by
        exact Nat.lt_succ_iff.mp
          (Finset.mem_range.mp (wickDefectSupport_subset_tightRange m hΔ))
      omega
    have hPpow :
        aubrunProposition73P (m + 1) ^ Δ ≤ (ρ * D) ^ Δ :=
      pow_le_pow_left₀ hP0 hP_ρD Δ
    have hsplit :
        (ρ * D) ^ Δ * D ^ (2 * (m + 1) + 2 - Δ) =
          ρ ^ Δ * D ^ (2 * (m + 1) + 2) := by
      calc
        (ρ * D) ^ Δ * D ^ (2 * (m + 1) + 2 - Δ)
            = (ρ ^ Δ * D ^ Δ) *
                D ^ (2 * (m + 1) + 2 - Δ) := by
                rw [mul_pow]
        _ = ρ ^ Δ *
              (D ^ Δ * D ^ (2 * (m + 1) + 2 - Δ)) := by ring
        _ = ρ ^ Δ * D ^ (2 * (m + 1) + 2) := by
              have hExp : Δ + (2 * (m + 1) + 2 - Δ) =
                  2 * (m + 1) + 2 := Nat.add_sub_of_le hΔle
              rw [← pow_add, hExp]
    calc
      aubrunFixedDefectCountEnvelope m Δ *
          D ^ (2 * (m + 1) + 2 - Δ)
          = (2 : ℝ) ^ (m + 1) *
              (aubrunProposition73P (m + 1) ^ Δ *
                D ^ (2 * (m + 1) + 2 - Δ)) := by
              simp [aubrunFixedDefectCountEnvelope, mul_assoc]
      _ ≤ (2 : ℝ) ^ (m + 1) *
            ((ρ * D) ^ Δ *
              D ^ (2 * (m + 1) + 2 - Δ)) := by
            exact mul_le_mul_of_nonneg_left
              (mul_le_mul_of_nonneg_right hPpow (pow_nonneg hD0 _))
              (by positivity)
      _ = ((2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2)) *
            ρ ^ Δ := by
            rw [hsplit]
            ring
  calc
    Finset.sum (wickDefectSupport m) (fun Δ =>
        aubrunFixedDefectCountEnvelope m Δ *
          D ^ (2 * (m + 1) + 2 - Δ)) ≤
      Finset.sum (wickDefectSupport m) (fun Δ =>
        ((2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2)) *
          ρ ^ Δ) := by
        exact Finset.sum_le_sum hterm
    _ = ((2 : ℝ) ^ (m + 1) * D ^ (2 * (m + 1) + 2)) *
        aubrunDefectRatioSupportSum m ρ := by
        simp [aubrunDefectRatioSupportSum, Finset.mul_sum]

/-- Last-envelope version of the crude Prop 7.3 route. -/
theorem aubrunGraduateRelationCounting_of_prop73CountAndCrudeTermEnvelope_last
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ}
    (hd : 1 ≤ d) (hsqrt : 1 ≤ Real.sqrt s)
    (hCount : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ)
    (hEnvelope :
      ((2 * (m + 1) + 3 : ℝ) *
        ((2 : ℝ) ^ (m + 1) *
          aubrunProposition73P (m + 1) ^ (2 * (m + 1) + 2))) *
          (d ^ (2 * (m + 1)) * Real.sqrt s ^ (2 * (m + 1))) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  apply aubrunGraduateRelationCounting_of_prop73CountAndCrudeTermEnvelope_factored
    (hd := hd) (hsqrt := hsqrt) (hCount := hCount)
  have hsum := aubrunFixedDefectCountEnvelope_sum_le_card_mul_last m
  have hterm_nonneg : 0 ≤ d ^ (2 * (m + 1)) *
      Real.sqrt s ^ (2 * (m + 1)) :=
    mul_nonneg (pow_nonneg (le_trans zero_le_one hd) _)
      (pow_nonneg (le_trans zero_le_one hsqrt) _)
  exact le_trans (mul_le_mul_of_nonneg_right hsum hterm_nonneg) hEnvelope

/-- Last-envelope crude route with the fixed-defect count supplied by Aubrun's
innovation-fiber data for each defect value. -/
theorem aubrunGraduateRelationCounting_of_prop73FiberDataAndCrudeTermEnvelope_last
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ}
    {Fiber LeftCouples RightCouples : ℕ → Finset (Fin (m + 1)) → Type*}
    [∀ Δ I, Fintype (Fiber Δ I)]
    [∀ Δ I, Fintype (LeftCouples Δ I)]
    [∀ Δ I, Fintype (RightCouples Δ I)]
    (hd : 1 ≤ d) (hsqrt : 1 ≤ Real.sqrt s)
    (defectEncode : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      WickPermutationDefectClass m Δ ↪ Sigma (Fiber Δ))
    (encode : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ I : Finset (Fin (m + 1)),
        Fiber Δ I ↪ LeftCouples Δ I × RightCouples Δ I)
    (hLeft : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ I : Finset (Fin (m + 1)),
        Fintype.card (LeftCouples Δ I) ≤
          (2 * (m + 1)) ^ (9 * compatibilityDefect (m + 1) I))
    (hRight : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ I : Finset (Fin (m + 1)),
        Fintype.card (RightCouples Δ I) ≤
          (2 * (m + 1)) ^ (9 * compatibilityDefect (m + 1) I))
    (hLarge : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ I : Finset (Fin (m + 1)),
        Fintype.card (Fiber Δ I) ≠ 0 → (m + 1) ≤ 2 * I.card + 2 * Δ)
    (hEnvelope :
      ((2 * (m + 1) + 3 : ℝ) *
        ((2 : ℝ) ^ (m + 1) *
          aubrunProposition73P (m + 1) ^ (2 * (m + 1) + 2))) *
          (d ^ (2 * (m + 1)) * Real.sqrt s ^ (2 * (m + 1))) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  apply aubrunGraduateRelationCounting_of_prop73CountAndCrudeTermEnvelope_last
    (hd := hd) (hsqrt := hsqrt)
  · intro Δ hΔ
    exact wickPermutationDefectCount_real_le_fixedEnvelope_of_embedding_to_sigma
      (m := m) (Δ := Δ) (Fiber := Fiber Δ)
      (LeftCouples := LeftCouples Δ) (RightCouples := RightCouples Δ)
      (defectEncode Δ hΔ) (encode Δ hΔ) (hLeft Δ hΔ)
      (hRight Δ hΔ) (hLarge Δ hΔ)
  · exact hEnvelope

/-- Degree obstruction for the crude last-envelope scalar route in the first
nontrivial Wick length (`m = 1`, so `k = 2`).

This diagnostic lemma isolates why the crude maximum-exponent envelope cannot
serve as a final Aubrun closure mechanism at large scale: after setting the two
analytic bases equal to a large value `D`, the crude left side has degree eight
in `D`, while the target envelope has degree six. -/
theorem crudeLastEnvelope_degree_obstruction_m_one
    {C D Q : ℝ} (hD : 1 ≤ D) (hQ : 0 ≤ Q) (hQle : Q ≤ D)
    (hBig : 256 < C * D ^ 2) :
    ¬ C * (D ^ 4 * D ^ 4) ≤ 4 * (D + Q) ^ 4 * (D + Q) ^ 2 := by
  intro h
  have hDnonneg : 0 ≤ D := le_trans zero_le_one hD
  have hDpos : 0 < D := lt_of_lt_of_le zero_lt_one hD
  have hsum_nonneg : 0 ≤ D + Q := add_nonneg hDnonneg hQ
  have hsum_le : D + Q ≤ 2 * D := by nlinarith
  have hpow4 : (D + Q) ^ 4 ≤ (2 * D) ^ 4 :=
    pow_le_pow_left₀ hsum_nonneg hsum_le 4
  have hpow2 : (D + Q) ^ 2 ≤ (2 * D) ^ 2 :=
    pow_le_pow_left₀ hsum_nonneg hsum_le 2
  have hprod :
      (D + Q) ^ 4 * (D + Q) ^ 2 ≤ (2 * D) ^ 4 * (2 * D) ^ 2 := by
    exact mul_le_mul hpow4 hpow2 (pow_nonneg hsum_nonneg 2)
      (pow_nonneg (mul_nonneg (by norm_num) hDnonneg) 4)
  have hscaled :
      4 * ((D + Q) ^ 4 * (D + Q) ^ 2) ≤
        4 * ((2 * D) ^ 4 * (2 * D) ^ 2) :=
    mul_le_mul_of_nonneg_left hprod (by norm_num)
  have hle : C * (D ^ 4 * D ^ 4) ≤
      4 * ((2 * D) ^ 4 * (2 * D) ^ 2) := by
    nlinarith
  have hle' : (C * D ^ 2) * D ^ 6 ≤ 256 * D ^ 6 := by
    convert hle using 1 <;> ring
  have hD6pos : 0 < D ^ 6 := pow_pos hDpos 6
  have hsmall : C * D ^ 2 ≤ 256 := le_of_mul_le_mul_right hle' hD6pos
  exact not_lt_of_ge hsmall hBig

/-- With a common analytic base, the Wick term exponent is exactly Aubrun's
weighted rank. -/
theorem wickAnalyticWeight_commonBase_eq_weightedRank
    {m : ℕ} (D : ℝ) (π : Equiv.Perm (Fin (m + 1))) :
    D ^ (wickLeftClassCount π + wickRightClassCount π) *
        D ^ (2 * wickColumnClassCount π) =
      D ^ wickWeightedRank π := by
  rw [← pow_add]
  rfl

/-- If the weighted rank is within Aubrun's budget, the truncated defect
recovers the missing exponent exactly. -/
theorem wickWeightedRank_eq_budget_sub_defect_of_le
    {m Δ : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hRank : wickWeightedRank π ≤ 2 * (m + 1) + 2)
    (hΔ : wickDefect π = Δ) :
    wickWeightedRank π = 2 * (m + 1) + 2 - Δ := by
  unfold wickDefect at hΔ
  omega

/-- Closed version of the rank/defect exponent identity, using the Cayley
rank budget already proved for every Wick permutation. -/
theorem wickWeightedRank_eq_budget_sub_defect
    {m Δ : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hΔ : wickDefect π = Δ) :
    wickWeightedRank π = 2 * (m + 1) + 2 - Δ :=
  wickWeightedRank_eq_budget_sub_defect_of_le
    (m := m) (Δ := Δ) (π := π) (wickWeightedRank_le_two_mul_add_two π) hΔ

/-- Defect-sensitive common-base form of the Wick analytic term.

This is the algebraic replacement for the crude maximum-exponent envelope:
once the remaining rank-budget estimate is supplied, a defect-`Δ` term carries
only the exponent `2k+2-Δ` in the common analytic base. -/
theorem wickAnalyticWeight_commonBase_eq_defectPower
    {m Δ : ℕ} {D : ℝ} {π : Equiv.Perm (Fin (m + 1))}
    (hRank : wickWeightedRank π ≤ 2 * (m + 1) + 2)
    (hΔ : wickDefect π = Δ) :
    D ^ (wickLeftClassCount π + wickRightClassCount π) *
        D ^ (2 * wickColumnClassCount π) =
      D ^ (2 * (m + 1) + 2 - Δ) := by
  rw [wickAnalyticWeight_commonBase_eq_weightedRank]
  rw [wickWeightedRank_eq_budget_sub_defect_of_le
    (m := m) (Δ := Δ) (π := π) hRank hΔ]

/-- Closed defect-sensitive common-base form of the Wick analytic term. -/
theorem wickAnalyticWeight_commonBase_eq_defectPower_closed
    {m Δ : ℕ} {D : ℝ} {π : Equiv.Perm (Fin (m + 1))}
    (hΔ : wickDefect π = Δ) :
    D ^ (wickLeftClassCount π + wickRightClassCount π) *
        D ^ (2 * wickColumnClassCount π) =
      D ^ (2 * (m + 1) + 2 - Δ) := by
  rw [wickAnalyticWeight_commonBase_eq_weightedRank]
  rw [wickWeightedRank_eq_budget_sub_defect (m := m) (Δ := Δ) (π := π) hΔ]

/-- The left-oriented Cayley defect, in the repository's cycle-pair convention.

This is one half of the bidefect split.  It measures how far the cycle-pair
inequality involving `finRotate * π` is from equality. -/
noncomputable def wickPlusDefect {m : ℕ}
    (π : Equiv.Perm (Fin (m + 1))) : ℕ :=
  (m + 1) + 1 -
    (permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π))

/-- The right-oriented Cayley defect, in the repository's cycle-pair
convention.  It measures how far the cycle-pair inequality involving
`π * finRotate⁻¹` is from equality. -/
noncomputable def wickMinusDefect {m : ℕ}
    (π : Equiv.Perm (Fin (m + 1))) : ℕ :=
  (m + 1) + 1 -
    (permCycleClassCount π +
      permCycleClassCount (π * (finRotate (m + 1)).symm))

/-- The total Aubrun defect is the sum of the two oriented Cayley defects.

This is the formal entry point for the bidefect count route: the total defect
`Δ` should no longer be counted directly when the two analytic bases are kept
separate. -/
theorem wickPlusDefect_add_wickMinusDefect_eq_wickDefect {m : ℕ}
    (π : Equiv.Perm (Fin (m + 1))) :
    wickPlusDefect π + wickMinusDefect π = wickDefect π := by
  unfold wickPlusDefect wickMinusDefect wickDefect
  rw [wickWeightedRank_eq_cycleClassBudget]
  have hLeft :
      permCycleClassCount π +
        permCycleClassCount (finRotate (m + 1) * π) ≤ (m + 1) + 1 := by
    exact cyclePairLeftBound_of_inverseLongCycleInvBound π
      (cyclePair_inverseLongCycleInvBound π)
  have hRight :
      permCycleClassCount π +
        permCycleClassCount (π * (finRotate (m + 1)).symm) ≤ (m + 1) + 1 := by
    exact cyclePairRightBound_of_inverseLongCycleBound π
      (cyclePair_inverseLongCycleBound π)
  omega

/-- Wick permutations with prescribed oriented bidefect `(a,b)`. -/
noncomputable def WickBiDefectClass (m a b : ℕ) :=
  {π : Equiv.Perm (Fin (m + 1)) //
    wickPlusDefect π = a ∧ wickMinusDefect π = b}

noncomputable instance (m a b : ℕ) : Fintype (WickBiDefectClass m a b) := by
  unfold WickBiDefectClass
  infer_instance

/-- Cardinality of the bidefect slice. -/
noncomputable def wickBiDefectCount (m a b : ℕ) : ℕ :=
  Fintype.card (WickBiDefectClass m a b)

/-- A bidefect slice lies inside the corresponding total-defect slice. -/
theorem wickDefect_eq_add_of_mem_biDefectClass {m a b : ℕ}
    (π : WickBiDefectClass m a b) :
    wickDefect π.1 = a + b := by
  have hsum := wickPlusDefect_add_wickMinusDefect_eq_wickDefect π.1
  rw [← hsum, π.2.1, π.2.2]

/-- Every bidefect slice is bounded by the ambient permutation count.  This is
only a sanity bound; the real `U-AUB-02` target is the binomial bidefect
envelope. -/
theorem wickBiDefectCount_le_perm_card (m a b : ℕ) :
    wickBiDefectCount m a b ≤
      Fintype.card (Equiv.Perm (Fin (m + 1))) := by
  classical
  unfold wickBiDefectCount WickBiDefectClass
  exact Fintype.card_subtype_le _

/-- Wick permutations with prescribed left-oriented Cayley defect. -/
noncomputable def WickPlusDefectClass (m a : ℕ) :=
  {π : Equiv.Perm (Fin (m + 1)) // wickPlusDefect π = a}

noncomputable instance (m a : ℕ) : Fintype (WickPlusDefectClass m a) := by
  unfold WickPlusDefectClass
  infer_instance

/-- Cardinality of a one-sided plus-defect slice. -/
noncomputable def wickPlusDefectCount (m a : ℕ) : ℕ :=
  Fintype.card (WickPlusDefectClass m a)

/-- Wick permutations in one-sided unicellular genus `g`.

This is the genus-sliced version of the plus-defect class.  The intended
Euler relation is `wickPlusDefect = 2g`; the remaining hard enumerative input
is the Chapuy slicing bound for these genus slices. -/
noncomputable def WickPlusGenusClass (m g : ℕ) :=
  {π : Equiv.Perm (Fin (m + 1)) // wickPlusDefect π = 2 * g}

noncomputable instance (m g : ℕ) : Fintype (WickPlusGenusClass m g) := by
  unfold WickPlusGenusClass
  infer_instance

/-- Cardinality of the one-sided unicellular genus slice. -/
noncomputable def wickPlusGenusCount (m g : ℕ) : ℕ :=
  Fintype.card (WickPlusGenusClass m g)

/-- The even plus-defect slice is exactly the corresponding genus slice. -/
noncomputable def wickPlusDefectClassEvenEquivGenus (m g : ℕ) :
    WickPlusDefectClass m (2 * g) ≃ WickPlusGenusClass m g where
  toFun := fun π => ⟨π.1, π.2⟩
  invFun := fun π => ⟨π.1, π.2⟩
  left_inv := by
    intro π
    rfl
  right_inv := by
    intro π
    rfl

/-- Counting form of the even-defect/genus identification. -/
theorem wickPlusDefectCount_even_eq_genusCount (m g : ℕ) :
    wickPlusDefectCount m (2 * g) = wickPlusGenusCount m g := by
  unfold wickPlusDefectCount wickPlusGenusCount
  exact Fintype.card_congr (wickPlusDefectClassEvenEquivGenus m g)

/-- A plus-defect slice is bounded by the ambient permutation count. -/
theorem wickPlusDefectCount_le_perm_card (m a : ℕ) :
    wickPlusDefectCount m a ≤
      Fintype.card (Equiv.Perm (Fin (m + 1))) := by
  unfold wickPlusDefectCount WickPlusDefectClass
  exact Fintype.card_subtype_le _

/-- Large one-sided plus-defect slices are already controlled by the common
Aubrun envelope using only the ambient permutation count.

This does not touch the Catalan/geodesic base case `a = 0`; it only removes
the high-defect tail from the one-sided count frontier. -/
theorem wickPlusDefectCount_le_largeDefectCommonEnvelope_nat
    {m a : ℕ} (hlarge : m + 1 ≤ 36 * a) :
    wickPlusDefectCount m a ≤
      2 ^ (2 * (m + 1)) * (2 * (2 * (m + 1))) ^ (36 * a) := by
  let n : ℕ := m + 1
  let B : ℕ := 2 * (2 * n)
  have hnpos : 0 < n := by
    dsimp [n]
    omega
  have hBpos : 0 < B := by
    dsimp [B, n]
    omega
  have hBone : 1 ≤ B := hBpos
  have hnB : n ≤ B := by
    dsimp [B, n]
    omega
  have hnlarge : n ≤ 36 * a := by
    simpa [n] using hlarge
  have hcount : wickPlusDefectCount m a ≤ n.factorial := by
    calc
      wickPlusDefectCount m a ≤
          Fintype.card (Equiv.Perm (Fin (m + 1))) :=
      wickPlusDefectCount_le_perm_card m a
      _ = n.factorial := by
        rw [Fintype.card_perm, Fintype.card_fin]
  have hfac : n.factorial ≤ n ^ n := Nat.factorial_le_pow n
  have hbasepow : n ^ n ≤ B ^ n :=
    pow_le_pow_left₀ (Nat.zero_le n) hnB n
  have hexppow : B ^ n ≤ B ^ (36 * a) :=
    Nat.pow_le_pow_right hBpos hnlarge
  have hscale :
      B ^ (36 * a) ≤ 2 ^ (2 * n) * B ^ (36 * a) := by
    exact Nat.le_mul_of_pos_left _ (by positivity)
  calc
    wickPlusDefectCount m a ≤ n.factorial := hcount
    _ ≤ n ^ n := hfac
    _ ≤ B ^ n := hbasepow
    _ ≤ B ^ (36 * a) := hexppow
    _ ≤ 2 ^ (2 * n) * B ^ (36 * a) := hscale

/-- Real-valued form of the high-defect plus-count tail bound. -/
theorem wickPlusDefectCount_real_le_commonEnvelope_of_large_defect
    {m a : ℕ} (hlarge : m + 1 ≤ 36 * a) :
    (wickPlusDefectCount m a : ℝ) ≤
      (2 : ℝ) ^ (2 * (m + 1)) *
        aubrunProposition73P (2 * (m + 1)) ^ a := by
  have hnat :=
    wickPlusDefectCount_le_largeDefectCommonEnvelope_nat
      (m := m) (a := a) hlarge
  calc
    (wickPlusDefectCount m a : ℝ) ≤
        (2 ^ (2 * (m + 1)) *
          (2 * (2 * (m + 1))) ^ (36 * a) : ℕ) := by
          exact_mod_cast hnat
    _ = (2 : ℝ) ^ (2 * (m + 1)) *
          aubrunProposition73P (2 * (m + 1)) ^ a := by
          unfold aubrunProposition73P
          norm_num
          rw [pow_mul]

/-- If the zero plus-defect slice is already swallowed by the `4^(m+1)`
prefactor, and every positive plus-defect is in the high-defect tail, then the
one-sided count bound holds for all plus defects. -/
theorem wickPlusDefectCount_real_le_commonEnvelope_of_factorial_le_four_pow_and_small_dim
    {m a : ℕ}
    (hfac : (m + 1).factorial ≤ 2 ^ (2 * (m + 1)))
    (hm : m + 1 ≤ 36) :
    (wickPlusDefectCount m a : ℝ) ≤
      (2 : ℝ) ^ (2 * (m + 1)) *
        aubrunProposition73P (2 * (m + 1)) ^ a := by
  by_cases ha : a = 0
  · subst a
    have hcountNat :
        wickPlusDefectCount m 0 ≤ 2 ^ (2 * (m + 1)) := by
      calc
        wickPlusDefectCount m 0 ≤
            Fintype.card (Equiv.Perm (Fin (m + 1))) :=
          wickPlusDefectCount_le_perm_card m 0
        _ = (m + 1).factorial := by
          rw [Fintype.card_perm, Fintype.card_fin]
        _ ≤ 2 ^ (2 * (m + 1)) := hfac
    have hcountReal :
        (wickPlusDefectCount m 0 : ℝ) ≤
          (2 : ℝ) ^ (2 * (m + 1)) := by
      exact_mod_cast hcountNat
    simpa using hcountReal
  · have hlarge : m + 1 ≤ 36 * a := by
      have hapos : 0 < a := Nat.pos_of_ne_zero ha
      omega
    exact wickPlusDefectCount_real_le_commonEnvelope_of_large_defect
      (m := m) (a := a) hlarge

/-- A bidefect class embeds in its plus-defect slice. -/
noncomputable def wickBiDefectClassEmbeddingPlusDefectClass (m a b : ℕ) :
    WickBiDefectClass m a b ↪ WickPlusDefectClass m a where
  toFun := fun π => ⟨π.1, π.2.1⟩
  inj' := by
    intro π τ h
    apply Subtype.ext
    exact congrArg (fun x : WickPlusDefectClass m a => x.1) h

/-- The bidefect count is bounded by the corresponding one-sided plus-defect
count. -/
theorem wickBiDefectCount_le_wickPlusDefectCount (m a b : ℕ) :
    wickBiDefectCount m a b ≤ wickPlusDefectCount m a := by
  unfold wickBiDefectCount wickPlusDefectCount
  exact Fintype.card_le_of_embedding
    (wickBiDefectClassEmbeddingPlusDefectClass m a b)

/-- A one-sided Aubrun geodesic-defect count bound supplies the common
bidefect envelope without binomial factors. -/
theorem wickBiDefectCount_le_commonEnvelope_of_plusDefectCount
    {m a b : ℕ}
    (hPlus :
      (wickPlusDefectCount m a : ℝ) ≤
        (2 : ℝ) ^ (2 * (m + 1)) *
          aubrunProposition73P (2 * (m + 1)) ^ a) :
    (wickBiDefectCount m a b : ℝ) ≤
      (2 : ℝ) ^ (2 * (m + 1)) *
        aubrunProposition73P (2 * (m + 1)) ^ (a + b) := by
  have hCount : (wickBiDefectCount m a b : ℝ) ≤
      (wickPlusDefectCount m a : ℝ) := by
    exact_mod_cast wickBiDefectCount_le_wickPlusDefectCount m a b
  have hPone : 1 ≤ aubrunProposition73P (2 * (m + 1)) :=
    aubrunProposition73P_one_le (2 * (m + 1)) (by omega)
  have hPow :
      aubrunProposition73P (2 * (m + 1)) ^ a ≤
        aubrunProposition73P (2 * (m + 1)) ^ (a + b) :=
    pow_le_pow_right₀ hPone (Nat.le_add_right a b)
  have hScale : 0 ≤ (2 : ℝ) ^ (2 * (m + 1)) := by positivity
  calc
    (wickBiDefectCount m a b : ℝ) ≤
        (wickPlusDefectCount m a : ℝ) := hCount
    _ ≤ (2 : ℝ) ^ (2 * (m + 1)) *
          aubrunProposition73P (2 * (m + 1)) ^ a := hPlus
    _ ≤ (2 : ℝ) ^ (2 * (m + 1)) *
          aubrunProposition73P (2 * (m + 1)) ^ (a + b) :=
        mul_le_mul_of_nonneg_left hPow hScale

/-- A bidefect class embeds in the total-defect class with defect `a+b`. -/
noncomputable def wickBiDefectClassEmbeddingDefectClass (m a b : ℕ) :
    WickBiDefectClass m a b ↪ WickPermutationDefectClass m (a + b) where
  toFun := fun π => ⟨π.1, wickDefect_eq_add_of_mem_biDefectClass π⟩
  inj' := by
    intro π τ h
    apply Subtype.ext
    exact congrArg (fun x : WickPermutationDefectClass m (a + b) => x.1) h

/-- The bidefect count refines the old total-defect count. -/
theorem wickBiDefectCount_le_wickPermutationDefectCount (m a b : ℕ) :
    wickBiDefectCount m a b ≤ wickPermutationDefectCount m (a + b) := by
  rw [wickPermutationDefectCount_eq_card_defectClass]
  exact Fintype.card_le_of_embedding
    (wickBiDefectClassEmbeddingDefectClass m a b)

/-- The bidefect count envelope suggested by the shifted-base Aubrun route.

Here `n = m + 1`; the two binomial factors are meant to be absorbed separately
by `(d+Q)^(n+2)` and `(sqrt s+Q)^n`. -/
def aubrunBiDefectCountEnvelope (m a b : ℕ) : ℝ :=
  (2 : ℝ) ^ (2 * (m + 1)) *
    (Nat.choose (m + 3) a : ℝ) *
      (Nat.choose (m + 1) b : ℝ) *
        aubrunProposition73P (2 * (m + 1)) ^ (a + b)

/-- Nonnegativity of the bidefect count envelope. -/
theorem aubrunBiDefectCountEnvelope_nonneg (m a b : ℕ) :
    0 ≤ aubrunBiDefectCountEnvelope m a b := by
  unfold aubrunBiDefectCountEnvelope
  have htwo : 0 ≤ (2 : ℝ) ^ (2 * (m + 1)) := by positivity
  have hchooseA : 0 ≤ (Nat.choose (m + 3) a : ℝ) := by exact_mod_cast Nat.zero_le _
  have hchooseB : 0 ≤ (Nat.choose (m + 1) b : ℝ) := by exact_mod_cast Nat.zero_le _
  have hP :
      0 ≤ aubrunProposition73P (2 * (m + 1)) ^ (a + b) :=
    pow_nonneg (aubrunProposition73P_nonneg (2 * (m + 1))) _
  exact mul_nonneg (mul_nonneg (mul_nonneg htwo hchooseA) hchooseB) hP

/-- The theorem-strength bidefect count target that should replace the false
single-defect envelope route. -/
abbrev AubrunBiDefectCountBound (m : ℕ) : Prop :=
  ∀ a b : ℕ,
    a ∈ Finset.range (m + 3 + 1) →
    b ∈ Finset.range (m + 1 + 1) →
      (wickBiDefectCount m a b : ℝ) ≤
        aubrunBiDefectCountEnvelope m a b

/-- A one-sided plus-defect count theorem supplies the ranged bidefect count
bound consumed by the shifted-base scalar route. -/
theorem wickBiDefectCount_le_biDefectEnvelope_of_plusDefectCount
    {m a b : ℕ}
    (ha : a ∈ Finset.range (m + 3 + 1))
    (hb : b ∈ Finset.range (m + 1 + 1))
    (hPlus :
      (wickPlusDefectCount m a : ℝ) ≤
        (2 : ℝ) ^ (2 * (m + 1)) *
          aubrunProposition73P (2 * (m + 1)) ^ a) :
    (wickBiDefectCount m a b : ℝ) ≤
      aubrunBiDefectCountEnvelope m a b := by
  have hCommon :=
    wickBiDefectCount_le_commonEnvelope_of_plusDefectCount
      (m := m) (a := a) (b := b) hPlus
  have ha_le : a ≤ m + 3 := by
    have := Finset.mem_range.mp ha
    omega
  have hb_le : b ≤ m + 1 := by
    have := Finset.mem_range.mp hb
    omega
  have hca : (1 : ℝ) ≤ (Nat.choose (m + 3) a : ℝ) := by
    have hnat : 1 ≤ Nat.choose (m + 3) a :=
      Nat.succ_le_iff.mpr (Nat.choose_pos ha_le)
    exact_mod_cast hnat
  have hcb : (1 : ℝ) ≤ (Nat.choose (m + 1) b : ℝ) := by
    have hnat : 1 ≤ Nat.choose (m + 1) b :=
      Nat.succ_le_iff.mpr (Nat.choose_pos hb_le)
    exact_mod_cast hnat
  let C : ℝ := (2 : ℝ) ^ (2 * (m + 1))
  let Ppow : ℝ := aubrunProposition73P (2 * (m + 1)) ^ (a + b)
  let chooseProd : ℝ :=
    (Nat.choose (m + 3) a : ℝ) * (Nat.choose (m + 1) b : ℝ)
  have hC : 0 ≤ C := by
    dsimp [C]
    positivity
  have hPpow : 0 ≤ Ppow := by
    dsimp [Ppow]
    exact pow_nonneg (aubrunProposition73P_nonneg (2 * (m + 1))) _
  have hchooseProd : 1 ≤ chooseProd := by
    dsimp [chooseProd]
    nlinarith [hca, hcb]
  have hP_with_choose : Ppow ≤ chooseProd * Ppow :=
    by simpa using mul_le_mul_of_nonneg_right hchooseProd hPpow
  have hEnvelope :
      (2 : ℝ) ^ (2 * (m + 1)) *
          aubrunProposition73P (2 * (m + 1)) ^ (a + b) ≤
        aubrunBiDefectCountEnvelope m a b := by
    calc
      (2 : ℝ) ^ (2 * (m + 1)) * Ppow ≤
          (2 : ℝ) ^ (2 * (m + 1)) * (chooseProd * Ppow) :=
        mul_le_mul_of_nonneg_left hP_with_choose hC
      _ = aubrunBiDefectCountEnvelope m a b := by
        simp [aubrunBiDefectCountEnvelope, Ppow, chooseProd, mul_assoc]
  exact le_trans hCommon hEnvelope

/-- A one-sided plus-defect count theorem supplies the ranged bidefect count
bound consumed by the shifted-base scalar route. -/
theorem AubrunBiDefectCountBound_of_plusDefectCountBound
    {m : ℕ}
    (hPlus : ∀ a : ℕ,
      (wickPlusDefectCount m a : ℝ) ≤
        (2 : ℝ) ^ (2 * (m + 1)) *
          aubrunProposition73P (2 * (m + 1)) ^ a) :
    AubrunBiDefectCountBound m := by
  intro a b ha hb
  exact wickBiDefectCount_le_biDefectEnvelope_of_plusDefectCount
    (m := m) (a := a) (b := b) ha hb (hPlus a)

/-- Small Wick lengths whose ambient factorial is below the base prefactor
have the full ranged bidefect count bound.  This closes a finite checked block
of the small plus-defect frontier; it is not the uniform Catalan/Biane count. -/
theorem AubrunBiDefectCountBound_of_factorial_le_four_pow_and_small_dim
    {m : ℕ}
    (hfac : (m + 1).factorial ≤ 2 ^ (2 * (m + 1)))
    (hm : m + 1 ≤ 36) :
    AubrunBiDefectCountBound m :=
  AubrunBiDefectCountBound_of_plusDefectCountBound
    (m := m)
    (fun a =>
      wickPlusDefectCount_real_le_commonEnvelope_of_factorial_le_four_pow_and_small_dim
        (m := m) (a := a) hfac hm)

/-- The corrected ranged bidefect count is closed in Wick length `m = 2`. -/
theorem AubrunBiDefectCountBound_two :
    AubrunBiDefectCountBound 2 :=
  AubrunBiDefectCountBound_of_factorial_le_four_pow_and_small_dim
    (m := 2) (by norm_num) (by norm_num)

/-- The corrected ranged bidefect count is closed in Wick length `m = 3`. -/
theorem AubrunBiDefectCountBound_three :
    AubrunBiDefectCountBound 3 :=
  AubrunBiDefectCountBound_of_factorial_le_four_pow_and_small_dim
    (m := 3) (by norm_num) (by norm_num)

/-- The corrected ranged bidefect count is closed in Wick length `m = 4`. -/
theorem AubrunBiDefectCountBound_four :
    AubrunBiDefectCountBound 4 :=
  AubrunBiDefectCountBound_of_factorial_le_four_pow_and_small_dim
    (m := 4) (by norm_num) (by norm_num)

/-- The corrected ranged bidefect count is closed in Wick length `m = 5`. -/
theorem AubrunBiDefectCountBound_five :
    AubrunBiDefectCountBound 5 :=
  AubrunBiDefectCountBound_of_factorial_le_four_pow_and_small_dim
    (m := 5) (by norm_num) (by norm_num)

/-- The corrected ranged bidefect count is closed in Wick length `m = 6`. -/
theorem AubrunBiDefectCountBound_six :
    AubrunBiDefectCountBound 6 :=
  AubrunBiDefectCountBound_of_factorial_le_four_pow_and_small_dim
    (m := 6) (by norm_num) (by norm_num)

/-- The corrected ranged bidefect count is closed in Wick length `m = 7`. -/
theorem AubrunBiDefectCountBound_seven :
    AubrunBiDefectCountBound 7 :=
  AubrunBiDefectCountBound_of_factorial_le_four_pow_and_small_dim
    (m := 7) (by norm_num) (by norm_num)

/-- One-sided innovation-fiber package for the corrected Aubrun count route.

This is the theorem-strength data still missing from `U-AUB-02`: an encoding
of each plus-defect slice into innovation fibers over a word of length
`2(m+1)`, with the same compatible-couple and large-innovation bounds used in
Aubrun's Proposition 7.3. -/
structure PlusDefectAubrunInnovationFiberPackage (m a : ℕ) where
  Fiber : Finset (Fin (2 * (m + 1))) → Type
  LeftCouples : Finset (Fin (2 * (m + 1))) → Type
  RightCouples : Finset (Fin (2 * (m + 1))) → Type
  fiberFintype : ∀ I, Fintype (Fiber I)
  leftFintype : ∀ I, Fintype (LeftCouples I)
  rightFintype : ∀ I, Fintype (RightCouples I)
  defectEncode :
    WickPlusDefectClass m a ↪ Sigma Fiber
  encode :
    ∀ I : Finset (Fin (2 * (m + 1))),
      Fiber I ↪ LeftCouples I × RightCouples I
  left_card_le :
    ∀ I : Finset (Fin (2 * (m + 1))),
      Fintype.card (LeftCouples I) ≤
        (2 * (2 * (m + 1))) ^
          (9 * compatibilityDefect (2 * (m + 1)) I)
  right_card_le :
    ∀ I : Finset (Fin (2 * (m + 1))),
      Fintype.card (RightCouples I) ≤
        (2 * (2 * (m + 1))) ^
          (9 * compatibilityDefect (2 * (m + 1)) I)
  large_innovation :
    ∀ I : Finset (Fin (2 * (m + 1))),
      Fintype.card (Fiber I) ≠ 0 →
        2 * (m + 1) ≤ 2 * I.card + 2 * a

/-- A one-sided innovation-fiber package implies the natural-number
plus-defect count bound. -/
theorem wickPlusDefectCount_le_of_plusDefectFiberPackage
    {m a : ℕ} (pkg : PlusDefectAubrunInnovationFiberPackage m a) :
    wickPlusDefectCount m a ≤
      2 ^ (2 * (m + 1)) * (2 * (2 * (m + 1))) ^ (36 * a) := by
  letI : ∀ I, Fintype (pkg.Fiber I) := pkg.fiberFintype
  letI : ∀ I, Fintype (pkg.LeftCouples I) := pkg.leftFintype
  letI : ∀ I, Fintype (pkg.RightCouples I) := pkg.rightFintype
  have hcard :
      wickPlusDefectCount m a ≤ Fintype.card (Sigma pkg.Fiber) := by
    unfold wickPlusDefectCount
    exact Fintype.card_le_of_embedding pkg.defectEncode
  have habstract :
      Fintype.card (Sigma pkg.Fiber) ≤
        2 ^ (2 * (m + 1)) * (2 * (2 * (m + 1))) ^ (36 * a) :=
    aubrunLemma74_fixedDefectClassCount_le
      (k := 2 * (m + 1)) (Δ := a)
      (hk := by omega)
      (Fiber := pkg.Fiber)
      (LeftCouples := pkg.LeftCouples)
      (RightCouples := pkg.RightCouples)
      pkg.encode pkg.left_card_le pkg.right_card_le pkg.large_innovation
  exact hcard.trans habstract

/-- Real-valued one-sided plus-defect count bound supplied by a one-sided
innovation-fiber package. -/
theorem wickPlusDefectCount_real_le_commonEnvelope_of_plusDefectFiberPackage
    {m a : ℕ} (pkg : PlusDefectAubrunInnovationFiberPackage m a) :
    (wickPlusDefectCount m a : ℝ) ≤
      (2 : ℝ) ^ (2 * (m + 1)) *
        aubrunProposition73P (2 * (m + 1)) ^ a := by
  have hnat := wickPlusDefectCount_le_of_plusDefectFiberPackage
    (m := m) (a := a) pkg
  calc
    (wickPlusDefectCount m a : ℝ) ≤
        (2 ^ (2 * (m + 1)) *
          (2 * (2 * (m + 1))) ^ (36 * a) : ℕ) := by
          exact_mod_cast hnat
    _ = (2 : ℝ) ^ (2 * (m + 1)) *
          aubrunProposition73P (2 * (m + 1)) ^ a := by
          unfold aubrunProposition73P
          norm_num
          rw [pow_mul]

/-- One-sided packages for every plus-defect slice supply the ranged bidefect
count bound consumed by the shifted-base scalar endpoint. -/
theorem AubrunBiDefectCountBound_of_plusDefectFiberPackages
    {m : ℕ}
    (pkg : ∀ a : ℕ, PlusDefectAubrunInnovationFiberPackage m a) :
    AubrunBiDefectCountBound m :=
  AubrunBiDefectCountBound_of_plusDefectCountBound
    (m := m)
    (fun a =>
      wickPlusDefectCount_real_le_commonEnvelope_of_plusDefectFiberPackage
        (m := m) (a := a) (pkg a))

/-- Trivial plus-defect innovation fiber for the base Wick length `m = 0`.

The fiber is placed over the full innovation set in the doubled word
`Fin (2*(0+1))`.  This closes the base case of the corrected one-sided
package route for every plus-defect value `a`. -/
abbrev plusDefectBaseFiber
    (a : ℕ) (I : Finset (Fin (2 * (0 + 1)))) : Type :=
  {_π : WickPlusDefectClass 0 a // I = Finset.univ}

/-- Trivial compatible-couple type for the base one-sided package. -/
abbrev plusDefectBaseCouples
    (_a : ℕ) (_I : Finset (Fin (2 * (0 + 1)))) : Type := Unit

noncomputable instance plusDefectBaseFiber_fintype
    (a : ℕ) (I : Finset (Fin (2 * (0 + 1)))) :
    Fintype (plusDefectBaseFiber a I) := by
  unfold plusDefectBaseFiber
  infer_instance

instance plusDefectBaseCouples_fintype
    (a : ℕ) (I : Finset (Fin (2 * (0 + 1)))) :
    Fintype (plusDefectBaseCouples a I) := by
  unfold plusDefectBaseCouples
  infer_instance

/-- Base-case plus-defect class encoding into the full innovation fiber. -/
noncomputable def plusDefectBase_defectEncode
    (a : ℕ) :
    WickPlusDefectClass 0 a ↪ Sigma (plusDefectBaseFiber a) :=
  {
    toFun := fun π => ⟨Finset.univ, ⟨π, rfl⟩⟩
    inj' := by
      intro π τ _h
      apply Subtype.ext
      apply Equiv.ext
      intro i
      have hπ : π.1 i = 0 := by
        simpa using Fin.fin_one_eq_zero (π.1 i)
      have hτ : τ.1 i = 0 := by
        simpa using Fin.fin_one_eq_zero (τ.1 i)
      rw [hπ, hτ]
  }

/-- Base-case fiber-to-compatible-couples encoding. -/
noncomputable def plusDefectBase_encode
    (a : ℕ) (I : Finset (Fin (2 * (0 + 1)))) :
    plusDefectBaseFiber a I ↪
      plusDefectBaseCouples a I × plusDefectBaseCouples a I :=
  {
    toFun := fun _ => ((), ())
    inj' := by
      intro π τ _h
      apply Subtype.ext
      apply Subtype.ext
      apply Equiv.ext
      intro i
      have hπ : π.1.1 i = 0 := by
        simpa using Fin.fin_one_eq_zero (π.1.1 i)
      have hτ : τ.1.1 i = 0 := by
        simpa using Fin.fin_one_eq_zero (τ.1.1 i)
      rw [hπ, hτ]
  }

/-- The base one-sided compatible-couple count satisfies Aubrun's envelope. -/
theorem plusDefectBase_leftCouples_bound
    (a : ℕ) (I : Finset (Fin (2 * (0 + 1)))) :
    Fintype.card (plusDefectBaseCouples a I) ≤
      (2 * (2 * (0 + 1))) ^
        (9 * compatibilityDefect (2 * (0 + 1)) I) := by
  change 1 ≤ 4 ^ (9 * compatibilityDefect 2 I)
  exact Nat.one_le_pow (9 * compatibilityDefect 2 I) 4 (by norm_num)

/-- The right-couple base bound is identical to the left-couple base bound. -/
theorem plusDefectBase_rightCouples_bound
    (a : ℕ) (I : Finset (Fin (2 * (0 + 1)))) :
    Fintype.card (plusDefectBaseCouples a I) ≤
      (2 * (2 * (0 + 1))) ^
        (9 * compatibilityDefect (2 * (0 + 1)) I) :=
  plusDefectBase_leftCouples_bound a I

/-- The full base innovation fiber satisfies the one-sided large-innovation
inequality. -/
theorem plusDefectBase_largeInnovation_bound
    (a : ℕ) (I : Finset (Fin (2 * (0 + 1)))) :
    Fintype.card (plusDefectBaseFiber a I) ≠ 0 →
      2 * (0 + 1) ≤ 2 * I.card + 2 * a := by
  intro hNonzero
  by_cases hI : I = Finset.univ
  · subst I
    simpa using (by omega : 2 ≤ 4 + 2 * a)
  · exfalso
    apply hNonzero
    letI : IsEmpty (plusDefectBaseFiber a I) := ⟨fun π => hI π.2⟩
    exact Fintype.card_eq_zero (α := plusDefectBaseFiber a I)

/-- The corrected one-sided Aubrun package is closed in the base Wick length
for every plus-defect slice. -/
noncomputable def plusDefectBasePackage
    (a : ℕ) :
    PlusDefectAubrunInnovationFiberPackage 0 a where
  Fiber := plusDefectBaseFiber a
  LeftCouples := plusDefectBaseCouples a
  RightCouples := plusDefectBaseCouples a
  fiberFintype := plusDefectBaseFiber_fintype a
  leftFintype := plusDefectBaseCouples_fintype a
  rightFintype := plusDefectBaseCouples_fintype a
  defectEncode := plusDefectBase_defectEncode a
  encode := plusDefectBase_encode a
  left_card_le := plusDefectBase_leftCouples_bound a
  right_card_le := plusDefectBase_rightCouples_bound a
  large_innovation := plusDefectBase_largeInnovation_bound a

/-- The ranged bidefect count bound is closed at the base Wick length through
the corrected one-sided package route. -/
theorem AubrunBiDefectCountBound_zero_of_plusDefectBasePackage :
    AubrunBiDefectCountBound 0 :=
  AubrunBiDefectCountBound_of_plusDefectFiberPackages
    (m := 0) plusDefectBasePackage

/-- In Wick length `m = 1`, the corrected one-sided plus-defect count bound
is already dominated by the ambient two-permutation count. -/
theorem wickPlusDefectCount_one_real_le_commonEnvelope (a : ℕ) :
    (wickPlusDefectCount 1 a : ℝ) ≤
      (2 : ℝ) ^ (2 * (1 + 1)) *
        aubrunProposition73P (2 * (1 + 1)) ^ a := by
  have hcountNat : wickPlusDefectCount 1 a ≤ 2 := by
    calc
      wickPlusDefectCount 1 a ≤
          Fintype.card (Equiv.Perm (Fin (1 + 1))) :=
        wickPlusDefectCount_le_perm_card 1 a
      _ = 2 := by
        rw [Fintype.card_perm, Fintype.card_fin]
        norm_num
  have hcountReal : (wickPlusDefectCount 1 a : ℝ) ≤ 2 := by
    exact_mod_cast hcountNat
  have hPone :
      (1 : ℝ) ≤ aubrunProposition73P (2 * (1 + 1)) ^ a := by
    exact one_le_pow₀
      (aubrunProposition73P_one_le (2 * (1 + 1)) (by norm_num))
  calc
    (wickPlusDefectCount 1 a : ℝ) ≤ 2 := hcountReal
    _ ≤ (2 : ℝ) ^ (2 * (1 + 1)) * 1 := by norm_num
    _ ≤ (2 : ℝ) ^ (2 * (1 + 1)) *
        aubrunProposition73P (2 * (1 + 1)) ^ a :=
      mul_le_mul_of_nonneg_left hPone (by norm_num)

/-- The ranged bidefect count bound is closed in Wick length `m = 1` by the
corrected one-sided count route. -/
theorem AubrunBiDefectCountBound_one_of_plusDefectCount :
    AubrunBiDefectCountBound 1 :=
  AubrunBiDefectCountBound_of_plusDefectCountBound
    (m := 1) wickPlusDefectCount_one_real_le_commonEnvelope

/-- A binomially weighted polynomial sum.  This is the scalar form produced by
the bidefect envelope after separating the two oriented defects. -/
def binomialWeightedSum (N : ℕ) (P x : ℝ) : ℝ :=
  Finset.sum (Finset.range (N + 1)) (fun a =>
    (Nat.choose N a : ℝ) * P ^ a * x ^ (N - a))

/-- Nonnegativity of the binomially weighted polynomial sum. -/
theorem binomialWeightedSum_nonneg
    (N : ℕ) {P x : ℝ} (hP0 : 0 ≤ P) (hx0 : 0 ≤ x) :
    0 ≤ binomialWeightedSum N P x := by
  unfold binomialWeightedSum
  exact Finset.sum_nonneg (by
    intro a _ha
    exact mul_nonneg
      (mul_nonneg (by exact_mod_cast Nat.zero_le _) (pow_nonneg hP0 a))
      (pow_nonneg hx0 (N - a)))

/-- A binomially weighted polynomial sum is absorbed by a shifted base.

This is the scalar core of the bidefect route: the defect cost `P^a` is paid by
the shift from `x` to `x+Q`. -/
theorem binomialWeightedSum_le_shiftedBase
    (N : ℕ) {P Q x : ℝ} (hP0 : 0 ≤ P) (hx0 : 0 ≤ x) (hPQ : P ≤ Q) :
    binomialWeightedSum N P x ≤ (x + Q) ^ N := by
  have hsum_eq : binomialWeightedSum N P x = (x + P) ^ N := by
    unfold binomialWeightedSum
    simpa [mul_assoc, mul_comm, mul_left_comm, add_comm] using (add_pow P x N).symm
  rw [hsum_eq]
  simpa [add_comm] using
    pow_le_pow_left₀ (add_nonneg hP0 hx0) (add_le_add_left hPQ x) N

/-- The scalar sum attached to the bidefect count envelope.

The first binomial sum is intended for the `d+Q` base and the second for the
`sqrt(s)+Q` base. -/
def aubrunBiDefectScalarSum (m : ℕ) (P d S : ℝ) : ℝ :=
  (2 : ℝ) ^ (2 * (m + 1)) *
    binomialWeightedSum (m + 3) P d *
      binomialWeightedSum (m + 1) P S

/-- The double scalar sum produced by the bidefect count envelope.

This is the exact sum obtained after assigning the plus-defect to the first
analytic base and the minus-defect to the second. -/
def aubrunBiDefectEnvelopeDoubleSum (m : ℕ) (d S : ℝ) : ℝ :=
  Finset.sum (Finset.range (m + 3 + 1)) (fun a =>
    Finset.sum (Finset.range (m + 1 + 1)) (fun b =>
      aubrunBiDefectCountEnvelope m a b *
        d ^ (m + 3 - a) * S ^ (m + 1 - b)))

/-- The actual bidefect count double sum with the two analytic bases separated. -/
def aubrunBiDefectCountDoubleSum (m : ℕ) (d S : ℝ) : ℝ :=
  Finset.sum (Finset.range (m + 3 + 1)) (fun a =>
    Finset.sum (Finset.range (m + 1 + 1)) (fun b =>
      (wickBiDefectCount m a b : ℝ) *
        d ^ (m + 3 - a) * S ^ (m + 1 - b)))

/-- The bidefect envelope double sum factors into the scalar sum checked by the
binomial absorption lemma. -/
theorem aubrunBiDefectEnvelopeDoubleSum_eq_scalarSum
    (m : ℕ) (d S : ℝ) :
    aubrunBiDefectEnvelopeDoubleSum m d S =
      aubrunBiDefectScalarSum m (aubrunProposition73P (2 * (m + 1))) d S := by
  simp [aubrunBiDefectEnvelopeDoubleSum, aubrunBiDefectCountEnvelope,
    aubrunBiDefectScalarSum, binomialWeightedSum, pow_add, Finset.mul_sum,
    mul_assoc, mul_comm, mul_left_comm]

/-- A bidefect count bound controls the actual bidefect double sum by its
envelope double sum. -/
theorem aubrunBiDefectCountDoubleSum_le_envelopeDoubleSum
    {m : ℕ} {d S : ℝ}
    (hCount : AubrunBiDefectCountBound m) (hd0 : 0 ≤ d) (hS0 : 0 ≤ S) :
    aubrunBiDefectCountDoubleSum m d S ≤
      aubrunBiDefectEnvelopeDoubleSum m d S := by
  unfold aubrunBiDefectCountDoubleSum aubrunBiDefectEnvelopeDoubleSum
  refine Finset.sum_le_sum ?_
  intro a _ha
  refine Finset.sum_le_sum ?_
  intro b _hb
  have hdPow : 0 ≤ d ^ (m + 3 - a) := pow_nonneg hd0 _
  have hSPow : 0 ≤ S ^ (m + 1 - b) := pow_nonneg hS0 _
  exact
    mul_le_mul_of_nonneg_right
      (mul_le_mul_of_nonneg_right (hCount a b _ha _hb) hdPow) hSPow

/-- The bidefect scalar envelope is absorbed by the two shifted analytic bases.

This is the scalar half of the bidefect strategy: once the bidefect counts have
the two binomial factors, the sum is paid separately by `(d+Q)^(m+3)` and
`(S+Q)^(m+1)`. -/
theorem aubrunBiDefectScalarSum_le_shiftedBases
    {m : ℕ} {P Q d S : ℝ}
    (hP0 : 0 ≤ P) (hd0 : 0 ≤ d) (hS0 : 0 ≤ S) (hPQ : P ≤ Q) :
    aubrunBiDefectScalarSum m P d S ≤
      (2 : ℝ) ^ (2 * (m + 1)) *
        (d + Q) ^ (m + 3) * (S + Q) ^ (m + 1) := by
  have hQ0 : 0 ≤ Q := le_trans hP0 hPQ
  have hleft :=
    binomialWeightedSum_le_shiftedBase (N := m + 3)
      (P := P) (Q := Q) (x := d) hP0 hd0 hPQ
  have hright :=
    binomialWeightedSum_le_shiftedBase (N := m + 1)
      (P := P) (Q := Q) (x := S) hP0 hS0 hPQ
  have hright_nonneg :
      0 ≤ binomialWeightedSum (m + 1) P S :=
    binomialWeightedSum_nonneg (m + 1) hP0 hS0
  have hleft_target_nonneg : 0 ≤ (d + Q) ^ (m + 3) :=
    pow_nonneg (add_nonneg hd0 hQ0) _
  have hprod :
      binomialWeightedSum (m + 3) P d *
          binomialWeightedSum (m + 1) P S ≤
        (d + Q) ^ (m + 3) * (S + Q) ^ (m + 1) :=
    mul_le_mul hleft hright hright_nonneg hleft_target_nonneg
  have htwo : 0 ≤ (2 : ℝ) ^ (2 * (m + 1)) := by positivity
  simpa [aubrunBiDefectScalarSum, mul_assoc] using
    mul_le_mul_of_nonneg_left hprod htwo

/-- Count bound plus scalar absorption for the bidefect route.

This is the current usable bidefect scalar endpoint: once
`AubrunBiDefectCountBound` is proved, the separated bidefect double sum is paid
by the two shifted analytic bases. -/
theorem aubrunBiDefectCountDoubleSum_le_shiftedBases
    {m : ℕ} {Q d S : ℝ}
    (hCount : AubrunBiDefectCountBound m)
    (hd0 : 0 ≤ d) (hS0 : 0 ≤ S)
    (hPQ : aubrunProposition73P (2 * (m + 1)) ≤ Q) :
    aubrunBiDefectCountDoubleSum m d S ≤
      (2 : ℝ) ^ (2 * (m + 1)) *
        (d + Q) ^ (m + 3) * (S + Q) ^ (m + 1) := by
  calc
    aubrunBiDefectCountDoubleSum m d S ≤
        aubrunBiDefectEnvelopeDoubleSum m d S :=
      aubrunBiDefectCountDoubleSum_le_envelopeDoubleSum
        (m := m) (d := d) (S := S) hCount hd0 hS0
    _ = aubrunBiDefectScalarSum m
        (aubrunProposition73P (2 * (m + 1))) d S :=
      aubrunBiDefectEnvelopeDoubleSum_eq_scalarSum m d S
    _ ≤ (2 : ℝ) ^ (2 * (m + 1)) *
        (d + Q) ^ (m + 3) * (S + Q) ^ (m + 1) :=
      aubrunBiDefectScalarSum_le_shiftedBases
        (m := m) (P := aubrunProposition73P (2 * (m + 1)))
        (Q := Q) (d := d) (S := S)
        (aubrunProposition73P_nonneg (2 * (m + 1))) hd0 hS0 hPQ

/-- Canonical `Q=Q₁(2(m+1))` version of the bidefect scalar endpoint. -/
theorem aubrunBiDefectCountDoubleSum_le_shiftedBases_Qone
    {m : ℕ} {d S : ℝ}
    (hCount : AubrunBiDefectCountBound m) (hd0 : 0 ≤ d) (hS0 : 0 ≤ S) :
    aubrunBiDefectCountDoubleSum m d S ≤
      (2 : ℝ) ^ (2 * (m + 1)) *
        (d + aubrunProposition71Q 1 (2 * (m + 1))) ^ (m + 3) *
          (S + aubrunProposition71Q 1 (2 * (m + 1))) ^ (m + 1) := by
  have hk : 1 ≤ 2 * (m + 1) := by omega
  exact aubrunBiDefectCountDoubleSum_le_shiftedBases
    (m := m) (Q := aubrunProposition71Q 1 (2 * (m + 1)))
    (d := d) (S := S) hCount hd0 hS0
    (aubrunProposition73P_le_Qone (2 * (m + 1)) hk)

/-- Concrete finite-set form of the bidefect slice count. -/
theorem wickBiDefectCount_eq_filter_card {m a b : ℕ} :
    wickBiDefectCount m a b =
      (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
        wickPlusDefect π = a ∧ wickMinusDefect π = b).card := by
  classical
  unfold wickBiDefectCount WickBiDefectClass
  rw [Fintype.card_subtype]

/-- Regroup the separated bidefect monomial by the two oriented defects. -/
theorem aubrunBiDefectWeight_sum_eq_countDoubleSum
    {m : ℕ} {d S : ℝ} :
    Finset.sum (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))) (fun π =>
      d ^ (m + 3 - wickPlusDefect π) *
        S ^ (m + 1 - wickMinusDefect π)) =
      aubrunBiDefectCountDoubleSum m d S := by
  classical
  unfold aubrunBiDefectCountDoubleSum
  have hmem : ∀ π ∈ (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))),
      (wickPlusDefect π, wickMinusDefect π) ∈
        (Finset.range (m + 3 + 1)).product (Finset.range (m + 1 + 1)) := by
    intro π _hπ
    simp
    constructor
    · have hle : wickPlusDefect π ≤ m := by
        have hπpos : 0 < permCycleClassCount π := by
          unfold permCycleClassCount setoidQuotientCard
          exact Fintype.card_pos_iff.mpr ⟨Quotient.mk'' (0 : Fin (m + 1))⟩
        have hγπpos :
            0 < permCycleClassCount (finRotate (m + 1) * π) := by
          unfold permCycleClassCount setoidQuotientCard
          exact Fintype.card_pos_iff.mpr ⟨Quotient.mk'' (0 : Fin (m + 1))⟩
        unfold wickPlusDefect
        omega
      omega
    · have hle : wickMinusDefect π ≤ m := by
        have hπpos : 0 < permCycleClassCount π := by
          unfold permCycleClassCount setoidQuotientCard
          exact Fintype.card_pos_iff.mpr ⟨Quotient.mk'' (0 : Fin (m + 1))⟩
        have hπγpos :
            0 < permCycleClassCount (π * (finRotate (m + 1)).symm) := by
          unfold permCycleClassCount setoidQuotientCard
          exact Fintype.card_pos_iff.mpr ⟨Quotient.mk'' (0 : Fin (m + 1))⟩
        unfold wickMinusDefect
        omega
      omega
  have hFiber :=
    Finset.sum_fiberwise_of_maps_to
      (s := (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))))
      (t := (Finset.range (m + 3 + 1)).product
        (Finset.range (m + 1 + 1)))
      (g := fun π : Equiv.Perm (Fin (m + 1)) =>
        (wickPlusDefect π, wickMinusDefect π))
      hmem
      (f := fun π : Equiv.Perm (Fin (m + 1)) =>
        d ^ (m + 3 - wickPlusDefect π) *
          S ^ (m + 1 - wickMinusDefect π))
  rw [← hFiber]
  trans Finset.sum (Finset.range (m + 3 + 1)) (fun a =>
      Finset.sum (Finset.range (m + 1 + 1)) (fun b =>
        Finset.sum (Finset.univ.filter
          fun π : Equiv.Perm (Fin (m + 1)) =>
            (wickPlusDefect π, wickMinusDefect π) = (a, b))
          (fun π => d ^ (m + 3 - wickPlusDefect π) *
            S ^ (m + 1 - wickMinusDefect π))))
  · exact Finset.sum_product (Finset.range (m + 3 + 1))
      (Finset.range (m + 1 + 1))
      (fun j : ℕ × ℕ =>
        Finset.sum (Finset.univ.filter
          fun π : Equiv.Perm (Fin (m + 1)) =>
            (wickPlusDefect π, wickMinusDefect π) = j)
          (fun π => d ^ (m + 3 - wickPlusDefect π) *
            S ^ (m + 1 - wickMinusDefect π)))
  · refine Finset.sum_congr rfl ?_
    intro a _ha
    refine Finset.sum_congr rfl ?_
    intro b _hb
    have hconst :
        Finset.sum (Finset.univ.filter
            fun π : Equiv.Perm (Fin (m + 1)) =>
              (wickPlusDefect π, wickMinusDefect π) = (a, b))
          (fun π => d ^ (m + 3 - wickPlusDefect π) *
            S ^ (m + 1 - wickMinusDefect π)) =
          ((Finset.univ.filter
            fun π : Equiv.Perm (Fin (m + 1)) =>
              (wickPlusDefect π, wickMinusDefect π) = (a, b)).card : ℝ) *
            (d ^ (m + 3 - a) * S ^ (m + 1 - b)) := by
      trans Finset.sum (Finset.univ.filter
            fun π : Equiv.Perm (Fin (m + 1)) =>
              (wickPlusDefect π, wickMinusDefect π) = (a, b))
          (fun _π => d ^ (m + 3 - a) * S ^ (m + 1 - b))
      · refine Finset.sum_congr rfl ?_
        intro π hπ
        have hp := (Finset.mem_filter.mp hπ).2
        injection hp with hpa hpb
        simp [hpa, hpb]
      · simp [nsmul_eq_mul]
    rw [hconst]
    have hcard :
        wickBiDefectCount m a b =
        (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          wickPlusDefect π = a ∧ wickMinusDefect π = b).card :=
      wickBiDefectCount_eq_filter_card (m := m) (a := a) (b := b)
    have hfilter :
        (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          (wickPlusDefect π, wickMinusDefect π) = (a, b)) =
        (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          wickPlusDefect π = a ∧ wickMinusDefect π = b) := by
      apply Finset.ext
      intro π
      simp [Prod.ext_iff]
    rw [hfilter, ← hcard]
    ring

/-- If every raw graduate-counting monomial is dominated by the separated
bidefect monomial, the whole raw permutation sum is controlled by the
bidefect double sum. -/
theorem graduateRelationSum_le_biDefectCountDoubleSum_of_term_le
    {m : ℕ} {d S : ℝ}
    (hTerm : ∀ π : Equiv.Perm (Fin (m + 1)),
      d ^ wickLeftClassCount π * d ^ wickRightClassCount π *
        S ^ (2 * wickColumnClassCount π) ≤
      d ^ (m + 3 - wickPlusDefect π) *
        S ^ (m + 1 - wickMinusDefect π)) :
    (Finset.sum (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))) (fun π =>
      d ^ wickLeftClassCount π * d ^ wickRightClassCount π *
        S ^ (2 * wickColumnClassCount π))) ≤
      aubrunBiDefectCountDoubleSum m d S := by
  calc
    Finset.sum (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))) (fun π =>
      d ^ wickLeftClassCount π * d ^ wickRightClassCount π *
        S ^ (2 * wickColumnClassCount π)) ≤
        Finset.sum (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))) (fun π =>
          d ^ (m + 3 - wickPlusDefect π) *
            S ^ (m + 1 - wickMinusDefect π)) := by
          exact Finset.sum_le_sum (by intro π _hπ; exact hTerm π)
    _ = aubrunBiDefectCountDoubleSum m d S :=
      aubrunBiDefectWeight_sum_eq_countDoubleSum (m := m) (d := d) (S := S)

/-- Graduate relation counting from the exact bidefect double-sum budget.

This is the honest public-facing bridge for the bidefect route: it does not
claim that the checked shifted-base scalar endpoint already has the old
graduate constant.  Instead, it exposes the two exact remaining inputs, namely
term domination by the separated bidefect monomial and the double-sum budget
with the graduate target constant. -/
theorem aubrunGraduateRelationCounting_of_biDefectDoubleSumBound_and_term_le
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ}
    (hTerm : ∀ π : Equiv.Perm (Fin (m + 1)),
      d ^ wickLeftClassCount π * d ^ wickRightClassCount π *
        Real.sqrt s ^ (2 * wickColumnClassCount π) ≤
      d ^ (m + 3 - wickPlusDefect π) *
        Real.sqrt s ^ (m + 1 - wickMinusDefect π))
    (hDouble :
      aubrunBiDefectCountDoubleSum m d (Real.sqrt s) ≤
        (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  unfold AubrunGraduateRelationCounting
  exact le_trans
    (graduateRelationSum_le_biDefectCountDoubleSum_of_term_le
      (m := m) (d := d) (S := Real.sqrt s) hTerm)
    hDouble

/-- Zero Aubrun defect is exactly simultaneous equality in the two Cayley
cycle-pair inequalities.

This is the geodesic form of the zero-defect slice: both paths
`1 → π → γ` and `1 → π → γ⁻¹` are tight in cycle-count distance. -/
theorem wickDefect_eq_zero_iff_cyclePairBounds_tight
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) :
    wickDefect π = 0 ↔
      permCycleClassCount π +
          permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1 ∧
        permCycleClassCount π +
          permCycleClassCount (π * (finRotate (m + 1)).symm) = (m + 1) + 1 := by
  constructor
  · intro hzero
    have hbudget := wickWeightedRank_add_wickDefect_eq_two_mul_add_two π
    have hrank : wickWeightedRank π = 2 * (m + 1) + 2 := by
      omega
    have hleftLe :
        permCycleClassCount π +
          permCycleClassCount (finRotate (m + 1) * π) ≤ (m + 1) + 1 := by
      exact cyclePairLeftBound_of_inverseLongCycleInvBound π
        (cyclePair_inverseLongCycleInvBound π)
    have hrightLe :
        permCycleClassCount π +
          permCycleClassCount (π * (finRotate (m + 1)).symm) ≤ (m + 1) + 1 := by
      exact cyclePairRightBound_of_inverseLongCycleBound π
        (cyclePair_inverseLongCycleBound π)
    have hsum :
        (permCycleClassCount π +
          permCycleClassCount (finRotate (m + 1) * π)) +
          (permCycleClassCount π +
            permCycleClassCount (π * (finRotate (m + 1)).symm)) =
            ((m + 1) + 1) + ((m + 1) + 1) := by
      have hrankCycle :
          permCycleClassCount (finRotate (m + 1) * π) +
              permCycleClassCount (π * (finRotate (m + 1)).symm) +
              2 * permCycleClassCount π =
            2 * (m + 1) + 2 := by
        simpa [wickWeightedRank_eq_cycleClassBudget] using hrank
      omega
    constructor <;> omega
  · rintro ⟨hleft, hright⟩
    have hrank : wickWeightedRank π = 2 * (m + 1) + 2 := by
      rw [wickWeightedRank_eq_cycleClassBudget]
      omega
    have hbudget := wickWeightedRank_add_wickDefect_eq_two_mul_add_two π
    omega

/-- Wick permutations that are tight for both Cayley cycle-pair inequalities. -/
noncomputable def WickCyclePairTightClass (m : ℕ) :=
  {π : Equiv.Perm (Fin (m + 1)) //
    permCycleClassCount π +
        permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1 ∧
      permCycleClassCount π +
        permCycleClassCount (π * (finRotate (m + 1)).symm) = (m + 1) + 1}

noncomputable instance (m : ℕ) : Fintype (WickCyclePairTightClass m) := by
  unfold WickCyclePairTightClass
  infer_instance

/-- Wick permutations tight for the left Cayley cycle-pair inequality. -/
noncomputable def WickCycleLeftTightClass (m : ℕ) :=
  {π : Equiv.Perm (Fin (m + 1)) //
    permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1}

noncomputable instance (m : ℕ) : Fintype (WickCycleLeftTightClass m) := by
  unfold WickCycleLeftTightClass
  infer_instance

/-- Transport a setoid on `Fin n` to a finpartition of the concrete range
`{0, …, n-1}` by sending each equivalence class through `Fin.val`. -/
noncomputable def finRangePartitionOfFinSetoid
    {n : ℕ} (S : Setoid (Fin n)) [DecidableRel S.r] :
    Finpartition (Finset.range n) := by
  classical
  let P : Finpartition (Finset.univ : Finset (Fin n)) :=
    Finpartition.ofSetoid S
  refine Finpartition.ofExistsUnique
    (P.parts.image (fun p : Finset (Fin n) => p.image Fin.val)) ?subset
    ?existsUnique ?nonempty
  · intro p hp
    rcases Finset.mem_image.mp hp with ⟨q, hq, rfl⟩
    intro a ha
    rcases Finset.mem_image.mp ha with ⟨i, _hi, rfl⟩
    exact Finset.mem_range.mpr i.2
  · intro a ha
    let i : Fin n := ⟨a, Finset.mem_range.mp ha⟩
    refine ⟨(P.part i).image Fin.val, ?_, ?_⟩
    · constructor
      · exact Finset.mem_image.mpr ⟨P.part i, P.part_mem.mpr (Finset.mem_univ i), rfl⟩
      · exact Finset.mem_image.mpr ⟨i, P.mem_part (Finset.mem_univ i), rfl⟩
    · intro t ht
      rcases ht with ⟨htParts, hat⟩
      rcases Finset.mem_image.mp htParts with ⟨q, hq, rfl⟩
      rcases Finset.mem_image.mp hat with ⟨j, hjq, hjval⟩
      have hji : j = i := by
        apply Fin.ext
        exact hjval
      subst j
      rw [P.part_eq_of_mem hq hjq]
  · intro h
    rcases Finset.mem_image.mp h with ⟨q, hq, hqempty⟩
    obtain ⟨i, hi⟩ := P.nonempty_of_mem_parts hq
    have : i.val ∈ q.image Fin.val :=
      Finset.mem_image.mpr ⟨i, hi, rfl⟩
    rw [hqempty] at this
    simpa using this

/-- Membership in the transported range partition is exactly membership in
the original `Fin n` setoid class. -/
theorem mem_finRangePartitionOfFinSetoid_part_iff
    {n : ℕ} (S : Setoid (Fin n)) [DecidableRel S.r]
    {a b : ℕ} (ha : a ∈ Finset.range n) (hb : b ∈ Finset.range n) :
    b ∈ (finRangePartitionOfFinSetoid S).part a ↔
      S ⟨a, Finset.mem_range.mp ha⟩ ⟨b, Finset.mem_range.mp hb⟩ := by
  classical
  let Pfin : Finpartition (Finset.univ : Finset (Fin n)) :=
    Finpartition.ofSetoid S
  let Prange : Finpartition (Finset.range n) :=
    finRangePartitionOfFinSetoid S
  let ia : Fin n := ⟨a, Finset.mem_range.mp ha⟩
  let ib : Fin n := ⟨b, Finset.mem_range.mp hb⟩
  constructor
  · intro h
    rcases (Finpartition.mem_part_iff_exists (P := Prange) (a := b) (b := a)).mp h
      with ⟨p, hp, hbp, hap⟩
    have hp' :
        p ∈ Pfin.parts.image (fun q : Finset (Fin n) => q.image Fin.val) := by
      simpa [Prange, finRangePartitionOfFinSetoid, Pfin] using hp
    rcases Finset.mem_image.mp hp' with ⟨q, hq, rfl⟩
    rcases Finset.mem_image.mp hap with ⟨ja, hja, hjaVal⟩
    rcases Finset.mem_image.mp hbp with ⟨jb, hjb, hjbVal⟩
    have hjaEq : ja = ia := by
      apply Fin.ext
      exact hjaVal
    have hjbEq : jb = ib := by
      apply Fin.ext
      exact hjbVal
    subst ja
    subst jb
    have hibPart : ib ∈ Pfin.part ia := by
      rw [Pfin.part_eq_of_mem hq hja]
      exact hjb
    simpa [Pfin, ia, ib] using
      (Finpartition.mem_part_ofSetoid_iff_rel (s := S) (a := ia) (b := ib)).mp
        hibPart
  · intro hrel
    have hibPart : ib ∈ Pfin.part ia := by
      exact
        (Finpartition.mem_part_ofSetoid_iff_rel (s := S) (a := ia) (b := ib)).mpr
          (by simpa [ia, ib] using hrel)
    have hp :
        (Pfin.part ia).image Fin.val ∈ Prange.parts := by
      have hp' :
          (Pfin.part ia).image Fin.val ∈
            Pfin.parts.image (fun q : Finset (Fin n) => q.image Fin.val) :=
        Finset.mem_image.mpr
          ⟨Pfin.part ia, Pfin.part_mem.mpr (Finset.mem_univ ia), rfl⟩
      simpa [Prange, finRangePartitionOfFinSetoid, Pfin] using hp'
    have hbmem : b ∈ (Pfin.part ia).image Fin.val :=
      Finset.mem_image.mpr ⟨ib, hibPart, rfl⟩
    have hamem : a ∈ (Pfin.part ia).image Fin.val :=
      Finset.mem_image.mpr
        ⟨ia, Pfin.mem_part (Finset.mem_univ ia), rfl⟩
    exact
      (Finpartition.mem_part_iff_exists (P := Prange) (a := b) (b := a)).mpr
        ⟨(Pfin.part ia).image Fin.val, hp, hbmem, hamem⟩

/-- The cycle partition of a one-sided geodesic permutation, transported to
the concrete range `{0, …, m}`.  This is the partition that should become
noncrossing in the Biane/Catalan base-count proof. -/
noncomputable def leftTightCyclePartitionRange
    {m : ℕ} (π : WickCycleLeftTightClass m) :
    Finpartition (Finset.range (m + 1)) := by
  classical
  exact finRangePartitionOfFinSetoid (Equiv.Perm.SameCycle.setoid π.1)

/-- Membership in the transported cycle partition is exactly membership in
the original permutation cycle. -/
theorem mem_leftTightCyclePartitionRange_part_iff
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1)) :
    b ∈ (leftTightCyclePartitionRange π).part a ↔
      π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩ := by
  classical
  simpa [leftTightCyclePartitionRange] using
    (mem_finRangePartitionOfFinSetoid_part_iff
      (Equiv.Perm.SameCycle.setoid π.1) ha hb)

/-- Equality of the transported natural-number cycle partitions is exactly
equality of the underlying `π` same-cycle setoids. -/
theorem leftTightCyclePartitionRange_eq_iff_sameCycle_setoid_eq
    {m : ℕ} {π τ : WickCycleLeftTightClass m} :
    leftTightCyclePartitionRange π = leftTightCyclePartitionRange τ ↔
      Equiv.Perm.SameCycle.setoid π.1 =
        Equiv.Perm.SameCycle.setoid τ.1 := by
  constructor
  · intro hPart
    apply Setoid.ext
    intro x y
    let hx : x.val ∈ Finset.range (m + 1) := Finset.mem_range.mpr x.2
    let hy : y.val ∈ Finset.range (m + 1) := Finset.mem_range.mpr y.2
    constructor
    · intro hxy
      have hmem :
          y.val ∈ (leftTightCyclePartitionRange π).part x.val := by
        exact (mem_leftTightCyclePartitionRange_part_iff π hx hy).mpr hxy
      have hmemτ :
          y.val ∈ (leftTightCyclePartitionRange τ).part x.val := by
        simpa [hPart] using hmem
      exact (mem_leftTightCyclePartitionRange_part_iff τ hx hy).mp hmemτ
    · intro hxy
      have hmem :
          y.val ∈ (leftTightCyclePartitionRange τ).part x.val := by
        exact (mem_leftTightCyclePartitionRange_part_iff τ hx hy).mpr hxy
      have hmemπ :
          y.val ∈ (leftTightCyclePartitionRange π).part x.val := by
        simpa [hPart] using hmem
      exact (mem_leftTightCyclePartitionRange_part_iff π hx hy).mp hmemπ
  · intro hSetoid
    unfold leftTightCyclePartitionRange
    rw [hSetoid]

/-- `y` is the cyclic predecessor of `x` inside the block of a finite setoid,
with the block ordered by the natural `Fin.val` order.

If the block has an element below `x`, the predecessor is the largest such
element.  If not, the predecessor is the largest element of the whole block.
For a singleton block this returns `x` itself. -/
def setoidBlockCyclicPred {n : ℕ} (S : Setoid (Fin n))
    (y x : Fin n) : Prop :=
  S y x ∧
    ((y.val < x.val ∧
        ∀ z : Fin n, S z x → z.val < x.val → z.val ≤ y.val) ∨
      ((∀ z : Fin n, S z x → ¬ z.val < x.val) ∧
        ∀ z : Fin n, S z x → z.val ≤ y.val))

/-- The cyclic predecessor in a finite setoid block is unique. -/
theorem setoidBlockCyclicPred_unique
    {n : ℕ} {S : Setoid (Fin n)} {x y z : Fin n}
    (hy : setoidBlockCyclicPred S y x)
    (hz : setoidBlockCyclicPred S z x) :
    y = z := by
  rcases hy with ⟨hyS, hyCases⟩
  rcases hz with ⟨hzS, hzCases⟩
  apply Fin.ext
  rcases hyCases with ⟨hylt, hyMaxBelow⟩ | ⟨hyNoBelow, hyMaxAll⟩
  · rcases hzCases with ⟨hzlt, hzMaxBelow⟩ | ⟨hzNoBelow, _hzMaxAll⟩
    · have hzy : z.val ≤ y.val := hyMaxBelow z hzS hzlt
      have hyz : y.val ≤ z.val := hzMaxBelow y hyS hylt
      omega
    · exact False.elim ((hzNoBelow y hyS) hylt)
  · rcases hzCases with ⟨hzlt, _hzMaxBelow⟩ | ⟨_hzNoBelow, hzMaxAll⟩
    · exact False.elim ((hyNoBelow z hzS) hzlt)
    · have hzy : z.val ≤ y.val := hyMaxAll z hzS
      have hyz : y.val ≤ z.val := hzMaxAll y hyS
      omega

/-- Ordered-predecessor reconstruction law for the one-sided left-tight
geodesic class.

This is the concrete remaining injectivity leaf suggested by the checked
finite cases: every left-tight permutation should send `x` to the cyclic
predecessor of `x` inside its own cycle block. -/
def leftTightOrderedPredecessorLaw (m : ℕ) : Prop :=
  ∀ π : WickCycleLeftTightClass m,
    ∀ x : Fin (m + 1),
      setoidBlockCyclicPred (Equiv.Perm.SameCycle.setoid π.1) (π.1 x) x

/-- The image of a point under a permutation lies in the same cycle as the
point itself. -/
theorem perm_apply_sameCycle_self
    {n : ℕ} (π : Equiv.Perm (Fin n)) (x : Fin n) :
    π.SameCycle (π x) x := by
  exact (Equiv.Perm.sameCycle_apply_left).mpr
    (Equiv.Perm.SameCycle.refl π x)

/-- Order-only form of the left-tight predecessor law.

The same-cycle part of `setoidBlockCyclicPred` is automatic for `π x`; the
real content is only the cyclic-order maximality of `π x` inside its cycle
block. -/
def leftTightOrderedPredecessorOrderLaw (m : ℕ) : Prop :=
  ∀ π : WickCycleLeftTightClass m,
    ∀ x : Fin (m + 1),
      (((π.1 x).val < x.val ∧
          ∀ z : Fin (m + 1),
            π.1.SameCycle z x → z.val < x.val → z.val ≤ (π.1 x).val) ∨
        ((∀ z : Fin (m + 1), π.1.SameCycle z x → ¬ z.val < x.val) ∧
          ∀ z : Fin (m + 1), π.1.SameCycle z x → z.val ≤ (π.1 x).val))

/-- The exact obstruction to `π x` being the cyclic predecessor of `x` in its
own cycle block.

There are two ways to fail.  In the non-wrapping case, `π x < x` but another
point of the same cycle lies strictly between `π x` and `x`.  In the wrapping
case, `π x` is not below `x`, but either the cycle has some point below `x` or
`π x` is not the maximum point of the cycle. -/
def permCyclicPredecessorSkip
    {n : ℕ} (π : Equiv.Perm (Fin n)) (x : Fin n) : Prop :=
  (((π x).val < x.val) ∧
      ∃ z : Fin n,
        π.SameCycle z x ∧ (π x).val < z.val ∧ z.val < x.val) ∨
    (¬ ((π x).val < x.val) ∧
      ((∃ z : Fin n, π.SameCycle z x ∧ z.val < x.val) ∨
        ∃ z : Fin n, π.SameCycle z x ∧ (π x).val < z.val))

/-- The order-only cyclic predecessor condition is exactly the absence of the
concrete skip obstruction. -/
theorem perm_orderPredecessorOrder_iff_not_cyclicPredecessorSkip
    {n : ℕ} (π : Equiv.Perm (Fin n)) (x : Fin n) :
    ((((π x).val < x.val ∧
          ∀ z : Fin n,
            π.SameCycle z x → z.val < x.val → z.val ≤ (π x).val) ∨
        ((∀ z : Fin n, π.SameCycle z x → ¬ z.val < x.val) ∧
          ∀ z : Fin n, π.SameCycle z x → z.val ≤ (π x).val))) ↔
      ¬ permCyclicPredecessorSkip π x := by
  constructor
  · intro hPred hSkip
    rcases hPred with ⟨hpx, hMaxBelow⟩ | ⟨hNoBelow, hMaxAll⟩
    · rcases hSkip with hSkipBelow | hSkipWrap
      · rcases hSkipBelow with ⟨_hpx', z, hz, hpz, hzx⟩
        have hzle := hMaxBelow z hz hzx
        omega
      · exact hSkipWrap.1 hpx
    · rcases hSkip with hSkipBelow | hSkipWrap
      · exact (hNoBelow (π x) (perm_apply_sameCycle_self π x)) hSkipBelow.1
      · rcases hSkipWrap with ⟨_hpx, hBelowOrAbove⟩
        rcases hBelowOrAbove with hBelow | hAbove
        · rcases hBelow with ⟨z, hz, hzx⟩
          exact (hNoBelow z hz) hzx
        · rcases hAbove with ⟨z, hz, hpz⟩
          have hzle := hMaxAll z hz
          omega
  · intro hNoSkip
    by_cases hpx : (π x).val < x.val
    · left
      refine ⟨hpx, ?_⟩
      intro z hz hzx
      by_contra hnot
      have hpz : (π x).val < z.val := Nat.lt_of_not_ge hnot
      exact hNoSkip (Or.inl ⟨hpx, z, hz, hpz, hzx⟩)
    · right
      refine ⟨?_, ?_⟩
      · intro z hz hzx
        exact hNoSkip (Or.inr ⟨hpx, Or.inl ⟨z, hz, hzx⟩⟩)
      · intro z hz
        by_contra hnot
        have hpz : (π x).val < z.val := Nat.lt_of_not_ge hnot
        exact hNoSkip (Or.inr ⟨hpx, Or.inr ⟨z, hz, hpz⟩⟩)

/-- Left-tight ordered-predecessor reconstruction is equivalent to ruling out
the concrete predecessor-skip pattern in every left-tight cycle. -/
theorem leftTightOrderedPredecessorOrderLaw_iff_no_cyclicPredecessorSkip
    (m : ℕ) :
    leftTightOrderedPredecessorOrderLaw m ↔
      ¬ ∃ π : WickCycleLeftTightClass m,
        ∃ x : Fin (m + 1), permCyclicPredecessorSkip π.1 x := by
  constructor
  · intro hLaw hBad
    rcases hBad with ⟨π, x, hSkip⟩
    exact
      (perm_orderPredecessorOrder_iff_not_cyclicPredecessorSkip
        π.1 x).mp (hLaw π x) hSkip
  · intro hNoBad π x
    exact
      (perm_orderPredecessorOrder_iff_not_cyclicPredecessorSkip
        π.1 x).mpr
        (fun hSkip => hNoBad ⟨π, x, hSkip⟩)

/-- Fixed points satisfy the order-only predecessor law trivially.

If `π x = x`, then the `π`-cycle block of `x` is a singleton, so there is no
element below `x` in that block and `x` is the maximum of the block. -/
theorem perm_fixed_point_orderPredecessorOrder
    {n : ℕ} (π : Equiv.Perm (Fin n)) {x : Fin n} (hfix : π x = x) :
    (((π x).val < x.val ∧
        ∀ z : Fin n, π.SameCycle z x → z.val < x.val → z.val ≤ (π x).val) ∨
      ((∀ z : Fin n, π.SameCycle z x → ¬ z.val < x.val) ∧
        ∀ z : Fin n, π.SameCycle z x → z.val ≤ (π x).val)) := by
  right
  constructor
  · intro z hz hzx
    have hxz : x = z :=
      hz.symm.eq_of_left (show Function.IsFixedPt π x from hfix)
    have hval : z.val = x.val := congrArg Fin.val hxz.symm
    omega
  · intro z hz
    have hxz : x = z :=
      hz.symm.eq_of_left (show Function.IsFixedPt π x from hfix)
    have hval : z.val = x.val := congrArg Fin.val hxz.symm
    have hπx : (π x).val = x.val := congrArg Fin.val hfix
    omega

/-- Left-tight specialization: fixed points already satisfy the order-only
predecessor condition. -/
theorem leftTightOrderedPredecessorOrderLaw_at_fixed
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hfix : π.1 x = x) :
    (((π.1 x).val < x.val ∧
        ∀ z : Fin (m + 1),
          π.1.SameCycle z x → z.val < x.val → z.val ≤ (π.1 x).val) ∨
      ((∀ z : Fin (m + 1), π.1.SameCycle z x → ¬ z.val < x.val) ∧
        ∀ z : Fin (m + 1),
          π.1.SameCycle z x → z.val ≤ (π.1 x).val)) :=
  perm_fixed_point_orderPredecessorOrder π.1 hfix

/-- After the fixed-point case is discharged, the ordered-predecessor leaf is
exactly the absence of non-fixed predecessor skips. -/
theorem leftTightOrderedPredecessorOrderLaw_iff_no_nonfixed_cyclicPredecessorSkip
    (m : ℕ) :
    leftTightOrderedPredecessorOrderLaw m ↔
      ¬ ∃ π : WickCycleLeftTightClass m,
        ∃ x : Fin (m + 1),
          π.1 x ≠ x ∧ permCyclicPredecessorSkip π.1 x := by
  constructor
  · intro hLaw hBad
    rcases hBad with ⟨π, x, _hnotfix, hSkip⟩
    exact
      (perm_orderPredecessorOrder_iff_not_cyclicPredecessorSkip
        π.1 x).mp (hLaw π x) hSkip
  · intro hNoBad π x
    by_cases hfix : π.1 x = x
    · exact leftTightOrderedPredecessorOrderLaw_at_fixed π hfix
    · exact
        (perm_orderPredecessorOrder_iff_not_cyclicPredecessorSkip
          π.1 x).mpr
          (fun hSkip => hNoBad ⟨π, x, hfix, hSkip⟩)

/-- The order-only predecessor law supplies the full predecessor law. -/
theorem leftTightOrderedPredecessorLaw_of_orderLaw
    {m : ℕ} (hLaw : leftTightOrderedPredecessorOrderLaw m) :
    leftTightOrderedPredecessorLaw m := by
  intro π x
  exact ⟨perm_apply_sameCycle_self π.1 x, hLaw π x⟩

/-- If the ordered-predecessor reconstruction law holds, then the same-cycle
setoid determines the left-tight permutation. -/
theorem leftTight_sameCycle_setoid_determines_perm_of_orderedPredecessorLaw
    {m : ℕ} (hLaw : leftTightOrderedPredecessorLaw m)
    {π τ : WickCycleLeftTightClass m}
    (hSetoid :
      Equiv.Perm.SameCycle.setoid π.1 =
        Equiv.Perm.SameCycle.setoid τ.1) :
    π.1 = τ.1 := by
  ext x
  have hfin : π.1 x = τ.1 x :=
    setoidBlockCyclicPred_unique
      (S := Equiv.Perm.SameCycle.setoid π.1) (x := x)
      (y := π.1 x) (z := τ.1 x)
      (hLaw π x)
      (by
        have hτ := hLaw τ x
        simpa [hSetoid] using hτ)
  exact congrArg Fin.val hfin

/-- The ordered-predecessor reconstruction law closes the injectivity of the
left-tight cycle-partition encoding. -/
theorem leftTightCyclePartitionRange_injective_of_orderedPredecessorLaw
    {m : ℕ} (hLaw : leftTightOrderedPredecessorLaw m) :
    Function.Injective
      (fun π : WickCycleLeftTightClass m => leftTightCyclePartitionRange π) := by
  intro π τ hPart
  apply Subtype.ext
  exact
    leftTight_sameCycle_setoid_determines_perm_of_orderedPredecessorLaw
      hLaw ((leftTightCyclePartitionRange_eq_iff_sameCycle_setoid_eq).mp hPart)

/-- The left-tight cycle-partition encoding is injective once non-fixed
predecessor skips are ruled out. -/
theorem leftTightCyclePartitionRange_injective_of_no_nonfixed_cyclicPredecessorSkip
    {m : ℕ}
    (hNoSkip :
      ¬ ∃ π : WickCycleLeftTightClass m,
        ∃ x : Fin (m + 1),
          π.1 x ≠ x ∧ permCyclicPredecessorSkip π.1 x) :
    Function.Injective
      (fun π : WickCycleLeftTightClass m => leftTightCyclePartitionRange π) := by
  exact
    leftTightCyclePartitionRange_injective_of_orderedPredecessorLaw
      (leftTightOrderedPredecessorLaw_of_orderLaw
        ((leftTightOrderedPredecessorOrderLaw_iff_no_nonfixed_cyclicPredecessorSkip
          m).mpr hNoSkip))

/-- Noncrossing of the transported cycle partition is exactly the concrete
crossing-exclusion statement for cycles of the permutation. -/
theorem leftTightCyclePartitionRange_nonCrossing_iff_no_crossing_cycles
    {m : ℕ} (π : WickCycleLeftTightClass m) :
    NCPartition.NonCrossing (leftTightCyclePartitionRange π) ↔
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ := by
  classical
  let P : Finpartition (Finset.range (m + 1)) :=
    leftTightCyclePartitionRange π
  constructor
  · intro hNC a b c d ha hb hc hd hab hbc hcd hac hbd
    have haPart : a ∈ P.part a := P.mem_part ha
    have hbPart : b ∈ P.part b := P.mem_part hb
    have hcPart : c ∈ P.part a := by
      have := (mem_leftTightCyclePartitionRange_part_iff π ha hc).mpr hac
      simpa [P] using this
    have hdPart : d ∈ P.part b := by
      have := (mem_leftTightCyclePartitionRange_part_iff π hb hd).mpr hbd
      simpa [P] using this
    have hparts :
        P.part a = P.part b :=
      hNC (P.part a) (P.part_mem.mpr ha)
        (P.part b) (P.part_mem.mpr hb)
        a haPart b hbPart c hcPart d hdPart hab hbc hcd
    have hbInPartA : b ∈ P.part a := by
      rw [hparts]
      exact hbPart
    exact (mem_leftTightCyclePartitionRange_part_iff π ha hb).mp
      (by simpa [P] using hbInPartA)
  · intro hcross
    intro B₁ hB₁ B₂ hB₂ a haB₁ b hbB₂ c hcB₁ d hdB₂ hab hbc hcd
    have ha : a ∈ Finset.range (m + 1) := P.le hB₁ haB₁
    have hb : b ∈ Finset.range (m + 1) := P.le hB₂ hbB₂
    have hc : c ∈ Finset.range (m + 1) := P.le hB₁ hcB₁
    have hd : d ∈ Finset.range (m + 1) := P.le hB₂ hdB₂
    have hPartA : P.part a = B₁ := P.part_eq_of_mem hB₁ haB₁
    have hPartB : P.part b = B₂ := P.part_eq_of_mem hB₂ hbB₂
    have hcPart : c ∈ P.part a := by
      simpa [hPartA] using hcB₁
    have hdPart : d ∈ P.part b := by
      simpa [hPartB] using hdB₂
    have hac :
        π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ :=
      (mem_leftTightCyclePartitionRange_part_iff π ha hc).mp
        (by simpa [P] using hcPart)
    have hbd :
        π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
          ⟨d, Finset.mem_range.mp hd⟩ :=
      (mem_leftTightCyclePartitionRange_part_iff π hb hd).mp
        (by simpa [P] using hdPart)
    have habCycle :=
      hcross a b c d ha hb hc hd hab hbc hcd hac hbd
    have hbInPartA : b ∈ P.part a :=
      (mem_leftTightCyclePartitionRange_part_iff π ha hb).mpr habCycle
    have hparts : P.part a = P.part b :=
      ((P.mem_part_iff_part_eq_part hb ha).mp hbInPartA).symm
    calc
      B₁ = P.part a := hPartA.symm
      _ = P.part b := hparts
      _ = B₂ := hPartB

/-- Catalan numbers satisfy the crude exponential bound needed after the
Biane/noncrossing injection. -/
theorem catalan_le_four_pow_real (m : ℕ) :
    (catalan m : ℝ) ≤ (4 : ℝ) ^ m := by
  have hcat_nat : catalan m ≤ Nat.centralBinom m := by
    rw [catalan_eq_centralBinom_div]
    exact Nat.div_le_self _ _
  exact_mod_cast (le_trans hcat_nat (Nat.centralBinom_le_four_pow m))

/-- The incidence edge generated by a point of the original finite set. -/
noncomputable def setoidIncidenceEdgeOf {α : Type*} [Fintype α]
    (S T : Setoid α) (a : α) : (setoidIncidenceGraph S T).edgeSet :=
  ⟨s(Sum.inl (Quotient.mk'' a), Sum.inr (Quotient.mk'' a)), by
    change (setoidIncidenceGraph S T).Adj
      (Sum.inl (Quotient.mk'' a)) (Sum.inr (Quotient.mk'' a))
    exact ⟨a, Or.inl ⟨rfl, rfl⟩⟩⟩

/-- Two incidence edges whose points are equivalent for the right setoid share
their right quotient vertex. -/
theorem setoidIncidenceEdgeOf_common_right_of_rel {α : Type*} [Fintype α]
    (S T : Setoid α) {x y : α} (hT : T x y) :
    ∃ v : Quotient S ⊕ Quotient T,
      v ∈ ((setoidIncidenceEdgeOf S T x :
          (setoidIncidenceGraph S T).edgeSet) :
        Sym2 (Quotient S ⊕ Quotient T)) ∧
        v ∈ ((setoidIncidenceEdgeOf S T y :
            (setoidIncidenceGraph S T).edgeSet) :
          Sym2 (Quotient S ⊕ Quotient T)) := by
  refine ⟨Sum.inr (Quotient.mk'' x), ?_, ?_⟩
  · simp [setoidIncidenceEdgeOf]
  · have hq : (Quotient.mk'' y : Quotient T) = Quotient.mk'' x :=
      (Quotient.sound hT).symm
    simp [setoidIncidenceEdgeOf, hq]

/-- Two incidence edges whose points are equivalent for the left setoid share
their left quotient vertex. -/
theorem setoidIncidenceEdgeOf_common_left_of_rel {α : Type*} [Fintype α]
    (S T : Setoid α) {x y : α} (hS : S x y) :
    ∃ v : Quotient S ⊕ Quotient T,
      v ∈ ((setoidIncidenceEdgeOf S T x :
          (setoidIncidenceGraph S T).edgeSet) :
        Sym2 (Quotient S ⊕ Quotient T)) ∧
        v ∈ ((setoidIncidenceEdgeOf S T y :
            (setoidIncidenceGraph S T).edgeSet) :
          Sym2 (Quotient S ⊕ Quotient T)) := by
  refine ⟨Sum.inl (Quotient.mk'' x), ?_, ?_⟩
  · simp [setoidIncidenceEdgeOf]
  · have hq : (Quotient.mk'' y : Quotient S) = Quotient.mk'' x :=
      (Quotient.sound hS).symm
    simp [setoidIncidenceEdgeOf, hq]

/-- Right-setoid equivalence gives line-graph adjacency between the
corresponding incidence edges, once the two edges are known to be distinct. -/
theorem setoidIncidenceEdgeOf_lineGraph_adj_right_of_rel_ne
    {α : Type*} [Fintype α]
    (S T : Setoid α) {x y : α} (hT : T x y)
    (hne : setoidIncidenceEdgeOf S T x ≠ setoidIncidenceEdgeOf S T y) :
    (setoidIncidenceGraph S T).lineGraph.Adj
      (setoidIncidenceEdgeOf S T x) (setoidIncidenceEdgeOf S T y) := by
  rw [SimpleGraph.lineGraph_adj_iff_exists]
  exact ⟨hne, setoidIncidenceEdgeOf_common_right_of_rel S T hT⟩

/-- Left-setoid equivalence gives line-graph adjacency between the
corresponding incidence edges, once the two edges are known to be distinct. -/
theorem setoidIncidenceEdgeOf_lineGraph_adj_left_of_rel_ne
    {α : Type*} [Fintype α]
    (S T : Setoid α) {x y : α} (hS : S x y)
    (hne : setoidIncidenceEdgeOf S T x ≠ setoidIncidenceEdgeOf S T y) :
    (setoidIncidenceGraph S T).lineGraph.Adj
      (setoidIncidenceEdgeOf S T x) (setoidIncidenceEdgeOf S T y) := by
  rw [SimpleGraph.lineGraph_adj_iff_exists]
  exact ⟨hne, setoidIncidenceEdgeOf_common_left_of_rel S T hS⟩

/-- Every incidence edge is generated by some point of the original finite
set. -/
theorem setoidIncidenceEdgeOf_surjective {α : Type*} [Fintype α]
    (S T : Setoid α) :
    Function.Surjective (setoidIncidenceEdgeOf S T) := by
  intro e
  rcases e with ⟨e, he⟩
  induction e using Sym2.ind with
  | h u v =>
      change (setoidIncidenceGraph S T).Adj u v at he
      rcases he with ⟨a, h | h⟩
      · rcases h with ⟨rfl, rfl⟩
        refine ⟨a, Subtype.ext ?_⟩
        rfl
      · rcases h with ⟨rfl, rfl⟩
        refine ⟨a, Subtype.ext ?_⟩
        exact Sym2.eq_swap

/-- A right-setoid link gives the direct two-edge walk between the two
corresponding left quotient vertices in the incidence graph. -/
def setoidIncidenceGraph_left_walk_of_right_rel
    {α : Type*} [Fintype α] (S T : Setoid α) {x y : α}
    (hT : T x y) :
    (setoidIncidenceGraph S T).Walk
      (Sum.inl (Quotient.mk'' x : Quotient S))
      (Sum.inl (Quotient.mk'' y : Quotient S)) := by
  have hxyq : (Quotient.mk'' x : Quotient T) = Quotient.mk'' y :=
    Quotient.sound hT
  have h1 :
      (setoidIncidenceGraph S T).Adj
        (Sum.inl (Quotient.mk'' x : Quotient S))
        (Sum.inr (Quotient.mk'' x : Quotient T)) :=
    setoidIncidenceGraph_left_adj_right S T x
  have h2 :
      (setoidIncidenceGraph S T).Adj
        (Sum.inr (Quotient.mk'' x : Quotient T))
        (Sum.inl (Quotient.mk'' y : Quotient S)) := by
    rw [hxyq]
    exact (setoidIncidenceGraph_left_adj_right S T y).symm
  exact SimpleGraph.Walk.cons h1 (SimpleGraph.Walk.cons h2 SimpleGraph.Walk.nil)

/-- If the two left quotient vertices are distinct, the direct walk supplied by
a right-setoid link is a simple path. -/
theorem setoidIncidenceGraph_left_walk_of_right_rel_isPath
    {α : Type*} [Fintype α] (S T : Setoid α) {x y : α}
    (hT : T x y) (hS : ¬ S x y) :
    (setoidIncidenceGraph_left_walk_of_right_rel S T hT).IsPath := by
  classical
  have hxyq : (Quotient.mk'' x : Quotient T) = Quotient.mk'' y :=
    Quotient.sound hT
  have hleft_ne :
      (Sum.inl (Quotient.mk'' x : Quotient S) :
          Quotient S ⊕ Quotient T) ≠
        Sum.inl (Quotient.mk'' y : Quotient S) := by
    intro h
    apply hS
    exact Quotient.exact (by simpa using Sum.inl.inj h)
  simp [setoidIncidenceGraph_left_walk_of_right_rel, hxyq, hleft_ne,
    SimpleGraph.Walk.isPath_def]

/-- The direct incidence walk attached to a right-setoid link has length two. -/
theorem setoidIncidenceGraph_left_walk_of_right_rel_length
    {α : Type*} [Fintype α] (S T : Setoid α) {x y : α}
    (hT : T x y) :
    (setoidIncidenceGraph_left_walk_of_right_rel S T hT).length = 2 := by
  simp [setoidIncidenceGraph_left_walk_of_right_rel]

/-- A left-setoid link gives the direct two-edge walk between the two
corresponding right quotient vertices in the incidence graph. -/
def setoidIncidenceGraph_right_walk_of_left_rel
    {α : Type*} [Fintype α] (S T : Setoid α) {x y : α}
    (hS : S x y) :
    (setoidIncidenceGraph S T).Walk
      (Sum.inr (Quotient.mk'' x : Quotient T))
      (Sum.inr (Quotient.mk'' y : Quotient T)) := by
  have hxyq : (Quotient.mk'' x : Quotient S) = Quotient.mk'' y :=
    Quotient.sound hS
  have h1 :
      (setoidIncidenceGraph S T).Adj
        (Sum.inr (Quotient.mk'' x : Quotient T))
        (Sum.inl (Quotient.mk'' x : Quotient S)) :=
    (setoidIncidenceGraph_left_adj_right S T x).symm
  have h2 :
      (setoidIncidenceGraph S T).Adj
        (Sum.inl (Quotient.mk'' x : Quotient S))
        (Sum.inr (Quotient.mk'' y : Quotient T)) := by
    rw [hxyq]
    exact setoidIncidenceGraph_left_adj_right S T y
  exact SimpleGraph.Walk.cons h1 (SimpleGraph.Walk.cons h2 SimpleGraph.Walk.nil)

/-- If the two right quotient vertices are distinct, the direct walk supplied
by a left-setoid link is a simple path. -/
theorem setoidIncidenceGraph_right_walk_of_left_rel_isPath
    {α : Type*} [Fintype α] (S T : Setoid α) {x y : α}
    (hS : S x y) (hT : ¬ T x y) :
    (setoidIncidenceGraph_right_walk_of_left_rel S T hS).IsPath := by
  classical
  have hxyq : (Quotient.mk'' x : Quotient S) = Quotient.mk'' y :=
    Quotient.sound hS
  have hright_ne :
      (Sum.inr (Quotient.mk'' x : Quotient T) :
          Quotient S ⊕ Quotient T) ≠
        Sum.inr (Quotient.mk'' y : Quotient T) := by
    intro h
    apply hT
    exact Quotient.exact (by simpa using Sum.inr.inj h)
  simp [setoidIncidenceGraph_right_walk_of_left_rel, hxyq, hright_ne,
    SimpleGraph.Walk.isPath_def]

/-- The direct incidence walk attached to a left-setoid link has length two. -/
theorem setoidIncidenceGraph_right_walk_of_left_rel_length
    {α : Type*} [Fintype α] (S T : Setoid α) {x y : α}
    (hS : S x y) :
    (setoidIncidenceGraph_right_walk_of_left_rel S T hS).length = 2 := by
  simp [setoidIncidenceGraph_right_walk_of_left_rel]

/-- If the incidence graph has as many edges as the original finite set, then
the point-to-edge map is bijective. -/
theorem setoidIncidenceEdgeOf_bijective_of_card_eq {α : Type*} [Fintype α]
    (S T : Setoid α)
    (hcard : Nat.card (setoidIncidenceGraph S T).edgeSet = Fintype.card α) :
    Function.Bijective (setoidIncidenceEdgeOf S T) := by
  classical
  refine
    (Fintype.bijective_iff_surjective_and_card
      (setoidIncidenceEdgeOf S T)).mpr ?_
  constructor
  · exact setoidIncidenceEdgeOf_surjective S T
  · rw [Nat.card_eq_fintype_card] at hcard
    exact hcard.symm

/-- Equality case in the Cayley cycle-count bound for the one-sided geodesic
class.

The proof of the Cayley bound uses the incidence graph between the cycle
partition of `finRotate * π` and the cycle partition of `π`.  If the left
cycle-pair bound is tight, this connected incidence graph has exactly `m+1`
edges, i.e. it is at the tree-count threshold.  This is a structural
component of the eventual Catalan/Biane count for the base slice `a = 0`. -/
theorem leftTight_incidenceGraph_edgeSet_card_eq_self
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1) :
    Nat.card (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).edgeSet = m + 1 := by
  classical
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  have hmul : (finRotate (m + 1) * π) * π⁻¹ = finRotate (m + 1) := by
    ext x
    simp
  have htopInv :
      Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π) ⊔
        Equiv.Perm.SameCycle.setoid π⁻¹ = ⊤ :=
    sameCycle_setoid_sup_top_of_mul_fullCycle
      (finRotate (m + 1) * π) π⁻¹ (Nat.succ_pos m) hmul
  have hinvSetoid :
      Equiv.Perm.SameCycle.setoid π⁻¹ = Equiv.Perm.SameCycle.setoid π := by
    apply Setoid.ext
    intro a b
    change π⁻¹.SameCycle a b ↔ π.SameCycle a b
    exact Equiv.Perm.sameCycle_inv
  have htop : S ⊔ T = ⊤ := by
    dsimp [S, T]
    simpa [hinvSetoid] using htopInv
  let G := setoidIncidenceGraph S T
  haveI : Nonempty (Fin (m + 1)) := ⟨0⟩
  have hconn : G.Connected :=
    setoidIncidenceGraph_connected_of_sup_top S T htop
  have hver := hconn.card_vert_le_card_edgeSet_add_one
  have hedge : Nat.card G.edgeSet ≤ m + 1 := by
    have h := setoidIncidenceGraph_edgeSet_card_le S T
    simpa [G] using h
  have hvertexCard : Nat.card (Quotient S ⊕ Quotient T) = (m + 1) + 1 := by
    rw [Nat.card_eq_fintype_card, Fintype.card_sum]
    dsimp [S, T]
    change setoidQuotientCard
        (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) +
      setoidQuotientCard (Equiv.Perm.SameCycle.setoid π) = (m + 1) + 1
    rw [add_comm]
    exact hleft
  have hver' : (m + 1) + 1 ≤ Nat.card G.edgeSet + 1 := by
    rw [← hvertexCard]
    exact hver
  change Nat.card G.edgeSet = m + 1
  omega

/-- The incidence graph attached to a one-sided Cayley-geodesic permutation is
a tree.

This packages the equality case of the Cayley cycle-count proof in graph
language: the incidence graph is connected and has exactly one fewer edge than
vertices. -/
theorem leftTight_incidenceGraph_isTree
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).IsTree := by
  classical
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  have hmul : (finRotate (m + 1) * π) * π⁻¹ = finRotate (m + 1) := by
    ext x
    simp
  have htopInv :
      Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π) ⊔
        Equiv.Perm.SameCycle.setoid π⁻¹ = ⊤ :=
    sameCycle_setoid_sup_top_of_mul_fullCycle
      (finRotate (m + 1) * π) π⁻¹ (Nat.succ_pos m) hmul
  have hinvSetoid :
      Equiv.Perm.SameCycle.setoid π⁻¹ = Equiv.Perm.SameCycle.setoid π := by
    apply Setoid.ext
    intro a b
    change π⁻¹.SameCycle a b ↔ π.SameCycle a b
    exact Equiv.Perm.sameCycle_inv
  have htop : S ⊔ T = ⊤ := by
    dsimp [S, T]
    simpa [hinvSetoid] using htopInv
  let G := setoidIncidenceGraph S T
  haveI : Nonempty (Fin (m + 1)) := ⟨0⟩
  have hconn : G.Connected :=
    setoidIncidenceGraph_connected_of_sup_top S T htop
  have hedge : Nat.card G.edgeSet = m + 1 := by
    dsimp [G, S, T]
    exact leftTight_incidenceGraph_edgeSet_card_eq_self hleft
  have hvertexCard : Nat.card (Quotient S ⊕ Quotient T) = (m + 1) + 1 := by
    rw [Nat.card_eq_fintype_card, Fintype.card_sum]
    dsimp [S, T]
    change setoidQuotientCard
        (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) +
      setoidQuotientCard (Equiv.Perm.SameCycle.setoid π) = (m + 1) + 1
    rw [add_comm]
    exact hleft
  have hcard : Nat.card G.edgeSet + 1 = Nat.card (Quotient S ⊕ Quotient T) := by
    rw [hedge, hvertexCard]
  have htree : G.IsTree := by
    rw [SimpleGraph.isTree_iff_connected_and_card]
    exact ⟨hconn, hcard⟩
  simpa [G, S, T] using htree

/-- Simple paths in the left-tight incidence graph are unique.

This is the exact tree-uniqueness principle needed to compare the Biane
contour path with the direct path supplied by a cycle link. -/
theorem leftTight_incidenceGraph_path_unique
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {u v : Quotient (Equiv.Perm.SameCycle.setoid
        (finRotate (m + 1) * π)) ⊕
      Quotient (Equiv.Perm.SameCycle.setoid π)}
    (p q : (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Path u v) :
    p = q := by
  exact (leftTight_incidenceGraph_isTree hleft).isAcyclic.path_unique p q

/-- Walk-level version of path uniqueness in the left-tight incidence graph:
there is a unique simple walk between any two incidence vertices. -/
theorem leftTight_incidenceGraph_existsUnique_isPath
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    (u v : Quotient (Equiv.Perm.SameCycle.setoid
        (finRotate (m + 1) * π)) ⊕
      Quotient (Equiv.Perm.SameCycle.setoid π)) :
    ∃! p : (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Walk u v, p.IsPath := by
  exact (SimpleGraph.isTree_iff_existsUnique_path.mp
    (leftTight_incidenceGraph_isTree hleft)).2 u v

/-- An acyclic simple graph cannot contain a four-cycle with opposite
vertices distinct. -/
theorem simpleGraph_isAcyclic_not_square
    {V : Type*} {G : SimpleGraph V}
    (hG : G.IsAcyclic)
    {a b c d : V}
    (hab : G.Adj a b) (hbc : G.Adj b c)
    (hcd : G.Adj c d) (hda : G.Adj d a)
    (hac : a ≠ c) (hbd : b ≠ d) :
    False := by
  have hab_ne : a ≠ b := hab.ne
  have hba_ne : b ≠ a := hab.ne.symm
  have hbc_ne : b ≠ c := hbc.ne
  have hcd_ne : c ≠ d := hcd.ne
  have hda_ne : d ≠ a := hda.ne
  have had_ne : a ≠ d := hda.ne.symm
  have hca : c ≠ a := hac.symm
  let w : G.Walk a a :=
    SimpleGraph.Walk.cons hab
      (SimpleGraph.Walk.cons hbc
        (SimpleGraph.Walk.cons hcd
          (SimpleGraph.Walk.cons hda SimpleGraph.Walk.nil)))
  have hw : w.IsCycle := by
    simp [w, SimpleGraph.Walk.isCycle_def, SimpleGraph.Walk.isTrail_def,
      SimpleGraph.Walk.edges_cons, SimpleGraph.Walk.support_cons,
      Sym2.eq, hab_ne, hba_ne, hbc_ne, hcd_ne, hda_ne, had_ne, hac, hca, hbd]
  exact hG w hw

/-- The incidence graph of a one-sided Cayley-geodesic permutation has no
embedded square.  This is the graph-theoretic obstruction needed after a
crossing of cycles has been converted into an incidence square. -/
theorem leftTight_incidenceGraph_not_square
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a b c d : Quotient (Equiv.Perm.SameCycle.setoid
        (finRotate (m + 1) * π)) ⊕
      Quotient (Equiv.Perm.SameCycle.setoid π)}
    (hab : (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Adj a b)
    (hbc : (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Adj b c)
    (hcd : (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Adj c d)
    (hda : (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Adj d a)
    (hac : a ≠ c) (hbd : b ≠ d) :
    False := by
  have htree := leftTight_incidenceGraph_isTree hleft
  exact simpleGraph_isAcyclic_not_square htree.isAcyclic hab hbc hcd hda hac hbd

/-- Point-level form of the incidence-square obstruction.

If two `π`-cycle links and two `(finRotate * π)`-cycle links form an
alternating square, then the left-tight incidence graph would contain a
forbidden four-cycle. -/
theorem leftTight_forbid_point_incidence_square
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {x₀ x₁ x₂ x₃ : Fin (m + 1)}
    (hT02 : π.SameCycle x₀ x₂)
    (hT13 : π.SameCycle x₁ x₃)
    (hS01 : (finRotate (m + 1) * π).SameCycle x₀ x₁)
    (hS23 : (finRotate (m + 1) * π).SameCycle x₂ x₃)
    (hT01 : ¬ π.SameCycle x₀ x₁)
    (hS02 : ¬ (finRotate (m + 1) * π).SameCycle x₀ x₂) :
    False := by
  classical
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  let A : Quotient S ⊕ Quotient T := Sum.inr (Quotient.mk'' x₀)
  let B : Quotient S ⊕ Quotient T := Sum.inl (Quotient.mk'' x₀)
  let C : Quotient S ⊕ Quotient T := Sum.inr (Quotient.mk'' x₁)
  let D : Quotient S ⊕ Quotient T := Sum.inl (Quotient.mk'' x₂)
  have hAB : (setoidIncidenceGraph S T).Adj A B := by
    exact ⟨x₀, Or.inr ⟨rfl, rfl⟩⟩
  have hBC : (setoidIncidenceGraph S T).Adj B C := by
    refine ⟨x₁, Or.inl ⟨?_, rfl⟩⟩
    exact congrArg Sum.inl (Quotient.sound (by simpa [S] using hS01))
  have hCD : (setoidIncidenceGraph S T).Adj C D := by
    refine ⟨x₃, Or.inr ⟨?_, ?_⟩⟩
    · exact congrArg Sum.inr (Quotient.sound (by simpa [T] using hT13))
    · exact congrArg Sum.inl (Quotient.sound (by simpa [S] using hS23))
  have hDA : (setoidIncidenceGraph S T).Adj D A := by
    refine ⟨x₂, Or.inl ⟨rfl, ?_⟩⟩
    exact congrArg Sum.inr (Quotient.sound (by simpa [T] using hT02))
  have hAC : A ≠ C := by
    intro h
    have hq : (Quotient.mk'' x₀ : Quotient T) = Quotient.mk'' x₁ := by
      simpa [A, C] using h
    exact hT01 (by simpa [T] using Quotient.exact hq)
  have hBD : B ≠ D := by
    intro h
    have hq : (Quotient.mk'' x₀ : Quotient S) = Quotient.mk'' x₂ := by
      simpa [B, D] using h
    exact hS02 (by simpa [S] using Quotient.exact hq)
  exact leftTight_incidenceGraph_not_square hleft hAB hBC hCD hDA hAC hBD

/-- Noncrossing follows from the Biane crossing-link lemma.

This isolates the remaining permutation-theoretic content of the genus-zero
base: every genuine crossing of `π`-cycles must produce the two
`(finRotate * π)` links and the separating non-link that make the point-level
incidence square. -/
theorem leftTightCyclePartitionRange_nonCrossing_of_bianeCrossingLinks
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hLinks :
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          (finRotate (m + 1) * π.1).SameCycle
              ⟨a, Finset.mem_range.mp ha⟩
              ⟨b, Finset.mem_range.mp hb⟩ ∧
            (finRotate (m + 1) * π.1).SameCycle
              ⟨c, Finset.mem_range.mp hc⟩
              ⟨d, Finset.mem_range.mp hd⟩ ∧
            ¬ (finRotate (m + 1) * π.1).SameCycle
              ⟨a, Finset.mem_range.mp ha⟩
              ⟨c, Finset.mem_range.mp hc⟩) :
    NCPartition.NonCrossing (leftTightCyclePartitionRange π) := by
  rw [leftTightCyclePartitionRange_nonCrossing_iff_no_crossing_cycles]
  intro a b c d ha hb hc hd hab hbc hcd hac hbd
  by_contra hnot
  rcases hLinks a b c d ha hb hc hd hab hbc hcd hac hbd hnot with
    ⟨hSab, hScd, hSacNot⟩
  exact False.elim
    (leftTight_forbid_point_incidence_square
      (m := m) (π := π.1) π.2
      (x₀ := ⟨a, Finset.mem_range.mp ha⟩)
      (x₁ := ⟨b, Finset.mem_range.mp hb⟩)
      (x₂ := ⟨c, Finset.mem_range.mp hc⟩)
      (x₃ := ⟨d, Finset.mem_range.mp hd⟩)
      hac hbd hSab hScd hnot hSacNot)

/-- In the left-tight case, each incidence edge is generated by a unique point.

Equivalently, the map
`x ↦ (cycle class of (finRotate * π) containing x, cycle class of π containing x)`
is bijective onto the incidence graph edges. -/
theorem leftTight_incidenceEdgeOf_bijective
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1) :
    Function.Bijective (setoidIncidenceEdgeOf
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)) := by
  apply setoidIncidenceEdgeOf_bijective_of_card_eq
  rw [leftTight_incidenceGraph_edgeSet_card_eq_self hleft, Fintype.card_fin]

/-- In the left-tight case, distinct points give distinct incidence edges. -/
theorem leftTight_incidenceEdgeOf_ne_of_ne
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {x y : Fin (m + 1)} (hxy : x ≠ y) :
    setoidIncidenceEdgeOf
        (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
        (Equiv.Perm.SameCycle.setoid π) x ≠
      setoidIncidenceEdgeOf
        (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
        (Equiv.Perm.SameCycle.setoid π) y := by
  intro hedge
  exact hxy ((leftTight_incidenceEdgeOf_bijective hleft).1 hedge)

/-- In the left-tight incidence graph, two distinct points in the same
`π`-cycle give adjacent vertices in the line graph of incidence edges. -/
theorem leftTight_incidenceLineGraph_adj_right_of_sameCycle_ne
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {x y : Fin (m + 1)} (hT : π.SameCycle x y) (hxy : x ≠ y) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).lineGraph.Adj
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) x)
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) y) := by
  exact
    setoidIncidenceEdgeOf_lineGraph_adj_right_of_rel_ne
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π) hT
      (leftTight_incidenceEdgeOf_ne_of_ne hleft hxy)

/-- In the left-tight incidence graph, two distinct points in the same
`(finRotate * π)`-cycle give adjacent vertices in the line graph of incidence
edges. -/
theorem leftTight_incidenceLineGraph_adj_left_of_sameCycle_ne
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {x y : Fin (m + 1)}
    (hS : (finRotate (m + 1) * π).SameCycle x y) (hxy : x ≠ y) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).lineGraph.Adj
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) x)
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) y) := by
  exact
    setoidIncidenceEdgeOf_lineGraph_adj_left_of_rel_ne
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π) hS
      (leftTight_incidenceEdgeOf_ne_of_ne hleft hxy)

/-- In the one-sided Cayley-geodesic equality case, a cycle of `π` and a cycle
of `finRotate * π` intersect in at most one point.

This is the partition-transversality form of the point-to-edge bijection. -/
theorem leftTight_cycle_intersection_subsingleton
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {x y : Fin (m + 1)}
    (hcol : π.SameCycle x y)
    (hleftCycle : (finRotate (m + 1) * π).SameCycle x y) :
    x = y := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  have hbij := leftTight_incidenceEdgeOf_bijective hleft
  have hS : S x y := hleftCycle
  have hT : T x y := hcol
  have hSq : (Quotient.mk'' x : Quotient S) = Quotient.mk'' y :=
    Quotient.sound hS
  have hTq : (Quotient.mk'' x : Quotient T) = Quotient.mk'' y :=
    Quotient.sound hT
  have hedge : setoidIncidenceEdgeOf S T x = setoidIncidenceEdgeOf S T y := by
    apply Subtype.ext
    dsimp [setoidIncidenceEdgeOf]
    rw [hSq, hTq]
  exact hbij.1 hedge

/-- One step around the long cycle factors through the two incidence
partitions attached to `π` and `finRotate * π`.

This is the local contour identity behind the Biane tree argument: the
successor edge `γ x` is reached from the edge `x` by first moving inside the
`π`-cycle to `π⁻¹ x`, then inside the `(γπ)`-cycle to `γ x`. -/
theorem finRotate_mul_perm_contour_step_sameCycle
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) :
    π.SameCycle x (π.symm x) ∧
      (finRotate (m + 1) * π).SameCycle
        (π.symm x) (finRotate (m + 1) x) := by
  constructor
  · have h : π.SameCycle (π.symm x) x := by
      exact ⟨1, by simp⟩
    exact h.symm
  · exact ⟨1, by simp [Equiv.Perm.mul_apply]⟩

/-- Direct-hit form of the pure skip-collision target.

If the next Biane contour point `finRotate (π x)` already lies in the same
`π`-cycle as `x`, and the hit is nontrivial, then `x` and that hit form the
nontrivial common `π`/`(finRotate*π)` pair needed by the skip-collision leaf. -/
theorem finRotate_mul_perm_commonCycle_of_sameCycle_self_finRotate_apply
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1))
    (hne : x ≠ finRotate (m + 1) (π x))
    (hT : π.SameCycle x (finRotate (m + 1) (π x))) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z := by
  refine ⟨x, finRotate (m + 1) (π x), hne, hT, ?_⟩
  have h := (finRotate_mul_perm_contour_step_sameCycle π (π x)).2
  simpa using h

/-- Nonwrapping predecessor-skip direct-hit subcase.

In the nonwrapping skip branch, `π x < x` with a cycle point strictly between
them.  Hence the point `finRotate (π x)` is strictly below `x`; if that point
is in the same `π`-cycle as `x`, the pure common-cycle collision is already
closed. -/
theorem permCyclicPredecessorSkip_nonwrap_direct_commonCycle
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {x : Fin (m + 1)}
    (hpx : (π x).val < x.val)
    (hbetween :
      ∃ z : Fin (m + 1),
        π.SameCycle z x ∧ (π x).val < z.val ∧ z.val < x.val)
    (hT : π.SameCycle x (finRotate (m + 1) (π x))) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z := by
  rcases hbetween with ⟨w, _hwCycle, hpw, hwx⟩
  have hpnotlast : π x ≠ Fin.last m := by
    intro hlast
    have hpval : (π x).val = m := by
      simpa using congrArg Fin.val hlast
    have hxle : x.val ≤ m := Nat.le_of_lt_succ x.2
    omega
  have hrotval :
      (finRotate (m + 1) (π x)).val = (π x).val + 1 := by
    rw [finRotate_succ_apply]
    simp [Fin.val_add_one, hpnotlast]
  have hlt : (finRotate (m + 1) (π x)).val < x.val := by
    omega
  have hne : x ≠ finRotate (m + 1) (π x) := by
    intro heq
    have hxval : x.val = (finRotate (m + 1) (π x)).val :=
      congrArg Fin.val heq
    omega
  exact
    finRotate_mul_perm_commonCycle_of_sameCycle_self_finRotate_apply
      π x hne hT

/-- First nested return in the nonwrapping predecessor-skip branch.

If `π x < x` and a same-`π` point lies strictly between `π x` and `x`, but
the immediate long-cycle successor `finRotate (π x)` is not in the `π`-cycle
of `x`, then the first such intermediate point is separated from `π x` by a
gap of length at least two.  This is the local datum needed before applying a
minimal contour argument to the genuinely nested nonwrapping branch. -/
theorem permCyclicPredecessorSkip_nonwrap_nested_exists_first_sameCycle_gap
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {x : Fin (m + 1)}
    (_hpx : (π x).val < x.val)
    (hbetween :
      ∃ z : Fin (m + 1),
        π.SameCycle z x ∧ (π x).val < z.val ∧ z.val < x.val)
    (hnotDirect : ¬ π.SameCycle x (finRotate (m + 1) (π x))) :
    ∃ c : ℕ,
      ∃ hc : c ∈ Finset.range (m + 1),
        (π x).val < c ∧
        c < x.val ∧
        1 < c - (π x).val ∧
        π.SameCycle ⟨c, Finset.mem_range.mp hc⟩ x ∧
        ∀ z : Fin (m + 1),
          π.SameCycle z x →
          (π x).val < z.val →
          z.val < c →
          False := by
  classical
  let P : ℕ → Prop := fun n =>
    ∃ z : Fin (m + 1),
      π.SameCycle z x ∧ (π x).val < z.val ∧ z.val < x.val ∧ z.val = n
  have hExists : ∃ n : ℕ, P n := by
    rcases hbetween with ⟨z, hz, hpz, hzx⟩
    exact ⟨z.val, z, hz, hpz, hzx, rfl⟩
  let c : ℕ := Nat.find hExists
  have hcSpec : P c := by
    simpa [c] using Nat.find_spec hExists
  rcases hcSpec with ⟨w, hwSame, hpw, hwx, hwc⟩
  have hc : c ∈ Finset.range (m + 1) := by
    exact Finset.mem_range.mpr (by
      rw [← hwc]
      exact w.2)
  have hSameC :
      π.SameCycle ⟨c, Finset.mem_range.mp hc⟩ x := by
    have hcw : (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) = w := by
      apply Fin.ext
      exact hwc.symm
    simpa [hcw] using hwSame
  have hgap : 1 < c - (π x).val := by
    by_contra hnot
    have hle : c - (π x).val ≤ 1 := Nat.le_of_not_gt hnot
    have hsubpos : 0 < c - (π x).val := by omega
    have hc_eq : c = (π x).val + 1 := by omega
    have hpnotlast : π x ≠ Fin.last m := by
      intro hlast
      have hpval : (π x).val = m := by
        simpa using congrArg Fin.val hlast
      have hxle : x.val ≤ m := Nat.le_of_lt_succ x.2
      omega
    have hrotval :
        (finRotate (m + 1) (π x)).val = (π x).val + 1 := by
      rw [finRotate_succ_apply]
      simp [Fin.val_add_one, hpnotlast]
    have hrot :
        (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) =
          finRotate (m + 1) (π x) := by
      apply Fin.ext
      rw [hrotval]
      exact hc_eq
    have hdirect : π.SameCycle x (finRotate (m + 1) (π x)) := by
      simpa [hrot] using hSameC.symm
    exact hnotDirect hdirect
  refine ⟨c, hc, ?_, ?_, hgap, hSameC, ?_⟩
  · simpa [← hwc] using hpw
  · simpa [← hwc] using hwx
  · intro z hzSame hpz hzc
    have hz_lt_x : z.val < x.val := by
      have hcx : c < x.val := by simpa [← hwc] using hwx
      omega
    have hPz : P z.val := ⟨z, hzSame, hpz, hz_lt_x, rfl⟩
    have hmin : c ≤ z.val := Nat.find_min' hExists hPz
    omega

/-- Wrapping direct-hit branch when `π x` is not the last cyclic point.

If `π x` is not below `x`, then `x ≤ π x` in the linear order.  When `π x`
is not the last point, its long-cycle successor has value `(π x).val + 1`,
so the direct hit is nontrivial. -/
theorem permCyclicPredecessorSkip_wrap_direct_commonCycle_of_not_last
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {x : Fin (m + 1)}
    (hnlt : ¬ (π x).val < x.val)
    (hpnotlast : π x ≠ Fin.last m)
    (hT : π.SameCycle x (finRotate (m + 1) (π x))) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z := by
  have hxle : x.val ≤ (π x).val := Nat.le_of_not_gt hnlt
  have hrotval :
      (finRotate (m + 1) (π x)).val = (π x).val + 1 := by
    rw [finRotate_succ_apply]
    simp [Fin.val_add_one, hpnotlast]
  have hne : x ≠ finRotate (m + 1) (π x) := by
    intro heq
    have hxval : x.val = (finRotate (m + 1) (π x)).val :=
      congrArg Fin.val heq
    omega
  exact
    finRotate_mul_perm_commonCycle_of_sameCycle_self_finRotate_apply
      π x hne hT

/-- Wrapping-above direct-hit subcase.

In the wrap-above skip branch there is a cycle point strictly above `π x`, so
`π x` cannot be the last point.  The direct-hit collision therefore follows
from the not-last wrapping branch. -/
theorem permCyclicPredecessorSkip_wrapAbove_direct_commonCycle
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {x : Fin (m + 1)}
    (hnlt : ¬ (π x).val < x.val)
    (habove :
      ∃ z : Fin (m + 1),
        π.SameCycle z x ∧ (π x).val < z.val)
    (hT : π.SameCycle x (finRotate (m + 1) (π x))) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z := by
  rcases habove with ⟨w, _hwCycle, hpw⟩
  have hpnotlast : π x ≠ Fin.last m := by
    intro hlast
    have hpval : (π x).val = m := by
      simpa using congrArg Fin.val hlast
    have hwle : w.val ≤ m := Nat.le_of_lt_succ w.2
    omega
  exact
    permCyclicPredecessorSkip_wrap_direct_commonCycle_of_not_last
      π hnlt hpnotlast hT

/-- Wrapping-below direct-hit subcase.

If a cycle point lies below `x`, then `x` is not the bottom point.  Thus the
direct hit is nontrivial even in the remaining last-point wrap case
`π x = Fin.last m`, where `finRotate (π x)` wraps to zero. -/
theorem permCyclicPredecessorSkip_wrapBelow_direct_commonCycle
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {x : Fin (m + 1)}
    (hnlt : ¬ (π x).val < x.val)
    (hbelow :
      ∃ z : Fin (m + 1),
        π.SameCycle z x ∧ z.val < x.val)
    (hT : π.SameCycle x (finRotate (m + 1) (π x))) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z := by
  by_cases hpnotlast : π x ≠ Fin.last m
  · exact
      permCyclicPredecessorSkip_wrap_direct_commonCycle_of_not_last
        π hnlt hpnotlast hT
  · rcases hbelow with ⟨w, _hwCycle, hwx⟩
    have hplast : π x = Fin.last m := by
      exact Classical.not_not.mp hpnotlast
    have hrotzero : (finRotate (m + 1) (π x)).val = 0 := by
      rw [finRotate_succ_apply]
      simp [hplast]
    have hne : x ≠ finRotate (m + 1) (π x) := by
      intro heq
      have hxval : x.val = (finRotate (m + 1) (π x)).val :=
        congrArg Fin.val heq
      omega
    exact
      finRotate_mul_perm_commonCycle_of_sameCycle_self_finRotate_apply
        π x hne hT

/-- Wrapping direct-hit subcase for either wrapped predecessor-skip branch. -/
theorem permCyclicPredecessorSkip_wrap_direct_commonCycle
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {x : Fin (m + 1)}
    (hnlt : ¬ (π x).val < x.val)
    (hwrap :
      (∃ z : Fin (m + 1), π.SameCycle z x ∧ z.val < x.val) ∨
        ∃ z : Fin (m + 1), π.SameCycle z x ∧ (π x).val < z.val)
    (hT : π.SameCycle x (finRotate (m + 1) (π x))) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z := by
  rcases hwrap with hbelow | habove
  · exact
      permCyclicPredecessorSkip_wrapBelow_direct_commonCycle
        π hnlt hbelow hT
  · exact
      permCyclicPredecessorSkip_wrapAbove_direct_commonCycle
        π hnlt habove hT

/-- Direct-hit closure for the full predecessor-skip predicate.

Once the skipped long-cycle successor `finRotate (π x)` is already in the
`π`-cycle of `x`, every branch of `permCyclicPredecessorSkip` gives the
required nontrivial common `π`/`(finRotate*π)` cycle pair. -/
theorem permCyclicPredecessorSkip_direct_commonCycle
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {x : Fin (m + 1)}
    (hskip : permCyclicPredecessorSkip π x)
    (hT : π.SameCycle x (finRotate (m + 1) (π x))) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z := by
  rcases hskip with hnonwrap | hwrap
  · rcases hnonwrap with ⟨hpx, hbetween⟩
    exact
      permCyclicPredecessorSkip_nonwrap_direct_commonCycle
        π hpx hbetween hT
  · rcases hwrap with ⟨hnlt, hwrapBranches⟩
    exact
      permCyclicPredecessorSkip_wrap_direct_commonCycle
        π hnlt hwrapBranches hT

/-- One-step transversality for the Biane contour.

In the left-tight case, `x` is automatically in the same `(finRotate * π)`-
cycle as `finRotate (π x)`.  If it is also in the same `π`-cycle as that
point, the two transverse cycle partitions meet twice, so the two points must
coincide. -/
theorem leftTight_sameCycle_self_finRotate_apply_eq
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    (x : Fin (m + 1))
    (hT : π.SameCycle x (finRotate (m + 1) (π x))) :
    x = finRotate (m + 1) (π x) := by
  have hS : (finRotate (m + 1) * π).SameCycle
      x (finRotate (m + 1) (π x)) := by
    have h := (finRotate_mul_perm_contour_step_sameCycle π (π x)).2
    simpa using h
  exact leftTight_cycle_intersection_subsingleton hleft hT hS

/-- Negated form of one-step transversality: a nontrivial Biane contour step
cannot stay inside a single `π`-cycle. -/
theorem leftTight_not_sameCycle_self_finRotate_apply_of_ne
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    (x : Fin (m + 1))
    (hne : x ≠ finRotate (m + 1) (π x)) :
    ¬ π.SameCycle x (finRotate (m + 1) (π x)) := by
  intro hT
  exact hne (leftTight_sameCycle_self_finRotate_apply_eq hleft x hT)

/-- Adjacent left-cycle repeats force a fixed point.

If `x` and its long-cycle successor lie in the same `(finRotate * π)`-cycle,
then comparing this with the built-in contour step through `π⁻¹ x` forces
`x = π⁻¹ x` by left-tight transversality. -/
theorem leftTight_fixed_of_sameCycle_self_finRotate
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    (x : Fin (m + 1))
    (hS : (finRotate (m + 1) * π).SameCycle x (finRotate (m + 1) x)) :
    π x = x := by
  have hstep := finRotate_mul_perm_contour_step_sameCycle π x
  have hSsymm :
      (finRotate (m + 1) * π).SameCycle x (π.symm x) :=
    hS.trans hstep.2.symm
  have heq : x = π.symm x :=
    leftTight_cycle_intersection_subsingleton hleft hstep.1 hSsymm
  have hπ := congrArg π heq
  simpa using hπ

/-- Fixed points give adjacent left-cycle repeats.

This is the easy converse to `leftTight_fixed_of_sameCycle_self_finRotate`:
if `π x = x`, then `(finRotate * π)` sends `x` to its long-cycle successor,
so the two points lie in the same `(finRotate * π)` cycle. -/
theorem finRotate_mul_perm_sameCycle_self_finRotate_of_fixed
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {x : Fin (m + 1)} (hfix : π x = x) :
    (finRotate (m + 1) * π).SameCycle x (finRotate (m + 1) x) := by
  exact ⟨1, by simp [Equiv.Perm.mul_apply, hfix]⟩

/-- In the left-tight case, the adjacent left-repeat branch is exactly the
fixed-point branch. -/
theorem leftTight_sameCycle_self_finRotate_iff_fixed
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    (x : Fin (m + 1)) :
    (finRotate (m + 1) * π).SameCycle x (finRotate (m + 1) x) ↔
      π x = x := by
  constructor
  · exact leftTight_fixed_of_sameCycle_self_finRotate hleft x
  · exact finRotate_mul_perm_sameCycle_self_finRotate_of_fixed

/-- Start-endpoint adjacent left repeats are impossible on a longer
`π`-same-cycle interval.

Indeed, such a repeat would make the left endpoint fixed by `π`; a fixed point
cannot lie in a nontrivial `π`-cycle with the right endpoint. -/
theorem leftTight_not_start_adjacent_left_repeat_of_sameCycle_one_lt_sub
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (_hgap : 1 < c - a) :
    ¬ (finRotate (m + 1) * π).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ := by
  intro hS
  let x : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  have hrot :
      finRotate (m + 1) x =
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ := by
    have hxnot : x ≠ Fin.last m := by
      intro hx
      have hxval : a = m := by
        simpa [x] using congrArg Fin.val hx
      have hc' := Finset.mem_range.mp hc
      omega
    rw [finRotate_succ_apply]
    apply Fin.ext
    simp [x, Fin.val_add_one, hxnot]
  have hSrot :
      (finRotate (m + 1) * π).SameCycle x (finRotate (m + 1) x) := by
    simpa [x, hrot] using hS
  have hfix : π x = x :=
    leftTight_fixed_of_sameCycle_self_finRotate hleft x hSrot
  have heq :
      (x : Fin (m + 1)) = ⟨c, Finset.mem_range.mp hc⟩ :=
    hT.eq_of_left (show Function.IsFixedPt π x from hfix)
  have hval : a = c := congrArg Fin.val heq
  omega

/-- Quotient form of `finRotate_mul_perm_contour_step_sameCycle`.

In the incidence graph between `(γπ)`-cycles and `π`-cycles, consecutive
points in the long-cycle order are connected through the intermediate point
`π⁻¹ x`: `x` and `π⁻¹ x` have the same `π`-class, while `π⁻¹ x` and `γ x`
have the same `(γπ)`-class. -/
theorem finRotate_mul_perm_contour_step_quotient
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) :
    (Quotient.mk'' x :
        Quotient (Equiv.Perm.SameCycle.setoid π)) =
        Quotient.mk'' (π.symm x) ∧
      (Quotient.mk'' (π.symm x) :
          Quotient (Equiv.Perm.SameCycle.setoid
            (finRotate (m + 1) * π))) =
        Quotient.mk'' (finRotate (m + 1) x) := by
  have h := finRotate_mul_perm_contour_step_sameCycle π x
  exact ⟨Quotient.sound h.1, Quotient.sound h.2⟩

/-- Incidence-graph contour form of
`finRotate_mul_perm_contour_step_sameCycle`.

Let `S` be the cycle setoid of `γπ` and `T` the cycle setoid of `π`.  The
incidence edge generated by `x` shares its `T`-vertex with the edge generated
by `π⁻¹ x`; that intermediate edge shares its `S`-vertex with the edge
generated by `γ x`. -/
theorem finRotate_mul_perm_incidence_contour_step_vertices
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) :
    (∃ v : Quotient (Equiv.Perm.SameCycle.setoid
          (finRotate (m + 1) * π)) ⊕
        Quotient (Equiv.Perm.SameCycle.setoid π),
      v ∈ ((setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) x :
          (setoidIncidenceGraph
            (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
            (Equiv.Perm.SameCycle.setoid π)).edgeSet) :
        Sym2 (Quotient (Equiv.Perm.SameCycle.setoid
          (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π))) ∧
        v ∈ ((setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) (π.symm x) :
          (setoidIncidenceGraph
            (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
            (Equiv.Perm.SameCycle.setoid π)).edgeSet) :
        Sym2 (Quotient (Equiv.Perm.SameCycle.setoid
          (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π)))) ∧
      (∃ v : Quotient (Equiv.Perm.SameCycle.setoid
            (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π),
        v ∈ ((setoidIncidenceEdgeOf
            (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
            (Equiv.Perm.SameCycle.setoid π) (π.symm x) :
            (setoidIncidenceGraph
              (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
              (Equiv.Perm.SameCycle.setoid π)).edgeSet) :
          Sym2 (Quotient (Equiv.Perm.SameCycle.setoid
            (finRotate (m + 1) * π)) ⊕
            Quotient (Equiv.Perm.SameCycle.setoid π))) ∧
          v ∈ ((setoidIncidenceEdgeOf
            (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
            (Equiv.Perm.SameCycle.setoid π) (finRotate (m + 1) x) :
            (setoidIncidenceGraph
              (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
              (Equiv.Perm.SameCycle.setoid π)).edgeSet) :
          Sym2 (Quotient (Equiv.Perm.SameCycle.setoid
            (finRotate (m + 1) * π)) ⊕
            Quotient (Equiv.Perm.SameCycle.setoid π)))) := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  have h := finRotate_mul_perm_contour_step_sameCycle π x
  exact
    ⟨setoidIncidenceEdgeOf_common_right_of_rel S T h.1,
      setoidIncidenceEdgeOf_common_left_of_rel S T h.2⟩

/-- Original-incidence-graph form of one Biane contour step.

The long-cycle step from `x` to `finRotate x` is the direct two-edge path
through the `π`-class of `x` and `π⁻¹x`, with the endpoint transported along
the `(finRotate * π)`-class identity `(finRotate * π)(π⁻¹x)=finRotate x`. -/
def finRotate_mul_perm_incidence_contour_step_left_walk
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Walk
        (Sum.inl (Quotient.mk'' x :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))))
        (Sum.inl (Quotient.mk'' (finRotate (m + 1) x) :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)))) := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  have h := finRotate_mul_perm_contour_step_sameCycle π x
  have hend :
      (Sum.inl (Quotient.mk'' (π.symm x) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' (finRotate (m + 1) x) : Quotient S) :=
    congrArg Sum.inl (Quotient.sound h.2)
  exact (setoidIncidenceGraph_left_walk_of_right_rel S T h.1).copy rfl hend

/-- The first vertex of one original-incidence contour step is the left
`(finRotate * π)`-cycle class of the starting point. -/
theorem finRotate_mul_perm_incidence_contour_step_left_walk_getVert_zero
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) :
    (finRotate_mul_perm_incidence_contour_step_left_walk π x).getVert 0 =
      (Sum.inl (Quotient.mk'' x :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))) :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π)) := by
  simp [finRotate_mul_perm_incidence_contour_step_left_walk,
    setoidIncidenceGraph_left_walk_of_right_rel]

/-- The middle vertex of one original-incidence contour step is the right
`π`-cycle class of the starting point. -/
theorem finRotate_mul_perm_incidence_contour_step_left_walk_getVert_one
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) :
    (finRotate_mul_perm_incidence_contour_step_left_walk π x).getVert 1 =
      (Sum.inr (Quotient.mk'' x :
        Quotient (Equiv.Perm.SameCycle.setoid π)) :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π)) := by
  simp [finRotate_mul_perm_incidence_contour_step_left_walk,
    setoidIncidenceGraph_left_walk_of_right_rel]

/-- The last vertex of one original-incidence contour step is the left
`(finRotate * π)`-cycle class of the long-cycle successor. -/
theorem finRotate_mul_perm_incidence_contour_step_left_walk_getVert_two
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) :
    (finRotate_mul_perm_incidence_contour_step_left_walk π x).getVert 2 =
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) x) :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))) :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π)) := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  have h := (finRotate_mul_perm_contour_step_sameCycle π x).2
  have hq :
      (Quotient.mk'' (π.symm x) : Quotient S) =
        Quotient.mk'' (finRotate (m + 1) x) :=
    Quotient.sound (by simpa [S] using h)
  have hsum := congrArg
    (fun z : Quotient S => (Sum.inl z : Quotient S ⊕ Quotient T)) hq
  simpa [finRotate_mul_perm_incidence_contour_step_left_walk,
    setoidIncidenceGraph_left_walk_of_right_rel, S, T] using hsum

/-- The original-incidence one-step contour walk has length two. -/
theorem finRotate_mul_perm_incidence_contour_step_left_walk_length
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) :
    (finRotate_mul_perm_incidence_contour_step_left_walk π x).length = 2 := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  have h := finRotate_mul_perm_contour_step_sameCycle π x
  have hend :
      (Sum.inl (Quotient.mk'' (π.symm x) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' (finRotate (m + 1) x) : Quotient S) :=
    congrArg Sum.inl (Quotient.sound h.2)
  simp [finRotate_mul_perm_incidence_contour_step_left_walk,
    setoidIncidenceGraph_left_walk_of_right_rel_length, S, T, h, hend]

/-- If the start and endpoint left classes are distinct, the original
one-step contour walk is a simple path. -/
theorem finRotate_mul_perm_incidence_contour_step_left_walk_isPath
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1))
    (hnotS :
      ¬ (finRotate (m + 1) * π).SameCycle x (finRotate (m + 1) x)) :
    (finRotate_mul_perm_incidence_contour_step_left_walk π x).IsPath := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  have h := finRotate_mul_perm_contour_step_sameCycle π x
  have hnotS' : ¬ S x (π.symm x) := by
    intro hx
    exact hnotS (hx.trans h.2)
  have hpath :=
    setoidIncidenceGraph_left_walk_of_right_rel_isPath S T h.1 hnotS'
  have hend :
      (Sum.inl (Quotient.mk'' (π.symm x) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' (finRotate (m + 1) x) : Quotient S) :=
    congrArg Sum.inl (Quotient.sound h.2)
  simpa [finRotate_mul_perm_incidence_contour_step_left_walk, S, T, h, hend]
    using (by
      simpa using
        (SimpleGraph.Walk.isPath_copy
          (setoidIncidenceGraph_left_walk_of_right_rel S T h.1) rfl hend).mpr hpath)

/-- Iterating the original-incidence contour step gives a walk from `x` to
`finRotate^n x` in the incidence tree. -/
def finRotate_mul_perm_incidence_contour_pow_left_walk
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) :
    (n : ℕ) →
      (setoidIncidenceGraph
        (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
        (Equiv.Perm.SameCycle.setoid π)).Walk
          (Sum.inl (Quotient.mk'' x :
            Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))))
          (Sum.inl (Quotient.mk'' (((finRotate (m + 1)) ^ n) x) :
            Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))))
  | 0 => SimpleGraph.Walk.nil
  | n + 1 =>
      let S : Setoid (Fin (m + 1)) :=
        Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
      let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
      let y : Fin (m + 1) := ((finRotate (m + 1)) ^ n) x
      let step :=
        finRotate_mul_perm_incidence_contour_step_left_walk π y
      have hend :
          (Sum.inl (Quotient.mk'' (finRotate (m + 1) y) : Quotient S) :
              Quotient S ⊕ Quotient T) =
            Sum.inl (Quotient.mk''
              (((finRotate (m + 1)) ^ (n + 1)) x) : Quotient S) := by
        simp [y, pow_succ', Equiv.Perm.mul_apply]
      (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).append
        (step.copy rfl hend)

/-- The iterated original-incidence contour walk has length `2n`. -/
theorem finRotate_mul_perm_incidence_contour_pow_left_walk_length
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) (n : ℕ) :
    (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).length =
      2 * n := by
  induction n with
  | zero =>
      rfl
  | succ n ih =>
      simp [finRotate_mul_perm_incidence_contour_pow_left_walk,
        SimpleGraph.Walk.length_append, SimpleGraph.Walk.length_copy,
        finRotate_mul_perm_incidence_contour_step_left_walk_length, ih,
        Nat.mul_succ]

/-- Even vertices of the iterated original-incidence contour are the left
`(finRotate * π)` classes of the corresponding long-cycle iterates. -/
theorem finRotate_mul_perm_incidence_contour_pow_left_walk_getVert_even
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1))
    {n t : ℕ} (ht : t ≤ n) :
    (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).getVert (2 * t) =
      (Sum.inl (Quotient.mk''
        (((finRotate (m + 1)) ^ t) x) :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))) :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π)) := by
  induction n generalizing t with
  | zero =>
      have ht0 : t = 0 := by omega
      subst t
      simp [finRotate_mul_perm_incidence_contour_pow_left_walk]
  | succ n ih =>
      by_cases htn : t < n
      · have hleft :
            2 * t <
              (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).length := by
          rw [finRotate_mul_perm_incidence_contour_pow_left_walk_length]
          omega
        simp [finRotate_mul_perm_incidence_contour_pow_left_walk,
          SimpleGraph.Walk.getVert_append, hleft, ih (Nat.le_of_lt htn)]
      · have htcase : t = n ∨ t = n + 1 := by omega
        rcases htcase with htEq | htEq
        · have hnot :
              ¬ 2 * n <
                (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).length := by
            rw [finRotate_mul_perm_incidence_contour_pow_left_walk_length]
            omega
          subst t
          have hsub :
              2 * n -
                  (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).length =
                0 := by
            rw [finRotate_mul_perm_incidence_contour_pow_left_walk_length]
            omega
          simp [finRotate_mul_perm_incidence_contour_pow_left_walk,
            SimpleGraph.Walk.getVert_append, hnot,
            finRotate_mul_perm_incidence_contour_step_left_walk_getVert_zero,
            hsub]
        · have hnot :
              ¬ 2 * (n + 1) <
                (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).length := by
            rw [finRotate_mul_perm_incidence_contour_pow_left_walk_length]
            omega
          subst t
          rw [finRotate_mul_perm_incidence_contour_pow_left_walk,
            SimpleGraph.Walk.getVert_append, if_neg hnot]
          simp only [SimpleGraph.Walk.getVert_copy,
            finRotate_mul_perm_incidence_contour_pow_left_walk_length]
          rw [show 2 * (n + 1) - 2 * n = 2 by omega]
          simpa [pow_succ', Equiv.Perm.mul_apply] using
            finRotate_mul_perm_incidence_contour_step_left_walk_getVert_two
              π (((finRotate (m + 1)) ^ n) x)

/-- Odd vertices of the iterated original-incidence contour are the right
`π` classes of the corresponding long-cycle iterates. -/
theorem finRotate_mul_perm_incidence_contour_pow_left_walk_getVert_odd
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1))
    {n t : ℕ} (ht : t < n) :
    (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).getVert (2 * t + 1) =
      (Sum.inr (Quotient.mk''
        (((finRotate (m + 1)) ^ t) x) :
        Quotient (Equiv.Perm.SameCycle.setoid π)) :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π)) := by
  induction n generalizing t with
  | zero =>
      omega
  | succ n ih =>
      by_cases htn : t < n
      · have hleft :
            2 * t + 1 <
              (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).length := by
          rw [finRotate_mul_perm_incidence_contour_pow_left_walk_length]
          omega
        simp [finRotate_mul_perm_incidence_contour_pow_left_walk,
          SimpleGraph.Walk.getVert_append, hleft, ih htn]
      · have htEq : t = n := by omega
        subst t
        have hnot :
            ¬ (2 * n + 1) <
              (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).length := by
          rw [finRotate_mul_perm_incidence_contour_pow_left_walk_length]
          omega
        have hsub :
            (2 * n + 1) -
                (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).length =
              1 := by
          rw [finRotate_mul_perm_incidence_contour_pow_left_walk_length]
          omega
        simp [finRotate_mul_perm_incidence_contour_pow_left_walk,
          SimpleGraph.Walk.getVert_append, hnot,
          finRotate_mul_perm_incidence_contour_step_left_walk_getVert_one,
          finRotate_mul_perm_incidence_contour_pow_left_walk_length, hsub]

/-- The iterated original-incidence contour walk supplies reachability from
`x` to `finRotate^n x`. -/
theorem finRotate_mul_perm_incidence_contour_pow_left_reachable
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) (x : Fin (m + 1)) (n : ℕ) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Reachable
        (Sum.inl (Quotient.mk'' x :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))))
        (Sum.inl (Quotient.mk'' (((finRotate (m + 1)) ^ n) x) :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)))) :=
  (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).reachable

/-- Nondegenerate contour steps give a two-step path in the line graph of the
left-tight incidence tree.

The two possible degeneracies are exactly fixed edges of the corresponding
cycle move; they are left as explicit inequalities so later arguments can use
zero-length steps where appropriate. -/
theorem leftTight_incidenceLineGraph_contour_step_adj
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    (x : Fin (m + 1))
    (hxT : x ≠ π.symm x)
    (hxS : π.symm x ≠ finRotate (m + 1) x) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).lineGraph.Adj
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) x)
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) (π.symm x)) ∧
      (setoidIncidenceGraph
        (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
        (Equiv.Perm.SameCycle.setoid π)).lineGraph.Adj
          (setoidIncidenceEdgeOf
            (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
            (Equiv.Perm.SameCycle.setoid π) (π.symm x))
          (setoidIncidenceEdgeOf
            (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
            (Equiv.Perm.SameCycle.setoid π) (finRotate (m + 1) x)) := by
  have h := finRotate_mul_perm_contour_step_sameCycle π x
  exact
    ⟨leftTight_incidenceLineGraph_adj_right_of_sameCycle_ne hleft h.1 hxT,
      leftTight_incidenceLineGraph_adj_left_of_sameCycle_ne hleft h.2 hxS⟩

/-- A single long-cycle contour step gives reachability in the line graph of
the left-tight incidence tree.

Unlike `leftTight_incidenceLineGraph_contour_step_adj`, this version handles
the two possible degenerate substeps automatically by using reflexive
reachability. -/
theorem leftTight_incidenceLineGraph_contour_step_reachable
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    (x : Fin (m + 1)) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).lineGraph.Reachable
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) x)
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) (finRotate (m + 1) x)) := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  let G := setoidIncidenceGraph S T
  let e := setoidIncidenceEdgeOf S T
  have h := finRotate_mul_perm_contour_step_sameCycle π x
  have hfirst : G.lineGraph.Reachable (e x) (e (π.symm x)) := by
    by_cases hx : x = π.symm x
    · have heq : e x = e (π.symm x) := congrArg e hx
      rw [heq]
    · exact
        (leftTight_incidenceLineGraph_adj_right_of_sameCycle_ne
          (m := m) (π := π) hleft h.1 hx).reachable
  have hsecond : G.lineGraph.Reachable (e (π.symm x))
      (e (finRotate (m + 1) x)) := by
    by_cases hx : π.symm x = finRotate (m + 1) x
    · have heq : e (π.symm x) = e (finRotate (m + 1) x) := congrArg e hx
      rw [heq]
    · exact
        (leftTight_incidenceLineGraph_adj_left_of_sameCycle_ne
          (m := m) (π := π) hleft h.2 hx).reachable
  exact hfirst.trans hsecond

/-- Iterating the long-cycle contour step gives reachability along any finite
arc of the cyclic contour in the line graph of the left-tight incidence tree. -/
theorem leftTight_incidenceLineGraph_contour_pow_reachable
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    (x : Fin (m + 1)) (n : ℕ) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).lineGraph.Reachable
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π) x)
        (setoidIncidenceEdgeOf
          (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
          (Equiv.Perm.SameCycle.setoid π)
          (((finRotate (m + 1)) ^ n) x)) := by
  induction n with
  | zero =>
      simp
  | succ n ih =>
      have hstep :=
        leftTight_incidenceLineGraph_contour_step_reachable
          (m := m) (π := π) hleft (((finRotate (m + 1)) ^ n) x)
      exact ih.trans (by
        simpa [pow_succ', Equiv.Perm.mul_apply] using hstep)

/-- Before wraparound, the `k`-th power of the long rotation sends `a` to
`a+k`. -/
theorem finRotate_pow_apply_of_add_lt
    {n a k : ℕ} (ha : a < n) (h : a + k < n) :
    (((finRotate n) ^ k) ⟨a, ha⟩ : Fin n) = ⟨a + k, h⟩ := by
  induction k generalizing a with
  | zero =>
      simp
  | succ k ih =>
      have hk : a + k < n := by omega
      rw [pow_succ', Equiv.Perm.mul_apply, ih ha hk]
      cases n with
      | zero => omega
      | succ n =>
          apply Fin.ext
          rw [finRotate_succ_apply]
          rw [Fin.val_add_one_of_lt]
          · change a + k + 1 = a + (k + 1)
            omega
          · rw [Fin.lt_def]
            change a + k < n
            omega

/-- Concrete interval form of the original-incidence contour walk: if
`a ≤ c` in the ordinary range order, the contour gives a walk in the
incidence tree from the left quotient vertex over `a` to the one over `c`. -/
def finRotate_mul_perm_incidence_contour_interval_left_walk
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a ≤ c) :
    (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Walk
        (Sum.inl (Quotient.mk'' ⟨a, Finset.mem_range.mp ha⟩ :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))))
        (Sum.inl (Quotient.mk'' ⟨c, Finset.mem_range.mp hc⟩ :
          Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)))) := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  let x : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let n : ℕ := c - a
  have hadd : a + (c - a) < m + 1 := by
    have hc' := Finset.mem_range.mp hc
    omega
  have hrot :
      (((finRotate (m + 1)) ^ n) x : Fin (m + 1)) =
        ⟨c, Finset.mem_range.mp hc⟩ := by
    have hformula :=
      finRotate_pow_apply_of_add_lt
        (n := m + 1) (a := a) (k := c - a)
        (Finset.mem_range.mp ha) hadd
    apply Fin.ext
    have hval := congrArg Fin.val hformula
    simp [x, n] at hval ⊢
    omega
  exact
    (finRotate_mul_perm_incidence_contour_pow_left_walk π x n).copy rfl
      (congrArg Sum.inl (congrArg Quotient.mk'' hrot))

/-- The concrete interval contour walk has length `2 * (c-a)`. -/
theorem finRotate_mul_perm_incidence_contour_interval_left_walk_length
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a ≤ c) :
    (finRotate_mul_perm_incidence_contour_interval_left_walk π ha hc hac).length =
      2 * (c - a) := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let x : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let n : ℕ := c - a
  have hadd : a + (c - a) < m + 1 := by
    have hc' := Finset.mem_range.mp hc
    omega
  have hrot :
      (((finRotate (m + 1)) ^ n) x : Fin (m + 1)) =
        ⟨c, Finset.mem_range.mp hc⟩ := by
    have hformula :=
      finRotate_pow_apply_of_add_lt
        (n := m + 1) (a := a) (k := c - a)
        (Finset.mem_range.mp ha) hadd
    apply Fin.ext
    have hval := congrArg Fin.val hformula
    simp [x, n] at hval ⊢
    omega
  simp [finRotate_mul_perm_incidence_contour_interval_left_walk,
    SimpleGraph.Walk.length_copy,
    finRotate_mul_perm_incidence_contour_pow_left_walk_length, x, n, hrot]

/-- Even vertices of a concrete interval contour are the left
`(finRotate * π)` classes of the corresponding ordinary indices `a+r`. -/
theorem finRotate_mul_perm_incidence_contour_interval_left_walk_getVert_even
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
    {a c r : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a ≤ c)
    (hr : r ≤ c - a) :
    (finRotate_mul_perm_incidence_contour_interval_left_walk
        π ha hc hac).getVert (2 * r) =
      (Sum.inl (Quotient.mk'' ⟨a + r, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))) :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π)) := by
  let x : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let n : ℕ := c - a
  have hadd : a + r < m + 1 := by
    have hc' := Finset.mem_range.mp hc
    omega
  have hrot :
      (((finRotate (m + 1)) ^ r) x : Fin (m + 1)) =
        ⟨a + r, hadd⟩ := by
    exact
      finRotate_pow_apply_of_add_lt
        (n := m + 1) (a := a) (k := r)
        (Finset.mem_range.mp ha) hadd
  have hpow :=
    finRotate_mul_perm_incidence_contour_pow_left_walk_getVert_even
      (m := m) π x (n := n) (t := r) (by simpa [n] using hr)
  simpa [finRotate_mul_perm_incidence_contour_interval_left_walk,
    SimpleGraph.Walk.getVert_copy, x, n, hrot] using hpow

/-- Odd vertices of a concrete interval contour are the right `π` classes of
the corresponding ordinary indices `a+r`. -/
theorem finRotate_mul_perm_incidence_contour_interval_left_walk_getVert_odd
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
    {a c r : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a ≤ c)
    (hr : r < c - a) :
    (finRotate_mul_perm_incidence_contour_interval_left_walk
        π ha hc hac).getVert (2 * r + 1) =
      (Sum.inr (Quotient.mk'' ⟨a + r, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ :
        Quotient (Equiv.Perm.SameCycle.setoid π)) :
        Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
          Quotient (Equiv.Perm.SameCycle.setoid π)) := by
  let x : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let n : ℕ := c - a
  have hadd : a + r < m + 1 := by
    have hc' := Finset.mem_range.mp hc
    omega
  have hrot :
      (((finRotate (m + 1)) ^ r) x : Fin (m + 1)) =
        ⟨a + r, hadd⟩ := by
    exact
      finRotate_pow_apply_of_add_lt
        (n := m + 1) (a := a) (k := r)
        (Finset.mem_range.mp ha) hadd
  have hpow :=
    finRotate_mul_perm_incidence_contour_pow_left_walk_getVert_odd
      (m := m) π x (n := n) (t := r) (by simpa [n] using hr)
  simpa [finRotate_mul_perm_incidence_contour_interval_left_walk,
    SimpleGraph.Walk.getVert_copy, x, n, hrot] using hpow

/-- If two even contour times in the same concrete interval have the same
vertex, then the corresponding ordinary indices lie in the same
`(finRotate * π)` cycle. -/
theorem finRotate_mul_perm_incidence_contour_interval_left_walk_even_eq_sameCycle
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
    {a c r s : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a ≤ c)
    (hr : r ≤ c - a) (hs : s ≤ c - a)
    (hEq :
      (finRotate_mul_perm_incidence_contour_interval_left_walk
          π ha hc hac).getVert (2 * r) =
        (finRotate_mul_perm_incidence_contour_interval_left_walk
          π ha hc hac).getVert (2 * s)) :
    (finRotate (m + 1) * π).SameCycle
      ⟨a + r, by
        have hc' := Finset.mem_range.mp hc
        omega⟩
      ⟨a + s, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π
  let xr : Fin (m + 1) := ⟨a + r, by
    have hc' := Finset.mem_range.mp hc
    omega⟩
  let xs : Fin (m + 1) := ⟨a + s, by
    have hc' := Finset.mem_range.mp hc
    omega⟩
  have hrVert :
      (finRotate_mul_perm_incidence_contour_interval_left_walk
          π ha hc hac).getVert (2 * r) =
        (Sum.inl (Quotient.mk'' xr : Quotient S) :
          Quotient S ⊕ Quotient T) := by
    simpa [S, T, xr] using
      finRotate_mul_perm_incidence_contour_interval_left_walk_getVert_even
        π ha hc hac hr
  have hsVert :
      (finRotate_mul_perm_incidence_contour_interval_left_walk
          π ha hc hac).getVert (2 * s) =
        (Sum.inl (Quotient.mk'' xs : Quotient S) :
          Quotient S ⊕ Quotient T) := by
    simpa [S, T, xs] using
      finRotate_mul_perm_incidence_contour_interval_left_walk_getVert_even
        π ha hc hac hs
  have hsum :
      (Sum.inl (Quotient.mk'' xr : Quotient S) :
          Quotient S ⊕ Quotient T) =
        (Sum.inl (Quotient.mk'' xs : Quotient S) :
          Quotient S ⊕ Quotient T) := by
    calc
      (Sum.inl (Quotient.mk'' xr : Quotient S) :
          Quotient S ⊕ Quotient T)
          = (finRotate_mul_perm_incidence_contour_interval_left_walk
              π ha hc hac).getVert (2 * r) := hrVert.symm
      _ = (finRotate_mul_perm_incidence_contour_interval_left_walk
              π ha hc hac).getVert (2 * s) := hEq
      _ = (Sum.inl (Quotient.mk'' xs : Quotient S) :
          Quotient S ⊕ Quotient T) := hsVert
  have hq : (Quotient.mk'' xr : Quotient S) = Quotient.mk'' xs :=
    Sum.inl.inj hsum
  change S xr xs
  exact Quotient.exact hq

/-- If two odd contour times in the same concrete interval have the same
vertex, then the corresponding ordinary indices lie in the same `π` cycle. -/
theorem finRotate_mul_perm_incidence_contour_interval_left_walk_odd_eq_sameCycle
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
    {a c r s : ℕ} (ha : a ∈ Finset.range (m + 1))
