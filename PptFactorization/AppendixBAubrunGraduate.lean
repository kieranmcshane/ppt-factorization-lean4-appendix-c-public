          rw [hsend]
          exact Nat.add_sub_of_le hac_lt.le
        have hS :
            (finRotate (m + 1) * π).SameCycle
              ⟨a, Finset.mem_range.mp ha⟩
              ⟨c, Finset.mem_range.mp hc⟩ := by
          simpa [hfin] using hSame
        exact False.elim
          ((leftTight_not_sameCycle_both_of_lt
            (m := m) (π := π) hleft ha hc hac_lt hT) hS)
      · right
        left
        exact ⟨s, hs, hsfar, by omega, hSame⟩
    · rcases hEndOrFixed with hEnd | hFixed
      · rcases hEnd with ⟨r, hr, hrfar, hSame⟩
        by_cases hrzero : r = 0
        · have hfin :
              (⟨a + r, by
                have hc' := Finset.mem_range.mp hc
                omega⟩ : Fin (m + 1)) =
                ⟨a, Finset.mem_range.mp ha⟩ := by
            apply Fin.ext
            change a + r = a
            rw [hrzero]
            omega
          have hS :
              (finRotate (m + 1) * π).SameCycle
                ⟨a, Finset.mem_range.mp ha⟩
                ⟨c, Finset.mem_range.mp hc⟩ := by
            simpa [hfin] using hSame
          exact False.elim
            ((leftTight_not_sameCycle_both_of_lt
              (m := m) (π := π) hleft ha hc hac_lt hT) hS)
        · right
          right
          left
          exact ⟨r, hr, by omega, hrfar, hSame⟩
      · right
        right
        right
        exact hFixed

/-- Fixed-predecessor branch from the strict frontier.

With no internal repeated `π` class, the strict frontier shows that the only
alternatives to a fixed right-end predecessor are genuinely proper left-repeat
obstructions.  Excluding exactly those proper obstructions forces the fixed
predecessor, without requiring the caller to rule out endpoint-to-endpoint
left repeats. -/
theorem leftTight_contour_interval_sameCycle_end_pred_fixed_of_no_internal_right_repeat_proper
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a)
    (hNoRight :
      ∀ r s : ℕ,
        ∀ hr : r < c - a,
        ∀ hs : s < c - a,
          r < s →
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftInterior :
      ∀ r s : ℕ,
        ∀ hr : r ≤ c - a,
        ∀ hs : s ≤ c - a,
          0 < r →
          s < c - a →
          r < s →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftStartProper :
      ∀ s : ℕ,
        ∀ hs : s ≤ c - a,
          1 < s →
          s < c - a →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftEndProper :
      ∀ r : ℕ,
        ∀ hr : r ≤ c - a,
          0 < r →
          r + 1 < c - a →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨c, Finset.mem_range.mp hc⟩) :
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ := by
  rcases
    leftTight_contour_interval_sameCycle_strict_frontier_of_no_internal_right_repeat
      hleft ha hc hac_lt hT hgap hNoRight with
    hInterior | hStartOrEndOrFixed
  · rcases hInterior with ⟨r, s, hr, hs, hrpos, hslt, hrs, hSame⟩
    exact False.elim
      ((hNoLeftInterior r s hr hs hrpos hslt hrs) hSame)
  · rcases hStartOrEndOrFixed with hStart | hEndOrFixed
    · rcases hStart with ⟨s, hs, hsfar, hslt, hSame⟩
      exact False.elim
        ((hNoLeftStartProper s hs hsfar hslt) hSame)
    · rcases hEndOrFixed with hEnd | hFixed
      · rcases hEnd with ⟨r, hr, hrpos, hrfar, hSame⟩
        exact False.elim
          ((hNoLeftEndProper r hr hrpos hrfar) hSame)
      · exact hFixed

/-- One-step descent for internal right repeats.

If the "no internal repeated `π` class" hypothesis fails inside an interval
`[a,c]`, then either the repeat is already adjacent in the linear order, or it
contains a strictly shorter longer same-`π` interval.  This is the arithmetic
minimality bridge needed before the positive contour frontier can be applied
without carrying an unexplained `hNoRight` hypothesis. -/
theorem leftTight_contour_interval_sameCycle_internal_right_repeat_descends_or_adjacent
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (_ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hRight :
      ∃ r s : ℕ,
        ∃ hr : r < c - a,
        ∃ hs : s < c - a,
          r < s ∧
          π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩) :
    (∃ r : ℕ,
      ∃ hr : r + 1 < c - a,
        π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + (r + 1), by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ a' c' : ℕ,
      ∃ ha' : a' ∈ Finset.range (m + 1),
      ∃ hc' : c' ∈ Finset.range (m + 1),
      ∃ _hac' : a' < c',
        1 < c' - a' ∧
        c' - a' < c - a ∧
        π.SameCycle
          ⟨a', Finset.mem_range.mp ha'⟩
          ⟨c', Finset.mem_range.mp hc'⟩) := by
  rcases hRight with ⟨r, s, hr, hs, hrs, hSame⟩
  by_cases hadj : s = r + 1
  · subst s
    left
    exact ⟨r, hs, by simpa [Nat.add_assoc] using hSame⟩
  · right
    let a' : ℕ := a + r
    let c' : ℕ := a + s
    have ha' : a' ∈ Finset.range (m + 1) := by
      have hc' := Finset.mem_range.mp hc
      exact Finset.mem_range.mpr (by dsimp [a']; omega)
    have hc' : c' ∈ Finset.range (m + 1) := by
      have hc'' := Finset.mem_range.mp hc
      exact Finset.mem_range.mpr (by dsimp [c']; omega)
    have hac' : a' < c' := by
      dsimp [a', c']
      omega
    have hgap' : 1 < c' - a' := by
      dsimp [a', c']
      omega
    have hshort : c' - a' < c - a := by
      dsimp [a', c']
      omega
    have hSame' :
        π.SameCycle
          ⟨a', Finset.mem_range.mp ha'⟩
          ⟨c', Finset.mem_range.mp hc'⟩ := by
      have hA :
          (⟨a', Finset.mem_range.mp ha'⟩ : Fin (m + 1)) =
            ⟨a + r, by
              have hc'' := Finset.mem_range.mp hc
              omega⟩ := by
        apply Fin.ext
        rfl
      have hC :
          (⟨c', Finset.mem_range.mp hc'⟩ : Fin (m + 1)) =
            ⟨a + s, by
              have hc'' := Finset.mem_range.mp hc
              omega⟩ := by
        apply Fin.ext
        rfl
      simpa [hA, hC] using hSame
    exact ⟨a', c', ha', hc', hac', hgap', hshort, hSame'⟩

/-- The residual strict frontier implies the descended residual frontier. -/
theorem leftTightStrictReturnIntervalResidual_descend_internal_right
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (h :
      leftTightStrictReturnIntervalResidual π ha hc hac) :
    leftTightStrictReturnIntervalDescendedResidual π ha hc hac := by
  rcases h with hInterior | hRest
  · left
    exact hInterior
  · right
    rcases hRest with hStart | hRest
    · left
      exact hStart
    · right
      rcases hRest with hEnd | hRest
      · left
        exact hEnd
      · right
        rcases hRest with hFixed | hRight
        · left
          exact hFixed
        · right
          rcases
            leftTight_contour_interval_sameCycle_internal_right_repeat_descends_or_adjacent
              ha hc hac hRight with
            hAdj | hShort
          · left
            exact hAdj
          · right
            exact hShort

/-- Any longer same-`π` interval either already gives the desired common-cycle
witness or re-enters the descended residual frontier.

This bridge is the re-entry step used in the well-founded descent below:
when the descended residual frontier produces a strictly shorter interval, the
shorter interval is not left as raw data.  It is immediately converted back
into the same residual/frontier language. -/
theorem leftTight_sameCycle_interval_common_or_descendedResidual
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (hgap : 1 < c - a)
    (hT : π.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩) :
    (∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z) ∨
    leftTightStrictReturnIntervalDescendedResidual π ha hc hac := by
  have hRepeat : leftTightContourIntervalRepeat π ha hc hac :=
    leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
      hleft ha hc hac hT hgap
  have hFrontier : leftTightStrictReturnIntervalFrontier π ha hc hac :=
    leftTightContourIntervalRepeat_strict_frontier
      hleft ha hc hac hgap hT hRepeat
  rcases
    leftTightStrictReturnIntervalFrontier_common_or_residual
      ha hc hac hFrontier with
    hCommon | hResidual
  · exact Or.inl hCommon
  · exact Or.inr
      (leftTightStrictReturnIntervalResidual_descend_internal_right
        ha hc hac hResidual)

/-- Well-founded removal of the shorter-interval branch.

If the five primitive residual branches always produce a nontrivial common
`π`/`(finRotate*π)` pair, then the full descended residual frontier also
produces such a pair.  The proof descends on interval length; the only
recursive branch is converted back into a descended residual frontier by
`leftTight_sameCycle_interval_common_or_descendedResidual`. -/
theorem leftTightStrictReturnIntervalDescendedResidual_common_of_primitive
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    (hPrimitive :
      ∀ {a c : ℕ},
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hac : a < c,
          1 < c - a →
          π.SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          leftTightStrictReturnIntervalPrimitiveResidual π ha hc hac →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.SameCycle y z ∧
                (finRotate (m + 1) * π).SameCycle y z)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (hgap : 1 < c - a)
    (hT : π.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hResidual :
      leftTightStrictReturnIntervalDescendedResidual π ha hc hac) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z := by
  have hmain :
      ∀ n : ℕ,
        ∀ a c : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hac : a < c,
          c - a = n →
          1 < c - a →
          π.SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          leftTightStrictReturnIntervalDescendedResidual π ha hc hac →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.SameCycle y z ∧
                (finRotate (m + 1) * π).SameCycle y z := by
    intro n
    refine Nat.strong_induction_on n ?_
    intro n ih a c ha hc hac hlen hgap hT hResidual
    rcases hResidual with hInterior | hRest
    · exact hPrimitive ha hc hac hgap hT (Or.inl hInterior)
    · rcases hRest with hStart | hRest
      · exact hPrimitive ha hc hac hgap hT (Or.inr (Or.inl hStart))
      · rcases hRest with hEnd | hRest
        · exact hPrimitive ha hc hac hgap hT
            (Or.inr (Or.inr (Or.inl hEnd)))
        · rcases hRest with hFixed | hRest
          · exact hPrimitive ha hc hac hgap hT
              (Or.inr (Or.inr (Or.inr (Or.inl hFixed))))
          · rcases hRest with hAdj | hShort
            · exact hPrimitive ha hc hac hgap hT
                (Or.inr (Or.inr (Or.inr (Or.inr hAdj))))
            · rcases hShort with
                ⟨a', c', ha', hc', hac', hgap', hshort, hSame'⟩
              rcases
                leftTight_sameCycle_interval_common_or_descendedResidual
                  hleft ha' hc' hac' hgap' hSame' with
                hCommon | hResidual'
              · exact hCommon
              · exact
                  ih (c' - a') (by omega)
                    a' c' ha' hc' hac' rfl hgap' hSame' hResidual'
  exact hmain (c - a) a c ha hc hac rfl hgap hT hResidual

/-- Minimality eliminates internal right repeats.

If a longer same-`π` interval has no adjacent repeated `π` class and no
strictly shorter longer same-`π` subinterval, then the `hNoRight` hypothesis
required by the contour-frontier lemmas follows automatically. -/
theorem leftTight_contour_interval_sameCycle_no_internal_right_repeat_of_minimal
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hNoAdjacentRight :
      ∀ r : ℕ,
        ∀ hr : r + 1 < c - a,
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + (r + 1), by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoShorter :
      ∀ a' c' : ℕ,
        ∀ ha' : a' ∈ Finset.range (m + 1),
        ∀ hc' : c' ∈ Finset.range (m + 1),
        ∀ _hac' : a' < c',
          1 < c' - a' →
          c' - a' < c - a →
          ¬ π.SameCycle
            ⟨a', Finset.mem_range.mp ha'⟩
            ⟨c', Finset.mem_range.mp hc'⟩) :
    ∀ r s : ℕ,
      ∀ hr : r < c - a,
      ∀ hs : s < c - a,
        r < s →
        ¬ π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ := by
  intro r s hr hs hrs hSame
  have hRight :
      ∃ r s : ℕ,
        ∃ hr : r < c - a,
        ∃ hs : s < c - a,
          r < s ∧
          π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ :=
    ⟨r, s, hr, hs, hrs, hSame⟩
  rcases
    leftTight_contour_interval_sameCycle_internal_right_repeat_descends_or_adjacent
      ha hc hac_lt hRight with
    hAdj | hShort
  · rcases hAdj with ⟨q, hq, hSameAdj⟩
    exact (hNoAdjacentRight q hq) hSameAdj
  · rcases hShort with ⟨a', c', ha', hc', hac', hgap', hshort, hSame'⟩
    exact (hNoShorter a' c' ha' hc' hac' hgap' hshort) hSame'

/-- Minimal-interval fixed-predecessor form.

This replaces the raw `hNoRight` premise of
`leftTight_contour_interval_sameCycle_end_pred_fixed_of_adjacent_left_repeat`
by the concrete minimality hypotheses supplied by the descent lemma: no
adjacent same-`π` repeat and no strictly shorter longer same-`π` interval. -/
theorem leftTight_contour_interval_sameCycle_end_pred_fixed_of_minimal
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a)
    (hNoAdjacentRight :
      ∀ r : ℕ,
        ∀ hr : r + 1 < c - a,
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + (r + 1), by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoShorter :
      ∀ a' c' : ℕ,
        ∀ ha' : a' ∈ Finset.range (m + 1),
        ∀ hc' : c' ∈ Finset.range (m + 1),
        ∀ _hac' : a' < c',
          1 < c' - a' →
          c' - a' < c - a →
          ¬ π.SameCycle
            ⟨a', Finset.mem_range.mp ha'⟩
            ⟨c', Finset.mem_range.mp hc'⟩)
    (hNoLeftInterior :
      ∀ r s : ℕ,
        ∀ hr : r ≤ c - a,
        ∀ hs : s ≤ c - a,
          0 < r →
          s < c - a →
          r < s →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftStartFar :
      ∀ s : ℕ,
        ∀ hs : s ≤ c - a,
          1 < s →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftEndFar :
      ∀ r : ℕ,
        ∀ hr : r ≤ c - a,
          r + 1 < c - a →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨c, Finset.mem_range.mp hc⟩) :
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ := by
  have hNoRight :=
    leftTight_contour_interval_sameCycle_no_internal_right_repeat_of_minimal
      (m := m) (π := π) ha hc hac_lt hNoAdjacentRight hNoShorter
  exact
    leftTight_contour_interval_sameCycle_end_pred_fixed_of_adjacent_left_repeat
      hleft ha hc hac_lt hT hgap hNoRight hNoLeftInterior
      hNoLeftStartFar hNoLeftEndFar

/-- Strict minimal-interval contour frontier.

This is the form consumed by the predecessor-skip branch: minimality supplies
the no-internal-right-repeat hypothesis, and endpoint-to-endpoint left repeats
are removed by transversality. -/
theorem leftTight_contour_interval_sameCycle_strict_frontier_of_minimal
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a)
    (hNoAdjacentRight :
      ∀ r : ℕ,
        ∀ hr : r + 1 < c - a,
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + (r + 1), by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoShorter :
      ∀ a' c' : ℕ,
        ∀ ha' : a' ∈ Finset.range (m + 1),
        ∀ hc' : c' ∈ Finset.range (m + 1),
        ∀ _hac' : a' < c',
          1 < c' - a' →
          c' - a' < c - a →
          ¬ π.SameCycle
            ⟨a', Finset.mem_range.mp ha'⟩
            ⟨c', Finset.mem_range.mp hc'⟩) :
    (∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
        0 < r ∧
        s < c - a ∧
        r < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        1 < s ∧
        s < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        0 < r ∧
        r + 1 < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) ∨
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ := by
  have hNoRight :=
    leftTight_contour_interval_sameCycle_no_internal_right_repeat_of_minimal
      (m := m) (π := π) ha hc hac_lt hNoAdjacentRight hNoShorter
  exact
    leftTight_contour_interval_sameCycle_strict_frontier_of_no_internal_right_repeat
      hleft ha hc hac_lt hT hgap hNoRight

/-- Minimal frontier extracted from a nonfixed predecessor skip.

After choosing a minimal long same-`π` interval, the obstruction is now one of
five explicit local alternatives: an adjacent right repeat, an internal left
repeat, a proper start-touching left repeat, a proper end-touching left repeat,
or a fixed predecessor at the right endpoint.  This removes the interval
selection and `hNoShorter` bookkeeping from the remaining skip branch. -/
theorem leftTight_nonfixed_cyclicPredecessorSkip_exists_minimal_frontier
    {m : ℕ} (π : WickCycleLeftTightClass m) {x : Fin (m + 1)}
    (hnotfix : π.1 x ≠ x)
    (hskip : permCyclicPredecessorSkip π.1 x) :
    ∃ a c : ℕ,
      ∃ ha : a ∈ Finset.range (m + 1),
      ∃ hc : c ∈ Finset.range (m + 1),
      ∃ hac : a < c,
        1 < c - a ∧
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ ∧
        (∀ a' c' : ℕ,
          ∀ ha' : a' ∈ Finset.range (m + 1),
          ∀ hc' : c' ∈ Finset.range (m + 1),
          ∀ _hac' : a' < c',
            1 < c' - a' →
            c' - a' < c - a →
            ¬ π.1.SameCycle
              ⟨a', Finset.mem_range.mp ha'⟩
              ⟨c', Finset.mem_range.mp hc'⟩) ∧
        ((∃ r : ℕ,
          ∃ hr : r + 1 < c - a,
            π.1.SameCycle
              ⟨a + r, by
                have hc' := Finset.mem_range.mp hc
                omega⟩
              ⟨a + (r + 1), by
                have hc' := Finset.mem_range.mp hc
                omega⟩) ∨
        (∃ r s : ℕ,
          ∃ hr : r ≤ c - a,
          ∃ hs : s ≤ c - a,
            0 < r ∧
            s < c - a ∧
            r < s ∧
            (finRotate (m + 1) * π.1).SameCycle
              ⟨a + r, by
                have hc' := Finset.mem_range.mp hc
                omega⟩
              ⟨a + s, by
                have hc' := Finset.mem_range.mp hc
                omega⟩) ∨
        (∃ s : ℕ,
          ∃ hs : s ≤ c - a,
            1 < s ∧
            s < c - a ∧
            (finRotate (m + 1) * π.1).SameCycle
              ⟨a, Finset.mem_range.mp ha⟩
              ⟨a + s, by
                have hc' := Finset.mem_range.mp hc
                omega⟩) ∨
        (∃ r : ℕ,
          ∃ hr : r ≤ c - a,
            0 < r ∧
            r + 1 < c - a ∧
            (finRotate (m + 1) * π.1).SameCycle
              ⟨a + r, by
                have hc' := Finset.mem_range.mp hc
                omega⟩
              ⟨c, Finset.mem_range.mp hc⟩) ∨
        π.1 ⟨c - 1, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ =
          ⟨c - 1, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) := by
  rcases
    leftTight_nonfixed_cyclicPredecessorSkip_exists_minimal_contourIntervalRepeat
      π hnotfix hskip with
    ⟨a, c, ha, hc, hac, hgap, hSame, _hRepeat, hNoShorter⟩
  refine ⟨a, c, ha, hc, hac, hgap, hSame, hNoShorter, ?_⟩
  by_cases hAdj :
      ∃ r : ℕ,
        ∃ hr : r + 1 < c - a,
          π.1.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + (r + 1), by
              have hc' := Finset.mem_range.mp hc
              omega⟩
  · exact Or.inl hAdj
  · have hNoAdjacentRight :
        ∀ r : ℕ,
          ∀ hr : r + 1 < c - a,
            ¬ π.1.SameCycle
              ⟨a + r, by
                have hc' := Finset.mem_range.mp hc
                omega⟩
              ⟨a + (r + 1), by
                have hc' := Finset.mem_range.mp hc
                omega⟩ := by
      intro r hr hSameAdj
      exact hAdj ⟨r, hr, hSameAdj⟩
    rcases
      leftTight_contour_interval_sameCycle_strict_frontier_of_minimal
        (m := m) (π := π.1) π.2 ha hc hac hSame hgap
        hNoAdjacentRight hNoShorter with
      hInterior | hStartOrEndOrFixed
    · exact Or.inr (Or.inl hInterior)
    · rcases hStartOrEndOrFixed with hStart | hEndOrFixed
      · exact Or.inr (Or.inr (Or.inl hStart))
      · rcases hEndOrFixed with hEnd | hFixed
        · exact Or.inr (Or.inr (Or.inr (Or.inl hEnd)))
        · exact Or.inr (Or.inr (Or.inr (Or.inr hFixed)))

/-- Fixed-predecessor branch with only proper left-repeat exclusions.

After the strict frontier theorem, callers no longer need to rule out
endpoint-to-endpoint `(finRotate * π)` repeats by hand.  It is enough to
exclude the genuinely proper repeated-contour alternatives; the fixed
right-end predecessor is then forced. -/
theorem leftTight_contour_interval_sameCycle_end_pred_fixed_of_minimal_proper
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a)
    (hNoAdjacentRight :
      ∀ r : ℕ,
        ∀ hr : r + 1 < c - a,
          ¬ π.SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + (r + 1), by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoShorter :
      ∀ a' c' : ℕ,
        ∀ ha' : a' ∈ Finset.range (m + 1),
        ∀ hc' : c' ∈ Finset.range (m + 1),
        ∀ _hac' : a' < c',
          1 < c' - a' →
          c' - a' < c - a →
          ¬ π.SameCycle
            ⟨a', Finset.mem_range.mp ha'⟩
            ⟨c', Finset.mem_range.mp hc'⟩)
    (hNoLeftInterior :
      ∀ r s : ℕ,
        ∀ hr : r ≤ c - a,
        ∀ hs : s ≤ c - a,
          0 < r →
          s < c - a →
          r < s →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftStartProper :
      ∀ s : ℕ,
        ∀ hs : s ≤ c - a,
          1 < s →
          s < c - a →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩)
    (hNoLeftEndProper :
      ∀ r : ℕ,
        ∀ hr : r ≤ c - a,
          0 < r →
          r + 1 < c - a →
          ¬ (finRotate (m + 1) * π).SameCycle
            ⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩
            ⟨c, Finset.mem_range.mp hc⟩) :
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ := by
  have hNoRight :=
    leftTight_contour_interval_sameCycle_no_internal_right_repeat_of_minimal
      (m := m) (π := π) ha hc hac_lt hNoAdjacentRight hNoShorter
  exact
    leftTight_contour_interval_sameCycle_end_pred_fixed_of_no_internal_right_repeat_proper
      hleft ha hc hac_lt hT hgap hNoRight hNoLeftInterior
      hNoLeftStartProper hNoLeftEndProper

/-- Noncrossing follows once every genuine cyclic crossing supplies the two
adjacent `(finRotate * π)` cycle links.

The third, separating, non-link needed by the point-level incidence-square
contradiction is automatic from left-tight transversality. -/
theorem leftTightCyclePartitionRange_nonCrossing_of_bianeAdjacentLinks
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hLinks :
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          (finRotate (m + 1) * π.1).SameCycle
              ⟨a, Finset.mem_range.mp ha⟩
              ⟨b, Finset.mem_range.mp hb⟩ ∧
            (finRotate (m + 1) * π.1).SameCycle
              ⟨c, Finset.mem_range.mp hc⟩
              ⟨d, Finset.mem_range.mp hd⟩) :
    NCPartition.NonCrossing (leftTightCyclePartitionRange π) := by
  apply leftTightCyclePartitionRange_nonCrossing_of_bianeCrossingLinks
  intro a b c d ha hb hc hd hab hbc hcd hac hbd hnot
  rcases hLinks a b c d ha hb hc hd hab hbc hcd hac hbd hnot with
    ⟨hSab, hScd⟩
  exact
    ⟨hSab, hScd,
      leftTight_not_sameCycle_both_of_lt
        (m := m) (π := π.1) π.2 ha hc (by omega) hac⟩

/-- Gap-two left half of Biane's adjacent-link theorem.

For a crossing `a < b < c < d` with `c-a=2`, the interval contour from `a`
to `c` has length four.  Tree uniqueness forces a repeated contour vertex.
The right-repeat option would put `a` and `b` in the same `π`-cycle, the
endpoint-to-endpoint left repeat contradicts transversality with the
`π`-link `a~c`, and the right adjacent left repeat would make `b` a fixed
point, contradicting the nontrivial `π`-link `b~d`.  Thus the repeated left
vertex must be the desired adjacent `(finRotate*π)` link `a~b`. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_two
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (_hbc : b < c) (hcd : c < d)
    (hgap : c - a = 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩ := by
  have hac_lt : a < c := by omega
  have hb_eq : b = a + 1 := by omega
  have hc_eq : c = a + 2 := by omega
  have hgap_lt : 1 < c - a := by omega
  rcases
    leftTight_contour_interval_sameCycle_exists_repeated_parity_sameCycle_of_one_lt_sub
      (m := m) (π := π.1) π.2 ha hc hac_lt hac hgap_lt with
    hLeft | hRight
  · rcases hLeft with ⟨r, s, hr, hs, hrs, hSame⟩
    have hpairs :
        (r = 0 ∧ s = 1) ∨ (r = 0 ∧ s = 2) ∨ (r = 1 ∧ s = 2) := by
      omega
    rcases hpairs with hrs01 | hrsRest
    · rcases hrs01 with ⟨hr0, hs1⟩
      have hleft :
          (⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ : Fin (m + 1)) =
            ⟨a, Finset.mem_range.mp ha⟩ := by
        apply Fin.ext
        simp [hr0]
      have hright :
          (⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ : Fin (m + 1)) =
            ⟨b, Finset.mem_range.mp hb⟩ := by
        apply Fin.ext
        simp [hs1, hb_eq]
      simpa [hleft, hright] using hSame
    · rcases hrsRest with hrs02 | hrs12
      · rcases hrs02 with ⟨hr0, hs2⟩
        have hleft :
            (⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
              ⟨a, Finset.mem_range.mp ha⟩ := by
          apply Fin.ext
          simp [hr0]
        have hright :
            (⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          apply Fin.ext
          simp [hs2, hc_eq]
        have hS_ac :
            (finRotate (m + 1) * π.1).SameCycle
              ⟨a, Finset.mem_range.mp ha⟩
              ⟨c, Finset.mem_range.mp hc⟩ := by
          simpa [hleft, hright] using hSame
        exact False.elim
          ((leftTight_not_sameCycle_both_of_lt
            (m := m) (π := π.1) π.2 ha hc hac_lt hac) hS_ac)
      · rcases hrs12 with ⟨hr1, hs2⟩
        let xb : Fin (m + 1) := ⟨b, Finset.mem_range.mp hb⟩
        have hleft :
            (⟨a + r, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) = xb := by
          apply Fin.ext
          simp [hr1, hb_eq, xb]
        have hright :
            (⟨a + s, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          apply Fin.ext
          simp [hs2, hc_eq]
        have hrot :
            finRotate (m + 1) xb =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          have xb_not_last : xb ≠ Fin.last m := by
            intro hlast
            have hbval : b = m := by
              simpa [xb] using congrArg Fin.val hlast
            have hc' := Finset.mem_range.mp hc
            omega
          rw [finRotate_succ_apply]
          apply Fin.ext
          simp [xb, Fin.val_add_one, xb_not_last]
          omega
        have hSrot :
            (finRotate (m + 1) * π.1).SameCycle xb (finRotate (m + 1) xb) := by
          simpa [hleft, hright, hrot] using hSame
        have hfix : π.1 xb = xb :=
          leftTight_fixed_of_sameCycle_self_finRotate π.2 xb hSrot
        have hbd' :
            π.1.SameCycle xb ⟨d, Finset.mem_range.mp hd⟩ := by
          simpa [xb] using hbd
        have hbd_eq : xb = ⟨d, Finset.mem_range.mp hd⟩ :=
          hbd'.eq_of_left (show Function.IsFixedPt π.1 xb from hfix)
        have hval : b = d := congrArg Fin.val hbd_eq
        omega
  · rcases hRight with ⟨r, s, hr, hs, hrs, hSame⟩
    have hpairs : r = 0 ∧ s = 1 := by
      omega
    rcases hpairs with ⟨hr0, hs1⟩
    have hleft :
        (⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)) =
          ⟨a, Finset.mem_range.mp ha⟩ := by
      apply Fin.ext
      simp [hr0]
    have hright :
        (⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)) =
          ⟨b, Finset.mem_range.mp hb⟩ := by
      apply Fin.ext
      simp [hs1, hb_eq]
    exact False.elim (hnot (by simpa [hleft, hright] using hSame))

/-- Gap-two right half of Biane's adjacent-link theorem.

This is the companion to `leftTight_bianeAdjacentLink_left_of_gap_two`.  On the
interval `[b,d]` with `d-b=2`, the only repeated-contour options are:
the desired adjacent left repeat `c~d`, the endpoint-to-endpoint left repeat,
the adjacent left repeat `b~c`, or the right repeat `b~c`.  The latter three
are ruled out by left-tight transversality, fixed-point transversality, and the
separating non-link `a≁b` together with `a~c`. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_two
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgap : d - b = 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨c, Finset.mem_range.mp hc⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
  have hbd_lt : b < d := by omega
  have hc_eq : c = b + 1 := by omega
  have hd_eq : d = b + 2 := by omega
  have hgap_lt : 1 < d - b := by omega
  rcases
    leftTight_contour_interval_sameCycle_exists_repeated_parity_sameCycle_of_one_lt_sub
      (m := m) (π := π.1) π.2 hb hd hbd_lt hbd hgap_lt with
    hLeft | hRight
  · rcases hLeft with ⟨r, s, hr, hs, hrs, hSame⟩
    have hpairs :
        (r = 0 ∧ s = 1) ∨ (r = 0 ∧ s = 2) ∨ (r = 1 ∧ s = 2) := by
      omega
    rcases hpairs with hrs01 | hrsRest
    · rcases hrs01 with ⟨hr0, hs1⟩
      let xb : Fin (m + 1) := ⟨b, Finset.mem_range.mp hb⟩
      have hleft :
          (⟨b + r, by
            have hd' := Finset.mem_range.mp hd
            omega⟩ : Fin (m + 1)) = xb := by
        apply Fin.ext
        simp [hr0, xb]
      have hright :
          (⟨b + s, by
            have hd' := Finset.mem_range.mp hd
            omega⟩ : Fin (m + 1)) =
            ⟨c, Finset.mem_range.mp hc⟩ := by
        apply Fin.ext
        simp [hs1, hc_eq]
      have hrot :
          finRotate (m + 1) xb =
            ⟨c, Finset.mem_range.mp hc⟩ := by
        have xb_not_last : xb ≠ Fin.last m := by
          intro hlast
          have hbval : b = m := by
            simpa [xb] using congrArg Fin.val hlast
          have hc' := Finset.mem_range.mp hc
          omega
        rw [finRotate_succ_apply]
        apply Fin.ext
        simp [xb, Fin.val_add_one, xb_not_last]
        omega
      have hSrot :
          (finRotate (m + 1) * π.1).SameCycle xb (finRotate (m + 1) xb) := by
        simpa [hleft, hright, hrot] using hSame
      have hfix : π.1 xb = xb :=
        leftTight_fixed_of_sameCycle_self_finRotate π.2 xb hSrot
      have hbd' :
          π.1.SameCycle xb ⟨d, Finset.mem_range.mp hd⟩ := by
        simpa [xb] using hbd
      have hbd_eq : xb = ⟨d, Finset.mem_range.mp hd⟩ :=
        hbd'.eq_of_left (show Function.IsFixedPt π.1 xb from hfix)
      have hval : b = d := congrArg Fin.val hbd_eq
      omega
    · rcases hrsRest with hrs02 | hrs12
      · rcases hrs02 with ⟨hr0, hs2⟩
        have hleft :
            (⟨b + r, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨b, Finset.mem_range.mp hb⟩ := by
          apply Fin.ext
          simp [hr0]
        have hright :
            (⟨b + s, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨d, Finset.mem_range.mp hd⟩ := by
          apply Fin.ext
          simp [hs2, hd_eq]
        have hS_bd :
            (finRotate (m + 1) * π.1).SameCycle
              ⟨b, Finset.mem_range.mp hb⟩
              ⟨d, Finset.mem_range.mp hd⟩ := by
          simpa [hleft, hright] using hSame
        exact False.elim
          ((leftTight_not_sameCycle_both_of_lt
            (m := m) (π := π.1) π.2 hb hd hbd_lt hbd) hS_bd)
      · rcases hrs12 with ⟨hr1, hs2⟩
        have hleft :
            (⟨b + r, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          apply Fin.ext
          simp [hr1, hc_eq]
        have hright :
            (⟨b + s, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨d, Finset.mem_range.mp hd⟩ := by
          apply Fin.ext
          simp [hs2, hd_eq]
        simpa [hleft, hright] using hSame
  · rcases hRight with ⟨r, s, hr, hs, hrs, hSame⟩
    have hpairs : r = 0 ∧ s = 1 := by
      omega
    rcases hpairs with ⟨hr0, hs1⟩
    have hleft :
        (⟨b + r, by
          have hd' := Finset.mem_range.mp hd
          omega⟩ : Fin (m + 1)) =
          ⟨b, Finset.mem_range.mp hb⟩ := by
      apply Fin.ext
      simp [hr0]
    have hright :
        (⟨b + s, by
          have hd' := Finset.mem_range.mp hd
          omega⟩ : Fin (m + 1)) =
          ⟨c, Finset.mem_range.mp hc⟩ := by
      apply Fin.ext
      simp [hs1, hc_eq]
    have hbcSame :
        π.1.SameCycle
          ⟨b, Finset.mem_range.mp hb⟩
          ⟨c, Finset.mem_range.mp hc⟩ := by
      simpa [hleft, hright] using hSame
    exact False.elim (hnot (hac.trans hbcSame.symm))

/-- Full Biane adjacent-link branch when both visible gaps have length two.

The two halves proved above close the complete adjacent-link obligation for
the first nontrivial local crossing shape: `a<b<c<d` with
`c-a=d-b=2`. -/
theorem leftTight_bianeAdjacentLinks_of_both_gap_two
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgapLeft : c - a = 2)
    (hgapRight : d - b = 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩) :
    (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩ ∧
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩ := by
  exact
    ⟨leftTight_bianeAdjacentLink_left_of_gap_two
        π ha hb hc hd hab hbc hcd hgapLeft hac hbd hnot,
      leftTight_bianeAdjacentLink_right_of_gap_two
        π ha hb hc hd hab hbc hcd hgapRight hac hbd hnot⟩

/-- A left Biane link follows from a gap-two subcrossing starting at the left
endpoint.

This closes the branch where a larger crossing has `b=a+1` and an internal
right repeat already gives the shorter `π`-link `a~a+2`.  The checked gap-two
left theorem then applies to the subcrossing `(a,b,a+2,d)`. -/
theorem leftTight_bianeAdjacentLink_left_of_start_gap_two_right_repeat
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hb_eq : b = a + 1)
    (ha2Same : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 2, by
        have hd' := Finset.mem_range.mp hd
        omega⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩ := by
  have hb_a2 : b < a + 2 := by
    omega
  have ha2_d : a + 2 < d := by
    have hc' := Finset.mem_range.mp hc
    omega
  have ha2_mem : a + 2 ∈ Finset.range (m + 1) :=
    Finset.mem_range.mpr (Nat.lt_trans ha2_d (Finset.mem_range.mp hd))
  have hgap : (a + 2) - a = 2 := by
    omega
  have hA2 :
      (⟨a + 2, by
        have hd' := Finset.mem_range.mp hd
        omega⟩ : Fin (m + 1)) =
        ⟨a + 2, Finset.mem_range.mp ha2_mem⟩ := by
    apply Fin.ext
    rfl
  have ha2Same' : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 2, Finset.mem_range.mp ha2_mem⟩ := by
    simpa [hA2] using ha2Same
  exact
    leftTight_bianeAdjacentLink_left_of_gap_two
      π ha hb ha2_mem hd hab hb_a2 ha2_d hgap ha2Same' hbd hnot

/-- An adjacent `(finRotate*π)` repeat cannot carry a nontrivial `π`-cycle
link.

The adjacent left repeat `x ~ finRotate x` makes `x` a fixed point of `π` by
left-tightness.  A same-`π`-cycle link from `x` to any distinct point is then
impossible. -/
theorem leftTight_adjacent_left_repeat_impossible_of_sameCycle_ne
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {x y : Fin (m + 1)}
    (hS : (finRotate (m + 1) * π.1).SameCycle x (finRotate (m + 1) x))
    (hT : π.1.SameCycle x y)
    (hne : x ≠ y) :
    False := by
  have hfix : π.1 x = x :=
    leftTight_fixed_of_sameCycle_self_finRotate π.2 x hS
  have hxy : x = y :=
    hT.eq_of_left (show Function.IsFixedPt π.1 x from hfix)
  exact hne hxy

/-- Natural-index adjacent-repeat contradiction.

If the adjacent natural points `x` and `x+1` lie in the same
`(finRotate*π)`-cycle and `x` is also `π`-connected to a strictly larger
point `z`, left-tightness is contradicted. -/
theorem leftTight_nat_adjacent_left_repeat_impossible_of_sameCycle_to_right
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {x z : ℕ}
    (hx : x ∈ Finset.range (m + 1))
    (hz : z ∈ Finset.range (m + 1))
    (hxz : x < z)
    (hS_x_succ : (finRotate (m + 1) * π.1).SameCycle
      ⟨x, Finset.mem_range.mp hx⟩
      ⟨x + 1, by
        have hz' := Finset.mem_range.mp hz
        omega⟩)
    (hT : π.1.SameCycle
      ⟨x, Finset.mem_range.mp hx⟩
      ⟨z, Finset.mem_range.mp hz⟩) :
    False := by
  let xx : Fin (m + 1) := ⟨x, Finset.mem_range.mp hx⟩
  have hx1_mem : x + 1 ∈ Finset.range (m + 1) := by
    exact Finset.mem_range.mpr
      (Nat.lt_of_le_of_lt (Nat.succ_le_of_lt hxz) (Finset.mem_range.mp hz))
  have hX1 :
      (⟨x + 1, by
        have hz' := Finset.mem_range.mp hz
        omega⟩ : Fin (m + 1)) =
        ⟨x + 1, Finset.mem_range.mp hx1_mem⟩ := by
    apply Fin.ext
    rfl
  have hrot :
      finRotate (m + 1) xx =
        ⟨x + 1, Finset.mem_range.mp hx1_mem⟩ := by
    rw [finRotate_succ_apply]
    apply Fin.ext
    have hxx_succ_lt : xx.val + 1 < m + 1 := by
      have hz' := Finset.mem_range.mp hz
      have hxxval : xx.val = x := rfl
      omega
    have hval : (xx + 1).val = xx.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xx) hxx_succ_lt
    change (xx + 1).val = x + 1
    calc
      (xx + 1).val = xx.val + 1 := hval
      _ = x + 1 := by
        simp [xx]
  have hSrot :
      (finRotate (m + 1) * π.1).SameCycle xx (finRotate (m + 1) xx) := by
    simpa [xx, hX1, hrot] using hS_x_succ
  have hT' : π.1.SameCycle xx ⟨z, Finset.mem_range.mp hz⟩ := by
    simpa [xx] using hT
  exact
    leftTight_adjacent_left_repeat_impossible_of_sameCycle_ne
      π hSrot hT' (by
        intro hEq
        have hval : x = z := congrArg Fin.val hEq
        omega)

/-- A start-adjacent left repeat is impossible when the start point has a
nontrivial `π`-link to the right.

If `b=a+1` and the repeated left class is `S(b,a+2)`, then this is the same
as `S(b,finRotate b)`, so left-tightness makes `b` a fixed point of `π`.
That contradicts a `π`-cycle link from `b` to a strictly larger point `d`. -/
theorem leftTight_start_adjacent_left_repeat_impossible_of_sameCycle_to_right
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b d : ℕ}
    (hb : b ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hbd_lt : b < d)
    (hb_eq : b = a + 1)
    (hS_b_a2 : (finRotate (m + 1) * π.1).SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨a + 2, by
        have hd' := Finset.mem_range.mp hd
        omega⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩) :
    False := by
  let xb : Fin (m + 1) := ⟨b, Finset.mem_range.mp hb⟩
  have ha2_mem : a + 2 ∈ Finset.range (m + 1) := by
    have ha2_le_d : a + 2 ≤ d := by
      omega
    exact Finset.mem_range.mpr
      (Nat.lt_of_le_of_lt ha2_le_d (Finset.mem_range.mp hd))
  have hA2 :
      (⟨a + 2, by
        have hd' := Finset.mem_range.mp hd
        omega⟩ : Fin (m + 1)) =
        ⟨a + 2, Finset.mem_range.mp ha2_mem⟩ := by
    apply Fin.ext
    rfl
  have hrot :
      finRotate (m + 1) xb =
        ⟨a + 2, Finset.mem_range.mp ha2_mem⟩ := by
    have xb_not_last : xb ≠ Fin.last m := by
      intro hlast
      have hbval : b = m := by
        simpa [xb] using congrArg Fin.val hlast
      have hd' := Finset.mem_range.mp hd
      omega
    rw [finRotate_succ_apply]
    apply Fin.ext
    have hxb_succ_lt : xb.val + 1 < m + 1 := by
      have hd' := Finset.mem_range.mp hd
      have hxbval : xb.val = b := rfl
      omega
    have hval : (xb + 1).val = xb.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xb) hxb_succ_lt
    change (xb + 1).val = a + 2
    calc
      (xb + 1).val = xb.val + 1 := hval
      _ = b + 1 := by
        simp [xb]
      _ = a + 2 := by
        omega
  have hSrot :
      (finRotate (m + 1) * π.1).SameCycle xb (finRotate (m + 1) xb) := by
    simpa [xb, hA2, hrot] using hS_b_a2
  have hbd' : π.1.SameCycle xb ⟨d, Finset.mem_range.mp hd⟩ := by
    simpa [xb] using hbd
  exact
    leftTight_adjacent_left_repeat_impossible_of_sameCycle_ne
      π hSrot hbd' (by
        intro hEq
        have hval : b = d := congrArg Fin.val hEq
        omega)

/-- In the `c-a=3`, `b=a+1` left Biane slice, the advertised target
`S(a,b)` is itself incompatible with the longer same-`π` interval `a~c`.

Thus the remaining start-adjacent finite branches in this slice should be read
as branch-impossibility obligations: producing the target is equivalent to
showing that the branch cannot occur. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_adjacent_target_impossible
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (_hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (_hbc : b < c) (_hcd : c < d)
    (hgap : c - a = 3)
    (hb_eq : b = a + 1)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩) :
    ¬ (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩ := by
  intro hS
  have hac_lt : a < c := by omega
  have hgap_lt : 1 < c - a := by omega
  have hB :
      (⟨b, Finset.mem_range.mp hb⟩ : Fin (m + 1)) =
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ := by
    apply Fin.ext
    exact hb_eq
  exact
    (leftTight_not_start_adjacent_left_repeat_of_sameCycle_one_lt_sub
      (m := m) (π := π.1) π.2 ha hc hac_lt hac hgap_lt)
      (by simpa [hB] using hS)

/-- Branch-to-target obligations in the `c-a=3`, `b=a+1` left Biane slice are
equivalent to branch-impossibility obligations.

This is a bookkeeping theorem, but it prevents a misleading reading of the
finite start slice: no surviving branch should be proved by constructing
`S(a,b)` directly, since that target contradicts the long `π` interval
`a~c`. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_adjacent_branch_to_target_iff_false
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgap : c - a = 3)
    (hb_eq : b = a + 1)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (Branch : Prop) :
    (Branch →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩) ↔
    (Branch → False) := by
  constructor
  · intro h branch
    exact
      (leftTight_bianeAdjacentLink_left_of_gap_three_start_adjacent_target_impossible
        π ha hb hc hd hab hbc hcd hgap hb_eq hac) (h branch)
  · intro h branch
    exact False.elim (h branch)

/-- The left-start branch `S(b,c)` is impossible once the right adjacent link
`S(c,d)` is available.

Indeed the two `(finRotate*π)` links compose to `S(b,d)`, contradicting the
nontrivial `π`-link `b~d` by left-tight transversality. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_S_b_c_false_of_right_link
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {b c d : ℕ}
    (hb : b ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hbc : b < c) (hcd : c < d)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hS_b_c : (finRotate (m + 1) * π.1).SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨c, by
        have hd' := Finset.mem_range.mp hd
        omega⟩)
    (hS_c_d : (finRotate (m + 1) * π.1).SameCycle
      ⟨c, by
        have hd' := Finset.mem_range.mp hd
        omega⟩
      ⟨d, Finset.mem_range.mp hd⟩) :
    False := by
  have hS_b_d : (finRotate (m + 1) * π.1).SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩ :=
    hS_b_c.trans hS_c_d
  exact
    (leftTight_not_sameCycle_both_of_lt
      (m := m) (π := π.1) π.2 hb hd (by omega) hbd) hS_b_d

/-- The left-start `S(b,c)` branch is not an independent endpoint input.

In the same crossing, the right Biane frontier supplies `S(c,d)`: either by
the large-gap right input, or by the special right `d-b=3, c=b+2` branch.
The previous lemma then contradicts the `π`-link `b~d`. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_S_b_c_false_of_right_frontier
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (_hgap : c - a = 3) (_hb_eq : b = a + 1)
    (hac : π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot : ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩)
    (hRightRest : ∀ a b c d : ℕ,
      ∀ ha : a ∈ Finset.range (m + 1),
      ∀ hb : b ∈ Finset.range (m + 1),
      ∀ hc : c ∈ Finset.range (m + 1),
      ∀ hd : d ∈ Finset.range (m + 1),
        a < b → b < c → c < d →
        π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ →
        π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
          ⟨d, Finset.mem_range.mp hd⟩ →
        ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
          ⟨b, Finset.mem_range.mp hb⟩ →
        2 < d - b →
        ¬ (d - b = 3 ∧ c = b + 2) →
        (finRotate (m + 1) * π.1).SameCycle
          ⟨c, Finset.mem_range.mp hc⟩
          ⟨d, Finset.mem_range.mp hd⟩)
    (hRightS_b_c : ∀ a b c d : ℕ,
      ∀ ha : a ∈ Finset.range (m + 1),
      ∀ hb : b ∈ Finset.range (m + 1),
      ∀ hc : c ∈ Finset.range (m + 1),
      ∀ hd : d ∈ Finset.range (m + 1),
        a < b → b < c → c < d →
        (hgap : d - b = 3) → (hc_eq : c = b + 2) →
        π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
          ⟨c, Finset.mem_range.mp hc⟩ →
        π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
          ⟨d, Finset.mem_range.mp hd⟩ →
        ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
          ⟨b, Finset.mem_range.mp hb⟩ →
        (finRotate (m + 1) * π.1).SameCycle
          ⟨b, Finset.mem_range.mp hb⟩
          ⟨c, Finset.mem_range.mp hc⟩ →
        (finRotate (m + 1) * π.1).SameCycle
          ⟨c, Finset.mem_range.mp hc⟩
          ⟨d, Finset.mem_range.mp hd⟩)
    (hS_b_c : (finRotate (m + 1) * π.1).SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨c, Finset.mem_range.mp hc⟩) :
    False := by
  have hlarge : 2 < d - b := by omega
  have hScd : (finRotate (m + 1) * π.1).SameCycle
      ⟨c, Finset.mem_range.mp hc⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
    by_cases hspecial : d - b = 3 ∧ c = b + 2
    · exact hRightS_b_c a b c d ha hb hc hd hab hbc hcd
        hspecial.1 hspecial.2 hac hbd hnot hS_b_c
    · exact hRightRest a b c d ha hb hc hd hab hbc hcd
        hac hbd hnot hlarge hspecial
  have hC_hd : (⟨c, by
        have hd' := Finset.mem_range.mp hd
        omega⟩ : Fin (m + 1)) = ⟨c, Finset.mem_range.mp hc⟩ := by
    apply Fin.ext
    rfl
  have hSbc' : (finRotate (m + 1) * π.1).SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨c, by
        have hd' := Finset.mem_range.mp hd
        omega⟩ := by
    simpa [hC_hd] using hS_b_c
  have hScd' : (finRotate (m + 1) * π.1).SameCycle
      ⟨c, by
        have hd' := Finset.mem_range.mp hd
        omega⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
    simpa [hC_hd] using hScd
  exact
    leftTight_bianeAdjacentLink_left_of_gap_three_start_S_b_c_false_of_right_link
      π hb hd hbc hcd hbd hSbc' hScd'

/-- Global supplier for the endpoint-facing left-start `S(b,c)` contradiction.

This has exactly the shape of the old left-start `S(b,c)` branch-impossibility
input, but proves it from the right half-link frontier already carried by the
sharp endpoint. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_S_b_c_false_of_global_right_frontier
    (hRightRest : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          2 < d - b →
          ¬ (d - b = 3 ∧ c = b + 2) →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨c, Finset.mem_range.mp hc⟩
            ⟨d, Finset.mem_range.mp hd⟩)
    (hRightS_b_c : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          (hgap : d - b = 3) → (hc_eq : c = b + 2) →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨b, Finset.mem_range.mp hb⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨c, Finset.mem_range.mp hc⟩
            ⟨d, Finset.mem_range.mp hd⟩) :
    ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          (hgap : c - a = 3) → (hb_eq : b = a + 1) →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨b, Finset.mem_range.mp hb⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          False := by
  intro m π a b c d ha hb hc hd hab hbc hcd hgap hb_eq hac hbd hnot hS_b_c
  exact
    leftTight_bianeAdjacentLink_left_of_gap_three_start_S_b_c_false_of_right_frontier
      π ha hb hc hd hab hbc hcd hgap hb_eq hac hbd hnot
      (fun a b c d ha hb hc hd hab hbc hcd hac hbd hnot hlarge hspecial =>
        hRightRest m π a b c d ha hb hc hd
          hab hbc hcd hac hbd hnot hlarge hspecial)
      (fun a b c d ha hb hc hd hab hbc hcd hgap hc_eq hac hbd hnot hS_b_c =>
        hRightS_b_c m π a b c d ha hb hc hd
          hab hbc hcd hgap hc_eq hac hbd hnot hS_b_c)
      hS_b_c

/-- In the start-adjacent `c-a=3` slice, the first two contour steps form a
simple path as soon as the four visible short repeats are absent.

This local helper is intentionally concrete.  It avoids re-running the full
finite branch classifier when the fixed `a+2` branch is copied to the endpoint
`c`; the only facts needed are the three missing left repeats and the missing
right repeat `π(a,b)`. -/
theorem leftTight_gap_three_start_prefix_isPath_of_no_visible_repeats
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (_hgap : c - a = 3)
    (hnotS_ab : ¬ (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 1, by have hc' := Finset.mem_range.mp hc; omega⟩)
    (hnotS_a_a2 : ¬ (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 2, by have hc' := Finset.mem_range.mp hc; omega⟩)
    (hnotS_b_a2 : ¬ (finRotate (m + 1) * π.1).SameCycle
      ⟨a + 1, by have hc' := Finset.mem_range.mp hc; omega⟩
      ⟨a + 2, by have hc' := Finset.mem_range.mp hc; omega⟩)
    (hnotT_ab : ¬ π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 1, by have hc' := Finset.mem_range.mp hc; omega⟩) :
    (finRotate_mul_perm_incidence_contour_interval_left_walk
        π.1 ha
        (Finset.mem_range.mpr
          (by have hc' := Finset.mem_range.mp hc; omega))
        (by omega : a ≤ a + 2)).IsPath := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π.1
  let xa : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let xb : Fin (m + 1) :=
    ⟨a + 1, by have hc' := Finset.mem_range.mp hc; omega⟩
  let xu : Fin (m + 1) :=
    ⟨a + 2, by have hc' := Finset.mem_range.mp hc; omega⟩
  have hxa_add_one : xa + 1 = xb := by
    apply Fin.ext
    have hxa_succ_lt : xa.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xa]
      omega
    have hval : (xa + 1).val = xa.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xa) hxa_succ_lt
    change (xa + 1).val = xb.val
    simp [xa, xb] at hval ⊢
    omega
  have hxb_add_one : xb + 1 = xu := by
    apply Fin.ext
    have hxb_succ_lt : xb.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xb]
      omega
    have hval : (xb + 1).val = xb.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xb) hxb_succ_lt
    change (xb + 1).val = xu.val
    simp [xb, xu] at hval ⊢
    omega
  have hrot_a : finRotate (m + 1) xa = xb := by
    rw [finRotate_succ_apply]
    simp [hxa_add_one]
  have hrot_b : finRotate (m + 1) xb = xu := by
    rw [finRotate_succ_apply]
    simp [hxb_add_one]
  have hstep_a : S (π.1.symm xa) xb := by
    have h := (finRotate_mul_perm_contour_step_sameCycle π.1 xa).2
    simpa [S, hrot_a] using h
  have hstep_b : S (π.1.symm xb) xu := by
    have h := (finRotate_mul_perm_contour_step_sameCycle π.1 xb).2
    simpa [S, hrot_b] using h
  have hne_S_a_preva :
      (Sum.inl (Quotient.mk'' xa : Quotient S) :
          Quotient S ⊕ Quotient T) ≠
        Sum.inl (Quotient.mk'' (π.1.symm xa) : Quotient S) := by
    intro hq
    have hS : S xa (π.1.symm xa) := Quotient.exact (Sum.inl.inj hq)
    exact hnotS_ab (by simpa [S, xa, xb] using hS.trans hstep_a)
  have hne_S_a_prevb :
      (Sum.inl (Quotient.mk'' xa : Quotient S) :
          Quotient S ⊕ Quotient T) ≠
        Sum.inl (Quotient.mk'' (π.1.symm xb) : Quotient S) := by
    intro hq
    have hS : S xa (π.1.symm xb) := Quotient.exact (Sum.inl.inj hq)
    exact hnotS_a_a2 (by simpa [S, xa, xu] using hS.trans hstep_b)
  have hne_S_preva_prevb :
      (Sum.inl (Quotient.mk'' (π.1.symm xa) : Quotient S) :
          Quotient S ⊕ Quotient T) ≠
        Sum.inl (Quotient.mk'' (π.1.symm xb) : Quotient S) := by
    intro hq
    have hS : S (π.1.symm xa) (π.1.symm xb) :=
      Quotient.exact (Sum.inl.inj hq)
    have hS_bu : S xb xu := hstep_a.symm.trans (hS.trans hstep_b)
    exact hnotS_b_a2 (by simpa [S, xb, xu] using hS_bu)
  have hne_T_a_b :
      (Sum.inr (Quotient.mk'' xa : Quotient T) :
          Quotient S ⊕ Quotient T) ≠
        Sum.inr (Quotient.mk'' xb : Quotient T) := by
    intro hq
    have hT : T xa xb := Quotient.exact (Sum.inr.inj hq)
    exact hnotT_ab (by simpa [T, xa, xb] using hT)
  rw [SimpleGraph.Walk.isPath_def]
  simp [finRotate_mul_perm_incidence_contour_interval_left_walk,
    SimpleGraph.Walk.support_copy]
  change
    (finRotate_mul_perm_incidence_contour_pow_left_walk
      π.1 xa (a + 2 - a)).support.Nodup
  have hsub : a + 2 - a = 2 := by omega
  rw [hsub]
  simp [finRotate_mul_perm_incidence_contour_pow_left_walk,
    finRotate_mul_perm_incidence_contour_step_left_walk,
    setoidIncidenceGraph_left_walk_of_right_rel,
    SimpleGraph.Walk.support_append,
    SimpleGraph.Walk.support_copy,
    SimpleGraph.Walk.support_cons,
    SimpleGraph.Walk.support_nil,
    xa, xb, hxa_add_one]
  change
    ([Sum.inl (Quotient.mk'' xa : Quotient S),
      Sum.inr (Quotient.mk'' xa : Quotient T),
      Sum.inl (Quotient.mk'' (π.1.symm xa) : Quotient S),
      Sum.inr (Quotient.mk'' xb : Quotient T),
      Sum.inl (Quotient.mk'' (π.1.symm xb) : Quotient S)] :
        List (Quotient S ⊕ Quotient T)).Nodup
  simp [List.nodup_cons,
    hne_S_a_preva, hne_S_a_prevb, hne_S_preva_prevb, hne_T_a_b]

/-- In the `c-a=3`, `b=a+1` start slice, a fixed predecessor `a+2`
forces the already-closed branch `S(b,c)`.

If `S(b,c)` failed, the first two Biane contour steps, copied along the fixed
left class `S(a+2)=S(c)`, would give a simple length-four path between the
same two left vertices as the direct length-two path coming from `π(a,c)`.
Tree uniqueness forbids this. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_fixed_a2_to_S_b_c
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgap : c - a = 3)
    (hb_eq : b = a + 1)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (_hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot : ¬ π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩)
    (hfix : π.1
      ⟨a + 2, by have hc' := Finset.mem_range.mp hc; omega⟩ =
      ⟨a + 2, by have hc' := Finset.mem_range.mp hc; omega⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨c, Finset.mem_range.mp hc⟩ := by
  by_contra hnotS_b_c
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  let xu : Fin (m + 1) :=
    ⟨a + 2, by have hc' := Finset.mem_range.mp hc; omega⟩
  have hrot_u : finRotate (m + 1) xu = ⟨c, Finset.mem_range.mp hc⟩ := by
    rw [finRotate_succ_apply]
    apply Fin.ext
    have hx_succ_lt : xu.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xu]
      omega
    have hval : (xu + 1).val = xu.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xu) hx_succ_lt
    change (xu + 1).val = c
    simp [xu] at hval ⊢
    omega
  have hS_u_c : (finRotate (m + 1) * π.1).SameCycle
      xu ⟨c, Finset.mem_range.mp hc⟩ := by
    have h := finRotate_mul_perm_sameCycle_self_finRotate_of_fixed
      (m := m) (π := π.1) (x := xu) hfix
    simpa [hrot_u] using h
  have hnotS_ab : ¬ (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 1, by have hc' := Finset.mem_range.mp hc; omega⟩ := by
    have hB :
        (⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)) =
          ⟨b, Finset.mem_range.mp hb⟩ := by
      apply Fin.ext
      change a + 1 = b
      omega
    intro hS
    exact
      (leftTight_bianeAdjacentLink_left_of_gap_three_start_adjacent_target_impossible
        π ha hb hc hd hab hbc hcd hgap hb_eq hac) (by simpa [hB] using hS)
  have hnotS_a_a2 : ¬ (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 2, by have hc' := Finset.mem_range.mp hc; omega⟩ := by
    intro hS_a_u
    have hS_ac : (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
      simpa [S, xu] using hS_a_u.trans hS_u_c
    exact (leftTight_not_sameCycle_both_of_lt
      (m := m) (π := π.1) π.2 ha hc (by omega) hac) hS_ac
  have hnotS_b_a2 : ¬ (finRotate (m + 1) * π.1).SameCycle
      ⟨a + 1, by have hc' := Finset.mem_range.mp hc; omega⟩
      ⟨a + 2, by have hc' := Finset.mem_range.mp hc; omega⟩ := by
    intro hS_b_u
    have hB :
        (⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)) =
          ⟨b, Finset.mem_range.mp hb⟩ := by
      apply Fin.ext
      change a + 1 = b
      omega
    have hSbc : (finRotate (m + 1) * π.1).SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
      simpa [hB, S, xu] using hS_b_u.trans hS_u_c
    exact hnotS_b_c hSbc
  have hnotT_ab : ¬ π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 1, by have hc' := Finset.mem_range.mp hc; omega⟩ := by
    have hB :
        (⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)) =
          ⟨b, Finset.mem_range.mp hb⟩ := by
      apply Fin.ext
      change a + 1 = b
      omega
    intro hT
    exact hnot (by simpa [hB] using hT)
  have hu : a + 2 ∈ Finset.range (m + 1) :=
    Finset.mem_range.mpr (by have hc' := Finset.mem_range.mp hc; omega)
  let p0 := finRotate_mul_perm_incidence_contour_interval_left_walk
        π.1 ha hu (by omega : a ≤ a + 2)
  have hp0 : p0.IsPath := by
    simpa [p0] using
      leftTight_gap_three_start_prefix_isPath_of_no_visible_repeats
        (m := m) π (a := a) (c := c)
        ha hc hgap hnotS_ab hnotS_a_a2 hnotS_b_a2 hnotT_ab
  let Sset : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  have hU : (⟨a + 2, Finset.mem_range.mp hu⟩ : Fin (m + 1)) = xu := by
    apply Fin.ext
    rfl
  have hS_u_c' :
      Sset ⟨a + 2, Finset.mem_range.mp hu⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
    simpa [Sset, hU] using hS_u_c
  have hend :
      (Sum.inl (Quotient.mk'' ⟨a + 2, Finset.mem_range.mp hu⟩ :
          Quotient Sset) :
          Quotient Sset ⊕ Quotient (Equiv.Perm.SameCycle.setoid π.1)) =
        Sum.inl (Quotient.mk'' ⟨c, Finset.mem_range.mp hc⟩ :
          Quotient Sset) := by
    exact congrArg Sum.inl (Quotient.sound hS_u_c')
  let p := p0.copy rfl hend
  have hp : p.IsPath :=
    (SimpleGraph.Walk.isPath_copy p0 rfl hend).mpr hp0
  have heq :=
    leftTight_incidenceGraph_left_walk_unique_of_sameCycle
      (m := m) (π := π.1) π.2 ha hc (by omega) hac (p := p) hp
  have hlen := congrArg SimpleGraph.Walk.length heq
  have hp0_len : p0.length = 2 * (a + 2 - a) := by
    simpa [p0] using
      finRotate_mul_perm_incidence_contour_interval_left_walk_length
        π.1 ha hu (by omega : a ≤ a + 2)
  have hbad : p0.length = 2 := by
    simpa [p, SimpleGraph.Walk.length_copy] using hlen
  rw [hp0_len] at hbad
  omega

/-- Global supplier for the fixed-`a+2` left-start branch.

The fixed branch first forces `S(b,c)`, and the right half-link frontier already
turns that branch into a contradiction. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_fixed_a2_false_of_global_right_frontier
    (hRightRest : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          2 < d - b →
          ¬ (d - b = 3 ∧ c = b + 2) →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨c, Finset.mem_range.mp hc⟩
            ⟨d, Finset.mem_range.mp hd⟩)
    (hRightS_b_c : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          (hgap : d - b = 3) → (hc_eq : c = b + 2) →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨b, Finset.mem_range.mp hb⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨c, Finset.mem_range.mp hc⟩
            ⟨d, Finset.mem_range.mp hd⟩) :
    ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          (hgap : c - a = 3) → (hb_eq : b = a + 1) →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          π.1
            ⟨a + 2, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ =
            ⟨a + 2, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ →
          False := by
  intro m π a b c d ha hb hc hd hab hbc hcd hgap hb_eq hac hbd hnot hfix
  have hS_b_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩ :=
    leftTight_bianeAdjacentLink_left_of_gap_three_start_fixed_a2_to_S_b_c
      π ha hb hc hd hab hbc hcd hgap hb_eq hac hbd hnot hfix
  exact
    (leftTight_bianeAdjacentLink_left_of_gap_three_start_S_b_c_false_of_global_right_frontier
        hRightRest hRightS_b_c)
      m π a b c d ha hb hc hd
      hab hbc hcd hgap hb_eq hac hbd hnot hS_b_c

/-- In the `c-a=3`, `b=a+1` start slice, the right-cycle repeat
`π(b,a+2)` forces the already-closed branch `S(b,c)`.

If `S(b,c)` failed, the contour step from `a` to `b` followed by the
compressed right-cycle step through `π(b,a+2)` would give a simple length-four
incidence path from `S(a)` to `S(c)`.  The direct `π(a,c)` edge gives the
unique simple path of length two, a contradiction. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_T_b_a2_to_S_b_c
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgap : c - a = 3)
    (hb_eq : b = a + 1)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (_hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot : ¬ π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩)
    (hT_b_a2 : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨a + 2, by
        have hc' := Finset.mem_range.mp hc
        omega⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨c, Finset.mem_range.mp hc⟩ := by
  by_contra hnotS_b_c
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π.1
  let xa : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let xb : Fin (m + 1) := ⟨b, Finset.mem_range.mp hb⟩
  let xu : Fin (m + 1) :=
    ⟨a + 2, by
      have hc' := Finset.mem_range.mp hc
      omega⟩
  let xc : Fin (m + 1) := ⟨c, Finset.mem_range.mp hc⟩
  have hxa_add_one : xa + 1 = xb := by
    apply Fin.ext
    have hxa_succ_lt : xa.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xa]
      omega
    have hval : (xa + 1).val = xa.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xa) hxa_succ_lt
    change (xa + 1).val = xb.val
    simp [xa, xb] at hval ⊢
    omega
  have hxu_add_one : xu + 1 = xc := by
    apply Fin.ext
    have hxu_succ_lt : xu.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xu]
      omega
    have hval : (xu + 1).val = xu.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xu) hxu_succ_lt
    change (xu + 1).val = xc.val
    simp [xu, xc] at hval ⊢
    omega
  have hrot_a : finRotate (m + 1) xa = xb := by
    rw [finRotate_succ_apply]
    simp [hxa_add_one]
  have hrot_u : finRotate (m + 1) xu = xc := by
    rw [finRotate_succ_apply]
    simp [hxu_add_one]
  have hstep_a : S (π.1.symm xa) xb := by
    have h := (finRotate_mul_perm_contour_step_sameCycle π.1 xa).2
    simpa [S, hrot_a] using h
  have hstep_u : S (π.1.symm xu) xc := by
    have h := (finRotate_mul_perm_contour_step_sameCycle π.1 xu).2
    simpa [S, hrot_u] using h
  have hT_b_prevu : T xb (π.1.symm xu) := by
    have hT_b_u : T xb xu := by
      simpa [T, xb, xu] using hT_b_a2
    have hT_u_prevu : T xu (π.1.symm xu) := by
      exact (finRotate_mul_perm_contour_step_sameCycle π.1 xu).1
    exact hT_b_u.trans hT_u_prevu
  have hnotS_ab : ¬ S xa xb := by
    intro hS
    exact
      (leftTight_bianeAdjacentLink_left_of_gap_three_start_adjacent_target_impossible
        π ha hb hc hd hab hbc hcd hgap hb_eq hac) (by
          simpa [S, xa, xb] using hS)
  have hnotS_ac : ¬ S xa xc := by
    intro hS
    exact
      (leftTight_not_sameCycle_both_of_lt
        (m := m) (π := π.1) π.2 ha hc (by omega) hac) (by
          simpa [S, xa, xc] using hS)
  have hnotS_b_prevu : ¬ S xb (π.1.symm xu) := by
    intro hS
    have hS_b_c : (finRotate (m + 1) * π.1).SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
      simpa [S, xb, xc] using hS.trans hstep_u
    exact hnotS_b_c hS_b_c
  have hnotT_ab : ¬ T xa xb := by
    intro hT
    exact hnot (by simpa [T, xa, xb] using hT)
  have hqne_S_a_preva :
      ¬ (Quotient.mk'' xa : Quotient S) = Quotient.mk'' (π.1.symm xa) := by
    intro hq
    have hS : S xa (π.1.symm xa) := Quotient.exact hq
    exact hnotS_ab (hS.trans hstep_a)
  have hqne_S_a_prevu :
      ¬ (Quotient.mk'' xa : Quotient S) = Quotient.mk'' (π.1.symm xu) := by
    intro hq
    have hS : S xa (π.1.symm xu) := Quotient.exact hq
    exact hnotS_ac (hS.trans hstep_u)
  have hqne_S_preva_prevu :
      ¬ (Quotient.mk'' (π.1.symm xa) : Quotient S) =
        Quotient.mk'' (π.1.symm xu) := by
    intro hq
    have hS : S (π.1.symm xa) (π.1.symm xu) := Quotient.exact hq
    exact hnotS_b_prevu (hstep_a.symm.trans hS)
  have hqne_T_a_b :
      ¬ (Quotient.mk'' xa : Quotient T) = Quotient.mk'' xb := by
    intro hq
    have hT : T xa xb := Quotient.exact hq
    exact hnotT_ab hT
  have hend_ab :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xa) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xb : Quotient S) := by
    simp [hrot_a]
  let pab :=
    (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xa).copy
      rfl hend_ab
  have hend_bc :
      (Sum.inl (Quotient.mk'' (π.1.symm xu) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xc : Quotient S) := by
    exact congrArg Sum.inl (Quotient.sound hstep_u)
  let pbc := (setoidIncidenceGraph_left_walk_of_right_rel S T hT_b_prevu).copy
    rfl hend_bc
  let p := pab.append pbc
  have hp : p.IsPath := by
    rw [SimpleGraph.Walk.isPath_def]
    simp [p, pab, pbc,
      finRotate_mul_perm_incidence_contour_step_left_walk,
      setoidIncidenceGraph_left_walk_of_right_rel,
      SimpleGraph.Walk.support_append,
      SimpleGraph.Walk.support_copy,
      SimpleGraph.Walk.support_cons,
      SimpleGraph.Walk.support_nil]
    exact
      ⟨⟨hqne_S_a_preva, hqne_S_a_prevu⟩,
        hqne_T_a_b, hqne_S_preva_prevu⟩
  have heq :=
    leftTight_incidenceGraph_left_walk_unique_of_sameCycle
      (m := m) (π := π.1) π.2 ha hc (by omega) hac (p := p) hp
  have hlen := congrArg SimpleGraph.Walk.length heq
  have hp_len : p.length = 4 := by
    simp [p, pab, pbc, SimpleGraph.Walk.length_append,
      SimpleGraph.Walk.length_copy,
      finRotate_mul_perm_incidence_contour_step_left_walk_length,
      setoidIncidenceGraph_left_walk_of_right_rel_length]
  have hbad : p.length = 2 := by
    simpa [p] using hlen
  omega

/-- Global supplier for the `π(b,a+2)` left-start branch.

The branch first forces `S(b,c)`, and the right half-link frontier already
turns that branch into a contradiction. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_T_b_a2_false_of_global_right_frontier
    (hRightRest : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          2 < d - b →
          ¬ (d - b = 3 ∧ c = b + 2) →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨c, Finset.mem_range.mp hc⟩
            ⟨d, Finset.mem_range.mp hd⟩)
    (hRightS_b_c : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          (hgap : d - b = 3) → (hc_eq : c = b + 2) →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨b, Finset.mem_range.mp hb⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨c, Finset.mem_range.mp hc⟩
            ⟨d, Finset.mem_range.mp hd⟩) :
    ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          (hgap : c - a = 3) → (hb_eq : b = a + 1) →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          π.1.SameCycle
            ⟨b, Finset.mem_range.mp hb⟩
            ⟨a + 2, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ →
          False := by
  intro m π a b c d ha hb hc hd hab hbc hcd hgap hb_eq hac hbd hnot hT_b_a2
  have hS_b_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩ :=
    leftTight_bianeAdjacentLink_left_of_gap_three_start_T_b_a2_to_S_b_c
      π ha hb hc hd hab hbc hcd hgap hb_eq hac hbd hnot hT_b_a2
  exact
    (leftTight_bianeAdjacentLink_left_of_gap_three_start_S_b_c_false_of_global_right_frontier
        hRightRest hRightS_b_c)
      m π a b c d ha hb hc hd
      hab hbc hcd hgap hb_eq hac hbd hnot hS_b_c

/-- The residual `S(a,a+2)` left-start branch is impossible when the
corresponding `π(a,a+2)` link is absent.

The repeat `S(a,a+2)` lets the single contour step from `a+2` to `c` be
copied to a length-two path from `S(a)` to `S(c)`.  Tree uniqueness compares it
with the direct length-two path supplied by `π(a,c)`, forcing the middle right
vertex to be both `T(a)` and `T(a+2)`, contrary to `¬π(a,a+2)`. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_S_a_a2_no_pi_false
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (_hbc : b < c) (_hcd : c < d)
    (_hgap : c - a = 3)
    (_hb_eq : b = a + 1)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (_hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (_hnot : ¬ π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩)
    (hNoPi_a_a2 : ¬ π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 2, by
        have hc' := Finset.mem_range.mp hc
        omega⟩)
    (hS_a_a2 : (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨a + 2, by
        have hc' := Finset.mem_range.mp hc
        omega⟩) :
    False := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π.1
  let xa : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let xu : Fin (m + 1) :=
    ⟨a + 2, by
      have hc' := Finset.mem_range.mp hc
      omega⟩
  let xc : Fin (m + 1) := ⟨c, Finset.mem_range.mp hc⟩
  have hS_a_u : S xa xu := by
    simpa [S, xa, xu] using hS_a_a2
  have hnotT_a_u : ¬ T xa xu := by
    intro hT
    exact hNoPi_a_a2 (by simpa [T, xa, xu] using hT)
  have hxu_add_one : xu + 1 = xc := by
    apply Fin.ext
    have hxu_succ_lt : xu.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xu]
      omega
    have hval : (xu + 1).val = xu.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xu) hxu_succ_lt
    change (xu + 1).val = xc.val
    simp [xu, xc] at hval ⊢
    omega
  have hrot_u : finRotate (m + 1) xu = xc := by
    rw [finRotate_succ_apply]
    simp [hxu_add_one]
  have hnotS_u_c : ¬ S xu xc := by
    intro hS_u_c
    have hS_ac : (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
      simpa [S, xa, xu, xc] using hS_a_u.trans hS_u_c
    exact
      (leftTight_not_sameCycle_both_of_lt
        (m := m) (π := π.1) π.2 ha hc (by omega) hac) hS_ac
  have hnotS_u_rot :
      ¬ (finRotate (m + 1) * π.1).SameCycle
        xu (finRotate (m + 1) xu) := by
    intro hS
    exact hnotS_u_c (by simpa [S, hrot_u] using hS)
  have hstart :
      (Sum.inl (Quotient.mk'' xu : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xa : Quotient S) := by
    exact congrArg Sum.inl (Quotient.sound hS_a_u.symm)
  have hend :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xu) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xc : Quotient S) := by
    simp [hrot_u]
  let p := (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xu).copy
    hstart hend
  have hp : p.IsPath := by
    exact (SimpleGraph.Walk.isPath_copy _ hstart hend).mpr
      (finRotate_mul_perm_incidence_contour_step_left_walk_isPath
        π.1 xu hnotS_u_rot)
  have heq :=
    leftTight_incidenceGraph_left_walk_unique_of_sameCycle
      (m := m) (π := π.1) π.2 ha hc (by omega) hac (p := p) hp
  have hmid := congrArg (fun q => q.getVert 1) heq
  have hmid' :
      (Sum.inr (Quotient.mk'' xu : Quotient T) :
          Quotient S ⊕ Quotient T) =
        Sum.inr (Quotient.mk'' xa : Quotient T) := by
    simpa [p,
      finRotate_mul_perm_incidence_contour_step_left_walk,
      leftTight_incidenceGraph_left_walk_of_sameCycle,
      setoidIncidenceGraph_left_walk_of_right_rel,
      SimpleGraph.Walk.getVert_copy] using hmid
  have hT_u_a : T xu xa := Quotient.exact (Sum.inr.inj hmid')
  exact hnotT_a_u hT_u_a.symm

/-- The `c-a=3`, `b=a+1` left Biane slice reduces to four explicit branches.

The contour repeat on `[a,c]` has only finitely many possibilities.  The
desired adjacent link, the endpoint-to-endpoint forbidden repeat, the
start-adjacent repeat contradiction, the separating `π`-repeat, and the
start-gap-two right-repeat branch are discharged internally.  The theorem
leaves only the genuinely unclosed finite branches as explicit inputs. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_start_adjacent_reduced
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgap : c - a = 3)
    (hb_eq : b = a + 1)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_a_a2 :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨a + 2, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_b_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_a2_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a + 2, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hT_b_a2 :
      π.1.SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨a + 2, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ →
