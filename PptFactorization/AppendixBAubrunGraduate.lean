/-- Off-cycle open internal residuals reduce to a smaller side-aware residual.

The off-cycle witness produces a strictly smaller contour-repeat interval
inside `(a,c)`.  Splitting that contour repeat either gives the desired common
cycle immediately, or leaves a residual frontier on the smaller interval.  The
important point is that the smaller residual still carries the side data needed
for a future descent: no point of the skipped `x`-cycle lies inside it, and its
whole `π`-block stays inside the original first-return interval and off the
skipped cycle. -/
theorem leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual_common_or_smallerResidual
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hπNC : NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    {x : Fin (m + 1)} {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hT :
      π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨c, Finset.mem_range.mp hc⟩)
    (haeq : a = (π.1 x).val)
    (hfirst :
      ∀ z : Fin (m + 1),
        π.1.SameCycle z x →
        a < z.val →
        z.val < c →
        False)
    (hOff :
      leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual
        π.1 x ha hc hac) :
    (∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.1.SameCycle y z ∧
          (finRotate (m + 1) * π.1).SameCycle y z) ∨
    ∃ a' c' : ℕ,
      ∃ ha' : a' ∈ Finset.range (m + 1),
      ∃ hc' : c' ∈ Finset.range (m + 1),
      ∃ hac' : a' < c',
        a < a' ∧
        c' < c ∧
        1 < c' - a' ∧
        π.1.SameCycle
          ⟨a', Finset.mem_range.mp ha'⟩
          ⟨c', Finset.mem_range.mp hc'⟩ ∧
        leftTightStrictReturnIntervalResidual π.1 ha' hc' hac' ∧
        (∀ z : Fin (m + 1),
          π.1.SameCycle z x →
          a' < z.val →
          z.val < c' →
          False) ∧
        ∀ y : Fin (m + 1),
          π.1.SameCycle y
            ⟨a', Finset.mem_range.mp ha'⟩ →
          (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x := by
  rcases
    leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual_strictSubinterval_contourRepeat
      π hπNC ha hc hac hT haeq hfirst hOff with
    ⟨a', c', ha', hc', hac', ha_lt, hc_lt, hgap', hSame', hRepeat, hBlock⟩
  have hFrontier :
      leftTightStrictReturnIntervalFrontier π.1 ha' hc' hac' := by
    exact
      leftTightContourIntervalRepeat_strict_frontier
        (m := m) (π := π.1) π.2 ha' hc' hac' hgap' hSame' hRepeat
  rcases
    leftTightStrictReturnIntervalFrontier_common_or_residual
      ha' hc' hac' hFrontier with
    hCommon | hResidual
  · left
    exact hCommon
  · right
    refine
      ⟨a', c', ha', hc', hac', ha_lt, hc_lt, hgap', hSame', hResidual,
        ?_, hBlock⟩
    intro z hzx hz_gt hz_lt
    exact hfirst z hzx (lt_trans ha_lt hz_gt) (lt_trans hz_lt hc_lt)

/-- Nonwrapping off-cycle internal residuals may be solved from the smaller
side-aware residual leaf.

This is the consumable form of
`leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual_common_or_smallerResidual`:
the old branch input is replaced by a strictly smaller residual interval that
still remembers the outer nonwrapping first-return data and the off-`x` block
invariant. -/
theorem leftTight_nonwrap_offCycleSubintervalResidual_common_of_smallerResidual
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hπNC : NCPartition.NonCrossing (leftTightCyclePartitionRange π))
