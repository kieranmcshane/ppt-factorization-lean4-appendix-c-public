lemma two_mul_card_le_sum_of_two_le {s : Multiset ℕ}
    (h : ∀ a ∈ s, 2 ≤ a) :
    2 * s.card ≤ s.sum := by
  induction s using Multiset.induction_on with
  | empty => simp
  | cons a s ih =>
      have ha : 2 ≤ a := h a (by simp)
      have hs : ∀ b ∈ s, 2 ≤ b := by
        intro b hb
        exact h b (by simp [hb])
      have ihs := ih hs
      simp only [Multiset.card_cons, Multiset.sum_cons]
      omega

lemma cycleType_eq_zero_of_permCycleClassCount_eq_card
    {α : Type*} [Fintype α] [DecidableEq α] (σ : Equiv.Perm α)
    (hcount : permCycleClassCount σ = Fintype.card α) :
    σ.cycleType = 0 := by
  have hformula :=
    permCycleClassCount_eq_card_sub_cycleType_sum_add_cycleType_card σ
  have hsumle := Equiv.Perm.sum_cycleType_le σ
  have htwice : 2 * σ.cycleType.card ≤ σ.cycleType.sum :=
    two_mul_card_le_sum_of_two_le
      (fun a ha => Equiv.Perm.two_le_of_mem_cycleType ha)
  let t := Fintype.card α - σ.cycleType.sum
  have ht : t + σ.cycleType.sum = Fintype.card α := by
    simpa [t] using Nat.sub_add_cancel hsumle
  have htr : t + σ.cycleType.card = Fintype.card α := by
    rw [← hcount]
    simpa [t] using hformula.symm
  clear_value t
  have hsum_eq_card : σ.cycleType.sum = σ.cycleType.card := by omega
  have hcard0 : σ.cycleType.card = 0 := by omega
  exact Multiset.card_eq_zero.mp hcard0

lemma cycleType_eq_singleton_two_of_permCycleClassCount_eq_card_sub_one
    {α : Type*} [Fintype α] [DecidableEq α] (σ : Equiv.Perm α)
    (hpos : 0 < Fintype.card α)
    (hcount : permCycleClassCount σ = Fintype.card α - 1) :
    σ.cycleType = {2} := by
  have hformula :=
    permCycleClassCount_eq_card_sub_cycleType_sum_add_cycleType_card σ
  have hsumle := Equiv.Perm.sum_cycleType_le σ
  have htwice : 2 * σ.cycleType.card ≤ σ.cycleType.sum :=
    two_mul_card_le_sum_of_two_le
      (fun a ha => Equiv.Perm.two_le_of_mem_cycleType ha)
  let t := Fintype.card α - σ.cycleType.sum
  have ht : t + σ.cycleType.sum = Fintype.card α := by
    simpa [t] using Nat.sub_add_cancel hsumle
  have htr : t + σ.cycleType.card = Fintype.card α - 1 := by
    rw [← hcount]
    simpa [t] using hformula.symm
  have hN : (Fintype.card α - 1) + 1 = Fintype.card α :=
    Nat.sub_add_cancel hpos
  have htr1 : (t + σ.cycleType.card) + 1 = Fintype.card α := by
    rw [htr, hN]
  clear htr hN hcount hformula hsumle
  clear_value t
  have hs_eq : σ.cycleType.sum = σ.cycleType.card + 1 := by omega
  have hcard_le_one : σ.cycleType.card ≤ 1 := by omega
  have hcard_pos : 0 < σ.cycleType.card := by
    by_contra hnot
    have hcard0 : σ.cycleType.card = 0 := by omega
    have hs0 : σ.cycleType.sum = 0 := by
      rw [Multiset.card_eq_zero.mp hcard0]
      simp
    omega
  have hcard1 : σ.cycleType.card = 1 := by omega
  have hsum2 : σ.cycleType.sum = 2 := by omega
  obtain ⟨a, ha⟩ := Multiset.card_eq_one.mp hcard1
  have ha2 : a = 2 := by
    rw [ha, Multiset.sum_singleton] at hsum2
    exact hsum2
  simp [ha, ha2]

/-- In `S₄`, four cycle classes force the identity cycle type. -/
theorem card_PermCycleCountClass_four_four_le_one :
    Fintype.card (PermCycleCountClass 4 4) ≤ 1 := by
  classical
  let f : PermCycleCountClass 4 4 ↪
      {π : Equiv.Perm (Fin 4) // π.cycleType = 0} := {
    toFun := fun π =>
      ⟨π.1, cycleType_eq_zero_of_permCycleClassCount_eq_card π.1
        (by simpa using π.2)⟩
    inj' := by
      intro π τ h
      apply Subtype.ext
      exact congrArg (fun x : {π : Equiv.Perm (Fin 4) // π.cycleType = 0} => x.1) h
  }
  have htarget :
      Fintype.card {π : Equiv.Perm (Fin 4) // π.cycleType = 0} = 1 := by
    rw [Fintype.card_subtype]
    rw [Equiv.Perm.card_of_cycleType]
    norm_num
  calc
    Fintype.card (PermCycleCountClass 4 4) ≤
        Fintype.card {π : Equiv.Perm (Fin 4) // π.cycleType = 0} :=
      Fintype.card_le_of_embedding f
    _ = 1 := htarget

/-- In `S₄`, three cycle classes force the transposition cycle type. -/
theorem card_PermCycleCountClass_four_three_le_six :
    Fintype.card (PermCycleCountClass 4 3) ≤ 6 := by
  classical
  let f : PermCycleCountClass 4 3 ↪
      {π : Equiv.Perm (Fin 4) // π.cycleType = {2}} := {
    toFun := fun π =>
      ⟨π.1,
        cycleType_eq_singleton_two_of_permCycleClassCount_eq_card_sub_one π.1
          (by norm_num)
          (by simpa using π.2)⟩
    inj' := by
      intro π τ h
      apply Subtype.ext
      exact congrArg (fun x : {π : Equiv.Perm (Fin 4) // π.cycleType = {2}} => x.1) h
  }
  have htarget :
      Fintype.card {π : Equiv.Perm (Fin 4) // π.cycleType = {2}} = 6 := by
    rw [Fintype.card_subtype]
    simpa using
      (Equiv.Perm.card_of_cycleType_singleton (α := Fin 4) (n := 2)
        (by norm_num) (by norm_num))
  calc
    Fintype.card (PermCycleCountClass 4 3) ≤
        Fintype.card {π : Equiv.Perm (Fin 4) // π.cycleType = {2}} :=
      Fintype.card_le_of_embedding f
    _ = 6 := htarget

/-- Computable cycle-class count formula used for small finite checks. -/
def cycleCountFormula {n : ℕ} (π : Equiv.Perm (Fin n)) : ℕ :=
  n - π.cycleType.sum + π.cycleType.card

theorem permCycleClassCount_eq_cycleCountFormula {n : ℕ}
    (π : Equiv.Perm (Fin n)) :
    permCycleClassCount π = cycleCountFormula π := by
  simp [cycleCountFormula,
    permCycleClassCount_eq_card_sub_cycleType_sum_add_cycleType_card]

/-- Bounded, decidable same-cycle predicate for finite formula checks.

Mathlib's `Equiv.Perm.SameCycle` is stated using an integer-power witness,
which is ideal for mathematics but inconvenient for `decide`.  On `Fin n`, a
same-cycle witness can be searched among the first `n+2` natural powers. -/
def sameCycleBounded {n : ℕ} (π : Equiv.Perm (Fin n)) (x y : Fin n) : Prop :=
  ∃ i : Fin (n + 2), (π ^ i.val) x = y

instance sameCycleBounded_decidable {n : ℕ}
    (π : Equiv.Perm (Fin n)) (x y : Fin n) :
    Decidable (sameCycleBounded π x y) := by
  unfold sameCycleBounded
  infer_instance

/-- The bounded finite predicate is equivalent to mathlib's same-cycle
relation. -/
theorem sameCycle_iff_sameCycleBounded {n : ℕ}
    (π : Equiv.Perm (Fin n)) (x y : Fin n) :
    π.SameCycle x y ↔ sameCycleBounded π x y := by
  constructor
  · intro h
    by_cases hxy : x = y
    · refine ⟨⟨0, by omega⟩, ?_⟩
      simp [hxy]
    · rcases Equiv.Perm.SameCycle.exists_pow_eq π h with
        ⟨i, _hi0, hi_le, hi_eq⟩
      have hcard_le : (π.cycleOf x).support.card ≤ n := by
        calc
          (π.cycleOf x).support.card ≤ Fintype.card (Fin n) :=
            Finset.card_le_univ _
          _ = n := Fintype.card_fin n
      refine ⟨⟨i, by omega⟩, hi_eq⟩
  · rintro ⟨i, hpow⟩
    exact ⟨(i.val : ℤ), by simpa [zpow_natCast] using hpow⟩

/-- Decidable version of the cyclic-predecessor skip predicate. -/
def permCyclicPredecessorSkipFormula
    {n : ℕ} (π : Equiv.Perm (Fin n)) (x : Fin n) : Prop :=
  (((π x).val < x.val) ∧
      ∃ z : Fin n,
        sameCycleBounded π z x ∧ (π x).val < z.val ∧ z.val < x.val) ∨
    (¬ ((π x).val < x.val) ∧
      ((∃ z : Fin n, sameCycleBounded π z x ∧ z.val < x.val) ∨
        ∃ z : Fin n, sameCycleBounded π z x ∧ (π x).val < z.val))

instance permCyclicPredecessorSkipFormula_decidable {n : ℕ}
    (π : Equiv.Perm (Fin n)) (x : Fin n) :
    Decidable (permCyclicPredecessorSkipFormula π x) := by
  unfold permCyclicPredecessorSkipFormula
  infer_instance

/-- The decidable skip formula is equivalent to the theorem-facing skip
predicate. -/
theorem permCyclicPredecessorSkip_iff_formula
    {n : ℕ} (π : Equiv.Perm (Fin n)) (x : Fin n) :
    permCyclicPredecessorSkip π x ↔
      permCyclicPredecessorSkipFormula π x := by
  unfold permCyclicPredecessorSkip permCyclicPredecessorSkipFormula
  simp only [sameCycle_iff_sameCycleBounded]

/-- The loose primitive-residual collision hypothesis is false as stated.

The current sharp endpoint still exposes a primitive-residual common-cycle
input.  This no-go theorem records that the input cannot be proved in the
over-broad form that forgets the nested predecessor-skip side data.  At
`m = 2`, the inverse long cycle is left-tight and noncrossing, and the interval
`(0,2)` satisfies the primitive residual predicate through the adjacent-`π`
branch, but `finRotate 3 * (finRotate 3)⁻¹ = 1`, so there is no nontrivial
common pair. -/
theorem not_forall_loose_primitiveResidual_commonCycle :
    ¬ (∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
