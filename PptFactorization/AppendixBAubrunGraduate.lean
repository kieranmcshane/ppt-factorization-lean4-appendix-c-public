    aubrunProposition71Q 1 ((aubrunEvenMomentParameter d - 1) + 1)
        =
          (((aubrunEvenMomentParameter d - 1 : ℕ) : ℝ) + 1) *
            aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) := by
          simp [aubrunProposition71Q]
    _ = (aubrunEvenMomentParameter d : ℝ) *
            aubrunProposition73P ((aubrunEvenMomentParameter d - 1) + 1) := by
          rw [hk_cast]
    _ ≤ (6 * Real.log ((d : ℝ) + 2) ^ 2) *
          (12 ^ (36 : ℕ) * Real.log ((d : ℝ) + 2) ^ (72 : ℕ)) := by
          exact mul_le_mul hk_le hP_le hP_nonneg (by positivity)
    _ = (6 * 12 ^ (36 : ℕ)) *
          Real.log ((d : ℝ) + 2) ^ (74 : ℕ) := by ring

/-- The concrete Aubrun `Q(k)=kP(k)` loss for the canonical even moment is
negligible compared with the dimension parameter `d`. -/
theorem tendsto_aubrunProposition71Q_evenMoment_div_natCast_zero :
