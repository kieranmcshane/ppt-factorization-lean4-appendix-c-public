    (leftTight_incidenceGraph_right_walk_of_sameCycle π ha hc hS).IsPath := by
  exact
    setoidIncidenceGraph_right_walk_of_left_rel_isPath
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π) hS
      (leftTight_not_right_sameCycle_of_left_sameCycle_lt
        hleft ha hc hac_lt hS)

/-- The natural-index direct path attached to a `(finRotate * π)`-cycle link
has length two. -/
theorem leftTight_incidenceGraph_right_walk_of_sameCycle_length
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hS : (finRotate (m + 1) * π).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩) :
    (leftTight_incidenceGraph_right_walk_of_sameCycle π ha hc hS).length = 2 := by
  exact
    setoidIncidenceGraph_right_walk_of_left_rel_length
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π) hS

/-- In the left-tight incidence tree, every simple walk between the two
endpoint right-vertices of a nontrivial `(finRotate * π)`-cycle link is the
direct length-two walk through the common `(finRotate * π)` class. -/
theorem leftTight_incidenceGraph_right_walk_unique_of_sameCycle
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hS : (finRotate (m + 1) * π).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    {p : (setoidIncidenceGraph
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π)).Walk
        (Sum.inr (Quotient.mk'' ⟨a, Finset.mem_range.mp ha⟩ :
          Quotient (Equiv.Perm.SameCycle.setoid π)))
        (Sum.inr (Quotient.mk'' ⟨c, Finset.mem_range.mp hc⟩ :
          Quotient (Equiv.Perm.SameCycle.setoid π)))}
    (hp : p.IsPath) :
    p = leftTight_incidenceGraph_right_walk_of_sameCycle π ha hc hS := by
  let u : Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
      Quotient (Equiv.Perm.SameCycle.setoid π) :=
    Sum.inr (Quotient.mk'' ⟨a, Finset.mem_range.mp ha⟩)
  let v : Quotient (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π)) ⊕
      Quotient (Equiv.Perm.SameCycle.setoid π) :=
    Sum.inr (Quotient.mk'' ⟨c, Finset.mem_range.mp hc⟩)
  rcases leftTight_incidenceGraph_existsUnique_isPath
      (m := m) (π := π) hleft u v with
    ⟨w, hw, huniq⟩
  have hdirect :
      (leftTight_incidenceGraph_right_walk_of_sameCycle π ha hc hS).IsPath :=
    leftTight_incidenceGraph_right_walk_of_sameCycle_isPath
      hleft ha hc hac_lt hS
  exact (huniq p hp).trans (huniq
    (leftTight_incidenceGraph_right_walk_of_sameCycle π ha hc hS) hdirect).symm

/-- If the interval contour between two points in one `π`-cycle is already a
simple path, then tree uniqueness forces it to be the direct two-edge path. -/
theorem leftTight_contour_interval_eq_direct_of_sameCycle_isPath
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hp :
      (finRotate_mul_perm_incidence_contour_interval_left_walk
        π ha hc hac_lt.le).IsPath) :
    finRotate_mul_perm_incidence_contour_interval_left_walk
        π ha hc hac_lt.le =
      leftTight_incidenceGraph_left_walk_of_sameCycle π ha hc hT := by
  exact
    leftTight_incidenceGraph_left_walk_unique_of_sameCycle
      hleft ha hc hac_lt hT hp

/-- A simple interval contour between two points in one `π`-cycle can only
span one step of the linear order.  Longer intervals must repeat a vertex in
the incidence tree. -/
theorem leftTight_contour_interval_sameCycle_isPath_sub_eq_one
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hp :
      (finRotate_mul_perm_incidence_contour_interval_left_walk
        π ha hc hac_lt.le).IsPath) :
    c - a = 1 := by
  have heq :=
    leftTight_contour_interval_eq_direct_of_sameCycle_isPath
      hleft ha hc hac_lt hT hp
  have hlen := congrArg SimpleGraph.Walk.length heq
  rw [finRotate_mul_perm_incidence_contour_interval_left_walk_length,
    leftTight_incidenceGraph_left_walk_of_sameCycle_length] at hlen
  omega

/-- Contrapositive form of the direct-path comparison: if two points in one
`π`-cycle are separated by at least one intermediate index, the corresponding
interval contour is not a simple path. -/
theorem leftTight_contour_interval_sameCycle_not_isPath_of_one_lt_sub
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a) :
    ¬ (finRotate_mul_perm_incidence_contour_interval_left_walk
        π ha hc hac_lt.le).IsPath := by
  intro hp
  have hsub :=
    leftTight_contour_interval_sameCycle_isPath_sub_eq_one
      hleft ha hc hac_lt hT hp
  omega

/-- Longer same-cycle interval contours have repeated support in the
left-tight incidence tree.  This is the explicit extraction point left by the
Biane adjacent-link proof: the next step is to identify which repeated vertex
forces the adjacent `(finRotate * π)` link. -/
theorem leftTight_contour_interval_sameCycle_support_not_nodup_of_one_lt_sub
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a) :
    ¬ (finRotate_mul_perm_incidence_contour_interval_left_walk
        π ha hc hac_lt.le).support.Nodup := by
  intro hnodup
  exact
    leftTight_contour_interval_sameCycle_not_isPath_of_one_lt_sub
      hleft ha hc hac_lt hT hgap
      ((SimpleGraph.Walk.isPath_def
        (finRotate_mul_perm_incidence_contour_interval_left_walk
          π ha hc hac_lt.le)).mpr hnodup)

/-- Witness form of the repeated-support obstruction: for a longer
same-cycle interval, two distinct contour times visit the same incidence-tree
vertex. -/
theorem leftTight_contour_interval_sameCycle_exists_repeated_getVert_of_one_lt_sub
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a) :
    ∃ i j : ℕ,
      i < j ∧
      j ≤ (finRotate_mul_perm_incidence_contour_interval_left_walk
          π ha hc hac_lt.le).length ∧
      (finRotate_mul_perm_incidence_contour_interval_left_walk
          π ha hc hac_lt.le).getVert i =
        (finRotate_mul_perm_incidence_contour_interval_left_walk
          π ha hc hac_lt.le).getVert j := by
  let p :=
    finRotate_mul_perm_incidence_contour_interval_left_walk
      π ha hc hac_lt.le
  have hnotPath : ¬ p.IsPath :=
    leftTight_contour_interval_sameCycle_not_isPath_of_one_lt_sub
      hleft ha hc hac_lt hT hgap
  have hnotInj : ¬ (p.support.get ·).Injective := by
    intro hinj
    exact hnotPath ((SimpleGraph.Walk.isPath_iff_injective_get_support p).mpr hinj)
  rw [Function.Injective] at hnotInj
  push_neg at hnotInj
  rcases hnotInj with ⟨i, j, hij, hne⟩
  have hneVal : i.val ≠ j.val := by
    intro hval
    exact hne (Fin.ext hval)
  have hsame : p.getVert i.val = p.getVert j.val := by
    have hij' : p.support[i.val] = p.support[j.val] := by
      simpa using hij
    have hiEq : p.support[i.val] = p.getVert i.val :=
      SimpleGraph.Walk.support_getElem_eq_getVert p i.2
    have hjEq : p.support[j.val] = p.getVert j.val :=
      SimpleGraph.Walk.support_getElem_eq_getVert p j.2
    simpa [hiEq, hjEq] using hij'
  rcases lt_or_gt_of_ne hneVal with hijlt | hjilt
  · refine ⟨i.val, j.val, hijlt, ?_, hsame⟩
    change j.val ≤ p.length
    have hjLen : j.val < p.length + 1 := by
      simpa [SimpleGraph.Walk.length_support] using j.2
    omega
  · refine ⟨j.val, i.val, hjilt, ?_, hsame.symm⟩
    change i.val ≤ p.length
    have hiLen : i.val < p.length + 1 := by
      simpa [SimpleGraph.Walk.length_support] using i.2
    omega

/-- Parity-classified form of the repeated-contour obstruction.

For a longer same-cycle interval, the repeated incidence-tree vertex can be
translated into either a repeated left `(finRotate * π)` class at two even
contour times, or a repeated right `π` class at two odd contour times. -/
theorem leftTight_contour_interval_sameCycle_exists_repeated_parity_sameCycle_of_one_lt_sub
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hgap : 1 < c - a) :
    (∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
      r < s ∧
      (finRotate (m + 1) * π).SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩) ∨
    (∃ r s : ℕ,
      ∃ hr : r < c - a,
      ∃ hs : s < c - a,
      r < s ∧
      π.SameCycle
        ⟨a + r, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨a + s, by
          have hc' := Finset.mem_range.mp hc
          omega⟩) := by
  rcases
    leftTight_contour_interval_sameCycle_exists_repeated_getVert_of_one_lt_sub
      hleft ha hc hac_lt hT hgap with
    ⟨i, j, hij, hjLen, hEq⟩
  have hjBound : j ≤ 2 * (c - a) := by
    have hlen :=
      finRotate_mul_perm_incidence_contour_interval_left_walk_length
        π ha hc hac_lt.le
    simpa [hlen] using hjLen
  have hiBound : i ≤ 2 * (c - a) := by
    omega
  rcases Nat.even_or_odd i with hiEven | hiOdd
  · rcases Nat.even_or_odd j with hjEven | hjOdd
    · let r : ℕ := i / 2
      let s : ℕ := j / 2
      have hiEq : i = 2 * r := by
        simpa [r] using (Nat.two_mul_div_two_of_even hiEven).symm
      have hjEq : j = 2 * s := by
        simpa [s] using (Nat.two_mul_div_two_of_even hjEven).symm
      have hrs : r < s := by omega
      have hrBound : r ≤ c - a := by omega
      have hsBound : s ≤ c - a := by omega
      left
      refine ⟨r, s, hrBound, hsBound, hrs, ?_⟩
      exact
        finRotate_mul_perm_incidence_contour_interval_left_walk_even_eq_sameCycle
          π ha hc hac_lt.le hrBound hsBound
          (by simpa [hiEq, hjEq] using hEq)
    · let r : ℕ := i / 2
      let s : ℕ := j / 2
      have hiEq : i = 2 * r := by
        simpa [r] using (Nat.two_mul_div_two_of_even hiEven).symm
      have hjEq : j = 2 * s + 1 := by
        simpa [s] using (Nat.two_mul_div_two_add_one_of_odd hjOdd).symm
      have hrBound : r ≤ c - a := by omega
      have hsBound : s < c - a := by omega
      exact False.elim
        (finRotate_mul_perm_incidence_contour_interval_left_walk_even_ne_odd
          π ha hc hac_lt.le hrBound hsBound
          (by simpa [hiEq, hjEq] using hEq))
  · rcases Nat.even_or_odd j with hjEven | hjOdd
    · let r : ℕ := j / 2
      let s : ℕ := i / 2
      have hiEq : i = 2 * s + 1 := by
        simpa [s] using (Nat.two_mul_div_two_add_one_of_odd hiOdd).symm
      have hjEq : j = 2 * r := by
        simpa [r] using (Nat.two_mul_div_two_of_even hjEven).symm
      have hrBound : r ≤ c - a := by omega
      have hsBound : s < c - a := by omega
      exact False.elim
        (finRotate_mul_perm_incidence_contour_interval_left_walk_even_ne_odd
          π ha hc hac_lt.le hrBound hsBound
          (by simpa [hiEq, hjEq] using hEq.symm))
    · let r : ℕ := i / 2
      let s : ℕ := j / 2
      have hiEq : i = 2 * r + 1 := by
        simpa [r] using (Nat.two_mul_div_two_add_one_of_odd hiOdd).symm
      have hjEq : j = 2 * s + 1 := by
        simpa [s] using (Nat.two_mul_div_two_add_one_of_odd hjOdd).symm
      have hrs : r < s := by omega
      have hrBound : r < c - a := by omega
      have hsBound : s < c - a := by omega
      right
      refine ⟨r, s, hrBound, hsBound, hrs, ?_⟩
      exact
        finRotate_mul_perm_incidence_contour_interval_left_walk_odd_eq_sameCycle
          π ha hc hac_lt.le hrBound hsBound
          (by simpa [hiEq, hjEq] using hEq)

/-- The repeated-contour alternative on an interval `[a,c]`: either two even
contour times give a repeated left `(finRotate * π)` class, or two odd contour
times give a repeated right `π` class. -/
def leftTightContourIntervalRepeat
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (_ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c) :
    Prop :=
  (∃ r s : ℕ,
    ∃ hr : r ≤ c - a,
    ∃ hs : s ≤ c - a,
    r < s ∧
    (finRotate (m + 1) * π).SameCycle
      ⟨a + r, by
        have hc' := Finset.mem_range.mp hc
        omega⟩
      ⟨a + s, by
        have hc' := Finset.mem_range.mp hc
        omega⟩) ∨
  (∃ r s : ℕ,
    ∃ hr : r < c - a,
    ∃ hs : s < c - a,
    r < s ∧
    π.SameCycle
      ⟨a + r, by
        have hc' := Finset.mem_range.mp hc
        omega⟩
      ⟨a + s, by
        have hc' := Finset.mem_range.mp hc
        omega⟩)

/-- A full-endpoint repeated contour immediately gives the common-cycle
witness required by the nested return-collision frontier.

This tiny bridge isolates the terminal case of the return-interval analysis:
if the same two endpoints of a nontrivial interval are related both by `π` and
by `(finRotate * π)`, then those endpoints are already the desired nontrivial
common pair. -/
theorem commonCycle_of_interval_endpoint_sameCycle_both
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (hT : π.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hS : (finRotate (m + 1) * π).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z := by
  refine
    ⟨⟨a, Finset.mem_range.mp ha⟩,
      ⟨c, Finset.mem_range.mp hc⟩, ?_, hT, hS⟩
  intro hEq
  have hval : a = c := congrArg Fin.val hEq
  omega

/-- Case split for a repeated contour on a return interval.

The full-endpoint left repeat is discharged immediately by
`commonCycle_of_interval_endpoint_sameCycle_both`; all other alternatives are
the proper/internal branches that still need geometric input in the nested
return-collision proof. -/
theorem leftTightContourIntervalRepeat_common_or_proper_cases
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (hT : π.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hRepeat : leftTightContourIntervalRepeat π ha hc hac) :
    (∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z) ∨
    (∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
        0 < r ∧
        s < c - a ∧
        r < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        0 < s ∧
        s < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        0 < r ∧
        r < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) ∨
    (∃ r s : ℕ,
      ∃ hr : r < c - a,
      ∃ hs : s < c - a,
        r < s ∧
        π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) := by
  rcases hRepeat with hLeft | hRight
  · rcases hLeft with ⟨r, s, hr, hs, hrs, hSame⟩
    by_cases hr0 : r = 0
    · subst r
      by_cases hsend : s = c - a
      · subst s
        have hleft :
            (⟨a + 0, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
              ⟨a, Finset.mem_range.mp ha⟩ := by
          apply Fin.ext
          simp
        have hright :
            (⟨a + (c - a), by
              have hc' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          apply Fin.ext
          exact Nat.add_sub_of_le hac.le
        left
        exact
          commonCycle_of_interval_endpoint_sameCycle_both ha hc hac hT
            (by simpa [hleft, hright] using hSame)
      · have hslt : s < c - a := by omega
        right
        right
        left
        refine ⟨s, hs, by omega, hslt, ?_⟩
        have hleft :
            (⟨a + 0, by
              have hc' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
              ⟨a, Finset.mem_range.mp ha⟩ := by
          apply Fin.ext
          simp
        simpa [hleft] using hSame
    · have hrpos : 0 < r := by omega
      by_cases hsend : s = c - a
      · subst s
        right
        right
        right
        left
        refine ⟨r, hr, hrpos, by omega, ?_⟩
        have hright :
            (⟨a + (c - a), by
              have hc' := Finset.mem_range.mp hc
              omega⟩ : Fin (m + 1)) =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          apply Fin.ext
          exact Nat.add_sub_of_le hac.le
        simpa [hright] using hSame
      · have hslt : s < c - a := by omega
        right
        left
        exact ⟨r, s, hr, hs, hrpos, hslt, hrs, hSame⟩
  · right
    right
    right
    right
    exact hRight

/-- Strict case split for a repeated contour on a return interval.

The raw return-interval split still allows the left repeat to be adjacent to
an endpoint.  Under left-tightness and a genuinely longer return interval, the
start-adjacent repeat is impossible, while the end-adjacent repeat is exactly
the fixed-predecessor branch.  The remaining live cases are therefore the
internal left repeat, the non-adjacent proper endpoint repeats, the fixed
predecessor, or the internal right repeat. -/
theorem leftTightContourIntervalRepeat_common_or_strict_cases
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (hgap : 1 < c - a)
    (hT : π.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hRepeat : leftTightContourIntervalRepeat π ha hc hac) :
    (∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z) ∨
    (∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
        0 < r ∧
        s < c - a ∧
        r < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        1 < s ∧
        s < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        0 < r ∧
        r + 1 < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) ∨
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ ∨
    (∃ r s : ℕ,
      ∃ hr : r < c - a,
      ∃ hs : s < c - a,
        r < s ∧
        π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) := by
  rcases
    leftTightContourIntervalRepeat_common_or_proper_cases
      ha hc hac hT hRepeat with
    hCommon | hRest
  · left
    exact hCommon
  · right
    rcases hRest with hInterior | hRest
    · left
      exact hInterior
    · right
      rcases hRest with hStart | hRest
      · rcases hStart with ⟨s, hs, hspos, hslt, hSame⟩
        by_cases hsone : s = 1
        · subst s
          have hS :
              (finRotate (m + 1) * π).SameCycle
                ⟨a, Finset.mem_range.mp ha⟩
                ⟨a + 1, by
                  have hc' := Finset.mem_range.mp hc
                  omega⟩ := by
            simpa using hSame
          exact False.elim
            ((leftTight_not_start_adjacent_left_repeat_of_sameCycle_one_lt_sub
              hleft ha hc hac hT hgap) hS)
        · left
          exact ⟨s, hs, by omega, hslt, hSame⟩
      · right
        rcases hRest with hEnd | hRight
        · rcases hEnd with ⟨r, hr, hrpos, hrlt, hSame⟩
          by_cases hradj : r + 1 = c - a
          · right
            left
            let x : Fin (m + 1) :=
              ⟨c - 1, by
                have hc' := Finset.mem_range.mp hc
                omega⟩
            have hleft_fin :
                (⟨a + r, by
                  have hc' := Finset.mem_range.mp hc
                  omega⟩ : Fin (m + 1)) = x := by
              apply Fin.ext
              simp [x]
              omega
            have hrot :
                finRotate (m + 1) x =
                  ⟨c, Finset.mem_range.mp hc⟩ := by
              have hxnot : x ≠ Fin.last m := by
                intro hx
                have hxval : c - 1 = m := by
                  simpa [x] using congrArg Fin.val hx
                have hc' := Finset.mem_range.mp hc
                omega
              rw [finRotate_succ_apply]
              apply Fin.ext
              have hx_succ_lt : x.val + 1 < m + 1 := by
                have hc' := Finset.mem_range.mp hc
                simp [x]
                omega
              have hval : (x + 1).val = x.val + 1 := by
                simpa using Fin.val_add_one_of_lt' (i := x) hx_succ_lt
              change (x + 1).val = c
              calc
                (x + 1).val = x.val + 1 := hval
                _ = c := by
                  simp [x]
                  omega
            have hSrot :
                (finRotate (m + 1) * π).SameCycle x
                  (finRotate (m + 1) x) := by
              simpa [x, hleft_fin, hrot] using hSame
            simpa [x] using
              leftTight_fixed_of_sameCycle_self_finRotate hleft x hSrot
          · left
            exact ⟨r, hr, hrpos, by omega, hSame⟩
        · right
          right
          exact hRight

/-- Strict frontier predicate for the return-interval collision leaf. -/
def leftTightStrictReturnIntervalFrontier
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
    (∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z) ∨
    (∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
        0 < r ∧
        s < c - a ∧
        r < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        1 < s ∧
        s < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        0 < r ∧
        r + 1 < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) ∨
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ ∨
    (∃ r s : ℕ,
      ∃ hr : r < c - a,
      ∃ hs : s < c - a,
        r < s ∧
        π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩)

/-- Residual strict return-interval frontier after the already-solved common
cycle branch has been removed. -/
def leftTightStrictReturnIntervalResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
    (∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
        0 < r ∧
        s < c - a ∧
        r < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        1 < s ∧
        s < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        0 < r ∧
        r + 1 < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) ∨
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ ∨
    (∃ r s : ℕ,
      ∃ hr : r < c - a,
      ∃ hs : s < c - a,
        r < s ∧
        π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩)

/-- Residual strict return-interval frontier after applying the checked
descent to the internal right-repeat branch.

The first four alternatives are unchanged from
`leftTightStrictReturnIntervalResidual`.  The last raw internal right-repeat
branch is replaced by the descent alternatives: an adjacent right repeat or a
strictly shorter longer same-`π` interval. -/
def leftTightStrictReturnIntervalDescendedResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (_hac : a < c) : Prop :=
    (∃ r s : ℕ,
      ∃ hr : r ≤ c - a,
      ∃ hs : s ≤ c - a,
        0 < r ∧
        s < c - a ∧
        r < s ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ s : ℕ,
      ∃ hs : s ≤ c - a,
        1 < s ∧
        s < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨a + s, by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ r : ℕ,
      ∃ hr : r ≤ c - a,
        0 < r ∧
        r + 1 < c - a ∧
        (finRotate (m + 1) * π).SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨c, Finset.mem_range.mp hc⟩) ∨
    π ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ =
      ⟨c - 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩ ∨
    (∃ r : ℕ,
      ∃ hr : r + 1 < c - a,
        π.SameCycle
          ⟨a + r, by
            have hc' := Finset.mem_range.mp hc
            omega⟩
          ⟨a + (r + 1), by
            have hc' := Finset.mem_range.mp hc
            omega⟩) ∨
    (∃ a' c' : ℕ,
      ∃ ha' : a' ∈ Finset.range (m + 1),
      ∃ hc' : c' ∈ Finset.range (m + 1),
      ∃ hac' : a' < c',
        1 < c' - a' ∧
        c' - a' < c - a ∧
        π.SameCycle
          ⟨a', Finset.mem_range.mp ha'⟩
          ⟨c', Finset.mem_range.mp hc'⟩)

/-- Primitive part of the descended residual frontier.

This is `leftTightStrictReturnIntervalDescendedResidual` with the recursive
"strictly shorter longer same-`π` interval" alternative removed.  The shorter
alternative is discharged separately by well-founded descent, so the
theorem-facing nested collision input can focus on these five genuinely local
branches. -/
def leftTightStrictReturnIntervalPrimitiveResidual
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
