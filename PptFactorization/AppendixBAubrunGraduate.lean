/-- In the left-tight case, a nontrivial `(finRotate * π)`-cycle link gives a
simple direct path between the two corresponding `π` quotient vertices. -/
theorem leftTight_incidenceGraph_right_walk_of_sameCycle_isPath
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hS : (finRotate (m + 1) * π).SameCycle
