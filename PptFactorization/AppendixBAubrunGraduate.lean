theorem finRotate_mul_perm_incidence_contour_interval_left_walk_even_ne_odd
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1)))
    {a c r s : ℕ} (ha : a ∈ Finset.range (m + 1))
