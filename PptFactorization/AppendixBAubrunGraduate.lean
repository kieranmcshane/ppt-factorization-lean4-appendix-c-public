    {d s : ℝ} {m : ℕ}
    (hd0 : 0 ≤ d) (hsqrt0 : 0 ≤ Real.sqrt s)
    (hsqrtpos : 0 < Real.sqrt s)
    (hd_le_sqrt : d ≤ Real.sqrt s)
    (hcloseAbove :
      Real.sqrt s ≤ d + aubrunProposition71Q 1 (m + 1))
    (hP_le_sqrt : aubrunProposition73P (m + 1) ≤ Real.sqrt s)
    (hCount : ∀ Δ ∈ Finset.range (2 * m + 1),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ) :
    AubrunGraduateRelationCounting (aubrunProposition71Q 1) d s m := by
  have hP0 : 0 ≤ aubrunProposition73P (m + 1) :=
    aubrunProposition73P_nonneg _
  have hρ0 : 0 ≤ aubrunProposition73P (m + 1) / Real.sqrt s :=
    div_nonneg hP0 hsqrtpos.le
  have hρ1 : aubrunProposition73P (m + 1) / Real.sqrt s ≤ 1 := by
    exact (div_le_one hsqrtpos).mpr hP_le_sqrt
  have hP_ρD :
      aubrunProposition73P (m + 1) ≤
        (aubrunProposition73P (m + 1) / Real.sqrt s) * Real.sqrt s := by
    rw [div_mul_cancel₀ _ (ne_of_gt hsqrtpos)]
  exact
    aubrunGraduateRelationCounting_of_prop73TightCountAndCayleyRankBudget_linearRatioRatioPowers_cancelTwo
      (Q := aubrunProposition71Q 1) (d := d) (s := s)
      (D := Real.sqrt s)
      (ρ := aubrunProposition73P (m + 1) / Real.sqrt s) (m := m)
      hd0 hsqrt0 hd_le_sqrt le_rfl hsqrtpos hρ0 hρ1 hP_ρD hCount
      (aubrun_linearRatio_ratioPowers_of_second_sqrt_base_Qone
        (d := d) (s := s) (m := m) hsqrtpos hcloseAbove)

/-- Tight-range count endpoint in the `Q(k)`-close window.

The proof chooses the larger of `d` and `sqrt(s)` as the common base.  If
`sqrt(s)≤d`, it uses `D=d`; if `d≤sqrt(s)`, it uses `D=sqrt(s)`. -/
theorem aubrunGraduateRelationCounting_of_prop73TightCountAndCayleyRankBudget_closeWindow_Qone
    {d s : ℝ} {m : ℕ}
    (hd0 : 0 ≤ d) (hsqrt0 : 0 ≤ Real.sqrt s)
    (hdpos : 0 < d)
    (hclose : |d - Real.sqrt s| ≤ aubrunProposition71Q 1 (m + 1))
    (hP_le_d : aubrunProposition73P (m + 1) ≤ d)
    (hCount : ∀ Δ ∈ Finset.range (2 * m + 1),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ) :
    AubrunGraduateRelationCounting (aubrunProposition71Q 1) d s m := by
  by_cases hsqrt_le_d : Real.sqrt s ≤ d
  · have hcloseBelow :
        d ≤ Real.sqrt s + aubrunProposition71Q 1 (m + 1) := by
      have hclose' := hclose
      rw [abs_sub_le_iff] at hclose'
      linarith
    exact
      aubrunGraduateRelationCounting_of_prop73TightCountAndCayleyRankBudget_firstDimensionBase_Qone
        (d := d) (s := s) (m := m)
        hd0 hsqrt0 hdpos hsqrt_le_d hcloseBelow hP_le_d hCount
  · have hd_le_sqrt : d ≤ Real.sqrt s := le_of_not_ge hsqrt_le_d
    have hsqrtpos : 0 < Real.sqrt s := lt_of_lt_of_le hdpos hd_le_sqrt
    have hcloseAbove :
        Real.sqrt s ≤ d + aubrunProposition71Q 1 (m + 1) := by
      have hclose' := hclose
      rw [abs_sub_le_iff] at hclose'
      linarith
    have hP_le_sqrt :
        aubrunProposition73P (m + 1) ≤ Real.sqrt s :=
      le_trans hP_le_d hd_le_sqrt
    exact
      aubrunGraduateRelationCounting_of_prop73TightCountAndCayleyRankBudget_secondSqrtBase_Qone
        (d := d) (s := s) (m := m)
        hd0 hsqrt0 hsqrtpos hd_le_sqrt hcloseAbove hP_le_sqrt hCount

