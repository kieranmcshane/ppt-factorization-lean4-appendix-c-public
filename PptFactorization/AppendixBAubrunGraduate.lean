/-- Concrete first-ratio supplier with common base `D=d`.

If the second shifted base is still at least `d`, then the first ratio
`(d+Q)/d = 1+Q/d` pays the finite correction with `ρ=P/d`. -/
theorem linearRatio_ratioPowers_of_first_dimension_base
    {m : ℕ} {d t P Q : ℝ}
    (hdpos : 0 < d)
    (hQ0 : 0 ≤ Q)
    (hSecondBase : d ≤ t + Q)
    (hgainRaw : (2 * (m : ℝ)) * P ≤ ((m : ℝ) + 3) * Q) :
    1 + (2 * (m : ℝ)) * (P / d) ≤
      ((d + Q) / d) ^ (m + 3) * ((t + Q) / d) ^ (m + 1) := by
  have hα0 : 0 ≤ Q / d := div_nonneg hQ0 hdpos.le
  have hFirst : 1 + Q / d ≤ (d + Q) / d := by
    have hdne : d ≠ 0 := ne_of_gt hdpos
    have hEq : 1 + Q / d = (d + Q) / d := by
      field_simp [hdne]
    exact le_of_eq hEq
  have hSecond : 1 ≤ (t + Q) / d := by
    have hbase : 1 * d ≤ t + Q := by simpa using hSecondBase
    exact (le_div_iff₀ hdpos).mpr hbase
  have hgain : (2 * (m : ℝ)) * (P / d) ≤ ((m : ℝ) + 3) * (Q / d) := by
    rw [← mul_div_assoc, ← mul_div_assoc]
    exact div_le_div_of_nonneg_right hgainRaw hdpos.le
  exact linearRatio_ratioPowers_of_first_bernoulli_gain
    (m := m) (x := (d + Q) / d) (y := (t + Q) / d)
    (α := Q / d) (ρ := P / d) hα0 hFirst hSecond hgain

/-- Concrete second-ratio supplier with common base `D=t`.

If the first shifted base is still at least `t`, then the second ratio
`(t+Q)/t = 1+Q/t` pays the finite correction with `ρ=P/t`. -/
theorem linearRatio_ratioPowers_of_second_dimension_base
    {m : ℕ} {d t P Q : ℝ}
    (htpos : 0 < t)
    (hQ0 : 0 ≤ Q)
    (hFirstBase : t ≤ d + Q)
    (hgainRaw : (2 * (m : ℝ)) * P ≤ ((m : ℝ) + 1) * Q) :
    1 + (2 * (m : ℝ)) * (P / t) ≤
      ((d + Q) / t) ^ (m + 3) * ((t + Q) / t) ^ (m + 1) := by
  have hβ0 : 0 ≤ Q / t := div_nonneg hQ0 htpos.le
  have hFirst : 1 ≤ (d + Q) / t := by
    have hbase : 1 * t ≤ d + Q := by simpa using hFirstBase
    exact (le_div_iff₀ htpos).mpr hbase
  have hSecond : 1 + Q / t ≤ (t + Q) / t := by
    have htne : t ≠ 0 := ne_of_gt htpos
    have hEq : 1 + Q / t = (t + Q) / t := by
      field_simp [htne]
    exact le_of_eq hEq
  have hgain : (2 * (m : ℝ)) * (P / t) ≤ ((m : ℝ) + 1) * (Q / t) := by
    rw [← mul_div_assoc, ← mul_div_assoc]
    exact div_le_div_of_nonneg_right hgainRaw htpos.le
  exact linearRatio_ratioPowers_of_second_bernoulli_gain
    (m := m) (x := (d + Q) / t) (y := (t + Q) / t)
    (β := Q / t) (ρ := P / t) hβ0 hFirst hSecond hgain

/-- The canonical `Q(k)=kP(k)` has enough first-ratio gain to pay the finite
correction. -/
theorem aubrunProposition73P_firstBernoulli_gainRaw_Qone (m : ℕ) :
    (2 * (m : ℝ)) * aubrunProposition73P (m + 1) ≤
      ((m : ℝ) + 3) * aubrunProposition71Q 1 (m + 1) := by
  have hP0 : 0 ≤ aubrunProposition73P (m + 1) :=
    aubrunProposition73P_nonneg _
  have hmle : (2 * (m : ℝ)) ≤ ((m : ℝ) + 3) * (m + 1 : ℝ) := by
    nlinarith [show (0 : ℝ) ≤ m by exact_mod_cast Nat.zero_le m]
  calc
    (2 * (m : ℝ)) * aubrunProposition73P (m + 1)
        ≤ (((m : ℝ) + 3) * (m + 1 : ℝ)) *
            aubrunProposition73P (m + 1) := by
          exact mul_le_mul_of_nonneg_right hmle hP0
    _ = ((m : ℝ) + 3) * aubrunProposition71Q 1 (m + 1) := by
          simp [aubrunProposition71Q, mul_assoc, mul_left_comm, mul_comm]

/-- The canonical `Q(k)=kP(k)` has enough second-ratio gain to pay the finite
correction. -/
theorem aubrunProposition73P_secondBernoulli_gainRaw_Qone (m : ℕ) :
    (2 * (m : ℝ)) * aubrunProposition73P (m + 1) ≤
      ((m : ℝ) + 1) * aubrunProposition71Q 1 (m + 1) := by
  have hP0 : 0 ≤ aubrunProposition73P (m + 1) :=
    aubrunProposition73P_nonneg _
  have hmle : (2 * (m : ℝ)) ≤ ((m : ℝ) + 1) * (m + 1 : ℝ) := by
    nlinarith [show (0 : ℝ) ≤ m by exact_mod_cast Nat.zero_le m]
  calc
    (2 * (m : ℝ)) * aubrunProposition73P (m + 1)
        ≤ (((m : ℝ) + 1) * (m + 1 : ℝ)) *
            aubrunProposition73P (m + 1) := by
          exact mul_le_mul_of_nonneg_right hmle hP0
    _ = ((m : ℝ) + 1) * aubrunProposition71Q 1 (m + 1) := by
          simp [aubrunProposition71Q, mul_assoc]

/-- Aubrun-specialized close-window scalar supplier using common base `D=d`. -/
theorem aubrun_linearRatio_ratioPowers_of_first_dimension_base_Qone
    {d s : ℝ} {m : ℕ}
    (hdpos : 0 < d)
    (hcloseBelow : d ≤ Real.sqrt s + aubrunProposition71Q 1 (m + 1)) :
    1 + (2 * (m : ℝ)) * (aubrunProposition73P (m + 1) / d) ≤
      ((d + aubrunProposition71Q 1 (m + 1)) / d) ^ (m + 3) *
        ((Real.sqrt s + aubrunProposition71Q 1 (m + 1)) / d) ^ (m + 1) := by
  exact linearRatio_ratioPowers_of_first_dimension_base
    (m := m) (d := d) (t := Real.sqrt s)
    (P := aubrunProposition73P (m + 1))
    (Q := aubrunProposition71Q 1 (m + 1))
    hdpos (aubrunProposition71Q_nonneg (by norm_num) _)
    hcloseBelow (aubrunProposition73P_firstBernoulli_gainRaw_Qone m)

/-- Aubrun-specialized close-window scalar supplier using common base
`D=sqrt(s)`. -/
theorem aubrun_linearRatio_ratioPowers_of_second_sqrt_base_Qone
    {d s : ℝ} {m : ℕ}
    (hsqrtpos : 0 < Real.sqrt s)
    (hcloseAbove : Real.sqrt s ≤ d + aubrunProposition71Q 1 (m + 1)) :
    1 + (2 * (m : ℝ)) * (aubrunProposition73P (m + 1) / Real.sqrt s) ≤
      ((d + aubrunProposition71Q 1 (m + 1)) / Real.sqrt s) ^ (m + 3) *
        ((Real.sqrt s + aubrunProposition71Q 1 (m + 1)) /
