  exact (le_div_iff₀ (pow_pos hDpos _)).mp hNormalized

/-- The normalized product is exactly the product of the two shifted base
ratios. -/
theorem linearRatio_normalizedProduct_eq_ratioPowers
    {m : ℕ} {d t D Q : ℝ} (hD : D ≠ 0) :
    ((d + Q) ^ (m + 3) * (t + Q) ^ (m + 1)) /
        D ^ (2 * (m + 1) + 2) =
      ((d + Q) / D) ^ (m + 3) * ((t + Q) / D) ^ (m + 1) := by
  rw [div_pow, div_pow]
  have hpow : D ^ (2 * (m + 1) + 2) = D ^ (m + 3) * D ^ (m + 1) := by
    rw [← pow_add]
    congr 1
    omega
  rw [hpow]
  field_simp [pow_ne_zero _ hD]

/-- Supplier for the variable-ratio common-base scalar envelope from the
ratio-power scalar target. -/
