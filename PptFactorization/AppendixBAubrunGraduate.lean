    (hWrapAbove :
      ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          ¬ (π.1 x).val < x.val →
          (∃ z : Fin (m + 1),
