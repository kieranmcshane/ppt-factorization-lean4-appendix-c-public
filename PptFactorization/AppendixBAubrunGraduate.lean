/-- The checked `m=3` no-skip datum transported back to the theorem-facing
one-sided geodesic class. -/
theorem WickCycleLeftTightClass_three_no_nonfixed_cyclicPredecessorSkip :
    ¬ ∃ π : WickCycleLeftTightClass 3,
      ∃ x : Fin (3 + 1),
        π.1 x ≠ x ∧ permCyclicPredecessorSkip π.1 x := by
