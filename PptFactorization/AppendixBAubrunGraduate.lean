      _ ≤ (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1) := hEnvelope

/-- The short name for the canonical Lemma 7.5 bridge. -/
theorem aubrunGraduateRelationCounting
