/-- The subinterval-preserving residual frontier implies the older broad
descended residual frontier. -/
theorem leftTightStrictReturnIntervalSubintervalDescendedResidual_to_descended
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (h :
      leftTightStrictReturnIntervalSubintervalDescendedResidual π ha hc hac) :
    leftTightStrictReturnIntervalDescendedResidual π ha hc hac := by
  rcases h with hPrimitive | hShort
  · rcases hPrimitive with hInterior | hRest
    · left
      exact hInterior
    · right
      rcases hRest with hStart | hRest
      · left
        exact hStart
      · right
        rcases hRest with hEnd | hRest
        · left
          exact hEnd
        · right
          rcases hRest with hFixed | hAdj
          · left
            exact hFixed
          · right
            left
            exact hAdj
  · right
    right
    right
    right
    right
    rcases hShort with ⟨r, s, hr, hs, hrs, hgap, hSame⟩
    let a' : ℕ := a + r
    let c' : ℕ := a + s
    have ha' : a' ∈ Finset.range (m + 1) := by
      exact Finset.mem_range.mpr (by
        have hc' := Finset.mem_range.mp hc
        dsimp [a']
        omega)
    have hc' : c' ∈ Finset.range (m + 1) := by
      exact Finset.mem_range.mpr (by
        have hc'' := Finset.mem_range.mp hc
        dsimp [c']
        omega)
    have hac' : a' < c' := by
      dsimp [a', c']
      omega
    have hgap' : 1 < c' - a' := by
      dsimp [a', c']
      omega
    have hshort : c' - a' < c - a := by
      dsimp [a', c']
      omega
    have hSame' :
        π.SameCycle
          ⟨a', Finset.mem_range.mp ha'⟩
          ⟨c', Finset.mem_range.mp hc'⟩ := by
      have hA :
          (⟨a', Finset.mem_range.mp ha'⟩ : Fin (m + 1)) =
            ⟨a + r, by
              have hc'' := Finset.mem_range.mp hc
              omega⟩ := by
        apply Fin.ext
        rfl
      have hC :
          (⟨c', Finset.mem_range.mp hc'⟩ : Fin (m + 1)) =
            ⟨a + s, by
              have hc'' := Finset.mem_range.mp hc
              omega⟩ := by
        apply Fin.ext
        rfl
      simpa [hA, hC] using hSame
    exact ⟨a', c', ha', hc', hac', hgap', hshort, hSame'⟩

/-- The raw residual frontier feeds the subinterval-preserving descended
frontier.

The only real work is the internal right-repeat branch: adjacent repeats are
kept as primitive data, while non-adjacent repeats keep their original
internal offsets instead of being widened to an arbitrary shorter interval. -/
theorem leftTightStrictReturnIntervalResidual_descend_internal_right_subinterval
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (h :
      leftTightStrictReturnIntervalResidual π ha hc hac) :
    leftTightStrictReturnIntervalSubintervalDescendedResidual π ha hc hac := by
  rcases h with hInterior | hRest
  · left
    left
    exact hInterior
  · rcases hRest with hStart | hRest
    · left
      right
      left
      exact hStart
    · rcases hRest with hEnd | hRest
      · left
        right
        right
        left
        exact hEnd
      · rcases hRest with hFixed | hRight
        · left
          right
          right
          right
          left
          exact hFixed
        · rcases hRight with ⟨r, s, hr, hs, hrs, hSame⟩
          by_cases hadj : s = r + 1
          · left
            right
            right
            right
            right
            refine ⟨r, ?_, ?_⟩
            · omega
            · subst s
              simpa [Nat.add_assoc] using hSame
          · right
            exact ⟨r, s, hr, hs, hrs, by omega, hSame⟩

/-- The strict frontier is either the already-solved common-cycle branch or
the residual strict frontier. -/
theorem leftTightStrictReturnIntervalFrontier_common_or_residual
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (h :
      leftTightStrictReturnIntervalFrontier π ha hc hac) :
    (∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.SameCycle y z ∧
          (finRotate (m + 1) * π).SameCycle y z) ∨
    leftTightStrictReturnIntervalResidual π ha hc hac := by
  simpa [leftTightStrictReturnIntervalFrontier,
    leftTightStrictReturnIntervalResidual] using h

/-- Packaged strict frontier supplied by a repeated contour on a return
interval. -/
theorem leftTightContourIntervalRepeat_strict_frontier
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac : a < c)
    (hgap : 1 < c - a)
    (hT : π.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hRepeat : leftTightContourIntervalRepeat π ha hc hac) :
    leftTightStrictReturnIntervalFrontier π ha hc hac := by
  simpa [leftTightStrictReturnIntervalFrontier] using
    leftTightContourIntervalRepeat_common_or_strict_cases
      hleft ha hc hac hgap hT hRepeat

/-- Packaged version of the repeated-contour obstruction for longer
same-cycle intervals. -/
theorem leftTight_contourIntervalRepeat_of_sameCycle_one_lt_sub
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1)
    {a c : ℕ} (ha : a ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1)) (hac_lt : a < c)
    (hT : π.SameCycle ⟨a, Finset.mem_range.mp ha⟩
