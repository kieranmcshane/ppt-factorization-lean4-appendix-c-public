/-- Positive natural dimensions have real cast at least one. -/
theorem one_le_natCast_of_pos {n : ℕ} (h : 0 < (n : ℝ)) :
    1 ≤ (n : ℝ) := by
  have hn : 0 < n := Nat.cast_pos.mp h
  exact Nat.one_le_cast.mpr hn

/-- Positive natural sample dimensions have square root at least one after
real coercion. -/
theorem one_le_sqrt_natCast_of_pos {n : ℕ} (h : 0 < (n : ℝ)) :
    1 ≤ Real.sqrt (n : ℝ) := by
  rw [Real.one_le_sqrt]
  exact one_le_natCast_of_pos h

/-- The explicit Aubrun polynomial really has degree `37`.  This is the
convenient downstream package for theorem interfaces that ask for an explicit
polynomial envelope. -/
theorem aubrunProposition71Q_polynomial_bound {C0 : ℝ} (hC0 : 0 ≤ C0) :
    ∃ C : ℝ, ∃ r : ℕ, 0 ≤ C ∧
      ∀ k : ℕ,
        aubrunProposition71Q C0 k ≤ C * ((k : ℝ) + 1) ^ r := by
  refine ⟨C0 * (2 : ℝ) ^ 36, 37, ?_, ?_⟩
  · positivity
  · intro k
    have hk0 : 0 ≤ (k : ℝ) := by positivity
    have hk1 : (k : ℝ) ≤ (k : ℝ) + 1 := by linarith
    have hpow : (k : ℝ) ^ 37 ≤ ((k : ℝ) + 1) ^ 37 :=
      pow_le_pow_left₀ hk0 hk1 37
    rw [aubrunProposition71Q_eq_monomial]
    exact mul_le_mul_of_nonneg_left hpow (by positivity)

/-- From the graduate-textbook relation count to the sharp surviving-pairing
sum bound, in the concrete square model. -/
theorem aubrunSurvivingPairingSumNorm_concrete_le_of_graduate_relation_counting
    {dNat sNat : ℕ} {Q : ℕ → ℝ} (m : ℕ)
    (hRel :
      AubrunGraduateRelationCounting
        Q (dNat : ℝ) (sNat : ℝ) m) :
    aubrunSurvivingPairingSumNorm
        (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat) m ≤
      (2 / (sNat : ℝ)) ^ (m + 1) *
        (dNat + Q (m + 1)) ^ (m + 3) *
          (Real.sqrt (sNat : ℝ) + Q (m + 1)) ^ (m + 1) := by
  classical
  let R : ℝ :=
    (dNat + Q (m + 1)) ^ (m + 3) *
      (Real.sqrt (sNat : ℝ) + Q (m + 1)) ^ (m + 1)
  have hFiber :=
    aubrunSurvivingPairingSumNorm_le_card_inv_pow_mul_fiber_sum
      (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat) m
  have hPower :=
    fiber_card_sum_le_relation_power_sum
      (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat) m
  have hRelR :
      (∑ π : Equiv.Perm (Fin (m + 1)),
        (dNat : ℝ) ^ wickLeftClassCount π *
          (dNat : ℝ) ^ wickRightClassCount π *
            Real.sqrt (sNat : ℝ) ^
              (2 * wickColumnClassCount π)) ≤
        (2 : ℝ) ^ (m + 1) * R := by
    simpa [AubrunGraduateRelationCounting, R, mul_assoc] using hRel
  have hCombined :
      aubrunSurvivingPairingSumNorm
          (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat) m ≤
        ((sNat : ℝ)⁻¹) ^ (m + 1) *
          ((2 : ℝ) ^ (m + 1) * R) := by
    calc
      aubrunSurvivingPairingSumNorm
          (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat) m
          ≤ ((Fintype.card (Fin sNat) : ℝ)⁻¹) ^ (m + 1) *
              ∑ π : Equiv.Perm (Fin (m + 1)),
                (Fintype.card
                  (WickPermutationFiber (Fin dNat) (Fin dNat) (Fin sNat) π) : ℝ) :=
            hFiber
      _ ≤ ((Fintype.card (Fin sNat) : ℝ)⁻¹) ^ (m + 1) *
            ∑ π : Equiv.Perm (Fin (m + 1)),
              (Fintype.card (Fin dNat) : ℝ) ^ wickLeftClassCount π *
                (Fintype.card (Fin dNat) : ℝ) ^ wickRightClassCount π *
                  Real.sqrt (Fintype.card (Fin sNat) : ℝ) ^
                    (2 * wickColumnClassCount π) := by
            exact mul_le_mul_of_nonneg_left hPower (by positivity)
      _ = ((sNat : ℝ)⁻¹) ^ (m + 1) *
            ∑ π : Equiv.Perm (Fin (m + 1)),
              (dNat : ℝ) ^ wickLeftClassCount π *
                (dNat : ℝ) ^ wickRightClassCount π *
                  Real.sqrt (sNat : ℝ) ^
                    (2 * wickColumnClassCount π) := by
            simp
      _ ≤ ((sNat : ℝ)⁻¹) ^ (m + 1) *
            ((2 : ℝ) ^ (m + 1) * R) := by
            exact mul_le_mul_of_nonneg_left hRelR (by positivity)
  have hpow :
      ((sNat : ℝ)⁻¹) ^ (m + 1) * (2 : ℝ) ^ (m + 1) =
        (2 / (sNat : ℝ)) ^ (m + 1) := by
    rw [div_eq_mul_inv, mul_pow]
    ring
  calc
    aubrunSurvivingPairingSumNorm
        (p := Fin dNat) (q := Fin dNat) (σ := Fin sNat) m
        ≤ ((sNat : ℝ)⁻¹) ^ (m + 1) *
            ((2 : ℝ) ^ (m + 1) * R) :=
          hCombined
    _ = (2 / (sNat : ℝ)) ^ (m + 1) * R := by
          rw [← mul_assoc, hpow]
    _ =
        (2 / (sNat : ℝ)) ^ (m + 1) *
          (dNat + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt (sNat : ℝ) + Q (m + 1)) ^ (m + 1) := by
          simp [R, mul_assoc]

