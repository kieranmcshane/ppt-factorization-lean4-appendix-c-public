/-- The left gap-three/end-adjacent branch `π(a,a+1)` is not a separate
frontier once the branch `S(a+1,b)` is available.

Indeed `π(a,a+1)` and the crossing link `π(a,c)` give `π(a+1,c)`.  The shifted
crossing `(a+1,b,c,d)` has left gap two, so the checked gap-two left theorem
gives `S(a+1,b)`; the exposed `S(a+1,b)` branch then gives the target
`S(a,b)`. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_end_adjacent_of_pi_a_a1
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgap : c - a = 3)
    (hb_eq : b = a + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hT_a_a1 :
      π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩)
    (hS_a1_b :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨b, Finset.mem_range.mp hb⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩ := by
  have ha1 : a + 1 ∈ Finset.range (m + 1) := by
    exact Finset.mem_range.mpr (by
      have hc' := Finset.mem_range.mp hc
      omega)
  have hgap_shift : c - (a + 1) = 2 := by omega
  have hT_a1_c :
      π.1.SameCycle
        ⟨a + 1, Finset.mem_range.mp ha1⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
    have hleft :
        (⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)) =
          ⟨a + 1, Finset.mem_range.mp ha1⟩ := by
      apply Fin.ext
      rfl
    simpa [hleft] using hT_a_a1.symm.trans hac
  have hnot_a1_b :
      ¬ π.1.SameCycle
        ⟨a + 1, Finset.mem_range.mp ha1⟩
        ⟨b, Finset.mem_range.mp hb⟩ := by
    intro hsame
    have hright :
        (⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ : Fin (m + 1)) =
          ⟨a + 1, Finset.mem_range.mp ha1⟩ := by
      apply Fin.ext
      rfl
    exact hnot (by
      simpa [hright] using hT_a_a1.trans hsame)
  have hS_a1_b' :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a + 1, Finset.mem_range.mp ha1⟩
        ⟨b, Finset.mem_range.mp hb⟩ :=
