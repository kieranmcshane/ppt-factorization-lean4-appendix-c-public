    (hcx : c < x.val)
    (hfirst :
      ∀ z : Fin (m + 1),
        π.1.SameCycle z x →
        a < z.val →
        z.val < c →
        False) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.1.SameCycle y z ∧
          (finRotate (m + 1) * π.1).SameCycle y z := by
  exact
    hOffCycleCommon a c ha hc hac hgap hT
