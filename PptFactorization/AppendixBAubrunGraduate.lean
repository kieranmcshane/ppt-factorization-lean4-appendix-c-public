            ∀ hac' : a' < c',
              a < a' →
              c' < c →
              1 < c' - a' →
              π.1.SameCycle
                ⟨a', Finset.mem_range.mp ha'⟩
                ⟨c', Finset.mem_range.mp hc'⟩ →
              leftTightStrictReturnIntervalPrimitiveResidualStartS
                π.1 ha' hc' hac' →
              (∀ z : Fin (m + 1),
                π.1.SameCycle z x →
