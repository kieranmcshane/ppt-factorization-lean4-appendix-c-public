/-- Nonwrapping off-cycle internal residuals may be solved from the smaller
side-aware contour-repeat leaf.

This keeps the actual child contour-repeat packet theorem-facing instead of
immediately splitting it into residual primitive branches.  The retained packet
is the natural data needed by the incidence-tree proof: the child interval is
strictly inside the parent first-return interval, carries a fresh contour
repeat, has no skipped `x`-cycle points inside, and its whole `π`-block remains
inside the parent interval and off the skipped cycle. -/
theorem leftTight_nonwrap_offCycleSubintervalResidual_common_of_smallerContourRepeat
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hπNC : NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    {x : Fin (m + 1)}
    (_hne : π.1 x ≠ x)
    (_hskip : permCyclicPredecessorSkip π.1 x)
    (_hnotDirect :
      ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)))
    (hSmallerContourCommon :
      ∀ a c : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ _ : a < c,
          1 < c - a →
          π.1.SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          a = (π.1 x).val →
          c < x.val →
          (∀ z : Fin (m + 1),
            π.1.SameCycle z x →
            a < z.val →
            z.val < c →
            False) →
          ∀ a' c' : ℕ,
            ∀ ha' : a' ∈ Finset.range (m + 1),
            ∀ hc' : c' ∈ Finset.range (m + 1),
            ∀ hac' : a' < c',
              a < a' →
              c' < c →
              1 < c' - a' →
              π.1.SameCycle
                ⟨a', Finset.mem_range.mp ha'⟩
                ⟨c', Finset.mem_range.mp hc'⟩ →
              leftTightContourIntervalRepeat π.1 ha' hc' hac' →
              (∀ z : Fin (m + 1),
                π.1.SameCycle z x →
                a' < z.val →
                z.val < c' →
                False) →
              (∀ y : Fin (m + 1),
                π.1.SameCycle y
                  ⟨a', Finset.mem_range.mp ha'⟩ →
                (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x) →
              ∃ y z : Fin (m + 1),
                y ≠ z ∧
                  π.1.SameCycle y z ∧
                    (finRotate (m + 1) * π.1).SameCycle y z)
    {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hgap : 1 < c - a)
    (hT : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hOff :
      leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual
        π.1 x ha hc hac)
    (haeq : a = (π.1 x).val)
    (hcx : c < x.val)
    (hfirst :
      ∀ z : Fin (m + 1),
        π.1.SameCycle z x →
        a < z.val →
        z.val < c →
        False) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.1.SameCycle y z ∧
          (finRotate (m + 1) * π.1).SameCycle y z := by
  rcases
    leftTightStrictReturnIntervalOpenInternalOffCycleSubintervalResidual_strictSubinterval_contourRepeat
      π hπNC ha hc hac hT haeq hfirst hOff with
    ⟨a', c', ha', hc', hac', ha_lt, hc_lt, hgap',
      hSame', hRepeat, hBlock⟩
  have hNoX :
      ∀ z : Fin (m + 1),
        π.1.SameCycle z x →
        a' < z.val →
        z.val < c' →
        False := by
    intro z hzx hza' hzc'
    exact hfirst z hzx (lt_trans ha_lt hza') (lt_trans hzc' hc_lt)
  exact
    hSmallerContourCommon a c ha hc hac hgap hT haeq hcx hfirst
      a' c' ha' hc' hac' ha_lt hc_lt hgap' hSame' hRepeat hNoX hBlock

/-- Side-aware smaller contour repeats split into strict branch cases.

This is the branch-level refinement of
