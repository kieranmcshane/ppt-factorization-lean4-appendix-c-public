    mul_le_mul_of_nonneg_right hc_le_pow hDpow0
  have hmul_pow :
      c ^ (m + 1) * D ^ (m + 1) = (c * D) ^ (m + 1) := by
    rw [mul_pow]
  have hBpow :
      (c * D) ^ (m + 1) ≤ B ^ (m + 1) :=
    pow_le_pow_left₀ hcD0 hSecond (m + 1)
  have hcD_to_B :
      c * D ^ (m + 1) ≤ B ^ (m + 1) := by
    exact le_trans hcDpow (by simpa [hmul_pow] using hBpow)
  have hprod :
      D ^ (m + 3) * (c * D ^ (m + 1)) ≤
        A ^ (m + 3) * B ^ (m + 1) := by
    calc
      D ^ (m + 3) * (c * D ^ (m + 1)) ≤
          D ^ (m + 3) * B ^ (m + 1) :=
        mul_le_mul_of_nonneg_left hcD_to_B (pow_nonneg hD0 _)
      _ ≤ A ^ (m + 3) * B ^ (m + 1) :=
