        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hac : a < c,
          1 < c - a →
          π.1.SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          leftTightStrictReturnIntervalPrimitiveResidual π.1 ha hc hac →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z) := by
  intro h
  let π : WickCycleLeftTightClass 2 :=
    ⟨((finRotate 3).symm : Equiv.Perm (Fin 3)), by
      rw [permCycleClassCount_eq_cycleCountFormula,
        permCycleClassCount_eq_cycleCountFormula]
      decide⟩
  have hNC : NCPartition.NonCrossing (leftTightCyclePartitionRange π) := by
    rw [leftTightCyclePartitionRange_nonCrossing_iff_no_crossing_cycles]
    intro a b c d _ha _hb _hc hd _hab _hbc _hcd _ _
    have hd' := Finset.mem_range.mp hd
    omega
  have ha : 0 ∈ Finset.range (2 + 1) := by decide
  have hc : 2 ∈ Finset.range (2 + 1) := by decide
  have hac : 0 < 2 := by omega
  have hgap : 1 < 2 - 0 := by omega
  have hT :
      π.1.SameCycle
        ⟨0, Finset.mem_range.mp ha⟩
        ⟨2, Finset.mem_range.mp hc⟩ := by
    change
      Equiv.Perm.SameCycle
        ((finRotate 3).symm : Equiv.Perm (Fin 3)) (0 : Fin 3) (2 : Fin 3)
    decide
  have hPrimitive :
      leftTightStrictReturnIntervalPrimitiveResidual π.1 ha hc hac := by
    dsimp [π]
    right; right; right; right
    refine ⟨0, ?_, ?_⟩
    · omega
    · convert
        (by decide :
          Equiv.Perm.SameCycle ((finRotate 3).symm : Equiv.Perm (Fin 3))
            (0 : Fin 3) (1 : Fin 3))
  have hNoCommon :
      ¬ (∃ y z : Fin (2 + 1),
