/-- Simultaneous-geodesic permutations inject into the one-sided long-cycle
geodesic class. -/
noncomputable def cyclePairTightClassEmbeddingLeft (m : ℕ) :
    WickCyclePairTightClass m ↪ WickCycleLeftTightClass m where
  toFun := fun π => ⟨π.1, π.2.1⟩
  inj' := by
    intro π τ h
    apply Subtype.ext
    exact congrArg (fun x : WickCycleLeftTightClass m => x.1) h

/-- The simultaneous-geodesic count is bounded by the one-sided long-cycle
geodesic count. -/
theorem card_cyclePairTightClass_le_leftTightClass (m : ℕ) :
    Fintype.card (WickCyclePairTightClass m) ≤
      Fintype.card (WickCycleLeftTightClass m) :=
  Fintype.card_le_of_embedding (cyclePairTightClassEmbeddingLeft m)

/-- The zero-defect fixed-defect count is exactly the simultaneous-geodesic
cycle-pair count. -/
theorem wickPermutationDefectCount_zero_eq_card_cyclePairTightClass
    (m : ℕ) :
    wickPermutationDefectCount m 0 =
      Fintype.card (WickCyclePairTightClass m) := by
  classical
  rw [wickPermutationDefectCount_eq_card_defectClass]
  refine Fintype.card_congr ?_
  exact
  {
    toFun := fun π =>
      ⟨π.1, (wickDefect_eq_zero_iff_cyclePairBounds_tight π.1).mp π.2⟩
    invFun := fun π =>
      ⟨π.1, (wickDefect_eq_zero_iff_cyclePairBounds_tight π.1).mpr π.2⟩
    left_inv := by
      intro π
      rfl
    right_inv := by
      intro π
      rfl
  }

/-- The remaining `m = 3`, zero-defect fixed-defect count closes as soon as
the simultaneous-geodesic class is counted by `16`. -/
theorem wickPermutationDefectCount_three_zero_le_fixedEnvelope_of_cyclePairTightCount
    (hcount : Fintype.card (WickCyclePairTightClass 3) ≤ 16) :
    (wickPermutationDefectCount 3 0 : ℝ) ≤
      aubrunFixedDefectCountEnvelope 3 0 := by
  have hcountNat : wickPermutationDefectCount 3 0 ≤ 16 := by
    rw [wickPermutationDefectCount_zero_eq_card_cyclePairTightClass]
    exact hcount
  have hcountReal : (wickPermutationDefectCount 3 0 : ℝ) ≤ 16 := by
    exact_mod_cast hcountNat
  have henv : (16 : ℝ) = aubrunFixedDefectCountEnvelope 3 0 := by
    unfold aubrunFixedDefectCountEnvelope aubrunProposition73P
    norm_num
  simpa [henv] using hcountReal

/-- The entire `m = 3` tight-range fixed-defect count estimate closes from
the single finite simultaneous-geodesic count. -/
theorem wickPermutationDefectCount_three_tightRange_le_fixedEnvelope_of_cyclePairTightCount
    (hcount : Fintype.card (WickCyclePairTightClass 3) ≤ 16) :
    ∀ Δ ∈ Finset.range (2 * 3 + 1),
      (wickPermutationDefectCount 3 Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope 3 Δ := by
  intro Δ hΔ
  by_cases hzero : Δ = 0
  · subst Δ
    exact wickPermutationDefectCount_three_zero_le_fixedEnvelope_of_cyclePairTightCount
      hcount
  · have hpos : 0 < Δ := by omega
    exact wickPermutationDefectCount_three_posDefect_tightRange_le_fixedEnvelope
      Δ hΔ hpos

/-- The `m = 3` tight-range fixed-defect count estimate closes from the
standard one-sided long-cycle geodesic count. -/
theorem wickPermutationDefectCount_three_tightRange_le_fixedEnvelope_of_leftTightCount
    (hcount : Fintype.card (WickCycleLeftTightClass 3) ≤ 16) :
    ∀ Δ ∈ Finset.range (2 * 3 + 1),
      (wickPermutationDefectCount 3 Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope 3 Δ := by
  exact wickPermutationDefectCount_three_tightRange_le_fixedEnvelope_of_cyclePairTightCount
    ((card_cyclePairTightClass_le_leftTightClass 3).trans hcount)

/-- Permutations with a prescribed cycle-class count. -/
noncomputable def PermCycleCountClass (n c : ℕ) :=
  {π : Equiv.Perm (Fin n) // permCycleClassCount π = c}

noncomputable instance (n c : ℕ) : Fintype (PermCycleCountClass n c) := by
  unfold PermCycleCountClass
  infer_instance

/-- Permutations whose left product with the long cycle has a prescribed
cycle-class count. -/
noncomputable def LeftProductCycleCountClass (n c : ℕ) :=
  {π : Equiv.Perm (Fin n) // permCycleClassCount (finRotate n * π) = c}

noncomputable instance (n c : ℕ) : Fintype (LeftProductCycleCountClass n c) := by
  unfold LeftProductCycleCountClass
  infer_instance

/-- Left multiplication by the long cycle identifies shifted cycle-count
slices with ordinary cycle-count slices. -/
noncomputable def leftProductCycleCountClassEquiv (n c : ℕ) :
    LeftProductCycleCountClass n c ≃ PermCycleCountClass n c where
  toFun := fun π => ⟨finRotate n * π.1, π.2⟩
  invFun := fun π =>
    ⟨(finRotate n).symm * π.1, by
      have hmul : finRotate n * ((finRotate n).symm * π.1) = π.1 := by
        ext x
        simp [Equiv.Perm.mul_apply]
      simpa [hmul] using π.2⟩
  left_inv := by
    intro π
    apply Subtype.ext
    ext x
    simp [Equiv.Perm.mul_apply]
  right_inv := by
    intro π
    apply Subtype.ext
    ext x
    simp [Equiv.Perm.mul_apply]

theorem card_leftProductCycleCountClass_eq (n c : ℕ) :
    Fintype.card (LeftProductCycleCountClass n c) =
      Fintype.card (PermCycleCountClass n c) :=
  Fintype.card_congr (leftProductCycleCountClassEquiv n c)

theorem permCycleClassCount_pos_of_nonempty
    {α : Type*} [Fintype α] [Nonempty α] (π : Equiv.Perm α) :
    0 < permCycleClassCount π := by
  classical
  unfold permCycleClassCount setoidQuotientCard
  exact Fintype.card_pos_iff.mpr
    ⟨Quotient.mk'' (Classical.choice inferInstance)⟩

/-- The left-oriented Cayley defect has the natural support `0 ≤ a ≤ m`.

This is the first support pruning needed by the bidefect count route: both
cycle-count terms in the left Cayley-pair sum are nonempty cycle quotients, so
their sum is at least two. -/
theorem wickPlusDefect_le_self
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) :
    wickPlusDefect π ≤ m := by
  have hπpos : 0 < permCycleClassCount π :=
    permCycleClassCount_pos_of_nonempty π
  have hγπpos :
      0 < permCycleClassCount (finRotate (m + 1) * π) :=
    permCycleClassCount_pos_of_nonempty (finRotate (m + 1) * π)
  unfold wickPlusDefect
  omega

/-- The right-oriented Cayley defect has the natural support `0 ≤ b ≤ m`. -/
theorem wickMinusDefect_le_self
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) :
    wickMinusDefect π ≤ m := by
  have hπpos : 0 < permCycleClassCount π :=
    permCycleClassCount_pos_of_nonempty π
  have hπγpos :
      0 < permCycleClassCount (π * (finRotate (m + 1)).symm) :=
    permCycleClassCount_pos_of_nonempty (π * (finRotate (m + 1)).symm)
  unfold wickMinusDefect
  omega

/-- Plus-defect slices above the natural support are empty. -/
theorem wickPlusDefectCount_eq_zero_of_self_lt
    {m a : ℕ} (ha : m < a) :
    wickPlusDefectCount m a = 0 := by
  classical
  unfold wickPlusDefectCount WickPlusDefectClass
  rw [Fintype.card_subtype]
  apply Finset.card_eq_zero.mpr
  ext π
  simp
  intro hdef
  have hle := wickPlusDefect_le_self (m := m) π
  omega

/-- Bidefect slices with plus-defect above the natural support are empty. -/
theorem wickBiDefectCount_eq_zero_of_plus_self_lt
    {m a b : ℕ} (ha : m < a) :
    wickBiDefectCount m a b = 0 := by
  have hplus := wickPlusDefectCount_eq_zero_of_self_lt (m := m) (a := a) ha
  have hle := wickBiDefectCount_le_wickPlusDefectCount m a b
  exact Nat.eq_zero_of_le_zero (by simpa [hplus] using hle)

/-- Bidefect slices with minus-defect above the natural support are empty. -/
theorem wickBiDefectCount_eq_zero_of_minus_self_lt
    {m a b : ℕ} (hb : m < b) :
    wickBiDefectCount m a b = 0 := by
  classical
  unfold wickBiDefectCount WickBiDefectClass
  rw [Fintype.card_subtype]
  apply Finset.card_eq_zero.mpr
  ext π
  simp
  intro hdef
  have hle := wickMinusDefect_le_self (m := m) π
  omega

/-- Bidefect slices outside the product support `[0,m] × [0,m]` are empty. -/
theorem wickBiDefectCount_eq_zero_of_outOfSelfRange
    {m a b : ℕ} (h : m < a ∨ m < b) :
    wickBiDefectCount m a b = 0 := by
  rcases h with ha | hb
  · exact wickBiDefectCount_eq_zero_of_plus_self_lt (m := m) (a := a) (b := b) ha
  · exact wickBiDefectCount_eq_zero_of_minus_self_lt (m := m) (a := a) (b := b) hb

/-- To prove the ranged bidefect count theorem, it is enough to prove it on
the true support rectangle `a,b ≤ m`.

The public scalar endpoint keeps the slightly larger analytic ranges
`a ≤ m+3` and `b ≤ m+1`; the support lemmas above discharge the extra slices
by showing their counts are zero. -/
theorem AubrunBiDefectCountBound_of_selfRangeBound
    {m : ℕ}
    (hCore :
      ∀ a : ℕ, a ∈ Finset.range (m + 1) →
      ∀ b : ℕ, b ∈ Finset.range (m + 1) →
        (wickBiDefectCount m a b : ℝ) ≤
          aubrunBiDefectCountEnvelope m a b) :
    AubrunBiDefectCountBound m := by
  intro a b _ha _hb
  by_cases haCore : a ∈ Finset.range (m + 1)
  · by_cases hbCore : b ∈ Finset.range (m + 1)
    · exact hCore a haCore b hbCore
    · have hbgt : m < b := by
        have hnot : ¬ b < m + 1 := by
          simpa using hbCore
        omega
      rw [wickBiDefectCount_eq_zero_of_minus_self_lt
        (m := m) (a := a) (b := b) hbgt]
      simpa using aubrunBiDefectCountEnvelope_nonneg m a b
  · have hagt : m < a := by
      have hnot : ¬ a < m + 1 := by
        simpa using haCore
      omega
    rw [wickBiDefectCount_eq_zero_of_plus_self_lt
      (m := m) (a := a) (b := b) hagt]
    simpa using aubrunBiDefectCountEnvelope_nonneg m a b

/-- After the high plus-defect tail is closed, the bidefect count theorem only
needs the small plus-defect range. -/
theorem AubrunBiDefectCountBound_of_smallPlusRangeBound
    {m : ℕ}
    (hSmall :
      ∀ a : ℕ, a ∈ Finset.range (m + 1) → 36 * a < m + 1 →
      ∀ b : ℕ, b ∈ Finset.range (m + 1) →
        (wickBiDefectCount m a b : ℝ) ≤
          aubrunBiDefectCountEnvelope m a b) :
    AubrunBiDefectCountBound m := by
  apply AubrunBiDefectCountBound_of_selfRangeBound
  intro a ha b hb
  by_cases hlarge : m + 1 ≤ 36 * a
  · have haAna : a ∈ Finset.range (m + 3 + 1) := by
      have _ha_lt := Finset.mem_range.mp ha
      exact Finset.mem_range.mpr (by omega)
    have hbAna : b ∈ Finset.range (m + 1 + 1) := by
      have _hb_lt := Finset.mem_range.mp hb
      exact Finset.mem_range.mpr (by omega)
    exact wickBiDefectCount_le_biDefectEnvelope_of_plusDefectCount
      (m := m) (a := a) (b := b) haAna hbAna
      (wickPlusDefectCount_real_le_commonEnvelope_of_large_defect hlarge)
  · have hsmall : 36 * a < m + 1 := by omega
    exact hSmall a ha hsmall b hb

theorem permCycleClassCount_le_card
    {α : Type*} [Fintype α] (π : Equiv.Perm α) :
    permCycleClassCount π ≤ Fintype.card α := by
  classical
  unfold permCycleClassCount setoidQuotientCard
  exact Fintype.card_quotient_le
    (s := Equiv.Perm.SameCycle.setoid π)

/-- Send a cycle class either to its fixed point, if it is a singleton fixed
class, or to the nontrivial cycle factor containing it. -/
noncomputable def cycleClassToFixedOrFactor
    {α : Type*} [Fintype α] [DecidableEq α] (σ : Equiv.Perm α) (x : α) :
    Function.fixedPoints σ ⊕ σ.cycleFactorsFinset := by
  by_cases hx : σ x = x
  · exact Sum.inl ⟨x, hx⟩
  · exact Sum.inr ⟨σ.cycleOf x, by
      rw [Equiv.Perm.cycleOf_mem_cycleFactorsFinset_iff]
      exact Equiv.Perm.mem_support.mpr hx⟩

lemma cycleClassToFixedOrFactor_eq_of_sameCycle
    {α : Type*} [Fintype α] [DecidableEq α] {σ : Equiv.Perm α}
    {x y : α} (hxy : σ.SameCycle x y) :
    cycleClassToFixedOrFactor σ x = cycleClassToFixedOrFactor σ y := by
  unfold cycleClassToFixedOrFactor
  by_cases hx : σ x = x
  · have hxyEq : x = y := hxy.eq_of_left hx
    subst hxyEq
    simp [hx]
  · have hy : σ y ≠ y := by
      intro hy
      exact hx ((hxy.apply_eq_self_iff).mpr hy)
    have hcycle : σ.cycleOf x = σ.cycleOf y := hxy.cycleOf_eq
    simp [hx, hy, hcycle]

/-- Cycle classes are exactly fixed points plus nontrivial cycle factors. -/
noncomputable def cycleClassQuotientEquivFixedPointsSumCycleFactors
    {α : Type*} [Fintype α] [DecidableEq α] (σ : Equiv.Perm α) :
    Quotient (Equiv.Perm.SameCycle.setoid σ) ≃
      Function.fixedPoints σ ⊕ σ.cycleFactorsFinset where
  toFun := Quotient.lift (cycleClassToFixedOrFactor σ)
    (fun _ _ h => cycleClassToFixedOrFactor_eq_of_sameCycle h)
  invFun := fun s =>
    match s with
    | Sum.inl x => Quotient.mk'' x.1
    | Sum.inr c =>
        Quotient.mk'' (Classical.choose
          (Equiv.Perm.IsCycle.nonempty_support
            (Equiv.Perm.mem_cycleFactorsFinset_iff.mp c.2).1))
  left_inv := by
    intro q
    refine Quotient.inductionOn q ?_
    intro x
    by_cases hx : σ x = x
    · simp [cycleClassToFixedOrFactor, hx]
    · simp [cycleClassToFixedOrFactor, hx]
      let c : σ.cycleFactorsFinset :=
        ⟨σ.cycleOf x, by
          rw [Equiv.Perm.cycleOf_mem_cycleFactorsFinset_iff]
          exact Equiv.Perm.mem_support.mpr hx⟩
      let y : α := Classical.choose
        (Equiv.Perm.IsCycle.nonempty_support
          (Equiv.Perm.mem_cycleFactorsFinset_iff.mp c.2).1)
      have hyc : y ∈ (σ.cycleOf x).support := by
        simpa [c, y] using
          (Classical.choose_spec
            (Equiv.Perm.IsCycle.nonempty_support
              (Equiv.Perm.mem_cycleFactorsFinset_iff.mp c.2).1))
      have hsame : σ.SameCycle x y := by
        rw [← Equiv.Perm.mem_support_cycleOf_iff' hx]
        exact hyc
      exact Quotient.sound hsame.symm
  right_inv := by
    intro s
    cases s with
    | inl x =>
        change Quotient.lift (cycleClassToFixedOrFactor σ)
          (fun _ _ h => cycleClassToFixedOrFactor_eq_of_sameCycle h)
          (Quotient.mk (Equiv.Perm.SameCycle.setoid σ) x.1) = Sum.inl x
        rw [Quotient.lift_mk]
        unfold cycleClassToFixedOrFactor
        split_ifs with hx
        · simp
        · exact False.elim (hx x.2)
    | inr c =>
        let y : α := Classical.choose
          (Equiv.Perm.IsCycle.nonempty_support
            (Equiv.Perm.mem_cycleFactorsFinset_iff.mp c.2).1)
        have hyc : y ∈ (c.1).support := by
          simpa [y] using
            (Classical.choose_spec
              (Equiv.Perm.IsCycle.nonempty_support
                (Equiv.Perm.mem_cycleFactorsFinset_iff.mp c.2).1))
        have hnot : σ y ≠ y := by
          have hys : y ∈ σ.support :=
            Equiv.Perm.mem_cycleFactorsFinset_support_le c.2 hyc
          exact Equiv.Perm.mem_support.mp hys
        change Quotient.lift (cycleClassToFixedOrFactor σ)
          (fun _ _ h => cycleClassToFixedOrFactor_eq_of_sameCycle h)
          (Quotient.mk (Equiv.Perm.SameCycle.setoid σ) y) = Sum.inr c
        rw [Quotient.lift_mk]
        unfold cycleClassToFixedOrFactor
        split_ifs with hy
        · exact False.elim (hnot hy)
        · apply congrArg Sum.inr
          apply Subtype.ext
          exact (Equiv.Perm.cycle_is_cycleOf hyc c.2).symm

theorem permCycleClassCount_eq_fixed_add_cycleFactors
    {α : Type*} [Fintype α] [DecidableEq α] (σ : Equiv.Perm α) :
    permCycleClassCount σ =
      Fintype.card (Function.fixedPoints σ) + Fintype.card σ.cycleFactorsFinset := by
  classical
  unfold permCycleClassCount setoidQuotientCard
  rw [Fintype.card_congr (cycleClassQuotientEquivFixedPointsSumCycleFactors σ)]
  rw [Fintype.card_sum]

theorem permCycleClassCount_eq_card_sub_cycleType_sum_add_cycleType_card
    {α : Type*} [Fintype α] [DecidableEq α] (σ : Equiv.Perm α) :
    permCycleClassCount σ =
      Fintype.card α - σ.cycleType.sum + σ.cycleType.card := by
  rw [permCycleClassCount_eq_fixed_add_cycleFactors, Equiv.Perm.card_fixedPoints]
  congr
  rw [Equiv.Perm.cycleType_def]
  simp

private theorem cycleType_card_le_sum {α : Type*} [Fintype α] [DecidableEq α]
    (σ : Equiv.Perm α) :
    σ.cycleType.card ≤ σ.cycleType.sum := by
  have hlist := List.length_le_sum_of_one_le σ.cycleType.toList (by
    intro i hi
    exact le_of_lt
      (Equiv.Perm.one_lt_of_mem_cycleType (σ := σ) (by simpa using hi)))
  simpa using hlist

private theorem permCycleSignExponent_even_iff_card_add_cycleCount_even
    {α : Type*} [Fintype α] [DecidableEq α] (σ : Equiv.Perm α) :
    Even (σ.cycleType.sum + σ.cycleType.card) ↔
      Even (Fintype.card α + permCycleClassCount σ) := by
  let n : ℕ := Fintype.card α
  let s : ℕ := σ.cycleType.sum
  let r : ℕ := σ.cycleType.card
  let c : ℕ := permCycleClassCount σ
  have hc : c = n - s + r := by
    dsimp [c, n, s, r]
    exact permCycleClassCount_eq_card_sub_cycleType_sum_add_cycleType_card σ
  have hs : s ≤ n := by
    dsimp [s, n]
    exact Equiv.Perm.sum_cycleType_le σ
  have hr : r ≤ s := by
    dsimp [r, s]
    exact cycleType_card_le_sum σ
  constructor
  · rintro ⟨t, ht⟩
    refine ⟨n + r - t, ?_⟩
    omega
  · rintro ⟨t, ht⟩
    refine ⟨n + r - t, ?_⟩
    omega

private theorem negOnePow_eq_iff_even {a b : ℕ}
    (h : (-1 : ℤˣ) ^ a = (-1 : ℤˣ) ^ b) :
    Even a ↔ Even b := by
  constructor
  · intro ha
    have hbpow : (-1 : ℤˣ) ^ b = 1 := by
      rw [← h]
      exact ha.neg_one_pow
    exact (neg_one_pow_eq_one_iff_even (R := ℤˣ) (by decide)).mp hbpow
  · intro hb
    have hapow : (-1 : ℤˣ) ^ a = 1 := by
      rw [h]
      exact hb.neg_one_pow
    exact (neg_one_pow_eq_one_iff_even (R := ℤˣ) (by decide)).mp hapow

private theorem even_target_of_parity_links
    {m e f A B target : ℕ}
    (hA : Even e ↔ Even A)
    (hB : Even f ↔ Even B)
    (hf : Even f ↔ Even (m + e))
    (hAB : A + B = target + m) :
    Even target := by
  obtain ⟨ue, he | he⟩ := Nat.even_or_odd' e
  · obtain ⟨um, hm | hm⟩ := Nat.even_or_odd' m
    · have heven : Even e := ⟨ue, by omega⟩
      have hme : Even (m + e) := ⟨um + ue, by omega⟩
      have hAeven : Even A := hA.mp heven
      have hBeven : Even B := hB.mp (hf.mpr hme)
      rcases hAeven with ⟨uA, hAeq⟩
      rcases hBeven with ⟨uB, hBeq⟩
      refine ⟨uA + uB - um, ?_⟩
      omega
    · have heven : Even e := ⟨ue, by omega⟩
      have hmodd : Odd m := ⟨um, hm⟩
      have hmeOdd : Odd (m + e) := by
        rcases hmodd with ⟨u, hu⟩
        refine ⟨u + ue, ?_⟩
        omega
      have hfOdd : Odd f := by
        exact (Nat.not_even_iff_odd).mp (fun hfe =>
          (Nat.not_even_iff_odd).mpr hmeOdd ((hf.mp hfe)))
      have hAeven : Even A := hA.mp heven
      have hBodd : Odd B := by
        exact (Nat.not_even_iff_odd).mp (fun hBe =>
          (Nat.not_even_iff_odd).mpr hfOdd ((hB.mpr hBe)))
      rcases hAeven with ⟨uA, hAeq⟩
      rcases hBodd with ⟨uB, hBeq⟩
      refine ⟨uA + uB - um, ?_⟩
      omega
  · obtain ⟨um, hm | hm⟩ := Nat.even_or_odd' m
    · have hodd : Odd e := ⟨ue, he⟩
      have hmeOdd : Odd (m + e) := by
        refine ⟨um + ue, ?_⟩
        omega
      have hfOdd : Odd f := by
        exact (Nat.not_even_iff_odd).mp (fun hfe =>
          (Nat.not_even_iff_odd).mpr hmeOdd ((hf.mp hfe)))
      have hAodd : Odd A := by
        exact (Nat.not_even_iff_odd).mp (fun hAe =>
          (Nat.not_even_iff_odd).mpr hodd ((hA.mpr hAe)))
      have hBodd : Odd B := by
        exact (Nat.not_even_iff_odd).mp (fun hBe =>
          (Nat.not_even_iff_odd).mpr hfOdd ((hB.mpr hBe)))
      rcases hAodd with ⟨uA, hAeq⟩
      rcases hBodd with ⟨uB, hBeq⟩
      refine ⟨uA + uB + 1 - um, ?_⟩
      omega
    · have hodd : Odd e := ⟨ue, he⟩
      have hmodd : Odd m := ⟨um, hm⟩
      have hmeEven : Even (m + e) := by
        rcases hmodd with ⟨v, hv⟩
        refine ⟨v + ue + 1, ?_⟩
        omega
      have hfeven : Even f := hf.mpr hmeEven
      have hAodd : Odd A := by
        exact (Nat.not_even_iff_odd).mp (fun hAe =>
          (Nat.not_even_iff_odd).mpr hodd ((hA.mpr hAe)))
      have hBeven : Even B := hB.mp hfeven
      rcases hAodd with ⟨uA, hAeq⟩
      rcases hBeven with ⟨uB, hBeq⟩
      refine ⟨uA + uB - um, ?_⟩
      omega

/-- The one-sided Cayley defect is always even.

In permutation language this is the parity half of the unicellular-map Euler
formula: if `γ` is the long cycle, then the sign identity
`sign(γπ)=sign(γ)sign(π)` forces
`(m+2)-(cycles(π)+cycles(γπ))` to be even. -/
theorem wickPlusDefect_even
    (m : ℕ) (π : Equiv.Perm (Fin (m + 1))) :
    Even (wickPlusDefect π) := by
  let γ : Equiv.Perm (Fin (m + 1)) := finRotate (m + 1)
  let cπ : ℕ := permCycleClassCount π
  let cγπ : ℕ := permCycleClassCount (γ * π)
  have hbound : cπ + cγπ ≤ (m + 1) + 1 := by
    dsimp [cπ, cγπ, γ]
    exact cyclePairLeftBound_of_inverseLongCycleInvBound π
      (cyclePair_inverseLongCycleInvBound π)
  let eπ : ℕ := π.cycleType.sum + π.cycleType.card
  let eγπ : ℕ := (γ * π).cycleType.sum + (γ * π).cycleType.card
  have hsignπ : Equiv.Perm.sign π = (-1 : ℤˣ) ^ eπ := by
    dsimp [eπ]
    exact Equiv.Perm.sign_of_cycleType π
  have hsignγπ : Equiv.Perm.sign (γ * π) = (-1 : ℤˣ) ^ eγπ := by
    dsimp [eγπ]
    exact Equiv.Perm.sign_of_cycleType (γ * π)
  have hsignγ : Equiv.Perm.sign γ = (-1 : ℤˣ) ^ m := by
    dsimp [γ]
    exact sign_finRotate m
  have hpow : (-1 : ℤˣ) ^ eγπ = (-1 : ℤˣ) ^ (m + eπ) := by
    calc
      (-1 : ℤˣ) ^ eγπ = Equiv.Perm.sign (γ * π) := hsignγπ.symm
      _ = Equiv.Perm.sign γ * Equiv.Perm.sign π := Equiv.Perm.sign_mul γ π
      _ = (-1 : ℤˣ) ^ m * (-1 : ℤˣ) ^ eπ := by rw [hsignγ, hsignπ]
      _ = (-1 : ℤˣ) ^ (m + eπ) := (pow_add (-1 : ℤˣ) m eπ).symm
  have hparPow : Even eγπ ↔ Even (m + eπ) := negOnePow_eq_iff_even hpow
  have hπpar : Even eπ ↔ Even ((m + 1) + cπ) := by
    dsimp [eπ, cπ]
    simpa [Fintype.card_fin] using
      (permCycleSignExponent_even_iff_card_add_cycleCount_even π)
  have hγπpar : Even eγπ ↔ Even ((m + 1) + cγπ) := by
    dsimp [eγπ, cγπ, γ]
    simpa [Fintype.card_fin] using
      (permCycleSignExponent_even_iff_card_add_cycleCount_even (γ * π))
  have hEvenSum : Even (((m + 1) + 1) + (cπ + cγπ)) := by
    refine even_target_of_parity_links
      (m := m) (e := eπ) (f := eγπ)
      (A := (m + 1) + cπ) (B := (m + 1) + cγπ)
      (target := ((m + 1) + 1) + (cπ + cγπ)) hπpar hγπpar hparPow ?_
    omega
  have hEvenDef : Even (((m + 1) + 1) - (cπ + cγπ)) := by
    rcases hEvenSum with ⟨t, ht⟩
    refine ⟨t - (cπ + cγπ), ?_⟩
    omega
  simpa [wickPlusDefect, cπ, cγπ, γ, add_assoc] using hEvenDef

/-- Equivalently, every one-sided plus defect is twice a genus. -/
theorem wickPlusDefect_eq_two_mul_genus
    (m : ℕ) (π : Equiv.Perm (Fin (m + 1))) :
    ∃ g : ℕ, wickPlusDefect π = 2 * g := by
  rcases wickPlusDefect_even m π with ⟨g, hg⟩
  exact ⟨g, by omega⟩

/-- Odd one-sided plus-defect slices are empty. -/
theorem wickPlusDefectCount_odd_eq_zero
    (m a : ℕ) (hodd : a % 2 = 1) :
    wickPlusDefectCount m a = 0 := by
  have haOdd : Odd a := Nat.odd_iff.mpr hodd
  unfold wickPlusDefectCount WickPlusDefectClass
  haveI :
      IsEmpty {π : Equiv.Perm (Fin (m + 1)) // wickPlusDefect π = a} :=
    ⟨fun π =>
      (Nat.not_even_iff_odd).mpr haOdd (by
        rw [← π.2]
        exact wickPlusDefect_even m π.1)⟩
  exact Fintype.card_eq_zero

/-- The Chapuy recurrence plus the genus-zero Catalan bound imply the
polynomial genus-count envelope.

This is the checked induction step in the unicellular route.  The two explicit
inputs are exactly the remaining theorem-strength counting leaves: genus zero
and the genus-decreasing slicing recurrence. -/
theorem wickPlusGenusCount_le_four_pow_mul_poly_of_zero_and_step
    (m g : ℕ)
    (hzero : (wickPlusGenusCount m 0 : ℝ) ≤ (4 : ℝ) ^ (m + 1))
    (hstep : ∀ g : ℕ,
      wickPlusGenusCount m (g + 1) ≤
        (2 * (m + 1)) ^ 3 * wickPlusGenusCount m g) :
    (wickPlusGenusCount m g : ℝ) ≤
      (4 : ℝ) ^ (m + 1) * (2 * (m + 1) : ℝ) ^ (3 * g) := by
  induction g with
  | zero =>
      simpa using hzero
  | succ g ih =>
      have hstepReal :
          (wickPlusGenusCount m (g + 1) : ℝ) ≤
            (2 * (m + 1) : ℝ) ^ 3 * (wickPlusGenusCount m g : ℝ) := by
        have hnat := hstep g
        calc
          (wickPlusGenusCount m (g + 1) : ℝ) ≤
              (((2 * (m + 1)) ^ 3 * wickPlusGenusCount m g : ℕ) : ℝ) := by
            exact_mod_cast hnat
          _ = (2 * (m + 1) : ℝ) ^ 3 * (wickPlusGenusCount m g : ℝ) := by
            norm_num
      have hmul :=
        mul_le_mul_of_nonneg_left ih
          (by positivity : 0 ≤ (2 * (m + 1) : ℝ) ^ 3)
      have hpow :
          (2 * (m + 1) : ℝ) ^ 3 *
              ((4 : ℝ) ^ (m + 1) * (2 * (m + 1) : ℝ) ^ (3 * g)) =
            (4 : ℝ) ^ (m + 1) *
              (2 * (m + 1) : ℝ) ^ (3 * (g + 1)) := by
        have hexp : 3 * (g + 1) = 3 + 3 * g := by omega
        rw [hexp, pow_add]
        ring
      calc
        (wickPlusGenusCount m (g + 1) : ℝ) ≤
            (2 * (m + 1) : ℝ) ^ 3 * (wickPlusGenusCount m g : ℝ) := hstepReal
        _ ≤ (2 * (m + 1) : ℝ) ^ 3 *
            ((4 : ℝ) ^ (m + 1) * (2 * (m + 1) : ℝ) ^ (3 * g)) := hmul
        _ = (4 : ℝ) ^ (m + 1) *
            (2 * (m + 1) : ℝ) ^ (3 * (g + 1)) := hpow

/-- Conditional conversion from the unicellular genus bounds to the one-sided
plus-defect envelope.

Odd plus-defect slices vanish, even slices are genus slices, and
`P(2(m+1)) = (2*(2(m+1)))^36` is large enough to absorb the Chapuy
`(2(m+1))^(3g)` cost. -/
theorem wickPlusDefectCount_real_le_commonEnvelope_of_genus_bounds
    (hzero : ∀ m : ℕ,
      (wickPlusGenusCount m 0 : ℝ) ≤ (4 : ℝ) ^ (m + 1))
    (hstep : ∀ m g : ℕ,
      wickPlusGenusCount m (g + 1) ≤
        (2 * (m + 1)) ^ 3 * wickPlusGenusCount m g)
    (m a : ℕ) :
    (wickPlusDefectCount m a : ℝ) ≤
      (4 : ℝ) ^ (m + 1) * aubrunProposition73P (2 * (m + 1)) ^ a := by
  obtain ⟨g, ha | ha⟩ := Nat.even_or_odd' a
  · have hgen :=
      wickPlusGenusCount_le_four_pow_mul_poly_of_zero_and_step
        m g (hzero m) (hstep m)
    have hbase_le :
        (2 * (m + 1) : ℝ) ≤ (2 * (2 * (m + 1)) : ℕ) := by
      exact_mod_cast (by omega : 2 * (m + 1) ≤ 2 * (2 * (m + 1)))
    have hbase_one : (1 : ℝ) ≤ (2 * (2 * (m + 1)) : ℕ) := by
      exact_mod_cast (by omega : 1 ≤ 2 * (2 * (m + 1)))
    have hpow_le :
        (2 * (m + 1) : ℝ) ^ (3 * g) ≤
          aubrunProposition73P (2 * (m + 1)) ^ (2 * g) := by
      calc
        (2 * (m + 1) : ℝ) ^ (3 * g) ≤
            (2 * (2 * (m + 1)) : ℕ) ^ (3 * g) := by
          exact pow_le_pow_left₀ (by positivity) hbase_le _
        _ ≤ (2 * (2 * (m + 1)) : ℕ) ^ (36 * (2 * g)) := by
          exact pow_le_pow_right₀ hbase_one (by omega)
        _ = aubrunProposition73P (2 * (m + 1)) ^ (2 * g) := by
          unfold aubrunProposition73P
          norm_num [Nat.cast_mul]
          rw [pow_mul]
    have hscale_nonneg : 0 ≤ (4 : ℝ) ^ (m + 1) := by positivity
    rw [ha, wickPlusDefectCount_even_eq_genusCount]
    exact le_trans hgen (mul_le_mul_of_nonneg_left hpow_le hscale_nonneg)
  · have hodd : a % 2 = 1 := by omega
    rw [wickPlusDefectCount_odd_eq_zero m a hodd]
    have h4 : 0 ≤ (4 : ℝ) ^ (m + 1) := by positivity
    have hPpow : 0 ≤ aubrunProposition73P (2 * (m + 1)) ^ a :=
      pow_nonneg (aubrunProposition73P_nonneg (2 * (m + 1))) _
    simpa using mul_nonneg h4 hPpow

/-- Base-two form of the genus-count route, matching the bidefect count
adapter's common envelope. -/
theorem wickPlusDefectCount_real_le_baseTwoCommonEnvelope_of_genus_bounds
    (hzero : ∀ m : ℕ,
      (wickPlusGenusCount m 0 : ℝ) ≤ (4 : ℝ) ^ (m + 1))
    (hstep : ∀ m g : ℕ,
      wickPlusGenusCount m (g + 1) ≤
        (2 * (m + 1)) ^ 3 * wickPlusGenusCount m g)
    (m a : ℕ) :
    (wickPlusDefectCount m a : ℝ) ≤
      (2 : ℝ) ^ (2 * (m + 1)) *
        aubrunProposition73P (2 * (m + 1)) ^ a := by
  have h :=
    wickPlusDefectCount_real_le_commonEnvelope_of_genus_bounds
      hzero hstep m a
  calc
    (wickPlusDefectCount m a : ℝ) ≤
        (4 : ℝ) ^ (m + 1) *
          aubrunProposition73P (2 * (m + 1)) ^ a := h
    _ = (2 : ℝ) ^ (2 * (m + 1)) *
          aubrunProposition73P (2 * (m + 1)) ^ a := by
          norm_num [pow_mul]

/-- The genus route supplies the bidefect count theorem once the genus-zero
base and Chapuy slicing recurrence are proved. -/
theorem AubrunBiDefectCountBound_of_genus_bounds
    {m : ℕ}
    (hzero : ∀ m : ℕ,
      (wickPlusGenusCount m 0 : ℝ) ≤ (4 : ℝ) ^ (m + 1))
    (hstep : ∀ m g : ℕ,
      wickPlusGenusCount m (g + 1) ≤
        (2 * (m + 1)) ^ 3 * wickPlusGenusCount m g) :
    AubrunBiDefectCountBound m := by
  exact
    AubrunBiDefectCountBound_of_plusDefectCountBound
      (m := m)
      (fun a =>
        wickPlusDefectCount_real_le_baseTwoCommonEnvelope_of_genus_bounds
          hzero hstep m a)

/-- Endpoint-facing form of the sharpened genus-zero route: the bidefect count
bound follows from noncrossing of the left-tight cycle partitions, absence of
non-fixed predecessor skips, and Chapuy slicing. -/
theorem AubrunBiDefectCountBound_of_noncrossing_noSkip_and_chapuy
    {m : ℕ}
    (hNC : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    (hNoSkip : ∀ m : ℕ,
      ¬ ∃ π : WickCycleLeftTightClass m,
        ∃ x : Fin (m + 1),
          π.1 x ≠ x ∧ permCyclicPredecessorSkip π.1 x)
    (hstep : ∀ m g : ℕ,
      wickPlusGenusCount m (g + 1) ≤
        (2 * (m + 1)) ^ 3 * wickPlusGenusCount m g) :
    AubrunBiDefectCountBound m := by
  apply AubrunBiDefectCountBound_of_genus_bounds
  · intro r
    exact
      wickPlusGenusCount_zero_le_four_pow_of_no_nonfixed_cyclicPredecessorSkip
        (hNC r) (hNoSkip r)
  · exact hstep

/-- Endpoint-facing form after replacing the no-skip leaf by the pure
noncrossing skip-collision statement.

The new theorem-strength input says that every non-fixed predecessor skip in a
noncrossing left-tight cycle partition forces a nontrivial common pair of a
`π`-cycle and a `(finRotate*π)`-cycle.  Left-tight transversality then removes
the old no-skip hypothesis. -/
theorem AubrunBiDefectCountBound_of_noncrossing_commonCycle_and_chapuy
    {m : ℕ}
    (hNC : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    (hCollision :
      ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          permCyclicPredecessorSkip π.1 x →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hstep : ∀ m g : ℕ,
      wickPlusGenusCount m (g + 1) ≤
        (2 * (m + 1)) ^ 3 * wickPlusGenusCount m g) :
    AubrunBiDefectCountBound m := by
  apply AubrunBiDefectCountBound_of_genus_bounds
  · intro r
    exact
      wickPlusGenusCount_zero_le_four_pow_of_nonCrossing_commonCycle
        (hCollision r) (hNC r)
  · exact hstep

/-- Endpoint-facing form after the direct skip branch has been discharged.

The remaining skip-collision input is only the nested non-direct case
`¬ π.SameCycle x (finRotate (π x))`; direct hits are consumed internally by
`permCyclicPredecessorSkip_direct_commonCycle`. -/
theorem AubrunBiDefectCountBound_of_noncrossing_nestedCommonCycle_and_chapuy
    {m : ℕ}
    (hNC : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    (hNested :
      ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          permCyclicPredecessorSkip π.1 x →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hstep : ∀ m g : ℕ,
      wickPlusGenusCount m (g + 1) ≤
        (2 * (m + 1)) ^ 3 * wickPlusGenusCount m g) :
    AubrunBiDefectCountBound m := by
  apply AubrunBiDefectCountBound_of_genus_bounds
  · intro r
    exact
      wickPlusGenusCount_zero_le_four_pow_of_nonCrossing_nestedCommonCycle
        (hNested r) (hNC r)
  · exact hstep

/-- Endpoint-facing form with the nested skip-collision input split by
nonwrapping and wrapping predecessor-skip geometry. -/
theorem AubrunBiDefectCountBound_of_noncrossing_branchNestedCommonCycle_and_chapuy
    {m : ℕ}
    (hNC : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    (hNonwrap :
      ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          (π.1 x).val < x.val →
          (∃ z : Fin (m + 1),
            π.1.SameCycle z x ∧ (π.1 x).val < z.val ∧ z.val < x.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hWrap :
      ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          ¬ (π.1 x).val < x.val →
          ((∃ z : Fin (m + 1), π.1.SameCycle z x ∧ z.val < x.val) ∨
            ∃ z : Fin (m + 1),
              π.1.SameCycle z x ∧ (π.1 x).val < z.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hstep : ∀ m g : ℕ,
      wickPlusGenusCount m (g + 1) ≤
        (2 * (m + 1)) ^ 3 * wickPlusGenusCount m g) :
    AubrunBiDefectCountBound m := by
  apply AubrunBiDefectCountBound_of_genus_bounds
  · intro r
    exact
      wickPlusGenusCount_zero_le_four_pow_of_nonCrossing_branchNestedCommonCycle
        (hNonwrap r) (hWrap r) (hNC r)
  · exact hstep

/-- Endpoint-facing form with all nested skip-collision branches exposed:
nonwrapping, wrap-below, and wrap-above. -/
theorem AubrunBiDefectCountBound_of_noncrossing_threeBranchNestedCommonCycle_and_chapuy
    {m : ℕ}
    (hNC : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    (hNonwrap :
      ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
