/-- In Wick length `m = 4`, every positive-defect tight slice is already
dominated by Aubrun's fixed-defect envelope. -/
theorem wickPermutationDefectCount_four_posDefect_tightRange_le_fixedEnvelope :
    ∀ Δ ∈ Finset.range (2 * 4 + 1), 0 < Δ →
      (wickPermutationDefectCount 4 Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope 4 Δ := by
  intro Δ _hΔ hΔpos
  have hcountNat : wickPermutationDefectCount 4 Δ ≤ 120 := by
    simpa using wickPermutationDefectCount_le_factorial 4 Δ
  have hcountReal : (wickPermutationDefectCount 4 Δ : ℝ) ≤ 120 := by
    exact_mod_cast hcountNat
  have henv : (120 : ℝ) ≤ aubrunFixedDefectCountEnvelope 4 Δ := by
    unfold aubrunFixedDefectCountEnvelope aubrunProposition73P
    let base : ℝ := (2 * ((4 + 1 : ℕ) : ℝ)) ^ 36
    have hbase120 : (120 : ℝ) ≤ 2 ^ (4 + 1) * base := by
      dsimp [base]
      norm_num
    have hbase1 : (1 : ℝ) ≤ base := by
      dsimp [base]
      norm_num
    have hpow : base ≤ base ^ Δ := by
      cases Δ with
      | zero => omega
      | succ n =>
          rw [pow_succ]
          have htail : (1 : ℝ) ≤ base ^ n := one_le_pow₀ hbase1
          nlinarith
    calc
      (120 : ℝ) ≤ 2 ^ (4 + 1) * base := hbase120
      _ ≤ 2 ^ (4 + 1) * base ^ Δ := by
        exact mul_le_mul_of_nonneg_left hpow (by norm_num)
  exact hcountReal.trans henv

