/-- Endpoint-facing form with the broad noncrossing input replaced by Biane's
adjacent-link statement.

The noncrossing hypothesis consumed by the three nested skip-collision
branches is now supplied internally from the pointwise adjacent-link theorem.
Thus the public geometric frontier is the real Biane link extraction, not an
opaque noncrossing assumption. -/
theorem AubrunBiDefectCountBound_of_bianeAdjacentLinks_threeBranchNestedCommonCycle_and_chapuy
    {m : ℕ}
    (hLinks : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          (finRotate (m + 1) * π.1).SameCycle
              ⟨a, Finset.mem_range.mp ha⟩
              ⟨b, Finset.mem_range.mp hb⟩ ∧
            (finRotate (m + 1) * π.1).SameCycle
              ⟨c, Finset.mem_range.mp hc⟩
              ⟨d, Finset.mem_range.mp hd⟩)
    (hNonwrap :
      ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          (π.1 x).val < x.val →
          (∃ z : Fin (m + 1),
            π.1.SameCycle z x ∧ (π.1 x).val < z.val ∧ z.val < x.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hWrapBelow :
      ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          ¬ (π.1 x).val < x.val →
          (∃ z : Fin (m + 1), π.1.SameCycle z x ∧ z.val < x.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hWrapAbove :
      ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
        NCPartition.NonCrossing (leftTightCyclePartitionRange π) →
        ∀ x : Fin (m + 1),
          π.1 x ≠ x →
          ¬ (π.1 x).val < x.val →
          (∃ z : Fin (m + 1),
            π.1.SameCycle z x ∧ (π.1 x).val < z.val) →
          ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    (hstep : ∀ m g : ℕ,
      wickPlusGenusCount m (g + 1) ≤
        (2 * (m + 1)) ^ 3 * wickPlusGenusCount m g) :
    AubrunBiDefectCountBound m := by
  have hNC : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π) := by
    intro r π
    exact
      leftTightCyclePartitionRange_nonCrossing_of_bianeAdjacentLinks
        π (hLinks r π)
  exact
    AubrunBiDefectCountBound_of_noncrossing_threeBranchNestedCommonCycle_and_chapuy
      (m := m) hNC hNonwrap hWrapBelow hWrapAbove hstep

/-- Endpoint-facing form with the genus-zero leaf stated directly as the
ordered-predecessor/no-skip theorem.

The previous frontier routed the Catalan/Biane base through a common-cycle
contradiction.  This statement exposes the cleaner mathematical leaf:
noncrossing of the left-tight cycle partition should rule out non-fixed cyclic
predecessor skips, equivalently it should make the cycle partition determine
`π` by the ordered predecessor rule. -/
theorem AubrunBiDefectCountBound_of_bianeAdjacentLinks_noNonfixedCyclicPredecessorSkip_and_chapuy
    {m : ℕ}
    (hLinks : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          (finRotate (m + 1) * π.1).SameCycle
              ⟨a, Finset.mem_range.mp ha⟩
              ⟨b, Finset.mem_range.mp hb⟩ ∧
            (finRotate (m + 1) * π.1).SameCycle
              ⟨c, Finset.mem_range.mp hc⟩
              ⟨d, Finset.mem_range.mp hd⟩)
    (hNoSkip : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
