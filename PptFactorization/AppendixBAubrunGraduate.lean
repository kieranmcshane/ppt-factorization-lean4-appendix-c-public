        ⟨b, Finset.mem_range.mp hb⟩)
    (hFixed_a1 :
      π.1
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ =
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_a1_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hT_a1_b_to_S_a_a1 :
      π.1.SameCycle
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨b, Finset.mem_range.mp hb⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩ :=
  leftTight_bianeAdjacentLink_left_of_gap_three_end_adjacent_reduced_no_pi_branches
    π ha hb hc hd hab hbc hcd hgap hb_eq hac hbd hnot
    (fun hS_a1_b =>
      let x : Fin (m + 1) :=
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
      have hrot :
          finRotate (m + 1) x =
            ⟨b, Finset.mem_range.mp hb⟩ := by
        rw [finRotate_succ_apply]
        apply Fin.ext
        have hx_succ_lt : x.val + 1 < m + 1 := by
          have hc' := Finset.mem_range.mp hc
          simp [x]
          omega
        have hval : (x + 1).val = x.val + 1 := by
          simpa using Fin.val_add_one_of_lt' (i := x) hx_succ_lt
        change (x + 1).val = b
        calc
          (x + 1).val = x.val + 1 := hval
          _ = a + 2 := by
            simp [x]
          _ = b := by omega
      have hSrot :
          (finRotate (m + 1) * π.1).SameCycle
            x (finRotate (m + 1) x) := by
        simpa [x, hrot] using hS_a1_b
      have hfix :
          π.1 x = x :=
        leftTight_fixed_of_sameCycle_self_finRotate π.2 x hSrot
      hFixed_a1 (by simpa [x] using hfix))
    hS_a1_c hT_a1_b_to_S_a_a1

/-- The left gap-three/end-adjacent fixed `a+1` branch is closed directly.

In the slice `c-a=3`, `b=a+2`, fixedness of `a+1` gives the adjacent repeat
`S(a+1,b)`.  If the target `S(a,b)` failed, the contour step `a -> a+1`,
followed by this repeat and the contour step `b -> c`, would give a simple
length-four path from `S(a)` to `S(c)`.  Tree uniqueness compares it with the
direct length-two path from `π(a,c)`, contradiction. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_end_adjacent_fixed_a1
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (_hbc : b < c) (hcd : c < d)
    (hgap : c - a = 3)
    (hb_eq : b = a + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hfix :
      π.1
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩ =
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b, Finset.mem_range.mp hb⟩ := by
  by_contra hnotS_a_b
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π.1
  let xa : Fin (m + 1) := ⟨a, Finset.mem_range.mp ha⟩
  let xu : Fin (m + 1) :=
    ⟨a + 1, by
      have hc' := Finset.mem_range.mp hc
      omega⟩
  let xb : Fin (m + 1) := ⟨b, Finset.mem_range.mp hb⟩
  let xc : Fin (m + 1) := ⟨c, Finset.mem_range.mp hc⟩
  have hxa_add_one : xa + 1 = xu := by
    apply Fin.ext
    have hxa_succ_lt : xa.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xa]
      omega
    have hval : (xa + 1).val = xa.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xa) hxa_succ_lt
    change (xa + 1).val = xu.val
    simp [xa, xu] at hval ⊢
    omega
  have hxu_add_one : xu + 1 = xb := by
    apply Fin.ext
    have hxu_succ_lt : xu.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xu]
      omega
    have hval : (xu + 1).val = xu.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xu) hxu_succ_lt
    change (xu + 1).val = xb.val
    simp [xu, xb] at hval ⊢
    omega
  have hxb_add_one : xb + 1 = xc := by
    apply Fin.ext
    have hxb_succ_lt : xb.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xb]
      omega
    have hval : (xb + 1).val = xb.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xb) hxb_succ_lt
    change (xb + 1).val = xc.val
    simp [xb, xc] at hval ⊢
    omega
  have hrot_a : finRotate (m + 1) xa = xu := by
    rw [finRotate_succ_apply]
    simp [hxa_add_one]
  have hrot_u : finRotate (m + 1) xu = xb := by
    rw [finRotate_succ_apply]
    simp [hxu_add_one]
  have hrot_b : finRotate (m + 1) xb = xc := by
    rw [finRotate_succ_apply]
    simp [hxb_add_one]
  have hstep_a : S (π.1.symm xa) xu := by
    have h := (finRotate_mul_perm_contour_step_sameCycle π.1 xa).2
    simpa [S, hrot_a] using h
  have hstep_b : S (π.1.symm xb) xc := by
    have h := (finRotate_mul_perm_contour_step_sameCycle π.1 xb).2
    simpa [S, hrot_b] using h
  have hS_u_b : S xu xb := by
    have hSrot :
        (finRotate (m + 1) * π.1).SameCycle
          xu (finRotate (m + 1) xu) :=
      finRotate_mul_perm_sameCycle_self_finRotate_of_fixed
        (m := m) (π := π.1) (x := xu) (by simpa [xu] using hfix)
    simpa [S, hrot_u] using hSrot
  have hnotS_a_c : ¬ S xa xc := by
    intro hS_a_c
    exact
      (leftTight_not_sameCycle_both_of_lt
        (m := m) (π := π.1) π.2 ha hc (by omega) hac)
        (by simpa [S, xa, xc] using hS_a_c)
  have hnotS_b_c : ¬ S xb xc := by
    intro hS_b_c
    have hc_eq : c = b + 1 := by omega
    have hC :
        (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) =
          ⟨b + 1, by
            have hc' := Finset.mem_range.mp hc
            omega⟩ := by
      apply Fin.ext
      exact hc_eq
    exact
      leftTight_nat_adjacent_left_repeat_impossible_of_sameCycle_to_right
        π hb hd (by omega)
        (by simpa [S, xb, xc, hC] using hS_b_c)
        (by simpa [xb] using hbd)
  have hnotT_a_b : ¬ T xa xb := by
    intro hT_a_b
    exact hnot (by simpa [T, xa, xb] using hT_a_b)
  have hqne_S_a_preva :
      ¬ (Quotient.mk'' xa : Quotient S) =
        Quotient.mk'' (π.1.symm xa) := by
    intro hq
    have hS : S xa (π.1.symm xa) := Quotient.exact hq
    exact hnotS_a_b (by simpa [S, xa, xb] using hS.trans (hstep_a.trans hS_u_b))
  have hqne_S_a_prevb :
      ¬ (Quotient.mk'' xa : Quotient S) =
        Quotient.mk'' (π.1.symm xb) := by
    intro hq
    have hS : S xa (π.1.symm xb) := Quotient.exact hq
    exact hnotS_a_c (hS.trans hstep_b)
  have hqne_S_preva_prevb :
      ¬ (Quotient.mk'' (π.1.symm xa) : Quotient S) =
        Quotient.mk'' (π.1.symm xb) := by
    intro hq
    have hS : S (π.1.symm xa) (π.1.symm xb) := Quotient.exact hq
    have hS_u_c : S xu xc := hstep_a.symm.trans (hS.trans hstep_b)
    exact hnotS_b_c (hS_u_b.symm.trans hS_u_c)
  have hqne_T_a_b :
      ¬ (Quotient.mk'' xa : Quotient T) = Quotient.mk'' xb := by
    intro hq
    exact hnotT_a_b (Quotient.exact hq)
  have hend_au :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xa) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xu : Quotient S) := by
    simp [hrot_a]
  let pau :=
    (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xa).copy
      rfl hend_au
  have hstart_bc :
      (Sum.inl (Quotient.mk'' xb : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xu : Quotient S) := by
    exact congrArg Sum.inl (Quotient.sound hS_u_b.symm)
  have hend_bc :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xb) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xc : Quotient S) := by
    simp [hrot_b]
  let pbc :=
    (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xb).copy
      hstart_bc hend_bc
  let p := pau.append pbc
  have hp : p.IsPath := by
    rw [SimpleGraph.Walk.isPath_def]
    simp [p, pau, pbc,
      finRotate_mul_perm_incidence_contour_step_left_walk,
      setoidIncidenceGraph_left_walk_of_right_rel,
      SimpleGraph.Walk.support_append,
      SimpleGraph.Walk.support_copy,
      SimpleGraph.Walk.support_cons,
      SimpleGraph.Walk.support_nil]
    exact
      ⟨⟨hqne_S_a_preva, hqne_S_a_prevb⟩,
        hqne_T_a_b, hqne_S_preva_prevb⟩
  have heq :=
    leftTight_incidenceGraph_left_walk_unique_of_sameCycle
      (m := m) (π := π.1) π.2 ha hc (by omega) hac (p := p) hp
  have hlen := congrArg SimpleGraph.Walk.length heq
  have hp_len : p.length = 4 := by
    simp [p, pau, pbc, SimpleGraph.Walk.length_append,
      SimpleGraph.Walk.length_copy,
      finRotate_mul_perm_incidence_contour_step_left_walk_length]
  have hbad : p.length = 2 := by
    simpa [p] using hlen
  omega

/-- The left gap-three/end-adjacent branch `S(a+1,c)` exposes the hidden
`π(a+1,b)` branch.

In the slice `c-a=3, b=a+2`, the branch `S(a+1,c)` identifies the start of the
contour step `a+1 -> b` with `S(c)`.  Comparing that copied step with the
reversed contour step `b -> c` gives two simple paths from `S(c)` to `S(b)`;
tree uniqueness forces their middle right vertices to agree, hence
`π(a+1,b)`. -/
theorem leftTight_bianeAdjacentLink_left_of_gap_three_end_adjacent_T_a1_b_of_S_a1_c
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (_hbc : b < c) (hcd : c < d)
    (hgap : c - a = 3)
    (hb_eq : b = a + 2)
    (_hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (_hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_a1_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a + 1, by
          have hc' := Finset.mem_range.mp hc
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩) :
    π.1.SameCycle
      ⟨a + 1, by
        have hc' := Finset.mem_range.mp hc
        omega⟩
      ⟨b, Finset.mem_range.mp hb⟩ := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π.1
  let xu : Fin (m + 1) :=
    ⟨a + 1, by
      have hc' := Finset.mem_range.mp hc
      omega⟩
  let xb : Fin (m + 1) := ⟨b, Finset.mem_range.mp hb⟩
  let xc : Fin (m + 1) := ⟨c, Finset.mem_range.mp hc⟩
  have hxu_add_one : xu + 1 = xb := by
    apply Fin.ext
    have hxu_succ_lt : xu.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xu]
      omega
    have hval : (xu + 1).val = xu.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xu) hxu_succ_lt
    change (xu + 1).val = xb.val
    simp [xu, xb] at hval ⊢
    omega
  have hxb_add_one : xb + 1 = xc := by
    apply Fin.ext
    have hxb_succ_lt : xb.val + 1 < m + 1 := by
      have hc' := Finset.mem_range.mp hc
      simp [xb]
      omega
    have hval : (xb + 1).val = xb.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xb) hxb_succ_lt
    change (xb + 1).val = xc.val
    simp [xb, xc] at hval ⊢
    omega
  have hrot_u : finRotate (m + 1) xu = xb := by
    rw [finRotate_succ_apply]
    simp [hxu_add_one]
  have hrot_b : finRotate (m + 1) xb = xc := by
    rw [finRotate_succ_apply]
    simp [hxb_add_one]
  have hS_u_c : S xu xc := by
    simpa [S, xu, xc] using hS_a1_c
  have hnotS_b_c : ¬ S xb xc := by
    intro hS_b_c
    have hc_eq : c = b + 1 := by omega
    have hC :
        (⟨c, Finset.mem_range.mp hc⟩ : Fin (m + 1)) =
          ⟨b + 1, by
            have hd' := Finset.mem_range.mp hd
            omega⟩ := by
      apply Fin.ext
      exact hc_eq
    exact
      leftTight_nat_adjacent_left_repeat_impossible_of_sameCycle_to_right
        π hb hd (by omega)
        (by simpa [S, xb, xc, hC] using hS_b_c)
        (by simpa [xb] using hbd)
  have hnotS_u_b : ¬ S xu xb := by
    intro hS_u_b
    exact hnotS_b_c (hS_u_b.symm.trans hS_u_c)
  have hnotS_u_rot :
      ¬ (finRotate (m + 1) * π.1).SameCycle xu (finRotate (m + 1) xu) := by
    intro hS
    exact hnotS_u_b (by simpa [S, hrot_u] using hS)
  have hnotS_b_rot :
      ¬ (finRotate (m + 1) * π.1).SameCycle xb (finRotate (m + 1) xb) := by
    intro hS
    exact hnotS_b_c (by simpa [S, hrot_b] using hS)
  have hstart_u :
      (Sum.inl (Quotient.mk'' xu : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xc : Quotient S) := by
    exact congrArg Sum.inl (Quotient.sound hS_u_c)
  have hend_u :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xu) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xb : Quotient S) := by
    simp [hrot_u]
  let pub :=
    (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xu).copy
      hstart_u hend_u
  have hpub : pub.IsPath := by
    exact (SimpleGraph.Walk.isPath_copy _ hstart_u hend_u).mpr
      (finRotate_mul_perm_incidence_contour_step_left_walk_isPath
        π.1 xu hnotS_u_rot)
  have hstart_b :
      (Sum.inl (Quotient.mk'' xb : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xb : Quotient S) := rfl
  have hend_b :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xb) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xc : Quotient S) := by
    simp [hrot_b]
  let pbc :=
    (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xb).copy
      hstart_b hend_b
  have hpbc : pbc.IsPath := by
    exact (SimpleGraph.Walk.isPath_copy _ hstart_b hend_b).mpr
      (finRotate_mul_perm_incidence_contour_step_left_walk_isPath
        π.1 xb hnotS_b_rot)
  let q := pbc.reverse
  have hq : q.IsPath := hpbc.reverse
  let uV : Quotient S ⊕ Quotient T :=
    Sum.inl (Quotient.mk'' xc : Quotient S)
  let vV : Quotient S ⊕ Quotient T :=
    Sum.inl (Quotient.mk'' xb : Quotient S)
  rcases leftTight_incidenceGraph_existsUnique_isPath
      (m := m) (π := π.1) π.2 uV vV with
    ⟨w, _hw, huniq⟩
  have heq : pub = q := by
    exact (huniq pub hpub).trans (huniq q hq).symm
  have hmid := congrArg (fun p => p.getVert 1) heq
  have hmid' :
      (Sum.inr (Quotient.mk'' xu : Quotient T) :
          Quotient S ⊕ Quotient T) =
        Sum.inr (Quotient.mk'' xb : Quotient T) := by
    simpa [pub, q, pbc,
      finRotate_mul_perm_incidence_contour_step_left_walk,
      setoidIncidenceGraph_left_walk_of_right_rel,
      SimpleGraph.Walk.getVert_copy,
      SimpleGraph.Walk.getVert_reverse,
      SimpleGraph.Walk.length_copy,
      finRotate_mul_perm_incidence_contour_step_left_walk_length] using hmid
  have hT_u_b : T xu xb := Quotient.exact (Sum.inr.inj hmid')
  simpa [T, xu, xb] using hT_u_b

/-- The `d-b=3`, `c=b+2` right Biane slice reduces to six explicit branches.

This is the right-hand analogue of the checked gap-three/start-adjacent left
reduction.  The contour repeat on `[b,d]` discharges the desired adjacent
link, the endpoint-to-endpoint forbidden repeat, and the start-adjacent
contradiction internally; the remaining finite branches are exposed as
explicit inputs. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_reduced
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (_hbc : b < c) (hcd : c < d)
    (hgap : d - b = 3)
    (hc_eq : c = b + 2)
    (_hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (_hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_b_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hS_b1_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hS_b1_d :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨d, Finset.mem_range.mp hd⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hT_b_b1 :
      π.1.SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hT_b_c :
      π.1.SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hT_b1_c :
      π.1.SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨c, Finset.mem_range.mp hc⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
  have hbd_lt : b < d := by omega
  have hgap_lt : 1 < d - b := by omega
  rcases
    leftTight_contour_interval_sameCycle_exists_repeated_parity_sameCycle_of_one_lt_sub
      (m := m) (π := π.1) π.2 hb hd hbd_lt hbd hgap_lt with
    hLeft | hRight
  · rcases hLeft with ⟨r, s, hr, hs, hrs, hSame⟩
    have hpairs :
        (r = 0 ∧ s = 1) ∨ (r = 0 ∧ s = 2) ∨
        (r = 0 ∧ s = 3) ∨ (r = 1 ∧ s = 2) ∨
        (r = 1 ∧ s = 3) ∨ (r = 2 ∧ s = 3) := by
      omega
    rcases hpairs with hrs01 | hrsRest
    · rcases hrs01 with ⟨hr0, hs1⟩
      have hleft :
          (⟨b + r, by
            have hd' := Finset.mem_range.mp hd
            omega⟩ : Fin (m + 1)) =
            ⟨b, Finset.mem_range.mp hb⟩ := by
        apply Fin.ext
        simp [hr0]
      have hright :
          (⟨b + s, by
            have hd' := Finset.mem_range.mp hd
            omega⟩ : Fin (m + 1)) =
            ⟨b + 1, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ := by
        apply Fin.ext
        simp [hs1]
      have hS_b_b1 :
          (finRotate (m + 1) * π.1).SameCycle
            ⟨b, Finset.mem_range.mp hb⟩
            ⟨b + 1, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ := by
        simpa [hleft, hright] using hSame
      exact False.elim
        (leftTight_nat_adjacent_left_repeat_impossible_of_sameCycle_to_right
          π hb hd hbd_lt hS_b_b1 hbd)
    · rcases hrsRest with hrs02 | hrsRest
      · rcases hrs02 with ⟨hr0, hs2⟩
        have hleft :
            (⟨b + r, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨b, Finset.mem_range.mp hb⟩ := by
          apply Fin.ext
          simp [hr0]
        have hright :
            (⟨b + s, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          apply Fin.ext
          simp [hs2, hc_eq]
        exact hS_b_c (by simpa [hleft, hright] using hSame)
      · rcases hrsRest with hrs03 | hrsRest
        · rcases hrs03 with ⟨hr0, hs3⟩
          have hleft :
              (⟨b + r, by
                have hd' := Finset.mem_range.mp hd
                omega⟩ : Fin (m + 1)) =
                ⟨b, Finset.mem_range.mp hb⟩ := by
            apply Fin.ext
            simp [hr0]
          have hright :
              (⟨b + s, by
                have hd' := Finset.mem_range.mp hd
                omega⟩ : Fin (m + 1)) =
                ⟨d, Finset.mem_range.mp hd⟩ := by
            apply Fin.ext
            have hd_eq : d = b + 3 := by omega
            simp [hs3, hd_eq]
          have hS_bd :
              (finRotate (m + 1) * π.1).SameCycle
                ⟨b, Finset.mem_range.mp hb⟩
                ⟨d, Finset.mem_range.mp hd⟩ := by
            simpa [hleft, hright] using hSame
          exact False.elim
            ((leftTight_not_sameCycle_both_of_lt
              (m := m) (π := π.1) π.2 hb hd hbd_lt hbd) hS_bd)
        · rcases hrsRest with hrs12 | hrsRest
          · rcases hrs12 with ⟨hr1, hs2⟩
            have hleft :
                (⟨b + r, by
                  have hd' := Finset.mem_range.mp hd
                  omega⟩ : Fin (m + 1)) =
                  ⟨b + 1, by
                    have hd' := Finset.mem_range.mp hd
                    omega⟩ := by
              apply Fin.ext
              simp [hr1]
            have hright :
                (⟨b + s, by
                  have hd' := Finset.mem_range.mp hd
                  omega⟩ : Fin (m + 1)) =
                  ⟨c, Finset.mem_range.mp hc⟩ := by
              apply Fin.ext
              simp [hs2, hc_eq]
            exact hS_b1_c (by simpa [hleft, hright] using hSame)
          · rcases hrsRest with hrs13 | hrs23
            · rcases hrs13 with ⟨hr1, hs3⟩
              have hleft :
                  (⟨b + r, by
                    have hd' := Finset.mem_range.mp hd
                    omega⟩ : Fin (m + 1)) =
                    ⟨b + 1, by
                      have hd' := Finset.mem_range.mp hd
                      omega⟩ := by
                apply Fin.ext
                simp [hr1]
              have hright :
                  (⟨b + s, by
                    have hd' := Finset.mem_range.mp hd
                    omega⟩ : Fin (m + 1)) =
                    ⟨d, Finset.mem_range.mp hd⟩ := by
                apply Fin.ext
                have hd_eq : d = b + 3 := by omega
                simp [hs3, hd_eq]
              exact hS_b1_d (by simpa [hleft, hright] using hSame)
            · rcases hrs23 with ⟨hr2, hs3⟩
              have hleft :
                  (⟨b + r, by
                    have hd' := Finset.mem_range.mp hd
                    omega⟩ : Fin (m + 1)) =
                    ⟨c, Finset.mem_range.mp hc⟩ := by
                apply Fin.ext
                simp [hr2, hc_eq]
              have hright :
                  (⟨b + s, by
                    have hd' := Finset.mem_range.mp hd
                    omega⟩ : Fin (m + 1)) =
                    ⟨d, Finset.mem_range.mp hd⟩ := by
                apply Fin.ext
                have hd_eq : d = b + 3 := by omega
                simp [hs3, hd_eq]
              simpa [hleft, hright] using hSame
  · rcases hRight with ⟨r, s, hr, hs, hrs, hSame⟩
    have hpairs :
        (r = 0 ∧ s = 1) ∨ (r = 0 ∧ s = 2) ∨
        (r = 1 ∧ s = 2) := by
      omega
    rcases hpairs with hrs01 | hrsRest
    · rcases hrs01 with ⟨hr0, hs1⟩
      have hleft :
          (⟨b + r, by
            have hd' := Finset.mem_range.mp hd
            omega⟩ : Fin (m + 1)) =
            ⟨b, Finset.mem_range.mp hb⟩ := by
        apply Fin.ext
        simp [hr0]
      have hright :
          (⟨b + s, by
            have hd' := Finset.mem_range.mp hd
            omega⟩ : Fin (m + 1)) =
            ⟨b + 1, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ := by
        apply Fin.ext
        simp [hs1]
      exact hT_b_b1 (by simpa [hleft, hright] using hSame)
    · rcases hrsRest with hrs02 | hrs12
      · rcases hrs02 with ⟨hr0, hs2⟩
        have hleft :
            (⟨b + r, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨b, Finset.mem_range.mp hb⟩ := by
          apply Fin.ext
          simp [hr0]
        have hright :
            (⟨b + s, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          apply Fin.ext
          simp [hs2, hc_eq]
        exact hT_b_c (by simpa [hleft, hright] using hSame)
      · rcases hrs12 with ⟨hr1, hs2⟩
        have hleft :
            (⟨b + r, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨b + 1, by
                have hd' := Finset.mem_range.mp hd
                omega⟩ := by
          apply Fin.ext
          simp [hr1]
        have hright :
            (⟨b + s, by
              have hd' := Finset.mem_range.mp hd
              omega⟩ : Fin (m + 1)) =
              ⟨c, Finset.mem_range.mp hc⟩ := by
          apply Fin.ext
          simp [hs2, hc_eq]
        exact hT_b1_c (by simpa [hleft, hright] using hSame)

/-- The `π(b,b+1)` branch in the right gap-three slice closes by shifting to
the checked gap-two right theorem.

If `d-b=3` and `c=b+2`, then `d-(b+1)=2`.  A same-`π` link `b~b+1` combines
with the crossing link `b~d` to give `(b+1)~d`; the separating non-link
`a≁b` also gives `a≁(b+1)`.  The gap-two right theorem applied to the
subcrossing `(a,b+1,c,d)` then gives the desired right adjacent link. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_of_pi_b_b1
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (_hbc : b < c) (hcd : c < d)
    (hgap : d - b = 3)
    (hc_eq : c = b + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hT_b_b1 : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨b + 1, by
        have hd' := Finset.mem_range.mp hd
        omega⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨c, Finset.mem_range.mp hc⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
  have hb1_mem : b + 1 ∈ Finset.range (m + 1) := by
    have hd' := Finset.mem_range.mp hd
    exact Finset.mem_range.mpr (by omega)
  have hB1 :
      (⟨b + 1, by
        have hd' := Finset.mem_range.mp hd
        omega⟩ : Fin (m + 1)) =
        ⟨b + 1, Finset.mem_range.mp hb1_mem⟩ := by
    apply Fin.ext
    rfl
  have hbc' : b + 1 < c := by
    omega
  have hab' : a < b + 1 := by
    omega
  have hgap' : d - (b + 1) = 2 := by
    omega
  have hbd' : π.1.SameCycle
      ⟨b + 1, Finset.mem_range.mp hb1_mem⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
    have hb1_b : π.1.SameCycle
        ⟨b + 1, Finset.mem_range.mp hb1_mem⟩
        ⟨b, Finset.mem_range.mp hb⟩ := by
      simpa [hB1] using hT_b_b1.symm
    exact hb1_b.trans hbd
  have hnot' :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b + 1, Finset.mem_range.mp hb1_mem⟩ := by
    intro hab1
    have hb1_b : π.1.SameCycle
        ⟨b + 1, Finset.mem_range.mp hb1_mem⟩
        ⟨b, Finset.mem_range.mp hb⟩ := by
      simpa [hB1] using hT_b_b1.symm
    exact hnot (hab1.trans hb1_b)
  exact
    leftTight_bianeAdjacentLink_right_of_gap_two
      π ha hb1_mem hc hd hab' hbc' hcd hgap' hac hbd' hnot'

/-- The `π(b,c)` branch in the right gap-three slice is contradictory.

Indeed, the crossing already has `π(a,c)`.  If also `π(b,c)`, then
transitivity gives `π(a,b)`, contradicting the separating non-link. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_of_pi_b_c
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (_hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (_hbc : b < c) (_hcd : c < d)
    (_hgap : d - b = 3)
    (_hc_eq : c = b + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (_hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp _hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hT_b_c : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨c, Finset.mem_range.mp hc⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨c, Finset.mem_range.mp hc⟩
      ⟨d, Finset.mem_range.mp _hd⟩ := by
  exact False.elim (hnot (hac.trans hT_b_c.symm))

/-- The right gap-three branch `S(b,c)` forces the target `S(c,d)`.

If `S(c,d)` failed, the one-step contour path from `c` to `d`, copied across
the branch equality `S(b)=S(c)`, would be a simple path from `S(b)` to `S(d)`.
Tree uniqueness compares this path with the direct path supplied by the
`π`-link `b~d`, forcing the middle right vertex to be both `T(c)` and `T(b)`.
Thus `π(b,c)`, which combines with `π(a,c)` to contradict `¬π(a,b)`. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_of_S_b_c
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (_hbc : b < c) (_hcd : c < d)
    (hgap : d - b = 3)
    (hc_eq : c = b + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_b_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨c, Finset.mem_range.mp hc⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
  by_contra hnotS_c_d
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π.1
  let xb : Fin (m + 1) := ⟨b, Finset.mem_range.mp hb⟩
  let xc : Fin (m + 1) := ⟨c, Finset.mem_range.mp hc⟩
  let xd : Fin (m + 1) := ⟨d, Finset.mem_range.mp hd⟩
  have hS_b_c' : S xb xc := by
    simpa [S, xb, xc] using hS_b_c
  have hnotT_b_c : ¬ T xb xc := by
    intro hT_b_c
    exact hnot (by
      simpa [T, xb, xc] using hac.trans hT_b_c.symm)
  have hxc_add_one : xc + 1 = xd := by
    apply Fin.ext
    have hxc_succ_lt : xc.val + 1 < m + 1 := by
      have hd' := Finset.mem_range.mp hd
      simp [xc]
      omega
    have hval : (xc + 1).val = xc.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xc) hxc_succ_lt
    change (xc + 1).val = xd.val
    simp [xc, xd] at hval ⊢
    omega
  have hrot_c : finRotate (m + 1) xc = xd := by
    rw [finRotate_succ_apply]
    simp [hxc_add_one]
  have hnotS_c_rot :
      ¬ (finRotate (m + 1) * π.1).SameCycle
        xc (finRotate (m + 1) xc) := by
    intro hS
    exact hnotS_c_d (by simpa [xc, xd, hrot_c] using hS)
  have hstart :
      (Sum.inl (Quotient.mk'' xc : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xb : Quotient S) := by
    exact congrArg Sum.inl (Quotient.sound hS_b_c'.symm)
  have hend :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xc) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xd : Quotient S) := by
    simp [hrot_c]
  let p := (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xc).copy
    hstart hend
  have hp : p.IsPath := by
    exact (SimpleGraph.Walk.isPath_copy _ hstart hend).mpr
      (finRotate_mul_perm_incidence_contour_step_left_walk_isPath
        π.1 xc hnotS_c_rot)
  have heq :=
    leftTight_incidenceGraph_left_walk_unique_of_sameCycle
      (m := m) (π := π.1) π.2 hb hd (by omega) hbd (p := p) hp
  have hmid := congrArg (fun q => q.getVert 1) heq
  have hmid' :
      (Sum.inr (Quotient.mk'' xc : Quotient T) :
          Quotient S ⊕ Quotient T) =
        Sum.inr (Quotient.mk'' xb : Quotient T) := by
    simpa [p,
      finRotate_mul_perm_incidence_contour_step_left_walk,
      leftTight_incidenceGraph_left_walk_of_sameCycle,
      setoidIncidenceGraph_left_walk_of_right_rel,
      SimpleGraph.Walk.getVert_copy] using hmid
  have hT_c_b : T xc xb := Quotient.exact (Sum.inr.inj hmid')
  exact hnotT_b_c hT_c_b.symm

/-- The remaining right branch `π(b+1,c)` reduces to the already-exposed
`S(b+1,d)` branch by the large-gap right frontier.

Indeed, `π(b+1,c)` and the crossing link `π(a,c)` give `π(a,b+1)`.  Applying
the large-gap right input to the shifted crossing `(a,b,b+1,d)` gives
`S(b+1,d)`, because this shifted crossing is not the special
`d-b=3, c=b+2` slice. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_T_b1_c_to_S_b1_d_of_right_rest
    (hRightRest : ∀ m : ℕ, ∀ π : WickCycleLeftTightClass m,
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          2 < d - b →
          ¬ (d - b = 3 ∧ c = b + 2) →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨c, Finset.mem_range.mp hc⟩
            ⟨d, Finset.mem_range.mp hd⟩)
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (_hbc : b < c) (_hcd : c < d)
    (hgap : d - b = 3)
    (hc_eq : c = b + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hT_b1_c :
      π.1.SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨b + 1, by
        have hd' := Finset.mem_range.mp hd
        omega⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
  have hb1_mem : b + 1 ∈ Finset.range (m + 1) := by
    exact Finset.mem_range.mpr (by
      have hd' := Finset.mem_range.mp hd
      omega)
  have hB1 :
      (⟨b + 1, by
        have hd' := Finset.mem_range.mp hd
        omega⟩ : Fin (m + 1)) =
        ⟨b + 1, Finset.mem_range.mp hb1_mem⟩ := by
    apply Fin.ext
    rfl
  have hbc1 : b < b + 1 := by omega
  have hb1d : b + 1 < d := by omega
  have hac_b1 : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨b + 1, Finset.mem_range.mp hb1_mem⟩ := by
    have hT_b1_c' : π.1.SameCycle
        ⟨b + 1, Finset.mem_range.mp hb1_mem⟩
        ⟨c, Finset.mem_range.mp hc⟩ := by
      simpa [hB1] using hT_b1_c
    exact hac.trans hT_b1_c'.symm
  have hlarge : 2 < d - b := by omega
  have hnot_special : ¬ (d - b = 3 ∧ b + 1 = b + 2) := by
    intro hspecial
    omega
  have hS_b1_d :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b + 1, Finset.mem_range.mp hb1_mem⟩
        ⟨d, Finset.mem_range.mp hd⟩ :=
    hRightRest m π a b (b + 1) d
      ha hb hb1_mem hd hab hbc1 hb1d hac_b1 hbd hnot hlarge hnot_special
  simpa [hB1] using hS_b1_d

/-- The right fixed-`b+1` branch reduces to the already-exposed
`S(b+1,d)` branch.

Fixedness gives the adjacent repeat `S(b+1,c)`.  If `S(b+1,d)` failed, the
contour step `b -> b+1` followed by the copied contour step `c -> d` would be
a simple length-four path from `S(b)` to `S(d)`.  Tree uniqueness compares it
with the direct length-two path coming from `π(b,d)`, contradiction. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_fixed_b1_to_S_b1_d
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (_hab : a < b) (_hbc : b < c) (_hcd : c < d)
    (hgap : d - b = 3)
    (hc_eq : c = b + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hfix :
      π.1
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩ =
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨b + 1, by
        have hd' := Finset.mem_range.mp hd
        omega⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
  by_contra hnotS_b1_d
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π.1
  let xb : Fin (m + 1) := ⟨b, Finset.mem_range.mp hb⟩
  let xu : Fin (m + 1) :=
    ⟨b + 1, by
      have hd' := Finset.mem_range.mp hd
      omega⟩
  let xc : Fin (m + 1) := ⟨c, Finset.mem_range.mp hc⟩
  let xd : Fin (m + 1) := ⟨d, Finset.mem_range.mp hd⟩
  have hxb_add_one : xb + 1 = xu := by
    apply Fin.ext
    have hxb_succ_lt : xb.val + 1 < m + 1 := by
      have hd' := Finset.mem_range.mp hd
      simp [xb]
      omega
    have hval : (xb + 1).val = xb.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xb) hxb_succ_lt
    change (xb + 1).val = xu.val
    simp [xb, xu] at hval ⊢
    omega
  have hxu_add_one : xu + 1 = xc := by
    apply Fin.ext
    have hxu_succ_lt : xu.val + 1 < m + 1 := by
      have hd' := Finset.mem_range.mp hd
      simp [xu]
      omega
    have hval : (xu + 1).val = xu.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xu) hxu_succ_lt
    change (xu + 1).val = xc.val
    simp [xu, xc] at hval ⊢
    omega
  have hxc_add_one : xc + 1 = xd := by
    apply Fin.ext
    have hxc_succ_lt : xc.val + 1 < m + 1 := by
      have hd' := Finset.mem_range.mp hd
      simp [xc]
      omega
    have hval : (xc + 1).val = xc.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xc) hxc_succ_lt
    change (xc + 1).val = xd.val
    simp [xc, xd] at hval ⊢
    omega
  have hrot_b : finRotate (m + 1) xb = xu := by
    rw [finRotate_succ_apply]
    simp [hxb_add_one]
  have hrot_u : finRotate (m + 1) xu = xc := by
    rw [finRotate_succ_apply]
    simp [hxu_add_one]
  have hrot_c : finRotate (m + 1) xc = xd := by
    rw [finRotate_succ_apply]
    simp [hxc_add_one]
  have hstep_b : S (π.1.symm xb) xu := by
    have h := (finRotate_mul_perm_contour_step_sameCycle π.1 xb).2
    simpa [S, hrot_b] using h
  have hstep_c : S (π.1.symm xc) xd := by
    have h := (finRotate_mul_perm_contour_step_sameCycle π.1 xc).2
    simpa [S, hrot_c] using h
  have hS_u_c : S xu xc := by
    have hSrot :
        (finRotate (m + 1) * π.1).SameCycle
          xu (finRotate (m + 1) xu) :=
      finRotate_mul_perm_sameCycle_self_finRotate_of_fixed
        (m := m) (π := π.1) (x := xu) (by simpa [xu] using hfix)
    simpa [S, hrot_u] using hSrot
  have hnotS_b_u : ¬ S xb xu := by
    intro hS_b_u
    exact
      leftTight_nat_adjacent_left_repeat_impossible_of_sameCycle_to_right
        π hb hd (by omega)
        (by simpa [S, xb, xu] using hS_b_u)
        (by simpa [xb, xd] using hbd)
  have hnotS_b_d : ¬ S xb xd := by
    intro hS_b_d
    exact
      (leftTight_not_sameCycle_both_of_lt
        (m := m) (π := π.1) π.2 hb hd (by omega) hbd)
        (by simpa [S, xb, xd] using hS_b_d)
  have hnotS_u_d : ¬ S xu xd := by
    intro hS_u_d
    exact hnotS_b1_d (by simpa [S, xu, xd] using hS_u_d)
  have hnotT_b_c : ¬ T xb xc := by
    intro hT_b_c
    exact hnot (by simpa [T, xb, xc] using hac.trans hT_b_c.symm)
  have hqne_S_b_u :
      ¬ (Quotient.mk'' xb : Quotient S) = Quotient.mk'' xu := by
    intro hq
    exact hnotS_b_u (Quotient.exact hq)
  have hqne_S_b_d :
      ¬ (Quotient.mk'' xb : Quotient S) = Quotient.mk'' xd := by
    intro hq
    exact hnotS_b_d (Quotient.exact hq)
  have hqne_S_u_d :
      ¬ (Quotient.mk'' xu : Quotient S) = Quotient.mk'' xd := by
    intro hq
    exact hnotS_u_d (Quotient.exact hq)
  have hqne_T_b_c :
      ¬ (Quotient.mk'' xb : Quotient T) = Quotient.mk'' xc := by
    intro hq
    exact hnotT_b_c (Quotient.exact hq)
  have hqne_S_b_prevb :
      ¬ (Quotient.mk'' xb : Quotient S) =
        Quotient.mk'' (π.1.symm xb) := by
    intro hq
    have hS : S xb (π.1.symm xb) := Quotient.exact hq
    exact hnotS_b_u (hS.trans hstep_b)
  have hqne_S_b_prevc :
      ¬ (Quotient.mk'' xb : Quotient S) =
        Quotient.mk'' (π.1.symm xc) := by
    intro hq
    have hS : S xb (π.1.symm xc) := Quotient.exact hq
    exact hnotS_b_d (hS.trans hstep_c)
  have hqne_S_prevb_prevc :
      ¬ (Quotient.mk'' (π.1.symm xb) : Quotient S) =
        Quotient.mk'' (π.1.symm xc) := by
    intro hq
    have hS : S (π.1.symm xb) (π.1.symm xc) := Quotient.exact hq
    exact hnotS_u_d (hstep_b.symm.trans (hS.trans hstep_c))
  have hend_bu :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xb) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xu : Quotient S) := by
    simp [hrot_b]
  let pbu :=
    (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xb).copy
      rfl hend_bu
  have hstart_cd :
      (Sum.inl (Quotient.mk'' xc : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xu : Quotient S) := by
    exact congrArg Sum.inl (Quotient.sound hS_u_c.symm)
  have hend_cd :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xc) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xd : Quotient S) := by
    simp [hrot_c]
  let pcd :=
    (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xc).copy
      hstart_cd hend_cd
  let p := pbu.append pcd
  have hp : p.IsPath := by
    rw [SimpleGraph.Walk.isPath_def]
    simp [p, pbu, pcd,
      finRotate_mul_perm_incidence_contour_step_left_walk,
      setoidIncidenceGraph_left_walk_of_right_rel,
      SimpleGraph.Walk.support_append,
      SimpleGraph.Walk.support_copy,
      SimpleGraph.Walk.support_cons,
      SimpleGraph.Walk.support_nil]
    exact
      ⟨⟨hqne_S_b_prevb, hqne_S_b_prevc⟩,
        hqne_T_b_c, hqne_S_prevb_prevc⟩
  have heq :=
    leftTight_incidenceGraph_left_walk_unique_of_sameCycle
      (m := m) (π := π.1) π.2 hb hd (by omega) hbd (p := p) hp
  have hlen := congrArg SimpleGraph.Walk.length heq
  have hp_len : p.length = 4 := by
    simp [p, pbu, pcd, SimpleGraph.Walk.length_append,
      SimpleGraph.Walk.length_copy,
      finRotate_mul_perm_incidence_contour_step_left_walk_length]
  have hbad : p.length = 2 := by
    simpa [p] using hlen
  omega

/-- If the right special-slice branch `S(b+1,d)` occurs while the target
`S(c,d)` fails, then the middle points `b+1` and `c` lie in the same
`π`-cycle.

The proof compares the two simple two-step incidence paths from `S(c)` to
`S(d)`: the contour step at `c`, and the reversed contour step at `b+1`
after copying its start along `S(b+1,d)`.  Tree uniqueness forces the middle
right vertices to agree. -/
theorem leftTight_right_gap_three_T_b1_c_of_S_b1_d_of_not_S_c_d
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {b c d : ℕ}
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (_hbc : b < c) (_hcd : c < d)
    (hgap : d - b = 3)
    (hc_eq : c = b + 2)
    (hS_b1_d :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hnotS_c_d :
      ¬ (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩) :
    π.1.SameCycle
      ⟨b + 1, by
        have hd' := Finset.mem_range.mp hd
        omega⟩
      ⟨c, Finset.mem_range.mp hc⟩ := by
  let S : Setoid (Fin (m + 1)) :=
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π.1)
  let T : Setoid (Fin (m + 1)) := Equiv.Perm.SameCycle.setoid π.1
  let xu : Fin (m + 1) :=
    ⟨b + 1, by
      have hd' := Finset.mem_range.mp hd
      omega⟩
  let xc : Fin (m + 1) := ⟨c, Finset.mem_range.mp hc⟩
  let xd : Fin (m + 1) := ⟨d, Finset.mem_range.mp hd⟩
  have hxu_add_one : xu + 1 = xc := by
    apply Fin.ext
    have hxu_succ_lt : xu.val + 1 < m + 1 := by
      have hd' := Finset.mem_range.mp hd
      simp [xu]
      omega
    have hval : (xu + 1).val = xu.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xu) hxu_succ_lt
    change (xu + 1).val = xc.val
    simp [xu, xc] at hval ⊢
    omega
  have hxc_add_one : xc + 1 = xd := by
    apply Fin.ext
    have hxc_succ_lt : xc.val + 1 < m + 1 := by
      have hd' := Finset.mem_range.mp hd
      simp [xc]
      omega
    have hval : (xc + 1).val = xc.val + 1 := by
      simpa using Fin.val_add_one_of_lt' (i := xc) hxc_succ_lt
    change (xc + 1).val = xd.val
    simp [xc, xd] at hval ⊢
    omega
  have hrot_u : finRotate (m + 1) xu = xc := by
    rw [finRotate_succ_apply]
    simp [hxu_add_one]
  have hrot_c : finRotate (m + 1) xc = xd := by
    rw [finRotate_succ_apply]
    simp [hxc_add_one]
  have hS_u_d : S xu xd := by
    simpa [S, xu, xd] using hS_b1_d
  have hnotS_u_c : ¬ S xu xc := by
    intro hS_u_c
    exact hnotS_c_d (by simpa [S, xu, xc, xd] using hS_u_c.symm.trans hS_u_d)
  have hnotS_u_rot :
      ¬ (finRotate (m + 1) * π.1).SameCycle xu (finRotate (m + 1) xu) := by
    intro hS
    exact hnotS_u_c (by simpa [S, hrot_u] using hS)
  have hnotS_c_rot :
      ¬ (finRotate (m + 1) * π.1).SameCycle xc (finRotate (m + 1) xc) := by
    intro hS
    exact hnotS_c_d (by simpa [xc, xd, hrot_c] using hS)
  have hstart_u :
      (Sum.inl (Quotient.mk'' xu : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xd : Quotient S) := by
    exact congrArg Sum.inl (Quotient.sound hS_u_d)
  have hend_u :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xu) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xc : Quotient S) := by
    simp [hrot_u]
  let puc :=
    (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xu).copy
      hstart_u hend_u
  have hpuc : puc.IsPath := by
    exact (SimpleGraph.Walk.isPath_copy _ hstart_u hend_u).mpr
      (finRotate_mul_perm_incidence_contour_step_left_walk_isPath
        π.1 xu hnotS_u_rot)
  have hstart_c :
      (Sum.inl (Quotient.mk'' xc : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xc : Quotient S) := rfl
  have hend_c :
      (Sum.inl (Quotient.mk'' (finRotate (m + 1) xc) : Quotient S) :
          Quotient S ⊕ Quotient T) =
        Sum.inl (Quotient.mk'' xd : Quotient S) := by
    simp [hrot_c]
  let pcd :=
    (finRotate_mul_perm_incidence_contour_step_left_walk π.1 xc).copy
      hstart_c hend_c
  have hpcd : pcd.IsPath := by
    exact (SimpleGraph.Walk.isPath_copy _ hstart_c hend_c).mpr
      (finRotate_mul_perm_incidence_contour_step_left_walk_isPath
        π.1 xc hnotS_c_rot)
  let q := puc.reverse
  have hq : q.IsPath := hpuc.reverse
  let uV : Quotient S ⊕ Quotient T :=
    Sum.inl (Quotient.mk'' xc : Quotient S)
  let vV : Quotient S ⊕ Quotient T :=
    Sum.inl (Quotient.mk'' xd : Quotient S)
  rcases leftTight_incidenceGraph_existsUnique_isPath
      (m := m) (π := π.1) π.2 uV vV with
    ⟨w, _hw, huniq⟩
  have heq : pcd = q := by
    exact (huniq pcd hpcd).trans (huniq q hq).symm
  have hmid := congrArg (fun p => p.getVert 1) heq
  have hmid' :
      (Sum.inr (Quotient.mk'' xc : Quotient T) :
          Quotient S ⊕ Quotient T) =
        Sum.inr (Quotient.mk'' xu : Quotient T) := by
    simpa [pcd, q, puc,
      finRotate_mul_perm_incidence_contour_step_left_walk,
      setoidIncidenceGraph_left_walk_of_right_rel,
      SimpleGraph.Walk.getVert_copy,
      SimpleGraph.Walk.getVert_reverse,
      SimpleGraph.Walk.length_copy,
      finRotate_mul_perm_incidence_contour_step_left_walk_length] using hmid
  have hT_c_u : T xc xu := Quotient.exact (Sum.inr.inj hmid')
  simpa [T, xu, xc] using hT_c_u.symm

/-- The remaining right `S(b+1,d)` branch is absorbed once the shifted left
adjacent link on `(a,b,b+1,d)` is available.

If the target `S(c,d)` failed, the previous lemma forces `π(b+1,c)`, hence
`π(a,b+1)`.  The shifted left link gives `S(a,b)`, while the assumed
`S(b+1,d)` gives the opposite left edge.  These four point-incidences form a
forbidden square in the left-tight incidence tree. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_of_S_b1_d_of_left_shift
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgap : d - b = 3)
    (hc_eq : c = b + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hLeftShift :
      π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_b1_d :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨d, Finset.mem_range.mp hd⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨c, Finset.mem_range.mp hc⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
  by_contra hnotS_c_d
  have hb1_mem : b + 1 ∈ Finset.range (m + 1) := by
    exact Finset.mem_range.mpr (by
      have hd' := Finset.mem_range.mp hd
      omega)
  have hB1 :
      (⟨b + 1, by
        have hd' := Finset.mem_range.mp hd
        omega⟩ : Fin (m + 1)) =
        ⟨b + 1, Finset.mem_range.mp hb1_mem⟩ := by
    apply Fin.ext
    rfl
  have hT_b1_c :
      π.1.SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩ :=
    leftTight_right_gap_three_T_b1_c_of_S_b1_d_of_not_S_c_d
      π hb hc hd hbc hcd hgap hc_eq hS_b1_d hnotS_c_d
  have hT_a_b1 :
      π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩ := by
    exact hac.trans hT_b1_c.symm
  have hS_a_b :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩ :=
    hLeftShift hT_a_b1
  have hnotS_a_b1 :
      ¬ (finRotate (m + 1) * π.1).SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩ := by
    have hT_a_b1' :
        π.1.SameCycle
          ⟨a, Finset.mem_range.mp ha⟩
          ⟨b + 1, Finset.mem_range.mp hb1_mem⟩ := by
      simpa [hB1] using hT_a_b1
    have hnot' :=
      leftTight_not_sameCycle_both_of_lt
        (m := m) (π := π.1) π.2 ha hb1_mem (by omega) hT_a_b1'
    intro hS
    exact hnot' (by simpa [hB1] using hS)
  exact
    leftTight_forbid_point_incidence_square
      (m := m) (π := π.1) π.2
      (x₀ := ⟨a, Finset.mem_range.mp ha⟩)
      (x₁ := ⟨b, Finset.mem_range.mp hb⟩)
      (x₂ := ⟨b + 1, by
        have hd' := Finset.mem_range.mp hd
        omega⟩)
      (x₃ := ⟨d, Finset.mem_range.mp hd⟩)
      hT_a_b1 hbd hS_a_b hS_b1_d hnot hnotS_a_b1

/-- Right gap-three/end-adjacent reduction with the `π(b,b+1)` branch removed.

The remaining inputs are the four finite branches not closed by the shifted
gap-two argument or the immediate `π(b,c)` contradiction. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_reduced_no_pi_b_b1_no_pi_b_c
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgap : d - b = 3)
    (hc_eq : c = b + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_b_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hS_b1_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hS_b1_d :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨d, Finset.mem_range.mp hd⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hT_b1_c :
      π.1.SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨c, Finset.mem_range.mp hc⟩
      ⟨d, Finset.mem_range.mp hd⟩ := by
  exact
    leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_reduced
      π ha hb hc hd hab hbc hcd hgap hc_eq hac hbd hnot
      hS_b_c hS_b1_c hS_b1_d
      (fun hT_b_b1 =>
        leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_of_pi_b_b1
          π ha hb hc hd hab hbc hcd hgap hc_eq hac hbd hnot hT_b_b1)
      (fun hT_b_c =>
        leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_of_pi_b_c
          π ha hb hc hd hab hbc hcd hgap hc_eq hac hbd hnot hT_b_c)
      hT_b1_c

/-- Right gap-three/end-adjacent reducer with the adjacent left-repeat branch
normalized to the equivalent fixed-point branch.

In the slice `d-b=3, c=b+2`, the branch `S(b+1,c)` is an adjacent
`(finRotate*π)` repeat.  Left-tightness turns this adjacent repeat into the
fixed-point statement `π(b+1)=b+1`, so the endpoint can expose the fixed-point
branch directly. -/
theorem leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_reduced_fixed_b1_no_pi_b_b1_no_pi_b_c
    {m : ℕ} (π : WickCycleLeftTightClass m)
    {a b c d : ℕ}
    (ha : a ∈ Finset.range (m + 1))
    (hb : b ∈ Finset.range (m + 1))
    (hc : c ∈ Finset.range (m + 1))
    (hd : d ∈ Finset.range (m + 1))
    (hab : a < b) (hbc : b < c) (hcd : c < d)
    (hgap : d - b = 3)
    (hc_eq : c = b + 2)
    (hac : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hbd : π.1.SameCycle
      ⟨b, Finset.mem_range.mp hb⟩
      ⟨d, Finset.mem_range.mp hd⟩)
    (hnot :
      ¬ π.1.SameCycle
        ⟨a, Finset.mem_range.mp ha⟩
        ⟨b, Finset.mem_range.mp hb⟩)
    (hS_b_c :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b, Finset.mem_range.mp hb⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hFixed_b1 :
      π.1
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩ =
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hS_b1_d :
      (finRotate (m + 1) * π.1).SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨d, Finset.mem_range.mp hd⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩)
    (hT_b1_c :
      π.1.SameCycle
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
        ⟨c, Finset.mem_range.mp hc⟩ →
      (finRotate (m + 1) * π.1).SameCycle
        ⟨c, Finset.mem_range.mp hc⟩
        ⟨d, Finset.mem_range.mp hd⟩) :
    (finRotate (m + 1) * π.1).SameCycle
      ⟨c, Finset.mem_range.mp hc⟩
      ⟨d, Finset.mem_range.mp hd⟩ :=
  leftTight_bianeAdjacentLink_right_of_gap_three_end_adjacent_reduced_no_pi_b_b1_no_pi_b_c
    π ha hb hc hd hab hbc hcd hgap hc_eq hac hbd hnot
    hS_b_c
    (fun hS_b1_c =>
      let x : Fin (m + 1) :=
        ⟨b + 1, by
          have hd' := Finset.mem_range.mp hd
          omega⟩
      have hrot :
          finRotate (m + 1) x =
            ⟨c, Finset.mem_range.mp hc⟩ := by
        rw [finRotate_succ_apply]
        apply Fin.ext
        have hx_succ_lt : x.val + 1 < m + 1 := by
          have hd' := Finset.mem_range.mp hd
          simp [x]
          omega
        have hval : (x + 1).val = x.val + 1 := by
          simpa using Fin.val_add_one_of_lt' (i := x) hx_succ_lt
        change (x + 1).val = c
        calc
          (x + 1).val = x.val + 1 := hval
          _ = b + 2 := by
            simp [x]
          _ = c := by omega
      have hSrot :
          (finRotate (m + 1) * π.1).SameCycle
            x (finRotate (m + 1) x) := by
        simpa [x, hrot] using hS_b1_c
      have hfix :
          π.1 x = x :=
        leftTight_fixed_of_sameCycle_self_finRotate π.2 x hSrot
      hFixed_b1 (by simpa [x] using hfix))
    hS_b1_d hT_b1_c

/-- Biane adjacent-link criterion with the fully solved both-gap-two crossing
case removed from the theorem-facing hypothesis.

The caller only has to supply adjacent links for crossings that are not
simultaneously `c-a=2` and `d-b=2`; the closed local branch is discharged by
`leftTight_bianeAdjacentLinks_of_both_gap_two`. -/
theorem leftTightCyclePartitionRange_nonCrossing_of_bianeAdjacentLinks_except_both_gap_two
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hLinks :
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          ¬ (c - a = 2 ∧ d - b = 2) →
          (finRotate (m + 1) * π.1).SameCycle
              ⟨a, Finset.mem_range.mp ha⟩
              ⟨b, Finset.mem_range.mp hb⟩ ∧
            (finRotate (m + 1) * π.1).SameCycle
              ⟨c, Finset.mem_range.mp hc⟩
              ⟨d, Finset.mem_range.mp hd⟩) :
    NCPartition.NonCrossing (leftTightCyclePartitionRange π) := by
  apply leftTightCyclePartitionRange_nonCrossing_of_bianeAdjacentLinks
  intro a b c d ha hb hc hd hab hbc hcd hac hbd hnot
  by_cases hboth : c - a = 2 ∧ d - b = 2
  · exact
      leftTight_bianeAdjacentLinks_of_both_gap_two
        π ha hb hc hd hab hbc hcd hboth.1 hboth.2 hac hbd hnot
  · exact hLinks a b c d ha hb hc hd hab hbc hcd hac hbd hnot hboth

/-- Biane adjacent-link criterion with each solved gap-two half removed
separately.

The left adjacent link is supplied internally when `c-a=2`; the right adjacent
link is supplied internally when `d-b=2`.  The remaining theorem-facing inputs
are therefore the genuinely larger-gap left and right link obligations. -/
theorem leftTightCyclePartitionRange_nonCrossing_of_bianeAdjacentLinkHalves_except_gap_two
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hLeft :
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          c - a ≠ 2 →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩)
    (hRight :
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          d - b ≠ 2 →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨c, Finset.mem_range.mp hc⟩
            ⟨d, Finset.mem_range.mp hd⟩) :
    NCPartition.NonCrossing (leftTightCyclePartitionRange π) := by
  apply leftTightCyclePartitionRange_nonCrossing_of_bianeAdjacentLinks
  intro a b c d ha hb hc hd hab hbc hcd hac hbd hnot
  constructor
  · by_cases hgap : c - a = 2
    · exact
        leftTight_bianeAdjacentLink_left_of_gap_two
          π ha hb hc hd hab hbc hcd hgap hac hbd hnot
    · exact hLeft a b c d ha hb hc hd hab hbc hcd hac hbd hnot hgap
  · by_cases hgap : d - b = 2
    · exact
        leftTight_bianeAdjacentLink_right_of_gap_two
          π ha hb hc hd hab hbc hcd hgap hac hbd hnot
    · exact hRight a b c d ha hb hc hd hab hbc hcd hac hbd hnot hgap

/-- Biane adjacent-link criterion with the remaining halves stated as genuine
larger-gap obligations.

For a crossing `a<b<c<d`, the visible left and right gaps are automatically at
least two.  After the gap-two halves have been checked, the theorem-facing
inputs are therefore exactly the cases `2<c-a` and `2<d-b`. -/
theorem leftTightCyclePartitionRange_nonCrossing_of_bianeAdjacentLinkHalves_large_gaps
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (hLeft :
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          2 < c - a →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩)
    (hRight :
      ∀ a b c d : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hb : b ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hd : d ∈ Finset.range (m + 1),
          a < b → b < c → c < d →
          π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          π.1.SameCycle ⟨b, Finset.mem_range.mp hb⟩
            ⟨d, Finset.mem_range.mp hd⟩ →
          ¬ π.1.SameCycle ⟨a, Finset.mem_range.mp ha⟩
            ⟨b, Finset.mem_range.mp hb⟩ →
          2 < d - b →
          (finRotate (m + 1) * π.1).SameCycle
            ⟨c, Finset.mem_range.mp hc⟩
            ⟨d, Finset.mem_range.mp hd⟩) :
    NCPartition.NonCrossing (leftTightCyclePartitionRange π) := by
  apply leftTightCyclePartitionRange_nonCrossing_of_bianeAdjacentLinks
  intro a b c d ha hb hc hd hab hbc hcd hac hbd hnot
  constructor
  · by_cases hgap : c - a = 2
    · exact
        leftTight_bianeAdjacentLink_left_of_gap_two
          π ha hb hc hd hab hbc hcd hgap hac hbd hnot
    · have hlarge : 2 < c - a := by omega
      exact hLeft a b c d ha hb hc hd hab hbc hcd hac hbd hnot hlarge
  · by_cases hgap : d - b = 2
    · exact
        leftTight_bianeAdjacentLink_right_of_gap_two
          π ha hb hc hd hab hbc hcd hgap hac hbd hnot
    · have hlarge : 2 < d - b := by omega
      exact hRight a b c d ha hb hc hd hab hbc hcd hac hbd hnot hlarge

/-- The cycle partitions of `finRotate * π` and `π` jointly connect the
underlying cyclic set. -/
theorem leftCycleColumn_sameCycle_setoid_sup_top
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) :
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π) ⊔
      Equiv.Perm.SameCycle.setoid π = ⊤ := by
  have hmul : (finRotate (m + 1) * π) * π⁻¹ = finRotate (m + 1) := by
    ext x
    simp
  have htopInv :
      Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π) ⊔
        Equiv.Perm.SameCycle.setoid π⁻¹ = ⊤ :=
    sameCycle_setoid_sup_top_of_mul_fullCycle
      (finRotate (m + 1) * π) π⁻¹ (Nat.succ_pos m) hmul
  have hinvSetoid :
      Equiv.Perm.SameCycle.setoid π⁻¹ = Equiv.Perm.SameCycle.setoid π := by
    apply Setoid.ext
    intro a b
    change π⁻¹.SameCycle a b ↔ π.SameCycle a b
    exact Equiv.Perm.sameCycle_inv
  simpa [hinvSetoid] using htopInv

/-- In the one-sided Cayley-geodesic equality case, the cycle partitions of
`finRotate * π` and `π` have discrete meet. -/
theorem leftTight_sameCycle_setoid_inf_bot
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1) :
    Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π) ⊓
      Equiv.Perm.SameCycle.setoid π = ⊥ := by
  apply Setoid.ext
  intro x y
  constructor
  · intro h
    change (finRotate (m + 1) * π).SameCycle x y ∧ π.SameCycle x y at h
    exact leftTight_cycle_intersection_subsingleton hleft h.2 h.1
  · intro hxy
    subst y
    change (finRotate (m + 1) * π).SameCycle x x ∧ π.SameCycle x x
    exact ⟨Equiv.Perm.SameCycle.refl _ _, Equiv.Perm.SameCycle.refl _ _⟩

/-- In the one-sided Cayley-geodesic equality case, the two cycle partitions
form complementary setoids: they jointly connect the cyclic set and intersect
only at singleton classes. -/
theorem leftTight_sameCycle_setoid_isCompl
    {m : ℕ} {π : Equiv.Perm (Fin (m + 1))}
    (hleft : permCycleClassCount π +
      permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1) :
    IsCompl
      (Equiv.Perm.SameCycle.setoid (finRotate (m + 1) * π))
      (Equiv.Perm.SameCycle.setoid π) := by
  rw [isCompl_iff]
  constructor
  · rw [disjoint_iff]
    exact leftTight_sameCycle_setoid_inf_bot hleft
  · rw [codisjoint_iff]
    exact leftCycleColumn_sameCycle_setoid_sup_top π

/-- Zero plus-defect is exactly tightness in the left Cayley cycle-pair
inequality. -/
theorem wickPlusDefect_eq_zero_iff_leftTight
    {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) :
    wickPlusDefect π = 0 ↔
      permCycleClassCount π +
        permCycleClassCount (finRotate (m + 1) * π) = (m + 1) + 1 := by
  have hleftLe :
      permCycleClassCount π +
        permCycleClassCount (finRotate (m + 1) * π) ≤ (m + 1) + 1 := by
    exact cyclePairLeftBound_of_inverseLongCycleInvBound π
      (cyclePair_inverseLongCycleInvBound π)
  unfold wickPlusDefect
  constructor
  · intro h
    omega
  · intro h
    omega

/-- The zero plus-defect slice is the one-sided long-cycle geodesic class. -/
noncomputable def wickPlusDefectClassZeroEquivLeftTightClass (m : ℕ) :
    WickPlusDefectClass m 0 ≃ WickCycleLeftTightClass m where
  toFun := fun π =>
    ⟨π.1, (wickPlusDefect_eq_zero_iff_leftTight π.1).mp π.2⟩
  invFun := fun π =>
    ⟨π.1, (wickPlusDefect_eq_zero_iff_leftTight π.1).mpr π.2⟩
  left_inv := by
    intro π
    rfl
  right_inv := by
    intro π
    rfl

/-- The zero plus-defect count is the one-sided long-cycle geodesic count. -/
theorem wickPlusDefectCount_zero_eq_card_leftTightClass (m : ℕ) :
    wickPlusDefectCount m 0 =
      Fintype.card (WickCycleLeftTightClass m) := by
  unfold wickPlusDefectCount
  exact Fintype.card_congr (wickPlusDefectClassZeroEquivLeftTightClass m)

/-- Genus zero is the one-sided long-cycle geodesic class. -/
theorem wickPlusGenusCount_zero_eq_card_leftTightClass (m : ℕ) :
    wickPlusGenusCount m 0 =
      Fintype.card (WickCycleLeftTightClass m) := by
  rw [← wickPlusDefectCount_even_eq_genusCount m 0]
  simpa using wickPlusDefectCount_zero_eq_card_leftTightClass m

/-- The genus-zero bound is exactly the remaining Catalan/geodesic base count. -/
theorem wickPlusGenusCount_zero_le_four_pow_of_leftTightCount
    {m : ℕ}
    (hcount :
      (Fintype.card (WickCycleLeftTightClass m) : ℝ) ≤
        (4 : ℝ) ^ (m + 1)) :
    (wickPlusGenusCount m 0 : ℝ) ≤ (4 : ℝ) ^ (m + 1) := by
  rwa [wickPlusGenusCount_zero_eq_card_leftTightClass]

/-- Turn a proof that every left-tight cycle partition is noncrossing into a
map from one-sided geodesic permutations to noncrossing partitions. -/
noncomputable def leftTightClassToNCPart_of_nonCrossing
    {m : ℕ}
    (hNC : ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π)) :
    WickCycleLeftTightClass m → NCPartition.NCPart (m + 1) :=
  fun π => ⟨leftTightCyclePartitionRange π, hNC π⟩

/-- If the left-tight cycle partition map is injective and its image is
noncrossing, then one-sided geodesic permutations inject into `NCPart`. -/
noncomputable def leftTightClassEmbeddingNCPart_of_nonCrossing_injective
    {m : ℕ}
    (hNC : ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    (hinj : Function.Injective
      (fun π : WickCycleLeftTightClass m => leftTightCyclePartitionRange π)) :
    WickCycleLeftTightClass m ↪ NCPartition.NCPart (m + 1) where
  toFun := leftTightClassToNCPart_of_nonCrossing hNC
  inj' := by
    intro π τ h
    apply hinj
    exact congrArg (fun x : NCPartition.NCPart (m + 1) => x.1) h

/-- Checked counting reduction for the genus-zero/Catalan base.

The remaining content is exactly the noncrossing proof, injectivity of the
cycle-partition encoding, and the cardinal bound for `NCPart`. -/
theorem card_leftTightClass_le_NCPart_of_nonCrossing_injective
    {m : ℕ}
    (hNC : ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    (hinj : Function.Injective
      (fun π : WickCycleLeftTightClass m => leftTightCyclePartitionRange π)) :
    Fintype.card (WickCycleLeftTightClass m) ≤
      Fintype.card (NCPartition.NCPart (m + 1)) := by
  exact Fintype.card_le_of_embedding
    (leftTightClassEmbeddingNCPart_of_nonCrossing_injective hNC hinj)

/-- Genus-zero bound from the exact noncrossing-partition counting inputs. -/
theorem wickPlusGenusCount_zero_le_four_pow_of_NCPart_count
    {m : ℕ}
    (hNC : ∀ π : WickCycleLeftTightClass m,
      NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    (hinj : Function.Injective
      (fun π : WickCycleLeftTightClass m => leftTightCyclePartitionRange π))
    (hCard :
      (Fintype.card (NCPartition.NCPart (m + 1)) : ℝ) ≤
        (4 : ℝ) ^ (m + 1)) :
    (wickPlusGenusCount m 0 : ℝ) ≤ (4 : ℝ) ^ (m + 1) := by
  have hleftNat :=
    card_leftTightClass_le_NCPart_of_nonCrossing_injective hNC hinj
  have hleftReal :
      (Fintype.card (WickCycleLeftTightClass m) : ℝ) ≤
        Fintype.card (NCPartition.NCPart (m + 1)) := by
    exact_mod_cast hleftNat
  exact wickPlusGenusCount_zero_le_four_pow_of_leftTightCount
    (le_trans hleftReal hCard)

