/-!
# Appendix B: Aubrun moment estimate up to textbook combinatorics

This file proves the sharp Aubrun moment bound from the exact Wick reduction
and the relation-counting theorem that is usually treated as the finite
graduate-level combinatorial core of Aubrun's proof.

Nothing here assumes the final moment estimate.  The remaining input is the
relation-level sum bound: after grouping Wick permutations by the equivalence
relations they induce on left, right, and column indices, the weighted sum is
bounded by Aubrun's polynomial envelope.  This is the precise Lean boundary for
the textbook combinatorics (`many innovations`, `label compatibility`, and
Geman's type-4 count).
-/

open MeasureTheory ProbabilityTheory Matrix
open scoped BigOperators Matrix.Norms.Frobenius NNReal ENNReal

noncomputable section

namespace PptFactorization
namespace AppendixB

open RandomMatrixModel GaussianModel HighProbabilityBounds
open TraceWickExpansion
open TraceWickExpansion.AubrunSurvivingCounting

variable {p q σ : Type*}
variable [Fintype p] [Fintype q] [Fintype σ]
variable [DecidableEq p] [DecidableEq q] [DecidableEq σ]

omit [Fintype p] [Fintype q] [DecidableEq σ] in
/-- A single off-diagonal Gamma edge coefficient has the exact normalization
bound `|σ|⁻¹`. -/
theorem gammaEdgeCoeff_norm_le_card_inv (i j : BipIndex p q) :
    ‖gammaEdgeCoeff (p := p) (q := q) (σ := σ) i j‖ ≤
      ((Fintype.card σ : ℝ)⁻¹) := by
  classical
  by_cases h : i = j
  · simp [gammaEdgeCoeff, h]
  · simp [gammaEdgeCoeff, h]

omit [Fintype p] [Fintype q] [DecidableEq σ] in
/-- A path coefficient is bounded by one normalization factor per edge. -/
theorem pathGammaCoeff_norm_le_card_inv_pow
    {m : ℕ} (w : ClosedWalk (BipIndex p q) m)
    (α : Fin (m + 1) → σ) :
    ‖pathGammaCoeff (p := p) (q := q) (σ := σ) w.1 w.1 w.2 α‖ ≤
      ((Fintype.card σ : ℝ)⁻¹) ^ (m + 1) := by
  classical
  unfold pathGammaCoeff
  calc
    ‖∏ e : Fin (m + 1),
        gammaEdgeCoeff (p := p) (q := q) (σ := σ)
          (pathSource w.1 w.2 e) (pathTarget w.1 w.2 e)‖
        ≤ ∏ e : Fin (m + 1),
            ‖gammaEdgeCoeff (p := p) (q := q) (σ := σ)
              (pathSource w.1 w.2 e) (pathTarget w.1 w.2 e)‖ := by
          exact Finset.norm_prod_le _ _
    _ ≤ ∏ _e : Fin (m + 1), ((Fintype.card σ : ℝ)⁻¹) := by
          exact Finset.prod_le_prod (fun _ _ => norm_nonneg _) fun e _ =>
            gammaEdgeCoeff_norm_le_card_inv
              (p := p) (q := q) (σ := σ)
              (pathSource w.1 w.2 e) (pathTarget w.1 w.2 e)
    _ = ((Fintype.card σ : ℝ)⁻¹) ^ (m + 1) := by
          simp

/-- Triples `(closed walk, sample word, surviving Wick permutation)`. -/
abbrev SurvivingWickTriple (m : ℕ) :=
  Σ w : ClosedWalk (BipIndex p q) m,
    Σ α : Fin (m + 1) → σ,
      SurvivingClosedWalkPairing (p := p) (q := q) (σ := σ) w α

/-- The same data grouped by the Wick permutation first. -/
abbrev WickPermutationFiberTotal (m : ℕ) :=
  Σ π : Equiv.Perm (Fin (m + 1)),
    WickPermutationFiber p q σ π

/-- Reindexing equivalence between the two ways of organizing the surviving
Wick data. -/
noncomputable def survivingWickTripleEquivFiberTotal (m : ℕ) :
    SurvivingWickTriple (p := p) (q := q) (σ := σ) m ≃
      WickPermutationFiberTotal (p := p) (q := q) (σ := σ) m where
  toFun := fun t =>
    ⟨t.2.2.1, ⟨(t.1, t.2.1), t.2.2.2⟩⟩
  invFun := fun t =>
    ⟨t.2.1.1, ⟨t.2.1.2, ⟨t.1, t.2.2⟩⟩⟩
  left_inv := by
    intro t
    rcases t with ⟨w, α, π, hπ⟩
    rfl
  right_inv := by
    intro t
    rcases t with ⟨π, t, ht⟩
    rcases t with ⟨w, α⟩
    rfl

/-- The finite Wick sum of cardinalities may be grouped by Wick permutation
instead of by closed walk and sample word. -/
theorem survivingPairing_card_sum_eq_fiber_card_sum (m : ℕ) :
    (∑ w : ClosedWalk (BipIndex p q) m,
      ∑ α : Fin (m + 1) → σ,
        Fintype.card
          (SurvivingClosedWalkPairing
            (p := p) (q := q) (σ := σ) w α)) =
      ∑ π : Equiv.Perm (Fin (m + 1)),
        Fintype.card (WickPermutationFiber p q σ π) := by
  classical
  calc
    (∑ w : ClosedWalk (BipIndex p q) m,
      ∑ α : Fin (m + 1) → σ,
        Fintype.card
          (SurvivingClosedWalkPairing
            (p := p) (q := q) (σ := σ) w α))
        = Fintype.card
            (SurvivingWickTriple (p := p) (q := q) (σ := σ) m) := by
          simp [SurvivingWickTriple]
    _ = Fintype.card
            (WickPermutationFiberTotal (p := p) (q := q) (σ := σ) m) := by
          exact Fintype.card_congr
            (survivingWickTripleEquivFiberTotal
              (p := p) (q := q) (σ := σ) m)
    _ = ∑ π : Equiv.Perm (Fin (m + 1)),
        Fintype.card (WickPermutationFiber p q σ π) := by
          simp [WickPermutationFiberTotal]

/-- The exact Wick surviving-pairing norm sum is controlled by the total
cardinality of the permutation fibers, with the correct normalization
`|σ|⁻¹` per edge. -/
theorem aubrunSurvivingPairingSumNorm_le_card_inv_pow_mul_fiber_sum (m : ℕ) :
    aubrunSurvivingPairingSumNorm (p := p) (q := q) (σ := σ) m ≤
      ((Fintype.card σ : ℝ)⁻¹) ^ (m + 1) *
        ∑ π : Equiv.Perm (Fin (m + 1)),
          (Fintype.card (WickPermutationFiber p q σ π) : ℝ) := by
  classical
  have hcardNat :=
    survivingPairing_card_sum_eq_fiber_card_sum
      (p := p) (q := q) (σ := σ) m
  have hcardReal :
      (∑ w : ClosedWalk (BipIndex p q) m,
        ∑ α : Fin (m + 1) → σ,
          (Fintype.card
            (SurvivingClosedWalkPairing
              (p := p) (q := q) (σ := σ) w α) : ℝ)) =
        ∑ π : Equiv.Perm (Fin (m + 1)),
          (Fintype.card (WickPermutationFiber p q σ π) : ℝ) := by
    exact_mod_cast hcardNat
  unfold aubrunSurvivingPairingSumNorm
  calc
    (∑ w : ClosedWalk (BipIndex p q) m,
      ∑ α : Fin (m + 1) → σ,
        ‖pathGammaCoeff (p := p) (q := q) (σ := σ) w.1 w.1 w.2 α *
          (Fintype.card
            (SurvivingClosedWalkPairing
              (p := p) (q := q) (σ := σ) w α) : ℂ)‖)
        ≤ ∑ w : ClosedWalk (BipIndex p q) m,
            ∑ α : Fin (m + 1) → σ,
              ((Fintype.card σ : ℝ)⁻¹) ^ (m + 1) *
                (Fintype.card
                  (SurvivingClosedWalkPairing
                    (p := p) (q := q) (σ := σ) w α) : ℝ) := by
          refine Finset.sum_le_sum fun w _ =>
            Finset.sum_le_sum fun α _ => ?_
          have hcoeff :=
            pathGammaCoeff_norm_le_card_inv_pow
              (p := p) (q := q) (σ := σ) w α
          calc
            ‖pathGammaCoeff (p := p) (q := q) (σ := σ) w.1 w.1 w.2 α *
              (Fintype.card
                (SurvivingClosedWalkPairing
                  (p := p) (q := q) (σ := σ) w α) : ℂ)‖
                ≤ ‖pathGammaCoeff (p := p) (q := q) (σ := σ) w.1 w.1 w.2 α‖ *
                    ‖(Fintype.card
                      (SurvivingClosedWalkPairing
                        (p := p) (q := q) (σ := σ) w α) : ℂ)‖ := by
                  exact norm_mul_le _ _
            _ =
                ‖pathGammaCoeff (p := p) (q := q) (σ := σ) w.1 w.1 w.2 α‖ *
                  (Fintype.card
                    (SurvivingClosedWalkPairing
                      (p := p) (q := q) (σ := σ) w α) : ℝ) := by
                  simp
            _ ≤
                ((Fintype.card σ : ℝ)⁻¹) ^ (m + 1) *
                  (Fintype.card
                    (SurvivingClosedWalkPairing
                      (p := p) (q := q) (σ := σ) w α) : ℝ) := by
                  exact mul_le_mul_of_nonneg_right hcoeff (by positivity)
    _ =
        ((Fintype.card σ : ℝ)⁻¹) ^ (m + 1) *
          (∑ w : ClosedWalk (BipIndex p q) m,
            ∑ α : Fin (m + 1) → σ,
              (Fintype.card
                (SurvivingClosedWalkPairing
                  (p := p) (q := q) (σ := σ) w α) : ℝ)) := by
          simp [Finset.mul_sum]
    _ =
        ((Fintype.card σ : ℝ)⁻¹) ^ (m + 1) *
          ∑ π : Equiv.Perm (Fin (m + 1)),
            (Fintype.card (WickPermutationFiber p q σ π) : ℝ) := by
          rw [hcardReal]

/-- Summing the fiber bound gives the relation-counting weighted sum. -/
theorem fiber_card_sum_le_relation_power_sum (m : ℕ) :
    (∑ π : Equiv.Perm (Fin (m + 1)),
      (Fintype.card (WickPermutationFiber p q σ π) : ℝ)) ≤
      ∑ π : Equiv.Perm (Fin (m + 1)),
        (Fintype.card p : ℝ) ^ wickLeftClassCount π *
          (Fintype.card q : ℝ) ^ wickRightClassCount π *
            Real.sqrt (Fintype.card σ : ℝ) ^
              (2 * wickColumnClassCount π) := by
  classical
  exact Finset.sum_le_sum fun π _ =>
    real_card_wickPermutationFiber_le_d_d_sqrt_powers
      (p := p) (q := q) (σ := σ) π

/-- The precise remaining graduate-textbook combinatorial input: the weighted
sum over Wick-permutation relation classes is bounded by Aubrun's polynomial
envelope. -/
abbrev AubrunGraduateRelationCounting
    (Q : ℕ → ℝ) (d s : ℝ) (m : ℕ) : Prop :=
  ∑ π : Equiv.Perm (Fin (m + 1)),
      d ^ wickLeftClassCount π *
        d ^ wickRightClassCount π *
          Real.sqrt s ^ (2 * wickColumnClassCount π) ≤
    (2 : ℝ) ^ (m + 1) *
      (d + Q (m + 1)) ^ (m + 3) *
        (Real.sqrt s + Q (m + 1)) ^ (m + 1)

/-! ## Paper-level Aubrun relation objects -/

/-- The three concrete words denoted by `\tilde a`, `\tilde b`, and
`\tilde c` in Aubrun's combinatorial proof.  The index type is the same
cyclic edge-position type used by the Wick setoids. -/
structure AubrunTildeWords (A B C : Type*) (m : ℕ) where
  tildeA : Fin (m + 1) → A
  tildeB : Fin (m + 1) → B
  tildeC : Fin (m + 1) → C

/-- The paper's list (3), packaged as the ordered triples
`(\tilde a_i, \tilde b_i, \tilde c_i)`. -/
def aubrunList3 {A B C : Type*} {m : ℕ}
    (T : AubrunTildeWords A B C m) :
    Fin (m + 1) → A × B × C :=
  fun i => (T.tildeA i, T.tildeB i, T.tildeC i)

/-- The paper's list (7), written as paired holomorphic/anti-holomorphic
edge data after applying the Wick permutation.  Its first component is the
edge data at `i`; its second component is the conjugate edge data selected by
`π i`. -/
def aubrunList7 {A B C : Type*} {m : ℕ}
    (T : AubrunTildeWords A B C m)
    (π : Equiv.Perm (Fin (m + 1))) :
    Fin (m + 1) → (A × B × C) × (A × B × C) :=
  fun i =>
    ((T.tildeA i, T.tildeB (cyclicSucc i), T.tildeC i),
      (T.tildeA (cyclicSucc (π i)), T.tildeB (π i), T.tildeC (π i)))

/-- Aubrun's four local edge types.  The detailed paper predicates are kept
separate from the finite tag; downstream arguments can classify an edge by
providing a function into this type. -/
inductive AubrunEdgeType where
  | type1
  | type2
  | type3
  | type4
deriving DecidableEq, Fintype

/-- Wishart matching condition for the paired list (7):
`a_i = a_{π(i)+1}`, `b_{i+1} = b_{π(i)}`, and `c_i = c_{π(i)}`. -/
def aubrunWishartMatching {A B C : Type*} {m : ℕ}
    (T : AubrunTildeWords A B C m)
    (π : Equiv.Perm (Fin (m + 1))) : Prop :=
  ∀ i : Fin (m + 1),
    T.tildeA i = T.tildeA (cyclicSucc (π i)) ∧
      T.tildeB (cyclicSucc i) = T.tildeB (π i) ∧
        T.tildeC i = T.tildeC (π i)

/-- Triple matching condition for the list (3), after applying a Wick
permutation. -/
def aubrunTripleMatching {A B C : Type*} {m : ℕ}
    (T : AubrunTildeWords A B C m)
    (π : Equiv.Perm (Fin (m + 1))) : Prop :=
  ∀ i : Fin (m + 1), aubrunList3 T i = aubrunList3 T (π i)

/-- Non-repetitiveness of the pair word `(\tilde a, \tilde b)`. -/
def aubrunPairNonrepetitive {A B C : Type*} {m : ℕ}
    (T : AubrunTildeWords A B C m) : Prop :=
  ∀ i j : Fin (m + 1),
    i ≠ j → (T.tildeA i, T.tildeB i) ≠ (T.tildeA j, T.tildeB j)

/-- Innovation positions: the first appearances of triples in list (3). -/
def aubrunInnovations {A B C : Type*} [DecidableEq A] [DecidableEq B]
    [DecidableEq C] {m : ℕ}
    (T : AubrunTildeWords A B C m) : Finset (Fin (m + 1)) :=
  Finset.univ.filter fun i =>
    ∀ j : Fin (m + 1), (j : ℕ) < i → aubrunList3 T j ≠ aubrunList3 T i

/-- Compatibility of the `A` and `C` words with the Wick-generated left and
column relations. -/
def aubrunCompatibleAC {A B C : Type*} {m : ℕ}
    (T : AubrunTildeWords A B C m)
    (π : Equiv.Perm (Fin (m + 1))) : Prop :=
  ∀ i : Fin (m + 1),
    T.tildeA i = T.tildeA (cyclicSucc (π i)) ∧
      T.tildeC i = T.tildeC (π i)

/-- The equivalence classes of the `A` word are the quotient classes of the
left Wick setoid. -/
abbrev aubrunAClasses {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) :=
  Quotient (wickLeftSetoid π)

/-- The equivalence classes of the `B` word are the quotient classes of the
right Wick setoid. -/
abbrev aubrunBClasses {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) :=
  Quotient (wickRightSetoid π)

/-- The equivalence classes of the `C` word are the quotient classes of the
column Wick setoid. -/
abbrev aubrunCClasses {m : ℕ} (π : Equiv.Perm (Fin (m + 1))) :=
  Quotient (wickColumnSetoid π)

/-- The concrete Aubrun words attached to an element of a surviving Wick
permutation fiber. -/
def aubrunTildeWordsOfFiber {m : ℕ}
    {π : Equiv.Perm (Fin (m + 1))}
    (t : WickPermutationFiber p q σ π) :
    AubrunTildeWords p q σ m where
  tildeA := leftVertexLabel (p := p) (q := q) t.1.1
  tildeB := rightVertexLabel (p := p) (q := q) t.1.1
  tildeC := t.1.2

omit [Fintype p] [Fintype q] [Fintype σ] [DecidableEq p] [DecidableEq q]
  [DecidableEq σ] in
/-- Surviving Wick fibers satisfy the paper's Wishart matching condition. -/
theorem aubrunTildeWordsOfFiber_wishartMatching {m : ℕ}
    {π : Equiv.Perm (Fin (m + 1))}
    (t : WickPermutationFiber p q σ π) :
    aubrunWishartMatching (aubrunTildeWordsOfFiber (p := p) (q := q) (σ := σ) t) π := by
  intro i
  constructor
  · have hmatch := congrArg (fun z : SampleCoord p q σ => z.1.1) (t.2 i)
    calc
      leftVertexLabel (p := p) (q := q) t.1.1 i =
          (pathTarget t.1.1.1 t.1.1.2 (π i)).1 := by
            simpa [aubrunTildeWordsOfFiber, leftVertexLabel, gammaEdgeHol,
              gammaEdgeConj] using hmatch
      _ = leftVertexLabel (p := p) (q := q) t.1.1 (cyclicSucc (π i)) := by
            rw [pathTarget_closed_eq_pathSource_cyclicSucc]
            rfl
  constructor
  · have hmatch := congrArg (fun z : SampleCoord p q σ => z.1.2) (t.2 i)
    calc
      rightVertexLabel (p := p) (q := q) t.1.1 (cyclicSucc i) =
          (pathTarget t.1.1.1 t.1.1.2 i).2 := by
            rw [pathTarget_closed_eq_pathSource_cyclicSucc]
            rfl
      _ = rightVertexLabel (p := p) (q := q) t.1.1 (π i) := by
            simpa [aubrunTildeWordsOfFiber, rightVertexLabel, gammaEdgeHol,
              gammaEdgeConj] using hmatch
  · have hmatch := congrArg Prod.snd (t.2 i)
    simpa [aubrunTildeWordsOfFiber, gammaEdgeHol, gammaEdgeConj] using hmatch

/-- The `A,C` compatibility condition is the corresponding projection of the
Wishart matching condition. -/
theorem aubrunCompatibleAC_of_wishartMatching {A B C : Type*} {m : ℕ}
    {T : AubrunTildeWords A B C m}
    {π : Equiv.Perm (Fin (m + 1))}
    (h : aubrunWishartMatching T π) :
    aubrunCompatibleAC T π := by
  intro i
  exact ⟨(h i).1, (h i).2.2⟩

omit [Fintype p] [Fintype q] [Fintype σ] [DecidableEq p] [DecidableEq q]
  [DecidableEq σ] in
/-- The concrete `A,C` words of a surviving Wick fiber are compatible with
the Wick-generated left and column equivalence relations. -/
theorem aubrunTildeWordsOfFiber_compatibleAC {m : ℕ}
    {π : Equiv.Perm (Fin (m + 1))}
    (t : WickPermutationFiber p q σ π) :
    aubrunCompatibleAC (aubrunTildeWordsOfFiber (p := p) (q := q) (σ := σ) t) π :=
  aubrunCompatibleAC_of_wishartMatching
    (aubrunTildeWordsOfFiber_wishartMatching (p := p) (q := q) (σ := σ) t)

/-- Lemma 3.6, in its reusable counting form: once the undetermined data are
encoded by `U` triples of positions in a word of length `k`, the family has
cardinality at most `k^(3U)`. -/
theorem aubrunLemma36_card_le_k_pow_three_mul
    {Family : Type*} [Fintype Family] {k U : ℕ}
    (encode : Family ↪ (Fin U → Fin k × Fin k × Fin k)) :
    Fintype.card Family ≤ k ^ (3 * U) := by
  calc
    Fintype.card Family ≤
        Fintype.card (Fin U → Fin k × Fin k × Fin k) :=
          Fintype.card_le_of_embedding encode
    _ = k ^ (3 * U) := by
          have hcard :
              Fintype.card (Fin U → Fin k × Fin k × Fin k) =
                (k * (k * k)) ^ U := by
            simp
          rw [hcard]
          have hbase : k * (k * k) = k ^ 3 := by
            ring
          rw [hbase, pow_mul]

/-- Lemma 7.4 in the formal spine: this is exactly the fixed-defect counting
closure already proved in `AppendixBAubrunCombinatorics`. -/
theorem aubrunLemma74_fixedDefectClassCount_le
    {k Δ : ℕ} (hk : 1 ≤ k)
    {Fiber LeftCouples RightCouples : Finset (Fin k) → Type*}
    [∀ I, Fintype (Fiber I)]
    [∀ I, Fintype (LeftCouples I)]
    [∀ I, Fintype (RightCouples I)]
    (encode :
      ∀ I : Finset (Fin k),
        Fiber I ↪ LeftCouples I × RightCouples I)
    (hLeft :
      ∀ I : Finset (Fin k),
        Fintype.card (LeftCouples I) ≤
          (2 * k) ^ (9 * compatibilityDefect k I))
    (hRight :
      ∀ I : Finset (Fin k),
        Fintype.card (RightCouples I) ≤
          (2 * k) ^ (9 * compatibilityDefect k I))
    (hLarge :
      ∀ I : Finset (Fin k),
        Fintype.card (Fiber I) ≠ 0 → k ≤ 2 * I.card + 2 * Δ) :
    Fintype.card (Σ I : Finset (Fin k), Fiber I) ≤
      2 ^ k * (2 * k) ^ (36 * Δ) :=
  fixedDefectClassCount_le hk encode hLeft hRight hLarge

/-- Concrete profile count for the relation data carried by a Wick permutation:
`ℓ₁ = #left + #right` and `ℓ₂ = #columns`. -/
noncomputable def wickRelationProfileCount
    (m l1 l2 : ℕ) : ℕ :=
  (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
      l1 = wickLeftClassCount π + wickRightClassCount π ∧
        l2 = wickColumnClassCount π).card

/-- Each left relation-class count is bounded by the number of positions. -/
theorem wickLeftClassCount_le (m : ℕ)
    (π : Equiv.Perm (Fin (m + 1))) :
    wickLeftClassCount π ≤ m + 1 := by
  classical
  simpa [wickLeftClassCount] using
    (Fintype.card_quotient_le (wickLeftSetoid π))

/-- Each right relation-class count is bounded by the number of positions. -/
theorem wickRightClassCount_le (m : ℕ)
    (π : Equiv.Perm (Fin (m + 1))) :
    wickRightClassCount π ≤ m + 1 := by
  classical
  simpa [wickRightClassCount] using
    (Fintype.card_quotient_le (wickRightSetoid π))

/-- Each column relation-class count is bounded by the number of positions. -/
theorem wickColumnClassCount_le (m : ℕ)
    (π : Equiv.Perm (Fin (m + 1))) :
    wickColumnClassCount π ≤ m + 1 := by
  classical
  simpa [wickColumnClassCount] using
    (Fintype.card_quotient_le (wickColumnSetoid π))

/-- A nonempty profile bin is exactly a Wick permutation with the advertised
left/right and column class counts. -/
theorem wickRelationProfileCount_pos_iff (m l1 l2 : ℕ) :
    0 < wickRelationProfileCount (m := m) l1 l2 ↔
      ∃ π : Equiv.Perm (Fin (m + 1)),
        l1 = wickLeftClassCount π + wickRightClassCount π ∧
          l2 = wickColumnClassCount π := by
  classical
  rw [wickRelationProfileCount, Finset.card_pos]
  constructor
  · intro h
    rcases h with ⟨π, hπ⟩
    exact ⟨π, (Finset.mem_filter.mp hπ).2⟩
  · intro h
    rcases h with ⟨π, hπ⟩
    exact ⟨π, Finset.mem_filter.mpr ⟨Finset.mem_univ π, hπ⟩⟩

/-- Nonzero profile bins lie inside the left/right range used by the profile
sum. -/
theorem wickRelationProfileCount_left_le_of_pos {m l1 l2 : ℕ}
    (h : 0 < wickRelationProfileCount (m := m) l1 l2) :
    l1 ≤ 2 * (m + 1) := by
  classical
  rcases (wickRelationProfileCount_pos_iff m l1 l2).mp h with ⟨π, hπ⟩
  rw [hπ.1]
  have hL := wickLeftClassCount_le m π
  have hR := wickRightClassCount_le m π
  omega

/-- Nonzero profile bins lie inside the column range used by the profile sum. -/
theorem wickRelationProfileCount_column_le_of_pos {m l1 l2 : ℕ}
    (h : 0 < wickRelationProfileCount (m := m) l1 l2) :
    l2 ≤ m + 1 := by
  classical
  rcases (wickRelationProfileCount_pos_iff m l1 l2).mp h with ⟨π, hπ⟩
  rw [hπ.2]
  exact wickColumnClassCount_le m π

/-- A profile bin outside the left/right range has zero count. -/
theorem wickRelationProfileCount_eq_zero_of_left_gt {m l1 l2 : ℕ}
    (h : 2 * (m + 1) < l1) :
    wickRelationProfileCount (m := m) l1 l2 = 0 := by
  classical
  exact Nat.eq_zero_of_not_pos (by
    intro hpos
    have hle :=
      wickRelationProfileCount_left_le_of_pos
        (m := m) (l1 := l1) (l2 := l2) hpos
    omega)

/-- A profile bin outside the column range has zero count. -/
theorem wickRelationProfileCount_eq_zero_of_column_gt {m l1 l2 : ℕ}
    (h : m + 1 < l2) :
    wickRelationProfileCount (m := m) l1 l2 = 0 := by
  classical
  exact Nat.eq_zero_of_not_pos (by
    intro hpos
    have hle :=
      wickRelationProfileCount_column_le_of_pos
        (m := m) (l1 := l1) (l2 := l2) hpos
    omega)

/-- Every profile bin is bounded by the total number of Wick permutations. -/
theorem wickRelationProfileCount_le_perm_card (m l1 l2 : ℕ) :
    wickRelationProfileCount (m := m) l1 l2 ≤
      Fintype.card (Equiv.Perm (Fin (m + 1))) := by
  classical
  rw [wickRelationProfileCount]
  exact Finset.card_filter_le _ _

/-- Factorial form of the crude profile-bin bound. -/
theorem wickRelationProfileCount_le_factorial (m l1 l2 : ℕ) :
    wickRelationProfileCount (m := m) l1 l2 ≤ (m + 1).factorial := by
  classical
  calc
    wickRelationProfileCount (m := m) l1 l2 ≤
        Fintype.card (Equiv.Perm (Fin (m + 1))) :=
          wickRelationProfileCount_le_perm_card m l1 l2
    _ = (m + 1).factorial := by
          simp [Fintype.card_perm]

/-- Weighted rank of a concrete profile bin. -/
def wickRelationProfileWeightedRank (l1 l2 : ℕ) : ℕ :=
  l1 + 2 * l2

/-- Profile-level defect matching Aubrun's Wick-permutation defect. -/
def wickRelationProfileDefect (m l1 l2 : ℕ) : ℕ :=
  2 * (m + 1) + 2 - wickRelationProfileWeightedRank l1 l2

/-- A nonzero profile bin contains a Wick permutation whose weighted rank and
defect are exactly the corresponding profile-level quantities. -/
theorem wickRelationProfileCount_pos_witness_defect {m l1 l2 : ℕ}
    (h : 0 < wickRelationProfileCount (m := m) l1 l2) :
    ∃ π : Equiv.Perm (Fin (m + 1)),
      l1 = wickLeftClassCount π + wickRightClassCount π ∧
      l2 = wickColumnClassCount π ∧
      wickWeightedRank π = wickRelationProfileWeightedRank l1 l2 ∧
      wickDefect π = wickRelationProfileDefect m l1 l2 := by
  classical
  rcases (wickRelationProfileCount_pos_iff m l1 l2).mp h with ⟨π, h1, h2⟩
  refine ⟨π, h1, h2, ?_, ?_⟩
  · simp [wickRelationProfileWeightedRank, wickWeightedRank, h1, h2]
  · simp [wickRelationProfileDefect, wickRelationProfileWeightedRank,
      wickDefect, wickWeightedRank, h1, h2]

/-- General finite regrouping identity for profile counts.

Any natural-valued weight depending only on the concrete profile
\((\ell_1,\ell_2)\) can be summed either over the profile bins or directly over
Wick permutations.  This is the profile-count version of the regrouping used
for the analytic weighted sum. -/
theorem wickRelationProfileCount_weighted_sum_eq_perm_sum_nat
    (m : ℕ) (F : ℕ → ℕ → ℕ) :
    (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
      Finset.sum (Finset.range (m + 2)) (fun l2 =>
        wickRelationProfileCount (m := m) l1 l2 * F l1 l2))) =
      Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
        F (wickLeftClassCount π + wickRightClassCount π)
          (wickColumnClassCount π)) := by
  classical
  let profile₁ : Equiv.Perm (Fin (m + 1)) → ℕ :=
    fun π => wickLeftClassCount π + wickRightClassCount π
  let profile₂ : Equiv.Perm (Fin (m + 1)) → ℕ :=
    fun π => wickColumnClassCount π
  calc
    (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
      Finset.sum (Finset.range (m + 2)) (fun l2 =>
        wickRelationProfileCount (m := m) l1 l2 * F l1 l2))) =
        Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
            Finset.sum
              (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
                l1 = profile₁ π ∧ l2 = profile₂ π)
              (fun _π => F l1 l2))) := by
      refine Finset.sum_congr rfl ?_
      intro l1 hl1
      refine Finset.sum_congr rfl ?_
      intro l2 hl2
      simp [wickRelationProfileCount, profile₁, profile₂, Finset.sum_const,
        Nat.mul_comm]
    _ = Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
          Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0))) := by
      congr 1
      funext l1
      calc
        Finset.sum (Finset.range (m + 2)) (fun l2 =>
            Finset.sum
              (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
                l1 = profile₁ π ∧ l2 = profile₂ π)
              (fun _π => F l1 l2)) =
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
            Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0)) := by
            refine Finset.sum_congr rfl ?_
            intro l2 hl2
            rw [Finset.sum_filter]
        _ = Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0)) := by
            rw [Finset.sum_comm]
    _ = Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
          Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0))) := by
      rw [Finset.sum_comm]
    _ = Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
        F (wickLeftClassCount π + wickRightClassCount π)
          (wickColumnClassCount π)) := by
      refine Finset.sum_congr rfl ?_
      intro π hπ
      have hprof₁ : profile₁ π ≤ 2 * (m + 1) := by
        dsimp [profile₁]
        have hL := wickLeftClassCount_le m π
        have hR := wickRightClassCount_le m π
        omega
      have hprof₂ : profile₂ π ≤ m + 1 := by
        dsimp [profile₂]
        exact wickColumnClassCount_le m π
      have hprof₁_mem : profile₁ π ∈ Finset.range (2 * (m + 1) + 1) :=
        Finset.mem_range.mpr (Nat.lt_succ_of_le hprof₁)
      have hprof₂_mem : profile₂ π ∈ Finset.range (m + 2) :=
        Finset.mem_range.mpr (Nat.lt_succ_of_le hprof₂)
      have hOuter :
          Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0)) =
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                F (profile₁ π) l2
              else 0) := by
        exact Finset.sum_eq_single_of_mem
          (s := Finset.range (2 * (m + 1) + 1))
          (a := profile₁ π)
          (f := fun l1 =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0))
          hprof₁_mem
          (by intro l1 hl1 hne; simp [hne, profile₁, profile₂])
      have hInner :
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                F (profile₁ π) l2
              else 0) =
            F (profile₁ π) (profile₂ π) := by
        calc
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                F (profile₁ π) l2
              else 0) =
            if profile₁ π = profile₁ π ∧ profile₂ π = profile₂ π then
              F (profile₁ π) (profile₂ π)
            else 0 := by
              exact Finset.sum_eq_single_of_mem
                (s := Finset.range (m + 2))
                (a := profile₂ π)
                (f := fun l2 =>
                  if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                    F (profile₁ π) l2
                  else 0)
                hprof₂_mem
                (by intro l2 hl2 hne; simp [hne, profile₁, profile₂])
          _ = F (profile₁ π) (profile₂ π) := by simp
      calc
        Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0)) =
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                F (profile₁ π) l2
              else 0) := hOuter
        _ = F (profile₁ π) (profile₂ π) := hInner
        _ =
          F (wickLeftClassCount π + wickRightClassCount π)
            (wickColumnClassCount π) := by rfl

/-- Real-valued version of `wickRelationProfileCount_weighted_sum_eq_perm_sum_nat`.

This is the form used by the Aubrun weighted profile sum. -/
theorem wickRelationProfileCount_weighted_sum_eq_perm_sum_real
    (m : ℕ) (F : ℕ → ℕ → ℝ) :
    (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
      Finset.sum (Finset.range (m + 2)) (fun l2 =>
        (wickRelationProfileCount (m := m) l1 l2 : ℝ) * F l1 l2))) =
      Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
        F (wickLeftClassCount π + wickRightClassCount π)
          (wickColumnClassCount π)) := by
  classical
  let profile₁ : Equiv.Perm (Fin (m + 1)) → ℕ :=
    fun π => wickLeftClassCount π + wickRightClassCount π
  let profile₂ : Equiv.Perm (Fin (m + 1)) → ℕ :=
    fun π => wickColumnClassCount π
  calc
    (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
      Finset.sum (Finset.range (m + 2)) (fun l2 =>
        (wickRelationProfileCount (m := m) l1 l2 : ℝ) * F l1 l2))) =
        Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
            Finset.sum
              (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
                l1 = profile₁ π ∧ l2 = profile₂ π)
              (fun _π => F l1 l2))) := by
      refine Finset.sum_congr rfl ?_
      intro l1 hl1
      refine Finset.sum_congr rfl ?_
      intro l2 hl2
      simp [wickRelationProfileCount, profile₁, profile₂, Finset.sum_const,
        nsmul_eq_mul]
    _ = Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
          Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0))) := by
      congr 1
      funext l1
      calc
        Finset.sum (Finset.range (m + 2)) (fun l2 =>
            Finset.sum
              (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
                l1 = profile₁ π ∧ l2 = profile₂ π)
              (fun _π => F l1 l2)) =
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
            Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0)) := by
            refine Finset.sum_congr rfl ?_
            intro l2 hl2
            rw [Finset.sum_filter]
        _ = Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0)) := by
            rw [Finset.sum_comm]
    _ = Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
          Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0))) := by
      rw [Finset.sum_comm]
    _ = Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
        F (wickLeftClassCount π + wickRightClassCount π)
          (wickColumnClassCount π)) := by
      refine Finset.sum_congr rfl ?_
      intro π hπ
      have hprof₁ : profile₁ π ≤ 2 * (m + 1) := by
        dsimp [profile₁]
        have hL := wickLeftClassCount_le m π
        have hR := wickRightClassCount_le m π
        omega
      have hprof₂ : profile₂ π ≤ m + 1 := by
        dsimp [profile₂]
        exact wickColumnClassCount_le m π
      have hprof₁_mem : profile₁ π ∈ Finset.range (2 * (m + 1) + 1) :=
        Finset.mem_range.mpr (Nat.lt_succ_of_le hprof₁)
      have hprof₂_mem : profile₂ π ∈ Finset.range (m + 2) :=
        Finset.mem_range.mpr (Nat.lt_succ_of_le hprof₂)
      have hOuter :
          Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0)) =
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                F (profile₁ π) l2
              else 0) := by
        exact Finset.sum_eq_single_of_mem
          (s := Finset.range (2 * (m + 1) + 1))
          (a := profile₁ π)
          (f := fun l1 =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0))
          hprof₁_mem
          (by intro l1 hl1 hne; simp [hne, profile₁, profile₂])
      have hInner :
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                F (profile₁ π) l2
              else 0) =
            F (profile₁ π) (profile₂ π) := by
        calc
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                F (profile₁ π) l2
              else 0) =
            if profile₁ π = profile₁ π ∧ profile₂ π = profile₂ π then
              F (profile₁ π) (profile₂ π)
            else 0 := by
              exact Finset.sum_eq_single_of_mem
                (s := Finset.range (m + 2))
                (a := profile₂ π)
                (f := fun l2 =>
                  if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                    F (profile₁ π) l2
                  else 0)
                hprof₂_mem
                (by intro l2 hl2 hne; simp [hne, profile₁, profile₂])
          _ = F (profile₁ π) (profile₂ π) := by simp
      calc
        Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then F l1 l2 else 0)) =
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                F (profile₁ π) l2
              else 0) := hOuter
        _ = F (profile₁ π) (profile₂ π) := hInner
        _ =
          F (wickLeftClassCount π + wickRightClassCount π)
            (wickColumnClassCount π) := by rfl

/-- Real-valued profile weights can also be regrouped by Aubrun's defect.

The defect range is finite because `wickDefect π` is a natural subtraction
from `2 * (m + 1) + 2`.  This is the bookkeeping bridge from profile bins to
the fixed-defect counting theorem. -/
theorem wickRelationProfileCount_weighted_sum_eq_defect_sum_real
    (m : ℕ) (F : ℕ → ℕ → ℝ) :
    (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
      Finset.sum (Finset.range (m + 2)) (fun l2 =>
        (wickRelationProfileCount (m := m) l1 l2 : ℝ) * F l1 l2))) =
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          wickDefect π = Δ) (fun π =>
            F (wickLeftClassCount π + wickRightClassCount π)
              (wickColumnClassCount π))) := by
  classical
  have hProfile :=
    wickRelationProfileCount_weighted_sum_eq_perm_sum_real (m := m) (F := F)
  have hmem : ∀ π ∈ (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))),
      wickDefect π ∈ Finset.range (2 * (m + 1) + 3) := by
    intro π hπ
    exact Finset.mem_range.mpr (Nat.lt_succ_of_le (Nat.sub_le _ _))
  have hFiber :=
    Finset.sum_fiberwise_of_maps_to
      (s := (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))))
      (t := Finset.range (2 * (m + 1) + 3))
      (g := fun π : Equiv.Perm (Fin (m + 1)) => wickDefect π)
      hmem
      (f := fun π : Equiv.Perm (Fin (m + 1)) =>
        F (wickLeftClassCount π + wickRightClassCount π)
          (wickColumnClassCount π))
  calc
    (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
      Finset.sum (Finset.range (m + 2)) (fun l2 =>
        (wickRelationProfileCount (m := m) l1 l2 : ℝ) * F l1 l2))) =
        Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
          F (wickLeftClassCount π + wickRightClassCount π)
            (wickColumnClassCount π)) := hProfile
    _ = Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          wickDefect π = Δ) (fun π =>
            F (wickLeftClassCount π + wickRightClassCount π)
              (wickColumnClassCount π))) := by
          simpa [Finset.sum_filter] using hFiber.symm

/-- Profile-level count of bins of a fixed Aubrun defect. -/
noncomputable def wickRelationProfileDefectCount (m Δ : ℕ) : ℕ :=
  Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
    Finset.sum (Finset.range (m + 2)) (fun l2 =>
      if wickRelationProfileDefect m l1 l2 = Δ then
        wickRelationProfileCount (m := m) l1 l2
      else 0))

/-- Permutation-level count of Wick permutations with a fixed Aubrun defect. -/
noncomputable def wickPermutationDefectCount (m Δ : ℕ) : ℕ :=
  (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
    wickDefect π = Δ).card

/-- Wick permutations with a fixed Aubrun defect, as a finite subtype. -/
noncomputable def WickPermutationDefectClass (m Δ : ℕ) :=
  {π : Equiv.Perm (Fin (m + 1)) // wickDefect π = Δ}

noncomputable instance (m Δ : ℕ) :
    Fintype (WickPermutationDefectClass m Δ) := by
  unfold WickPermutationDefectClass
  infer_instance

/-- The fixed-defect permutation count is the cardinality of the corresponding
finite subtype. -/
theorem wickPermutationDefectCount_eq_card_defectClass (m Δ : ℕ) :
    wickPermutationDefectCount m Δ =
      Fintype.card (WickPermutationDefectClass m Δ) := by
  classical
  rw [wickPermutationDefectCount]
  unfold WickPermutationDefectClass
  rw [Fintype.card_subtype]

/-- If the fixed-defect Wick permutations inject into Aubrun's innovation
fibers, the abstract Lemma 7.4 count bounds the concrete fixed-defect count. -/
theorem wickPermutationDefectCount_le_of_embedding_to_sigma
    {m Δ : ℕ}
    {Fiber LeftCouples RightCouples : Finset (Fin (m + 1)) → Type*}
    [∀ I, Fintype (Fiber I)]
    [∀ I, Fintype (LeftCouples I)]
    [∀ I, Fintype (RightCouples I)]
    (defectEncode :
      WickPermutationDefectClass m Δ ↪ Sigma Fiber)
    (encode :
      ∀ I : Finset (Fin (m + 1)),
        Fiber I ↪ LeftCouples I × RightCouples I)
    (hLeft :
      ∀ I : Finset (Fin (m + 1)),
        Fintype.card (LeftCouples I) ≤
          (2 * (m + 1)) ^ (9 * compatibilityDefect (m + 1) I))
    (hRight :
      ∀ I : Finset (Fin (m + 1)),
        Fintype.card (RightCouples I) ≤
          (2 * (m + 1)) ^ (9 * compatibilityDefect (m + 1) I))
    (hLarge :
      ∀ I : Finset (Fin (m + 1)),
        Fintype.card (Fiber I) ≠ 0 → (m + 1) ≤ 2 * I.card + 2 * Δ) :
    wickPermutationDefectCount m Δ ≤
      2 ^ (m + 1) * (2 * (m + 1)) ^ (36 * Δ) := by
  have hcard :
      wickPermutationDefectCount m Δ ≤ Fintype.card (Sigma Fiber) := by
    rw [wickPermutationDefectCount_eq_card_defectClass]
    exact Fintype.card_le_of_embedding defectEncode
  have habstract :
      Fintype.card (Sigma Fiber) ≤
        2 ^ (m + 1) * (2 * (m + 1)) ^ (36 * Δ) :=
    aubrunLemma74_fixedDefectClassCount_le
      (k := m + 1) (Δ := Δ)
      (hk := Nat.succ_le_succ (Nat.zero_le m))
      (Fiber := Fiber) (LeftCouples := LeftCouples)
      (RightCouples := RightCouples)
      encode hLeft hRight hLarge
  exact hcard.trans habstract

/-- The profile-defect count agrees with the direct Wick-permutation defect
count. -/
theorem wickRelationProfileDefectCount_eq_wickPermutationDefectCount
    (m Δ : ℕ) :
    wickRelationProfileDefectCount m Δ = wickPermutationDefectCount m Δ := by
  classical
  unfold wickRelationProfileDefectCount wickPermutationDefectCount
  have h :=
    wickRelationProfileCount_weighted_sum_eq_perm_sum_nat
      m (fun l1 l2 => if wickRelationProfileDefect m l1 l2 = Δ then 1 else 0)
  have hleft :
      (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
        Finset.sum (Finset.range (m + 2)) (fun l2 =>
          (if wickRelationProfileDefect m l1 l2 = Δ then
            wickRelationProfileCount (m := m) l1 l2
          else 0)))) =
      (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
        Finset.sum (Finset.range (m + 2)) (fun l2 =>
          wickRelationProfileCount (m := m) l1 l2 *
            (if wickRelationProfileDefect m l1 l2 = Δ then 1 else 0)))) := by
    refine Finset.sum_congr rfl ?_
    intro l1 hl1
    refine Finset.sum_congr rfl ?_
    intro l2 hl2
    by_cases hΔ : wickRelationProfileDefect m l1 l2 = Δ
    · simp [hΔ]
    · simp [hΔ]
  have hright :
      Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
        (if wickRelationProfileDefect m
            (wickLeftClassCount π + wickRightClassCount π)
            (wickColumnClassCount π) = Δ then 1 else 0)) =
      Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
        (if wickDefect π = Δ then 1 else 0)) := by
    refine Finset.sum_congr rfl ?_
    intro π hπ
    have hdef :
        wickRelationProfileDefect m
            (wickLeftClassCount π + wickRightClassCount π)
            (wickColumnClassCount π) = wickDefect π := by
      simp [wickRelationProfileDefect, wickRelationProfileWeightedRank,
        wickDefect, wickWeightedRank]
    rw [hdef]
  calc
    Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
        Finset.sum (Finset.range (m + 2)) (fun l2 =>
          (if wickRelationProfileDefect m l1 l2 = Δ then
            wickRelationProfileCount (m := m) l1 l2
          else 0))) =
      Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
        Finset.sum (Finset.range (m + 2)) (fun l2 =>
          wickRelationProfileCount (m := m) l1 l2 *
            (if wickRelationProfileDefect m l1 l2 = Δ then 1 else 0))) := hleft
    _ = Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
        (if wickRelationProfileDefect m
            (wickLeftClassCount π + wickRightClassCount π)
            (wickColumnClassCount π) = Δ then 1 else 0)) := h
    _ = Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
        (if wickDefect π = Δ then 1 else 0)) := hright
    _ =
        (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          wickDefect π = Δ).card := by
          rw [Finset.card_filter]

/-- The weighted Wick relation sum can be regrouped exactly by the concrete
profile counts `(ℓ₁, ℓ₂) = (#left + #right, #columns)`. -/
theorem graduateRelationSum_eq_profileCountSum
    (d s : ℝ) (m : ℕ) :
    (∑ π : Equiv.Perm (Fin (m + 1)),
      d ^ wickLeftClassCount π *
        d ^ wickRightClassCount π *
          Real.sqrt s ^ (2 * wickColumnClassCount π)) =
      Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
        Finset.sum (Finset.range (m + 2)) (fun l2 =>
          (wickRelationProfileCount (m := m) l1 l2 : ℝ) *
            d ^ l1 * Real.sqrt s ^ (2 * l2))) := by
  classical
  let profile₁ : Equiv.Perm (Fin (m + 1)) → ℕ :=
    fun π => wickLeftClassCount π + wickRightClassCount π
  let profile₂ : Equiv.Perm (Fin (m + 1)) → ℕ :=
    fun π => wickColumnClassCount π
  calc
    (∑ π : Equiv.Perm (Fin (m + 1)),
      d ^ wickLeftClassCount π *
        d ^ wickRightClassCount π *
          Real.sqrt s ^ (2 * wickColumnClassCount π)) =
        Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
          Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
            Finset.sum (Finset.range (m + 2)) (fun l2 =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then
                d ^ l1 * Real.sqrt s ^ (2 * l2)
              else 0))) := by
          refine Finset.sum_congr rfl ?_
          intro π hπ
          have hprof₁ :
              profile₁ π ≤ 2 * (m + 1) := by
            dsimp [profile₁]
            have hL := wickLeftClassCount_le m π
            have hR := wickRightClassCount_le m π
            omega
          have hprof₂ :
              profile₂ π ≤ m + 1 := by
            dsimp [profile₂]
            exact wickColumnClassCount_le m π
          have hprof₁_mem :
              profile₁ π ∈ Finset.range (2 * (m + 1) + 1) := by
            exact Finset.mem_range.mpr (Nat.lt_succ_of_le hprof₁)
          have hprof₂_mem :
              profile₂ π ∈ Finset.range (m + 2) := by
            exact Finset.mem_range.mpr (Nat.lt_succ_of_le hprof₂)
          have hOuter :
              Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 : ℕ =>
                Finset.sum (Finset.range (m + 2)) (fun l2 : ℕ =>
                  if l1 = profile₁ π ∧ l2 = profile₂ π then
                    d ^ l1 * Real.sqrt s ^ (2 * l2)
                  else 0)) =
                Finset.sum (Finset.range (m + 2)) (fun l2 : ℕ =>
                  if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                    d ^ profile₁ π * Real.sqrt s ^ (2 * l2)
                  else 0) := by
            exact Finset.sum_eq_single_of_mem
              (s := Finset.range (2 * (m + 1) + 1))
              (a := profile₁ π)
              (f := fun l1 : ℕ =>
                Finset.sum (Finset.range (m + 2)) (fun l2 : ℕ =>
                  if l1 = profile₁ π ∧ l2 = profile₂ π then
                    d ^ l1 * Real.sqrt s ^ (2 * l2)
                  else 0))
              hprof₁_mem
              (by
                intro l1 hl1 hl1_ne
                simp [hl1_ne, profile₁, profile₂])
          have hInner0 :
              Finset.sum (Finset.range (m + 2)) (fun l2 : ℕ =>
                if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                  d ^ profile₁ π * Real.sqrt s ^ (2 * l2)
                else 0) =
              if profile₁ π = profile₁ π ∧ profile₂ π = profile₂ π then
                d ^ profile₁ π * Real.sqrt s ^ (2 * profile₂ π)
              else 0 := by
            exact Finset.sum_eq_single_of_mem
              (s := Finset.range (m + 2))
              (a := profile₂ π)
              (f := fun l2 : ℕ =>
                if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                  d ^ profile₁ π * Real.sqrt s ^ (2 * l2)
                else 0)
              hprof₂_mem
              (by
                intro l2 hl2 hl2_ne
                simp [hl2_ne, profile₁, profile₂])
          have hInner :
              Finset.sum (Finset.range (m + 2)) (fun l2 : ℕ =>
                if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                  d ^ profile₁ π * Real.sqrt s ^ (2 * l2)
                else 0) =
              d ^ profile₁ π * Real.sqrt s ^ (2 * profile₂ π) := by
            calc
              Finset.sum (Finset.range (m + 2)) (fun l2 : ℕ =>
                  if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                    d ^ profile₁ π * Real.sqrt s ^ (2 * l2)
                  else 0) =
                if profile₁ π = profile₁ π ∧ profile₂ π = profile₂ π then
                  d ^ profile₁ π * Real.sqrt s ^ (2 * profile₂ π)
                else 0 := hInner0
              _ = d ^ profile₁ π * Real.sqrt s ^ (2 * profile₂ π) := by
                simp
          calc
            d ^ wickLeftClassCount π *
                d ^ wickRightClassCount π *
                Real.sqrt s ^ (2 * wickColumnClassCount π)
                = d ^ profile₁ π * Real.sqrt s ^ (2 * profile₂ π) := by
                    simp [profile₁, profile₂, pow_add, mul_comm]
            _ = Finset.sum (Finset.range (m + 2)) (fun l2 : ℕ =>
                  if profile₁ π = profile₁ π ∧ l2 = profile₂ π then
                    d ^ profile₁ π * Real.sqrt s ^ (2 * l2)
                  else 0) := by
                    symm
                    exact hInner
            _ = Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 : ℕ =>
                  Finset.sum (Finset.range (m + 2)) (fun l2 : ℕ =>
                    if l1 = profile₁ π ∧ l2 = profile₂ π then
                      d ^ l1 * Real.sqrt s ^ (2 * l2)
                    else 0)) := by
                    symm
                    exact hOuter
    _ =
        Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
            Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
              if l1 = profile₁ π ∧ l2 = profile₂ π then
                d ^ l1 * Real.sqrt s ^ (2 * l2)
              else 0))) := by
          rw [Finset.sum_comm]
          congr 1
          funext l1
          rw [Finset.sum_comm]
    _ =
        Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
          Finset.sum (Finset.range (m + 2)) (fun l2 =>
            (wickRelationProfileCount (m := m) l1 l2 : ℝ) *
              d ^ l1 * Real.sqrt s ^ (2 * l2))) := by
          refine Finset.sum_congr rfl ?_
          intro l1 hl1
          refine Finset.sum_congr rfl ?_
          intro l2 hl2
          rw [← Finset.sum_filter]
          simp [wickRelationProfileCount, profile₁, profile₂,
            Finset.sum_const, nsmul_eq_mul, mul_assoc, mul_left_comm, mul_comm]

/-- The concrete profile counts form a finite partition of all Wick
permutations.

This is the unweighted specialization of
`graduateRelationSum_eq_profileCountSum`: every Wick permutation contributes to
exactly one pair
\[
  (\ell_1,\ell_2)
    =
  (\#\mathrm{left}+\#\mathrm{right},\#\mathrm{columns}).
\]
It is a bookkeeping step toward the finite profile-count sum bound, not the
weighted Aubrun estimate itself. -/
theorem wickRelationProfileCount_sum_eq_perm_card (m : ℕ) :
    (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
      Finset.sum (Finset.range (m + 2)) (fun l2 =>
        wickRelationProfileCount (m := m) l1 l2))) =
      Fintype.card (Equiv.Perm (Fin (m + 1))) := by
  classical
  have h :=
    graduateRelationSum_eq_profileCountSum (d := (1 : ℝ)) (s := (1 : ℝ)) m
  simp only [Real.sqrt_one, one_pow, mul_one] at h
  have hNat :
      (Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
        Finset.sum (Finset.range (m + 2)) (fun l2 =>
          wickRelationProfileCount (m := m) l1 l2))) =
        (∑ _π : Equiv.Perm (Fin (m + 1)), 1) := by
    exact_mod_cast h.symm
  simpa using hNat

/-- Final local bridge: any proved bound on the concrete profile-count sum
immediately yields the relation inequality consumed downstream. -/
theorem aubrunGraduateRelationCounting_of_profileCountSumBound
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ}
    (hProfile :
      Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
        Finset.sum (Finset.range (m + 2)) (fun l2 =>
          (wickRelationProfileCount (m := m) l1 l2 : ℝ) *
            d ^ l1 * Real.sqrt s ^ (2 * l2))) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  rw [AubrunGraduateRelationCounting, graduateRelationSum_eq_profileCountSum]
  exact hProfile

/-- A defect-sliced Wick sum bound implies the graduate relation-counting
interface.

This is the sharper entrance point for Aubrun's fixed-defect counting theorem:
the remaining estimate can be proved slice by slice in the defect parameter
`Δ`, instead of as a raw two-dimensional profile-count inequality. -/
theorem aubrunGraduateRelationCounting_of_defectSumBound
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ}
    (hDefect :
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          wickDefect π = Δ) (fun π =>
            d ^ (wickLeftClassCount π + wickRightClassCount π) *
              Real.sqrt s ^ (2 * wickColumnClassCount π))) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  apply aubrunGraduateRelationCounting_of_profileCountSumBound
  have hRegroup :=
    wickRelationProfileCount_weighted_sum_eq_defect_sum_real
      (m := m)
      (F := fun l1 l2 => d ^ l1 * Real.sqrt s ^ (2 * l2))
  calc
    Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
      Finset.sum (Finset.range (m + 2)) (fun l2 =>
        (wickRelationProfileCount (m := m) l1 l2 : ℝ) *
          d ^ l1 * Real.sqrt s ^ (2 * l2))) =
        Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
          Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
            wickDefect π = Δ) (fun π =>
              d ^ (wickLeftClassCount π + wickRightClassCount π) *
                Real.sqrt s ^ (2 * wickColumnClassCount π))) := by
          simpa [mul_assoc] using hRegroup
      _ ≤ (2 : ℝ) ^ (m + 1) *
            (d + Q (m + 1)) ^ (m + 3) *
              (Real.sqrt s + Q (m + 1)) ^ (m + 1) := hDefect

/-- The finite set of Aubrun defects that are actually attained by Wick
permutations of length `m + 1`. -/
noncomputable def wickDefectSupport (m : ℕ) : Finset ℕ :=
  (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))).image fun π => wickDefect π

@[simp] theorem wickDefect_mem_support {m : ℕ}
    (π : Equiv.Perm (Fin (m + 1))) :
    wickDefect π ∈ wickDefectSupport m := by
  classical
  exact Finset.mem_image.mpr ⟨π, Finset.mem_univ π, rfl⟩

/-- The actual defect support lies in the coarse range used by earlier wrappers. -/
theorem wickDefectSupport_subset_range (m : ℕ) :
    wickDefectSupport m ⊆ Finset.range (2 * (m + 1) + 3) := by
  classical
  intro Δ hΔ
  rcases Finset.mem_image.mp hΔ with ⟨π, _hπ, rfl⟩
  exact Finset.mem_range.mpr (Nat.lt_succ_of_le (Nat.sub_le _ _))

/-- The elementary positivity of the three quotient class counts removes the top
four values from the naive defect range: actual defects are at most `2m`. -/
theorem wickDefectSupport_subset_tightRange (m : ℕ) :
    wickDefectSupport m ⊆ Finset.range (2 * m + 1) := by
  classical
  intro Δ hΔ
  rcases Finset.mem_image.mp hΔ with ⟨π, _hπ, rfl⟩
  exact Finset.mem_range.mpr (Nat.lt_succ_of_le (wickDefect_le_two_mul π))

/-- Defect values outside the actual support have zero fixed-defect
permutation count. -/
theorem wickPermutationDefectCount_eq_zero_of_not_mem_support
    {m Δ : ℕ} (hΔ : Δ ∉ wickDefectSupport m) :
    wickPermutationDefectCount m Δ = 0 := by
  classical
  rw [wickPermutationDefectCount]
  apply Finset.card_eq_zero.mpr
  ext π
  simp only [Finset.mem_filter, Finset.mem_univ, true_and]
  constructor
  · intro hdef
    exact False.elim
      (hΔ (by simpa [hdef] using wickDefect_mem_support (m := m) π))
  · intro hEmpty
    cases hEmpty

/-- Defect values outside the tight numerical range `Δ≤2m` have zero
fixed-defect permutation count. -/
theorem wickPermutationDefectCount_eq_zero_of_tightRange_lt
    {m Δ : ℕ} (hΔ : 2 * m < Δ) :
    wickPermutationDefectCount m Δ = 0 := by
  classical
  apply wickPermutationDefectCount_eq_zero_of_not_mem_support
  intro hsupport
  have htight := wickDefectSupport_subset_tightRange m hsupport
  have hle : Δ ≤ 2 * m := by
    exact Nat.lt_succ_iff.mp (Finset.mem_range.mp htight)
  omega

/-- A support-restricted count estimate extends to the old coarse range, since
outside the actual support the fixed-defect count is zero. -/
theorem wickPermutationDefectCount_range_bound_of_support_bound
    {m : ℕ} {C : ℕ → ℝ}
    (hCnonneg : ∀ Δ, 0 ≤ C Δ)
    (hCount : ∀ Δ ∈ wickDefectSupport m,
      (wickPermutationDefectCount m Δ : ℝ) ≤ C Δ) :
    ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤ C Δ := by
  intro Δ _hΔrange
  by_cases hΔsupport : Δ ∈ wickDefectSupport m
  · exact hCount Δ hΔsupport
  · have hzero :=
      wickPermutationDefectCount_eq_zero_of_not_mem_support
        (m := m) (Δ := Δ) hΔsupport
    rw [hzero]
    simpa using hCnonneg Δ

/-- A count estimate on the tight numerical range `Δ≤2m` extends to the old
coarse defect range.  Outside the tight range the fixed-defect count is zero. -/
theorem wickPermutationDefectCount_range_bound_of_tightRange_bound
    {m : ℕ} {C : ℕ → ℝ}
    (hCnonneg : ∀ Δ, 0 ≤ C Δ)
    (hCount : ∀ Δ ∈ Finset.range (2 * m + 1),
      (wickPermutationDefectCount m Δ : ℝ) ≤ C Δ) :
    ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      (wickPermutationDefectCount m Δ : ℝ) ≤ C Δ := by
  intro Δ _hΔrange
  by_cases htight : Δ ∈ Finset.range (2 * m + 1)
  · exact hCount Δ htight
  · have hgt : 2 * m < Δ := by
      have hnot : ¬ Δ < 2 * m + 1 := by
        simpa using htight
      omega
    have hzero :=
      wickPermutationDefectCount_eq_zero_of_tightRange_lt
        (m := m) (Δ := Δ) hgt
    rw [hzero]
    simpa using hCnonneg Δ

/-- A defect-sliced Wick sum bound over the actually occurring defect values is
enough for the graduate relation-counting interface. -/
theorem aubrunGraduateRelationCounting_of_defectSupportSumBound
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ}
    (hDefect :
      Finset.sum (wickDefectSupport m) (fun Δ =>
        Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          wickDefect π = Δ) (fun π =>
            d ^ (wickLeftClassCount π + wickRightClassCount π) *
              Real.sqrt s ^ (2 * wickColumnClassCount π))) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  classical
  apply aubrunGraduateRelationCounting_of_profileCountSumBound
  have hProfile :=
    wickRelationProfileCount_weighted_sum_eq_perm_sum_real (m := m)
      (F := fun l1 l2 => d ^ l1 * Real.sqrt s ^ (2 * l2))
  have hmem : ∀ π ∈ (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))),
      wickDefect π ∈ wickDefectSupport m := by
    intro π _hπ
    exact wickDefect_mem_support π
  have hFiber :=
    Finset.sum_fiberwise_of_maps_to
      (s := (Finset.univ : Finset (Equiv.Perm (Fin (m + 1)))))
      (t := wickDefectSupport m)
      (g := fun π : Equiv.Perm (Fin (m + 1)) => wickDefect π)
      hmem
      (f := fun π : Equiv.Perm (Fin (m + 1)) =>
        d ^ (wickLeftClassCount π + wickRightClassCount π) *
          Real.sqrt s ^ (2 * wickColumnClassCount π))
  calc
    Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
      Finset.sum (Finset.range (m + 2)) (fun l2 =>
        (wickRelationProfileCount (m := m) l1 l2 : ℝ) *
          d ^ l1 * Real.sqrt s ^ (2 * l2))) =
        Finset.sum (wickDefectSupport m) (fun Δ =>
          Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
            wickDefect π = Δ) (fun π =>
              d ^ (wickLeftClassCount π + wickRightClassCount π) *
                Real.sqrt s ^ (2 * wickColumnClassCount π))) := by
          calc
            Finset.sum (Finset.range (2 * (m + 1) + 1)) (fun l1 =>
              Finset.sum (Finset.range (m + 2)) (fun l2 =>
                (wickRelationProfileCount (m := m) l1 l2 : ℝ) *
                  d ^ l1 * Real.sqrt s ^ (2 * l2))) =
                Finset.sum Finset.univ (fun π : Equiv.Perm (Fin (m + 1)) =>
                  d ^ (wickLeftClassCount π + wickRightClassCount π) *
                    Real.sqrt s ^ (2 * wickColumnClassCount π)) := by
                  simpa [mul_assoc] using hProfile
            _ = Finset.sum (wickDefectSupport m) (fun Δ =>
                  Finset.sum
                    (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
                      wickDefect π = Δ) (fun π =>
                        d ^ (wickLeftClassCount π + wickRightClassCount π) *
                          Real.sqrt s ^ (2 * wickColumnClassCount π))) := by
                  simpa [Finset.sum_filter] using hFiber.symm
    _ ≤ (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1) := hDefect

/-- A fixed-defect slice is bounded by its cardinality times any uniform
term-envelope on that slice. -/
theorem wickDefectSlice_sum_le_count_mul_of_forall_le
    {m Δ : ℕ} {B : ℝ} {W : Equiv.Perm (Fin (m + 1)) → ℝ}
    (hW : ∀ π : Equiv.Perm (Fin (m + 1)), wickDefect π = Δ → W π ≤ B) :
    Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
      wickDefect π = Δ) W ≤
      (wickPermutationDefectCount m Δ : ℝ) * B := by
  classical
  have hsum :=
    Finset.sum_le_card_nsmul
      (s := Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
        wickDefect π = Δ)
      (f := W) (n := B)
      (by
        intro π hπ
        exact hW π (Finset.mem_filter.mp hπ).2)
  calc
    Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
      wickDefect π = Δ) W ≤
        (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          wickDefect π = Δ).card • B := hsum
    _ = (wickPermutationDefectCount m Δ : ℝ) * B := by
          simp [wickPermutationDefectCount, nsmul_eq_mul]

/-- The cardinality-times-envelope bound specialized to the Aubrun analytic
weight on one fixed-defect slice. -/
theorem wickDefectSlice_weight_sum_le_count_mul_of_forall_le
    {m Δ : ℕ} {d s B : ℝ}
    (hW : ∀ π : Equiv.Perm (Fin (m + 1)), wickDefect π = Δ →
      d ^ (wickLeftClassCount π + wickRightClassCount π) *
          Real.sqrt s ^ (2 * wickColumnClassCount π) ≤ B) :
    Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
      wickDefect π = Δ) (fun π =>
        d ^ (wickLeftClassCount π + wickRightClassCount π) *
          Real.sqrt s ^ (2 * wickColumnClassCount π)) ≤
      (wickPermutationDefectCount m Δ : ℝ) * B :=
  wickDefectSlice_sum_le_count_mul_of_forall_le
    (m := m) (Δ := Δ) (B := B)
    (W := fun π : Equiv.Perm (Fin (m + 1)) =>
      d ^ (wickLeftClassCount π + wickRightClassCount π) *
        Real.sqrt s ^ (2 * wickColumnClassCount π)) hW

/-- A finite family of per-defect term envelopes reduces the graduate
relation-counting input to a scalar envelope involving the fixed-defect
counts. -/
theorem aubrunGraduateRelationCounting_of_defectSliceCountBounds
    {Q : ℕ → ℝ} {d s : ℝ} {m : ℕ} {B : ℕ → ℝ}
    (hTerm : ∀ Δ ∈ Finset.range (2 * (m + 1) + 3),
      ∀ π : Equiv.Perm (Fin (m + 1)), wickDefect π = Δ →
        d ^ (wickLeftClassCount π + wickRightClassCount π) *
          Real.sqrt s ^ (2 * wickColumnClassCount π) ≤ B Δ)
    (hEnvelope :
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        (wickPermutationDefectCount m Δ : ℝ) * B Δ) ≤
      (2 : ℝ) ^ (m + 1) *
          (d + Q (m + 1)) ^ (m + 3) *
            (Real.sqrt s + Q (m + 1)) ^ (m + 1)) :
    AubrunGraduateRelationCounting Q d s m := by
  apply aubrunGraduateRelationCounting_of_defectSumBound
  calc
    Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        Finset.sum (Finset.univ.filter fun π : Equiv.Perm (Fin (m + 1)) =>
          wickDefect π = Δ) (fun π =>
            d ^ (wickLeftClassCount π + wickRightClassCount π) *
              Real.sqrt s ^ (2 * wickColumnClassCount π))) ≤
      Finset.sum (Finset.range (2 * (m + 1) + 3)) (fun Δ =>
        (wickPermutationDefectCount m Δ : ℝ) * B Δ) := by
          refine Finset.sum_le_sum ?_
          intro Δ hΔ
          exact wickDefectSlice_weight_sum_le_count_mul_of_forall_le
            (m := m) (Δ := Δ) (d := d) (s := s) (B := B Δ)
            (hTerm Δ hΔ)
      _ ≤ (2 : ℝ) ^ (m + 1) *
            (d + Q (m + 1)) ^ (m + 3) *
              (Real.sqrt s + Q (m + 1)) ^ (m + 1) := hEnvelope

/-- Support-restricted version of
`aubrunGraduateRelationCounting_of_defectSliceCountBounds`: only actually
