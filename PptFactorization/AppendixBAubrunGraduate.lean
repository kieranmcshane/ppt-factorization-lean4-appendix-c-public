/-- Tight-range count endpoint in the close-window branch `sqrt(s)≤d`.

The common base is fixed to `D=d`, the ratio parameter is fixed to
`ρ=P(k)/d`, and the scalar ratio-power target is supplied by the canonical
`Q(k)=kP(k)` first-ratio gain. -/
theorem aubrunGraduateRelationCounting_of_prop73TightCountAndCayleyRankBudget_firstDimensionBase_Qone
    {d s : ℝ} {m : ℕ}
    (hd0 : 0 ≤ d) (hsqrt0 : 0 ≤ Real.sqrt s)
    (hdpos : 0 < d)
    (hsqrt_le_d : Real.sqrt s ≤ d)
    (hcloseBelow :
      d ≤ Real.sqrt s + aubrunProposition71Q 1 (m + 1))
    (hP_le_d : aubrunProposition73P (m + 1) ≤ d)
    (hCount : ∀ Δ ∈ Finset.range (2 * m + 1),
      (wickPermutationDefectCount m Δ : ℝ) ≤
        aubrunFixedDefectCountEnvelope m Δ) :
    AubrunGraduateRelationCounting (aubrunProposition71Q 1) d s m := by
  have hP0 : 0 ≤ aubrunProposition73P (m + 1) :=
    aubrunProposition73P_nonneg _
  have hρ0 : 0 ≤ aubrunProposition73P (m + 1) / d :=
    div_nonneg hP0 hdpos.le
  have hρ1 : aubrunProposition73P (m + 1) / d ≤ 1 := by
    exact (div_le_one hdpos).mpr hP_le_d
  have hP_ρD :
      aubrunProposition73P (m + 1) ≤
        (aubrunProposition73P (m + 1) / d) * d := by
    rw [div_mul_cancel₀ _ (ne_of_gt hdpos)]
  exact
    aubrunGraduateRelationCounting_of_prop73TightCountAndCayleyRankBudget_linearRatioRatioPowers_cancelTwo
      (Q := aubrunProposition71Q 1) (d := d) (s := s) (D := d)
      (ρ := aubrunProposition73P (m + 1) / d) (m := m)
      hd0 hsqrt0 le_rfl hsqrt_le_d hdpos hρ0 hρ1 hP_ρD hCount
      (aubrun_linearRatio_ratioPowers_of_first_dimension_base_Qone
        (d := d) (s := s) (m := m) hdpos hcloseBelow)

/-- Tight-range count endpoint in the close-window branch `d≤sqrt(s)`.

The common base is fixed to `D=sqrt(s)`, the ratio parameter is fixed to
