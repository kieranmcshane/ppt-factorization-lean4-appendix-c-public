        (Sum.inl (Quotient.mk'' xr : Quotient S) :
          Quotient S ⊕ Quotient T) := by
    simpa [S, T, xr] using
      finRotate_mul_perm_incidence_contour_interval_left_walk_getVert_even
        π ha hc hac hr
  have hsVert :
      (finRotate_mul_perm_incidence_contour_interval_left_walk
          π ha hc hac).getVert (2 * s + 1) =
        (Sum.inr (Quotient.mk'' xs : Quotient T) :
          Quotient S ⊕ Quotient T) := by
    simpa [S, T, xs] using
      finRotate_mul_perm_incidence_contour_interval_left_walk_getVert_odd
