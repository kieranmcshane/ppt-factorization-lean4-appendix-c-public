        False)
    (hBlock :
      ∀ y : Fin (m + 1),
        π.1.SameCycle y
          ⟨a', Finset.mem_range.mp ha'⟩ →
        (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x) :
    ∃ a'' c'' : ℕ,
      ∃ ha'' : a'' ∈ Finset.range (m + 1),
      ∃ hc'' : c'' ∈ Finset.range (m + 1),
      ∃ hac'' : a'' < c'',
        a < a'' ∧
        c'' < c ∧
        1 < c'' - a'' ∧
        c'' - a'' < c' - a' ∧
        π.1.SameCycle
          ⟨a'', Finset.mem_range.mp ha''⟩
          ⟨c'', Finset.mem_range.mp hc''⟩ ∧
        (∀ z : Fin (m + 1),
          π.1.SameCycle z x →
          a'' < z.val →
          z.val < c'' →
          False) ∧
        ∀ y : Fin (m + 1),
          π.1.SameCycle y
            ⟨a'', Finset.mem_range.mp ha''⟩ →
          (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x := by
  classical
  rcases hInternal with ⟨r, s, hr, hs, hrs, hgap, hSame⟩
  let a'' : ℕ := a' + r
  let c'' : ℕ := a' + s
  have ha'' : a'' ∈ Finset.range (m + 1) := by
    have hcBound := Finset.mem_range.mp hc'
    exact Finset.mem_range.mpr (by dsimp [a'']; omega)
  have hc'' : c'' ∈ Finset.range (m + 1) := by
    have hcBound := Finset.mem_range.mp hc'
    exact Finset.mem_range.mpr (by dsimp [c'']; omega)
  have hac'' : a'' < c'' := by
    dsimp [a'', c'']
    omega
  have hgap'' : 1 < c'' - a'' := by
    dsimp [a'', c'']
    omega
  have hshort : c'' - a'' < c' - a' := by
    dsimp [a'', c'']
    omega
  have hSame'' :
      π.1.SameCycle
        ⟨a'', Finset.mem_range.mp ha''⟩
        ⟨c'', Finset.mem_range.mp hc''⟩ := by
    have hA :
        (⟨a'', Finset.mem_range.mp ha''⟩ : Fin (m + 1)) =
          ⟨a' + r, by
            have hcBound := Finset.mem_range.mp hc'
            omega⟩ := by
      apply Fin.ext
      rfl
    have hC :
        (⟨c'', Finset.mem_range.mp hc''⟩ : Fin (m + 1)) =
          ⟨a' + s, by
            have hcBound := Finset.mem_range.mp hc'
            omega⟩ := by
      apply Fin.ext
      rfl
    simpa [hA, hC] using hSame
  have ha_parent : a < a'' := by
    dsimp [a'']
    omega
  have hc_parent : c'' < c := by
    dsimp [c'']
    omega
  have hNoX'' :
      ∀ z : Fin (m + 1),
        π.1.SameCycle z x →
        a'' < z.val →
        z.val < c'' →
        False := by
    intro z hzx hzgt hzlt
    exact hNoX z hzx (by dsimp [a''] at hzgt; omega)
      (by dsimp [c''] at hzlt; omega)
  have hBlock'' :
      ∀ y : Fin (m + 1),
        π.1.SameCycle y
          ⟨a'', Finset.mem_range.mp ha''⟩ →
        (a < y.val ∧ y.val < c) ∧ ¬ π.1.SameCycle y x := by
    intro y hy
    let ia' : Fin (m + 1) := ⟨a', Finset.mem_range.mp ha'⟩
    let ic' : Fin (m + 1) := ⟨c', Finset.mem_range.mp hc'⟩
    let ia'' : Fin (m + 1) := ⟨a'', Finset.mem_range.mp ha''⟩
    by_cases hSameLeft : π.1.SameCycle ia'' ia'
    · exact hBlock y (hy.trans hSameLeft)
    · have hrpos : 0 < r := by
        by_contra hnot
        have hrzero : r = 0 := by omega
        have hia : ia'' = ia' := by
          apply Fin.ext
          dsimp [ia'', ia', a''] at *
          omega
        have hsame_refl : π.1.SameCycle ia'' ia' := by
          simpa [hia] using (Equiv.Perm.SameCycle.refl π.1 ia')
        exact hSameLeft hsame_refl
      let Pnc : NCPartition.NCPart (m + 1) :=
        ⟨leftTightCyclePartitionRange π, hπNC⟩
      have hir_gt : ia'.val < ia''.val := by
        simp [ia', ia'', a'']
        omega
      have hir_lt : ia''.val < ic'.val := by
        simp [ia', ia'', ic', a'']
        omega
      have hc_mem :
          ic'.val ∈ (leftTightCyclePartitionRange π).part ia'.val := by
        simpa [ia', ic'] using
          (mem_leftTightCyclePartitionRange_part_iff π ha' hc').mpr hSame'
      have hpart_ne :
          (leftTightCyclePartitionRange π).part ia'.val ≠
            (leftTightCyclePartitionRange π).part ia''.val := by
        intro hpart
        have hirRange : ia''.val ∈ Finset.range (m + 1) :=
          Finset.mem_range.mpr ia''.2
        have hir_mem_self :
            ia''.val ∈ (leftTightCyclePartitionRange π).part ia''.val :=
          (leftTightCyclePartitionRange π).mem_part hirRange
        have hir_mem_a :
            ia''.val ∈ (leftTightCyclePartitionRange π).part ia'.val := by
          simpa [hpart] using hir_mem_self
        have hir_same_a : π.1.SameCycle ia' ia'' :=
          (mem_leftTightCyclePartitionRange_part_iff π ha' hirRange).mp
            (by simpa [ia', ia''] using hir_mem_a)
        exact hSameLeft hir_same_a.symm
      have hsubset :
          ∀ y0 ∈ (leftTightCyclePartitionRange π).part ia''.val,
            ia'.val ≤ y0 ∧ y0 ≤ ic'.val := by
        exact
          Pnc.part_subset_Icc_of_between_distinct
            hir_gt hir_lt hc_mem hpart_ne
      have hyRange : y.val ∈ Finset.range (m + 1) :=
        Finset.mem_range.mpr y.2
      have hirRange : ia''.val ∈ Finset.range (m + 1) :=
        Finset.mem_range.mpr ia''.2
      have hy_mem :
          y.val ∈ (leftTightCyclePartitionRange π).part ia''.val := by
        exact
          (mem_leftTightCyclePartitionRange_part_iff π hirRange hyRange).mpr
            (by simpa [ia''] using hy.symm)
      have hy_closed := hsubset y.val hy_mem
      have hy_ne_left : y.val ≠ a' := by
        intro hya
        have hy_eq : y = ia' := by
          apply Fin.ext
          simpa [ia'] using hya
        exact hSameLeft (by simpa [hy_eq, ia''] using hy.symm)
      have hy_ne_right : y.val ≠ c' := by
        intro hyc
        have hy_eq : y = ic' := by
          apply Fin.ext
          simpa [ic'] using hyc
        have hia''_ic' : π.1.SameCycle ia'' ic' := by
          simpa [hy_eq, ia''] using hy.symm
        exact hSameLeft (hia''_ic'.trans hSame'.symm)
      have hy_gt_child : a' < y.val := by
        have hle : a' ≤ y.val := by
          simpa [ia'] using hy_closed.1
        omega
      have hy_lt_child : y.val < c' := by
        have hle : y.val ≤ c' := by
          simpa [ic'] using hy_closed.2
        omega
      refine ⟨?_, ?_⟩
      · constructor <;> omega
      · intro hyx
        exact hNoX y hyx hy_gt_child hy_lt_child
  exact
    ⟨a'', c'', ha'', hc'', hac'', ha_parent, hc_parent, hgap'', hshort,
      hSame'', hNoX'', hBlock''⟩

/-- Nonwrapping internal-subinterval collision may be proved with the open
internal-subinterval residual.

This is the theorem-facing use of
`leftTightStrictReturnIntervalInternalSubintervalResidual_nonwrap_start_pos`:
the old nonwrapping internal-subinterval branch allowed the shorter interval to
begin at `a`; the first-return side data removes that case, so callers only
need to solve the stricter open-internal branch. -/
theorem leftTight_nonwrap_internalSubintervalResidual_common_of_openInternal
    {m : ℕ} (π : WickCycleLeftTightClass m)
    (_hπNC : NCPartition.NonCrossing (leftTightCyclePartitionRange π))
    {x : Fin (m + 1)}
    (_hne : π.1 x ≠ x)
    (_hskip : permCyclicPredecessorSkip π.1 x)
    (_hnotDirect :
      ¬ π.1.SameCycle x (finRotate (m + 1) (π.1 x)))
    (hOpenCommon :
      ∀ a c : ℕ,
        ∀ ha : a ∈ Finset.range (m + 1),
        ∀ hc : c ∈ Finset.range (m + 1),
        ∀ hac : a < c,
          1 < c - a →
          π.1.SameCycle
            ⟨a, Finset.mem_range.mp ha⟩
            ⟨c, Finset.mem_range.mp hc⟩ →
          leftTightStrictReturnIntervalOpenInternalSubintervalResidual
            π.1 ha hc hac →
          a = (π.1 x).val →
          c < x.val →
          (∀ z : Fin (m + 1),
            π.1.SameCycle z x →
            a < z.val →
            z.val < c →
            False) →
          ∃ y z : Fin (m + 1),
            y ≠ z ∧
              π.1.SameCycle y z ∧
                (finRotate (m + 1) * π.1).SameCycle y z)
    {a c : ℕ}
    (ha : a ∈ Finset.range (m + 1)) (hc : c ∈ Finset.range (m + 1))
    (hac : a < c)
    (hgap : 1 < c - a)
    (hT : π.1.SameCycle
      ⟨a, Finset.mem_range.mp ha⟩
      ⟨c, Finset.mem_range.mp hc⟩)
    (hInternal :
      leftTightStrictReturnIntervalInternalSubintervalResidual π.1 ha hc hac)
    (haeq : a = (π.1 x).val)
    (hcx : c < x.val)
    (hfirst :
      ∀ z : Fin (m + 1),
        π.1.SameCycle z x →
        a < z.val →
        z.val < c →
        False) :
    ∃ y z : Fin (m + 1),
      y ≠ z ∧
        π.1.SameCycle y z ∧
          (finRotate (m + 1) * π.1).SameCycle y z := by
  exact
    hOpenCommon a c ha hc hac hgap hT
      (leftTightStrictReturnIntervalInternalSubintervalResidual_nonwrap_start_pos
        ha hc hac haeq hfirst hInternal)
      haeq hcx hfirst

/-- Nonwrapping open-internal collision may be proved with the off-cycle
open-internal residual.

The first-return side data removes the subcase where the internal shorter
same-`π` interval starts in the skipped `x`-cycle.  Thus callers only need to
solve the stricter branch where the internal witness is genuinely off the
